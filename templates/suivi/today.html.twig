<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Check-in quotidien — Bekri</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --dark:       #1a2332;
            --gray:       #64748b;
            --light:      #f8fafc;
            --white:      #ffffff;
            --sidebar-w:  260px;
            --shadow-sm:  0 2px 12px rgba(0,0,0,0.06);
            --shadow:     0 8px 30px rgba(0,0,0,0.10);
            --radius:     16px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--light);
            color: var(--dark);
            display: flex;
            min-height: 100vh;
        }

        /* ── SIDEBAR ─────────────────────────────────────────────── */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--dark);
            min-height: 100vh;
            max-height: 100vh;
            position: fixed;
            top: 0; left: 0;
            display: flex;
            flex-direction: column;
            z-index: 100;
            transition: transform 0.3s ease;
            overflow: hidden;
        }

        .sidebar-logo {
            padding: 28px 24px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }

        .sidebar-logo img { height: 36px; width: auto; }

        .sidebar-logo-text {
            font-size: 20px;
            font-weight: 800;
            background: linear-gradient(135deg, var(--teal), #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .sidebar-user {
            padding: 20px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }

        .sidebar-avatar {
            width: 42px; height: 42px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--teal), var(--purple));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 16px;
            flex-shrink: 0;
        }

        .sidebar-user-name { font-size: 14px; font-weight: 600; color: white; }
        .sidebar-user-role { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 2px; }

        .sidebar-nav { flex: 1; padding: 16px 0; overflow-y: auto; }

        .nav-section-label {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: rgba(255,255,255,0.25);
            padding: 12px 24px 6px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 24px;
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s;
            border-left: 3px solid transparent;
        }

        .nav-item:hover { color: white; background: rgba(255,255,255,0.05); }

        .nav-item.active {
            color: var(--teal);
            background: rgba(32,178,170,0.1);
            border-left-color: var(--teal);
        }

        .nav-item i { width: 20px; text-align: center; font-size: 16px; }

        .sidebar-footer {
            padding: 16px 0;
            border-top: 1px solid rgba(255,255,255,0.07);
        }

        /* ── MAIN ─────────────────���──────────────────────────────── */
        .main { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh; }

        /* ── TOPBAR ──────────────────────────────────────────────── */
        .topbar {
            background: white;
            padding: 0 32px;
            height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: var(--shadow-sm);
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .topbar-title { font-size: 18px; font-weight: 700; color: var(--dark); }
        .topbar-sub   { font-size: 13px; color: var(--gray); margin-top: 2px; }
        .topbar-right { display: flex; align-items: center; gap: 12px; }

        .topbar-btn {
            width: 40px; height: 40px;
            border-radius: 10px;
            background: var(--light);
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--gray);
            font-size: 16px;
            text-decoration: none;
            transition: all 0.2s;
        }

        .topbar-btn:hover { background: var(--teal-light); color: var(--teal-dark); }

        .topbar-avatar {
            width: 40px; height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--teal), var(--purple));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 14px;
            text-decoration: none;
        }

        /* ── CONTENT ─────────────────────────────────────────────── */
        .content { padding: 32px; flex: 1; }

        /* ── PAGE HEADER ─────────────────────────────────────────── */
        .page-header {
            background: linear-gradient(135deg, var(--teal), var(--teal-dark), var(--purple));
            border-radius: var(--radius);
            padding: 28px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
            position: relative;
            overflow: hidden;
        }

        .page-header::before {
            content: '';
            position: absolute;
            top: -40px; right: -40px;
            width: 160px; height: 160px;
            background: rgba(255,255,255,0.06);
            border-radius: 50%;
        }

        .page-header-text h1 { font-size: 22px; font-weight: 800; color: white; margin-bottom: 4px; }
        .page-header-text p  { font-size: 14px; color: rgba(255,255,255,0.8); }

        .page-header-icon {
            width: 56px; height: 56px;
            background: rgba(255,255,255,0.15);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: white;
            backdrop-filter: blur(8px);
        }

        /* ── ALERTS ──────────────────────────────────────────────── */
        .alert {
            padding: 14px 18px;
            border-radius: 12px;
            margin-bottom: 16px;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 500;
        }

        .alert-success { background: #f0fdf4; color: #166534; border-left: 4px solid #22c55e; }
        .alert-warning { background: #fffbeb; color: #92400e; border-left: 4px solid #f59e0b; }
        .alert-danger  { background: #fff5f5; color: #dc2626; border-left: 4px solid #ef4444; }
        .alert-danger-list { align-items: flex-start; }

        /* ── QUESTIONS GRID ──────────────────────────────────────── */
        .questions-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-bottom: 24px;
        }

        .question-card {
            background: white;
            border-radius: var(--radius);
            border: 2px solid #f1f5f9;
            box-shadow: var(--shadow-sm);
            padding: 22px;
            transition: all 0.3s;
        }

        .question-card:hover { box-shadow: var(--shadow); transform: translateY(-2px); }
        .question-card.has-error { border-color: #ef4444; background: #fff5f5; }

        .question-category {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 12px;
            background: var(--teal-light);
            color: var(--teal-dark);
            border-radius: 50px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
        }

        .question-text {
            font-size: 15px;
            font-weight: 600;
            color: var(--dark);
            line-height: 1.5;
            margin-bottom: 16px;
        }

        .question-text .required { color: #ef4444; margin-left: 4px; }

        /* ── RADIO OPTIONS ───────────────────────────────────────── */
        .radio-options { display: flex; flex-direction: column; gap: 8px; }

        /* Override Symfony form radio styles */
        .radio-options .form-check,
        .radio-options label {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 14px;
            color: var(--dark);
            background: var(--light);
        }

        .radio-options input[type="radio"] {
            accent-color: var(--teal);
            width: 16px; height: 16px;
            cursor: pointer;
            flex-shrink: 0;
        }

        .radio-options .form-check:has(input:checked),
        .radio-options label:has(input:checked) {
            border-color: var(--teal);
            background: var(--teal-light);
            color: var(--teal-dark);
            font-weight: 600;
        }

        .radio-options .form-check:hover,
        .radio-options label:hover {
            border-color: var(--teal);
            background: var(--teal-light);
        }

        .field-error {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 12px;
            color: #dc2626;
            margin-top: 8px;
        }

        /* ── COMMENT CARD ────────────────────────────────────────── */
        .comment-card {
            background: white;
            border-radius: var(--radius);
            border: 2px solid #f1f5f9;
            box-shadow: var(--shadow-sm);
            padding: 24px;
            margin-bottom: 28px;
        }

        .comment-card.has-error { border-color: #ef4444; }

        .comment-card h3 {
            font-size: 15px;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 4px;
        }

        .comment-card .hint {
            font-size: 12px;
            color: #94a3b8;
            margin-bottom: 14px;
        }

        .comment-textarea {
            width: 100%;
            padding: 14px 16px;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            font-size: 14px;
            color: var(--dark);
            font-family: 'Inter', sans-serif;
            background: var(--light);
            outline: none;
            resize: vertical;
            min-height: 110px;
            transition: all 0.25s;
        }

        .comment-textarea:focus {
            border-color: var(--teal);
            background: white;
            box-shadow: 0 0 0 4px rgba(32,178,170,0.1);
        }

        /* ── SUBMIT ──────────────────────────────────────────────── */
        .submit-row {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
        }

        .btn {
            padding: 13px 28px;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            transition: all 0.25s;
            font-family: 'Inter', sans-serif;
        }

        .btn-teal {
            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
            color: white;
            box-shadow: 0 4px 15px rgba(32,178,170,0.3);
        }

        .btn-teal:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(32,178,170,0.4); }

        .btn-ghost { background: white; color: var(--gray); border: 2px solid #e2e8f0; }
        .btn-ghost:hover { background: var(--light); color: var(--dark); }

        /* ── MOBILE ──────────────────────────────────────────────── */
        .menu-toggle { display: none; background: none; border: none; font-size: 22px; color: var(--dark); cursor: pointer; }
        .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 99; }

        @media (max-width: 1024px) { .questions-grid { grid-template-columns: 1fr; } }

        @media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main { margin-left: 0; }
            .menu-toggle { display: block; }
            .content { padding: 16px; }
            .topbar { padding: 0 16px; }
            .page-header { flex-direction: column; gap: 16px; text-align: center; }
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'">
            <span class="sidebar-logo-text">Bekri</span>
        </div>

        <div class="sidebar-user">
            <div class="sidebar-avatar">
                {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
            </div>
            <div>
                <div class="sidebar-user-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
                <div class="sidebar-user-role">Membre Bekri</div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-label">Principal</div>
            <a href="{{ path('user_dashboard') }}" class="nav-item"><i class="bi bi-grid-fill"></i> Tableau de bord</a>
            <a href="{{ path('suivi_today') }}"    class="nav-item active"><i class="bi bi-clipboard2-pulse-fill"></i> Check-in quotidien</a>
            <a href="{{ path('insight_weekly') }}" class="nav-item"><i class="bi bi-graph-up-arrow"></i> Insights hebdo</a>
            <a href="{{ path('chat_index') }}"     class="nav-item"><i class="bi bi-robot"></i> Coach Eya IA</a>

            <div class="nav-section-label">Bien-être</div>
            <a href="{{ path('objectif_index') }}" class="nav-item"><i class="bi bi-trophy-fill"></i> Mes objectifs</a>
            <a href="{{ path('plan_index') }}" class="nav-item"><i class="bi bi-calendar2-week-fill"></i> Plan hebdomadaire</a>
            <a href="{{ path('food_analyzer_index') }}" class="nav-item"><i class="bi bi-egg-fried"></i> Analyseur Alimentaire</a>
            <a href="#" class="nav-item"><i class="bi bi-brain"></i> Test de santé mentale</a>

            <div class="nav-section-label">Communauté</div>
            <a href="{{ path('posts_list') }}"      class="nav-item"><i class="bi bi-newspaper"></i> Publications</a>
            <a href="{{ path('evenements_home') }}"  class="nav-item"><i class="bi bi-calendar-event-fill"></i> Événements</a>

            <div class="nav-section-label">Mon compte</div>
            <a href="{{ path('user_profile') }}"    class="nav-item"><i class="bi bi-person-fill"></i> Mon profil</a>
            <a href="{{ path('user_profile_edit') }}" class="nav-item"><i class="bi bi-gear-fill"></i> Paramètres</a>
        </nav>

        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;">
                <i class="bi bi-box-arrow-left"></i> Se déconnecter
            </a>
        </div>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- MAIN -->
    <div class="main">

        <!-- TOPBAR -->
        <header class="topbar">
            <div style="display:flex;align-items:center;gap:16px;">
                <button class="menu-toggle" id="menuToggle"><i class="bi bi-list"></i></button>
                <div>
                    <div class="topbar-title">Check-in quotidien</div>
                    <div class="topbar-sub">{{ suivi.date|date('l d MMMM yyyy') }}</div>
                </div>
            </div>
            <div class="topbar-right">
                <a href="{{ path('chat_index') }}"  class="topbar-btn" title="Coach Eya"><i class="bi bi-robot"></i></a>
                <a href="{{ path('user_profile') }}" class="topbar-avatar">
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                </a>
            </div>
        </header>

        <!-- CONTENT -->
        <main class="content">

            <!-- Page header banner -->
            <div class="page-header">
                <div class="page-header-text">
                    <h1><i class="bi bi-clipboard2-pulse-fill" style="margin-right:10px;"></i>Check-in du {{ suivi.date|date('d/m/Y') }}</h1>
                    <p>Prenez 2 minutes pour évaluer votre bien-être du jour — chaque réponse compte !</p>
                </div>
                <div class="page-header-icon">
                    <i class="bi bi-heart-pulse-fill"></i>
                </div>
            </div>

            <!-- Flash messages -->
            {% for message in app.flashes('success') %}
                <div class="alert alert-success">
                    <i class="bi bi-check-circle-fill"></i> {{ message }}
                </div>
            {% endfor %}

            {% for message in app.flashes('warning') %}
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle-fill"></i> {{ message }}
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger">
                    <i class="bi bi-x-circle-fill"></i> {{ message }}
                </div>
            {% endfor %}

            {% if not form.vars.valid and form.vars.submitted %}
                <div class="alert alert-danger alert-danger-list">
                    <i class="bi bi-x-circle-fill" style="flex-shrink:0;margin-top:2px;"></i>
                    <div>
                        <strong>Veuillez corriger les erreurs suivantes :</strong>
                        <ul style="margin-top:6px;padding-left:16px;font-size:13px;list-style:disc;">
                            {% for field in form %}
                                {% for error in field.vars.errors %}
                                    <li>{{ error.message }}</li>
                                {% endfor %}
                            {% endfor %}
                            {% for error in form.vars.errors %}
                                <li>{{ error.message }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>
            {% endif %}

            {{ form_start(form) }}

            <!-- Questions -->
            <div class="questions-grid">
                {% for question in questions %}
                    {% set fieldName = 'question_' ~ question.id %}
                    {% set hasError = form[fieldName] is defined and form[fieldName].vars.errors|length > 0 %}

                    <div class="question-card {{ hasError ? 'has-error' : '' }}">

                        <div class="question-category">
                            {% set catIcons = {
                                'humeur':     'bi-emoji-smile',
                                'sommeil':    'bi-moon-stars-fill',
                                'activite':   'bi-bicycle',
                                'nutrition':  'bi-apple',
                                'stress':     'bi-lightning-fill',
                                'energie':    'bi-battery-charging',
                                'social':     'bi-people-fill'
                            } %}
                            <i class="bi {{ catIcons[question.category|lower] ?? 'bi-heart-fill' }}"></i>
                            {{ question.category|capitalize }}
                        </div>

                        <p class="question-text">
                            {{ question.texte }}
                            <span class="required">*</span>
                        </p>

                        <div class="radio-options">
                            {{ form_widget(attribute(form, fieldName)) }}
                        </div>

                        {% if hasError %}
                            <div class="field-error">
                                <i class="bi bi-exclamation-circle-fill"></i>
                                {% for error in form[fieldName].vars.errors %}{{ error.message }}{% endfor %}
                            </div>
                        {% endif %}

                    </div>
                {% endfor %}
            </div>

            <!-- Comment -->
            <div class="comment-card {{ form.commentaire.vars.errors|length > 0 ? 'has-error' : '' }}">
                <h3><i class="bi bi-chat-text-fill" style="color:var(--teal);margin-right:8px;"></i>Commentaire général</h3>
                <p class="hint">Optionnel — partagez ce que vous ressentez aujourd'hui (max 1000 caractères)</p>
                {{ form_widget(form.commentaire, {
                    attr: {
                        class: 'comment-textarea',
                        maxlength: '1000',
                        placeholder: 'Comment vous sentez-vous aujourd\'hui ? Partagez librement...'
                    }
                }) }}
                {% if form.commentaire.vars.errors|length > 0 %}
                    <div class="field-error" style="margin-top:8px;">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        {% for error in form.commentaire.vars.errors %}{{ error.message }}{% endfor %}
                    </div>
                {% endif %}
            </div>

            <!-- Submit -->
            <div class="submit-row">
                <a href="{{ path('user_dashboard') }}" class="btn btn-ghost">
                    <i class="bi bi-arrow-left"></i> Retour
                </a>
                <button type="submit" class="btn btn-teal">
                    <i class="bi bi-check-lg"></i>
                    Enregistrer mon check-in
                </button>
            </div>

            {{ form_end(form) }}

        </main>
    </div>

    <script>
        const menuToggle = document.getElementById('menuToggle');
        const sidebar    = document.getElementById('sidebar');
        const overlay    = document.getElementById('sidebarOverlay');
        menuToggle.addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('open'); });
        overlay.addEventListener('click',   () => { sidebar.classList.remove('open'); overlay.classList.remove('open'); });
    </script>
</body>
</html>