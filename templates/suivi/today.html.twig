<!DOCTYPE html>
<html lang="fr" class="h-full bg-gray-50">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Check-in quotidien - Bekri</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        teal: {
                            50:  '#f0fdfa',
                            100: '#ccfbf1',
                            500: '#14b8a6',
                            600: '#0d9488',
                            700: '#0f766e',
                        }
                    }
                }
            }
        }
    </script>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body class="h-full antialiased">

<div class="flex h-screen overflow-hidden bg-gray-50">

    <!-- Sidebar -->
    <aside class="hidden md:flex md:w-64 md:flex-shrink-0">
        <div class="flex flex-col w-full">
            <div class="flex items-center justify-center h-16 bg-teal-600 text-white font-bold text-2xl tracking-tight">
                bekri
            </div>

            <nav class="flex-1 px-3 py-6 bg-white border-r border-gray-100 overflow-y-auto">
                <div class="space-y-1">
                    <a href="{{ path('home') }}" class="flex items-center px-3 py-2.5 text-sm font-medium rounded-lg text-gray-700 hover:bg-teal-50 hover:text-teal-700">
                        <i class="fas fa-home w-5 mr-3"></i> Accueil
                    </a>
                    <a href="{{ path('user_profile') }}" class="flex items-center px-3 py-2.5 text-sm font-medium rounded-lg text-gray-700 hover:bg-teal-50 hover:text-teal-700">
                        <i class="fas fa-user w-5 mr-3"></i> Mon profil
                    </a>
                    <a href="{{ path('objectif_index') }}" class="flex items-center px-3 py-2.5 text-sm font-medium rounded-lg text-gray-700 hover:bg-teal-50 hover:text-teal-700">
                        <i class="fas fa-bullseye w-5 mr-3"></i> Mes objectifs
                    </a>
                    <a href="#" class="flex items-center px-3 py-2.5 text-sm font-medium bg-teal-50 text-teal-700 rounded-lg">
                        <i class="fas fa-calendar-check w-5 mr-3"></i> Mes suivis
                    </a>
                    <a href="#" class="flex items-center px-3 py-2.5 text-sm font-medium rounded-lg text-gray-700 hover:bg-teal-50 hover:text-teal-700">
                        <i class="fas fa-brain w-5 mr-3"></i> Tests mentaux
                    </a>
                    <a href="#" class="flex items-center px-3 py-2.5 text-sm font-medium rounded-lg text-gray-700 hover:bg-teal-50 hover:text-teal-700">
                        <i class="fas fa-comments w-5 mr-3"></i> Posts
                    </a>
                    <a href="#" class="flex items-center px-3 py-2.5 text-sm font-medium rounded-lg text-gray-700 hover:bg-teal-50 hover:text-teal-700">
                        <i class="fas fa-calendar-alt w-5 mr-3"></i> Événements
                    </a>
                    <div class="pt-4 border-t border-gray-100 mt-4"></div>
                    <a href="{{ path('app_logout') }}" class="flex items-center px-3 py-2.5 text-sm font-medium text-red-600 hover:bg-red-50 rounded-lg">
                        <i class="fas fa-sign-out-alt w-5 mr-3"></i> Déconnexion
                    </a>
                </div>
            </nav>
        </div>
    </aside>

    <!-- Main -->
    <main class="flex-1 p-6 overflow-y-auto">
        <div class="max-w-6xl mx-auto">

            <!-- Header -->
            <div class="mb-8">
                <h2 class="text-3xl font-bold text-gray-800">Check-in quotidien</h2>
                <p class="text-gray-500 mt-1">{{ suivi.date|date('d/m/Y') }}</p>
            </div>

            <!-- ✅ Success flash -->
            {% for message in app.flashes('success') %}
                <div class="mb-6 flex items-center gap-3 bg-green-50 border border-green-200 text-green-800 px-5 py-4 rounded-xl shadow-sm">
                    <i class="fas fa-circle-check text-green-500 text-lg"></i>
                    <span class="font-medium">{{ message }}</span>
                </div>
            {% endfor %}

            <!-- ⚠️ Warning flash (duplicate check-in) -->
            {% for message in app.flashes('warning') %}
                <div class="mb-6 flex items-center gap-3 bg-amber-50 border border-amber-300 text-amber-800 px-5 py-4 rounded-xl shadow-sm">
                    <i class="fas fa-triangle-exclamation text-amber-500 text-lg"></i>
                    <span class="font-medium">{{ message }}</span>
                </div>
            {% endfor %}

            <!-- ❌ Error flash -->
            {% for message in app.flashes('error') %}
                <div class="mb-6 flex items-center gap-3 bg-red-50 border border-red-200 text-red-800 px-5 py-4 rounded-xl shadow-sm">
                    <i class="fas fa-circle-xmark text-red-500 text-lg"></i>
                    <span class="font-medium">{{ message }}</span>
                </div>
            {% endfor %}

            <!-- Global form errors (Assert violations) -->
            {% if not form.vars.valid and form.vars.submitted %}
                <div class="mb-6 flex items-start gap-3 bg-red-50 border border-red-200 text-red-800 px-5 py-4 rounded-xl shadow-sm">
                    <i class="fas fa-circle-xmark text-red-500 text-lg mt-0.5"></i>
                    <div>
                        <p class="font-semibold mb-1">Veuillez corriger les erreurs suivantes :</p>
                        <ul class="list-disc list-inside text-sm space-y-1">
                            {% for field in form %}
                                {% for error in field.vars.errors %}
                                    <li>{{ error.message }}</li>
                                {% endfor %}
                            {% endfor %}
                            {% for error in form.vars.errors %}
                                <li>{{ error.message }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>
            {% endif %}

            {{ form_start(form) }}

            <!-- Questions Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                {% for question in questions %}
                    {% set fieldName = 'question_' ~ question.id %}
                    {% set hasError = form[fieldName] is defined and form[fieldName].vars.errors|length > 0 %}

                    <div class="bg-white rounded-2xl border {{ hasError ? 'border-red-400 ring-1 ring-red-300' : 'border-gray-200' }} shadow-sm p-5 hover:shadow-md transition">

                        <!-- Category Badge -->
                        <span class="inline-block px-3 py-1 text-xs font-medium bg-teal-50 text-teal-700 rounded-full mb-3">
                            {{ question.category|capitalize }}
                        </span>

                        <!-- Question text -->
                        <h3 class="text-base font-semibold text-gray-800 mb-4 leading-snug">
                            {{ question.texte }}
                            <span class="text-red-500 ml-1">*</span>
                        </h3>

                        <!-- Radio options -->
                        <div class="space-y-2 text-sm text-gray-700">
                            {{ form_widget(attribute(form, fieldName)) }}
                        </div>

                        <!-- Field error message -->
                        {% if hasError %}
                            <p class="mt-2 text-xs text-red-600 flex items-center gap-1">
                                <i class="fas fa-circle-exclamation"></i>
                                {% for error in form[fieldName].vars.errors %}
                                    {{ error.message }}
                                {% endfor %}
                            </p>
                        {% endif %}

                    </div>
                {% endfor %}
            </div>

            <!-- Comment -->
            <div class="mt-8 bg-white rounded-2xl border {{ form.commentaire.vars.errors|length > 0 ? 'border-red-400 ring-1 ring-red-300' : 'border-gray-200' }} shadow-sm p-5">
                <h3 class="text-base font-semibold text-gray-800 mb-3">
                    Commentaire général
                    <span class="text-gray-400 text-xs font-normal ml-1">(optionnel — max 1000 caractères)</span>
                </h3>
                {{ form_widget(form.commentaire, {
                    attr: {
                        class: 'w-full border border-gray-300 rounded-xl p-3 focus:ring-2 focus:ring-teal-500 focus:outline-none',
                        maxlength: '1000'
                    }
                }) }}
                {% if form.commentaire.vars.errors|length > 0 %}
                    <p class="mt-2 text-xs text-red-600 flex items-center gap-1">
                        <i class="fas fa-circle-exclamation"></i>
                        {% for error in form.commentaire.vars.errors %}
                            {{ error.message }}
                        {% endfor %}
                    </p>
                {% endif %}
            </div>

            <!-- Submit -->
            <div class="mt-8 flex justify-end">
                <button type="submit" class="px-8 py-3 bg-teal-600 text-white font-medium rounded-xl hover:bg-teal-700 shadow-md hover:shadow-lg transition-all flex items-center gap-2">
                    <i class="fas fa-check"></i>
                    Enregistrer mon check-in
                </button>
            </div>

            {{ form_end(form) }}

        </div>
    </main>

</div>

</body>
</html>
