<style>
    .wrapper { background: #f6f9fc; padding: 24px; }
    .card { max-width: 640px; margin: 0 auto; background: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.08); }
    .header { background: linear-gradient(135deg, #20b2aa 0%, #667eea 100%); padding: 28px 28px; color: #fff; }
    .brand { font-size: 20px; font-weight: 800; letter-spacing: -0.02em; margin: 0; }
    .subtitle { margin: 6px 0 0 0; opacity: 0.9; font-size: 14px; }
    .content { padding: 28px; color: #1f2937; }
    .title { font-size: 20px; margin: 0 0 8px 0; }
    .text { font-size: 15px; line-height: 1.6; margin: 0 0 16px 0; color: #374151; }
    .button-wrap { text-align: center; margin: 24px 0; }
    .btn { display: inline-block; background: #20b2aa; color: #fff !important; text-decoration: none; padding: 12px 18px; border-radius: 12px; font-weight: 700; }
    .muted { font-size: 13px; color: #6b7280; line-height: 1.6; }
    .footer { padding: 18px 28px; background: #f9fafb; border-top: 1px solid #eef2f7; }
    .code { word-break: break-all; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; font-size: 12px; color: #4b5563; }
  </style>

  <div class="wrapper">
    <div class="card">
      <div class="header">
        <p class="brand">Bekri Wellbeing</p>
        <p class="subtitle">Email verification</p>
      </div>

      <div class="content">
        <h1 class="title">Verify your email address</h1>
        <p class="text">
          Hi {{ user.prenom }} {{ user.nom }},<br>
          Thanks for creating an account. Please confirm your email address to activate your account.
        </p>

        <div class="button-wrap">
          <a class="btn" href="{{ signedUrl }}">Verify Email</a>
        </div>

        <p class="muted">
          This link will expire {{ expiresAtMessageKey|trans(expiresAtMessageData, 'VerifyEmailBundle') }}.
          If you didn’t create this account, you can safely ignore this email.
        </p>

        <hr style="border: none; border-top: 1px solid #eef2f7; margin: 22px 0;">

        <p class="muted" style="margin-bottom: 6px;">
          Having trouble with the button? Copy and paste this URL into your browser:
        </p>
        <div class="code">{{ signedUrl }}</div>
      </div>

      <div class="footer">
        <p class="muted" style="margin: 0;">
          Need help? Contact us at <a href="mailto:{{ supportEmail }}">{{ supportEmail }}</a>.
        </p>
      </div>
    </div>
  </div>

