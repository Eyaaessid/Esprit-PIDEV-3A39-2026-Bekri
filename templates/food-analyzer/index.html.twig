<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analyseur Alimentaire — Bekri</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --teal:        #20b2aa;
            --teal-dark:   #0d9488;
            --teal-light:  #e0f7f6;
            --purple:      #667eea;
            --dark:        #1a2332;
            --gray:        #64748b;
            --light:       #f8fafc;
            --white:       #ffffff;
            --sidebar-w:   260px;
            --shadow-sm:   0 2px 12px rgba(0,0,0,0.06);
            --shadow:      0 8px 30px rgba(0,0,0,0.10);
            --radius:      16px;
        }

        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior: smooth; }

        body { font-family: 'Inter', sans-serif; background: var(--light); color: var(--dark); display: flex; min-height: 100vh; }

        /* ── SIDEBAR ── */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--dark);
            min-height: 100vh;
            max-height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            display: flex;
            flex-direction: column;
            z-index: 100;
            transition: transform 0.3s ease;
            overflow-y: auto;
        }
        .sidebar-logo { padding: 28px 24px 20px; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid rgba(255,255,255,0.07); flex-shrink: 0; }
        .sidebar-logo img { height: 36px; width: auto; }
        .sidebar-logo-text { font-size: 20px; font-weight: 800; background: linear-gradient(135deg, var(--teal), #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .sidebar-user { padding: 20px 24px; display: flex; align-items: center; gap: 12px; border-bottom: 1px solid rgba(255,255,255,0.07); flex-shrink: 0; }
        .sidebar-avatar { width: 42px; height: 42px; border-radius: 50%; background: linear-gradient(135deg, var(--teal), var(--purple)); display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 16px; flex-shrink: 0; overflow: hidden; }
        .sidebar-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .sidebar-user-name { font-size: 14px; font-weight: 600; color: white; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .sidebar-user-role { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 2px; }
        .sidebar-nav { flex: 1; padding: 16px 0; overflow-y: auto; min-height: 0; }
        .sidebar-nav::-webkit-scrollbar { width: 4px; }
        .sidebar-nav::-webkit-scrollbar-track { background: transparent; }
        .sidebar-nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 10px; }
        .nav-section-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,0.25); padding: 12px 24px 6px; }
        .nav-item { display: flex; align-items: center; gap: 12px; padding: 11px 24px; color: rgba(255,255,255,0.6); text-decoration: none; font-size: 14px; font-weight: 500; transition: all 0.2s; border-left: 3px solid transparent; }
        .nav-item:hover { color: white; background: rgba(255,255,255,0.05); }
        .nav-item.active { color: var(--teal); background: rgba(32,178,170,0.1); border-left-color: var(--teal); }
        .nav-item i { width: 20px; text-align: center; font-size: 16px; }
        .nav-badge { margin-left: auto; background: var(--teal); color: white; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 50px; }
        .sidebar-footer { padding: 16px 0; border-top: 1px solid rgba(255,255,255,0.07); flex-shrink: 0; margin-top: auto; }

        /* ── MAIN ── */
        .main { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh; }

        /* ── TOPBAR ── */
        .topbar { background: white; padding: 0 32px; height: 68px; display: flex; align-items: center; justify-content: space-between; box-shadow: var(--shadow-sm); position: sticky; top: 0; z-index: 50; }
        .topbar-left { display: flex; align-items: center; gap: 16px; }
        .topbar-greeting h2 { font-size: 18px; font-weight: 700; color: var(--dark); }
        .topbar-greeting p { font-size: 13px; color: var(--gray); }
        .topbar-right { display: flex; align-items: center; gap: 12px; }
        .topbar-btn { width: 40px; height: 40px; border-radius: 10px; background: var(--light); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--gray); font-size: 16px; transition: all 0.2s; text-decoration: none; }
        .topbar-btn:hover { background: var(--teal-light); color: var(--teal-dark); }
        .topbar-avatar { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, var(--teal), var(--purple)); display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 14px; cursor: pointer; overflow: hidden; text-decoration: none; }
        .topbar-avatar img { width: 100%; height: 100%; object-fit: cover; }

        /* ── CONTENT ── */
        .content { padding: 32px; flex: 1; }

        /* ── ICON COLORS ── */
        .icon-teal   { background: var(--teal-light); color: var(--teal-dark); }
        .icon-purple { background: #ede9fe; color: #7c3aed; }
        .icon-amber  { background: #fef3c7; color: #d97706; }
        .icon-rose   { background: #ffe4e6; color: #e11d48; }
        .icon-blue   { background: #dbeafe; color: #2563eb; }
        .icon-green  { background: #d1fae5; color: #059669; }

        /* ── PAGE BANNER ── */
        .welcome-banner { background: linear-gradient(135deg, #059669 0%, var(--teal-dark) 50%, var(--purple) 100%); border-radius: var(--radius); padding: 32px 36px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; position: relative; overflow: hidden; color: white; }
        .welcome-banner::before { content: ''; position: absolute; top: -50px; right: -50px; width: 200px; height: 200px; background: rgba(255,255,255,0.06); border-radius: 50%; }
        .welcome-banner h1 { font-size: 22px; font-weight: 800; margin-bottom: 6px; }
        .welcome-banner p { font-size: 13px; color: rgba(255,255,255,0.8); }
        .banner-icon { width: 64px; height: 64px; background: rgba(255,255,255,0.15); border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 28px; flex-shrink: 0; }

        /* ── CARD ── */
        .card { background: white; border-radius: var(--radius); box-shadow: var(--shadow-sm); border: 1px solid #f1f5f9; overflow: hidden; margin-bottom: 24px; }
        .card-header { padding: 20px 24px 0; display: flex; align-items: center; justify-content: space-between; }
        .card-title { font-size: 15px; font-weight: 700; color: var(--dark); display: flex; align-items: center; gap: 8px; }
        .card-title i { color: var(--teal); }
        .card-body { padding: 20px 24px; }

        /* ── FORM ── */
        .form-group label { display: block; font-size: 13px; font-weight: 600; color: var(--gray); margin-bottom: 6px; }
        .form-control { width: 100%; border: 1.5px solid #e2e8f0; border-radius: 10px; padding: 10px 14px; font-size: 14px; font-family: 'Inter', sans-serif; color: var(--dark); background: white; transition: all 0.2s; outline: none; }
        .form-control:focus { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(32,178,170,0.1); }
        .textarea-large { min-height: 160px; resize: vertical; }

        /* ── BUTTONS ── */
        .btn-primary { display: inline-flex; align-items: center; gap: 8px; padding: 12px 28px; background: linear-gradient(135deg, var(--teal), var(--teal-dark)); color: white; border: none; border-radius: 50px; font-weight: 600; font-size: 14px; cursor: pointer; text-decoration: none; transition: all 0.3s; box-shadow: 0 4px 15px rgba(32,178,170,0.3); }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(32,178,170,0.4); color: white; }

        /* ── RESULT GRID ── */
        .result-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 8px; }
        .result-card-list { list-style: none; padding-left: 0; margin: 0; }
        .result-card-list li { font-size: 13px; padding: 5px 0; display: flex; align-items: flex-start; gap: 8px; color: var(--dark); border-bottom: 1px solid rgba(0,0,0,0.04); }
        .result-card-list li:last-child { border-bottom: none; }
        .result-bullet { width: 18px; height: 18px; border-radius: 50%; background: var(--teal-light); color: var(--teal-dark); display: flex; align-items: center; justify-content: center; font-size: 11px; flex-shrink: 0; margin-top: 2px; }

        /* ── STATS ROW (for calories) ── */
        .stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 24px; }
        .stat-card { background: white; border-radius: var(--radius); padding: 22px 24px; box-shadow: var(--shadow-sm); display: flex; align-items: center; gap: 16px; border: 1px solid #f1f5f9; }
        .stat-icon { width: 50px; height: 50px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
        .stat-value { font-size: 20px; font-weight: 800; color: var(--dark); line-height: 1.2; }
        .stat-label { font-size: 12px; color: var(--gray); margin-top: 4px; }

        /* ── LOADING ── */
        .loading-overlay { display: none; position: fixed; inset: 0; background: rgba(26,35,50,0.75); z-index: 999; align-items: center; justify-content: center; flex-direction: column; gap: 16px; }
        .loading-overlay.active { display: flex; }
        .loading-spinner { width: 52px; height: 52px; border: 4px solid rgba(255,255,255,0.2); border-top-color: var(--teal); border-radius: 50%; animation: spin 0.8s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }
        .loading-text { color: white; font-size: 15px; font-weight: 600; }

        /* ── ALERT ── */
        .alert-error { background: #ffe4e6; border: 1px solid #fecdd3; border-radius: 12px; padding: 14px 18px; color: #be123c; font-size: 14px; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }

        /* ── MOBILE ── */
        .menu-toggle { display: none; background: none; border: none; font-size: 22px; color: var(--dark); cursor: pointer; }
        .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 99; }

        @media (max-width: 1200px) {
            .result-grid { grid-template-columns: repeat(2, 1fr); }
            .stats-row { grid-template-columns: repeat(2, 1fr); }
        }
        @media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main { margin-left: 0; }
            .menu-toggle { display: block; }
            .content { padding: 20px 16px; }
            .topbar { padding: 0 16px; }
            .result-grid { grid-template-columns: 1fr; }
            .stats-row { grid-template-columns: 1fr; }
            .welcome-banner { flex-direction: column; gap: 16px; }
        }
    </style>
</head>
<body>

    <!-- LOADING -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="loading-spinner"></div>
        <div class="loading-text">🥗 L'IA analyse votre repas...</div>
    </div>

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'">
            <span class="sidebar-logo-text">Bekri</span>
        </div>
        <div class="sidebar-user">
            <div class="sidebar-avatar">
                {% if app.user.photo is defined and app.user.photo %}
                    <img src="{{ asset('uploads/photos/' ~ app.user.photo) }}" alt="avatar">
                {% else %}
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                {% endif %}
            </div>
            <div>
                <div class="sidebar-user-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
                <div class="sidebar-user-role">Membre Bekri</div>
            </div>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section-label">Principal</div>
            <a href="{{ path('user_dashboard') }}" class="nav-item"><i class="bi bi-grid-fill"></i> Tableau de bord</a>
            <a href="{{ path('suivi_today') }}" class="nav-item"><i class="bi bi-clipboard2-pulse-fill"></i> Check-in quotidien <span class="nav-badge">!</span></a>
            <a href="{{ path('insight_weekly') }}" class="nav-item"><i class="bi bi-graph-up-arrow"></i> Insights hebdo</a>
            <a href="{{ path('chat_index') }}" class="nav-item"><i class="bi bi-robot"></i> Coach Eya IA</a>
            <div class="nav-section-label">Bien-être</div>
            <a href="{{ path('user_analyse') }}" class="nav-item"><i class="bi bi-heart-pulse-fill"></i> Mon analyse bien-être</a>
            <a href="{{ path('objectif_index') }}" class="nav-item"><i class="bi bi-trophy-fill"></i> Mes objectifs</a>
            <a href="{{ path('plan_index') }}" class="nav-item"><i class="bi bi-calendar2-week-fill"></i> Plan hebdomadaire</a>
            <a href="{{ path('food_analyzer_index') }}" class="nav-item active"><i class="bi bi-egg-fried"></i> Analyseur Alimentaire</a>
            <div class="nav-section-label">Communauté</div>
            <a href="{{ path('posts_list') }}" class="nav-item"><i class="bi bi-newspaper"></i> Publications</a>
            <a href="{{ path('evenements_home') }}" class="nav-item"><i class="bi bi-calendar-event-fill"></i> Événements</a>
            <div class="nav-section-label">Mon compte</div>
            <a href="{{ path('user_profile') }}" class="nav-item"><i class="bi bi-person-fill"></i> Mon profil</a>
            <a href="{{ path('user_profile_edit') }}" class="nav-item"><i class="bi bi-gear-fill"></i> Paramètres</a>
        </nav>
        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;"><i class="bi bi-box-arrow-left"></i> Se déconnecter</a>
        </div>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- MAIN -->
    <div class="main">

        <!-- TOPBAR -->
        <header class="topbar">
            <div class="topbar-left">
                <button class="menu-toggle" id="menuToggle"><i class="bi bi-list"></i></button>
                <div class="topbar-greeting">
                    <h2>Analyseur Alimentaire 🥗</h2>
                    <p>Analysez instantanément vos repas grâce à l'IA</p>
                </div>
            </div>
            <div class="topbar-right">
                <a href="{{ path('suivi_today') }}" class="topbar-btn" title="Check-in du jour"><i class="bi bi-clipboard2-pulse"></i></a>
                <a href="{{ path('chat_index') }}" class="topbar-btn" title="Chat avec Eya"><i class="bi bi-robot"></i></a>
                <a href="{{ path('user_profile') }}" class="topbar-avatar">
                    {% if app.user.photo is defined and app.user.photo %}
                        <img src="{{ asset('uploads/photos/' ~ app.user.photo) }}" alt="avatar">
                    {% else %}
                        {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                    {% endif %}
                </a>
            </div>
        </header>

        <!-- CONTENT -->
        <main class="content">

            <!-- Banner -->
            <div class="welcome-banner">
                <div class="welcome-text">
                    <h1>🥗 Analysez vos repas en quelques secondes</h1>
                    <p>Saisissez un plat ou une liste d'ingrédients et obtenez une analyse détaillée : calories, nutriments, bienfaits et risques.</p>
                </div>
                <div class="banner-icon"><i class="bi bi-egg-fried"></i></div>
            </div>

            {% if error %}
            <div class="alert-error"><i class="bi bi-exclamation-circle-fill"></i> {{ error }}</div>
            {% endif %}

            <!-- Form -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title"><i class="bi bi-pen-fill"></i> Décrivez votre repas</div>
                </div>
                <div class="card-body">
                    <form method="POST" action="{{ path('food_analyzer_index') }}" id="foodAnalyzerForm">
                        <div class="form-group">
                            <label>Repas ou liste d'ingrédients</label>
                            <textarea name="ingredients" class="form-control textarea-large" required
                                      placeholder="Exemples :&#10;- Bol de pâtes à la bolognaise avec fromage râpé&#10;- 2 œufs, 1 tranche de pain complet, 1 avocat, huile d'olive&#10;- Salade de quinoa, pois chiches, tomates, concombre, feta..."
                            >{{ input }}</textarea>
                        </div>
                        <div style="display:flex; gap:12px; margin-top:20px; flex-wrap:wrap; align-items:center;">
                            <button type="submit" class="btn-primary" onclick="showLoading()">
                                <i class="bi bi-stars"></i> Analyser mon repas
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            {% if analysis %}

            <!-- Quick stats -->
            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-icon icon-amber"><i class="bi bi-fire"></i></div>
                    <div>
                        <div class="stat-value">{{ analysis.estimated_calories|default('N/A') }}</div>
                        <div class="stat-label">Calories estimées</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon icon-blue"><i class="bi bi-nutrition"></i></div>
                    <div>
                        <div class="stat-value">Macronutriments</div>
                        <div class="stat-label">Protéines, glucides, lipides</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon icon-green"><i class="bi bi-heart-pulse-fill"></i></div>
                    <div>
                        <div class="stat-value">Conseils santé</div>
                        <div class="stat-label">Bienfaits & points de vigilance</div>
                    </div>
                </div>
            </div>

            <!-- Results cards -->
            <div class="result-grid">
                <div class="card">
                    <div class="card-header">
                        <div class="card-title"><i class="bi bi-fire"></i> Calories estimées</div>
                    </div>
                    <div class="card-body">
                        <p style="font-size:14px; color:var(--dark); line-height:1.7;">
                            {{ analysis.estimated_calories|default('Analyse des calories non disponible.') }}
                        </p>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <div class="card-title"><i class="bi bi-diagram-3-fill"></i> Macronutriments</div>
                    </div>
                    <div class="card-body">
                        <ul class="result-card-list">
                            {% if analysis.macronutrients is iterable %}
                                {% for item in analysis.macronutrients %}
                                <li>
                                    <div class="result-bullet">●</div>
                                    <span>{{ item }}</span>
                                </li>
                                {% endfor %}
                            {% else %}
                                <li>
                                    <div class="result-bullet">●</div>
                                    <span>{{ analysis.macronutrients|default('Informations non disponibles.') }}</span>
                                </li>
                            {% endif %}
                        </ul>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <div class="card-title"><i class="bi bi-capsule-pill"></i> Vitamines & minéraux</div>
                    </div>
                    <div class="card-body">
                        <ul class="result-card-list">
                            {% if analysis.vitamins_minerals is iterable %}
                                {% for item in analysis.vitamins_minerals %}
                                <li>
                                    <div class="result-bullet">●</div>
                                    <span>{{ item }}</span>
                                </li>
                                {% endfor %}
                            {% else %}
                                <li>
                                    <div class="result-bullet">●</div>
                                    <span>{{ analysis.vitamins_minerals|default('Informations non disponibles.') }}</span>
                                </li>
                            {% endif %}
                        </ul>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <div class="card-title"><i class="bi bi-emoji-smile-fill"></i> Bienfaits pour la santé</div>
                    </div>
                    <div class="card-body">
                        <ul class="result-card-list">
                            {% if analysis.health_benefits is iterable %}
                                {% for item in analysis.health_benefits %}
                                <li>
                                    <div class="result-bullet">●</div>
                                    <span>{{ item }}</span>
                                </li>
                                {% endfor %}
                            {% else %}
                                <li>
                                    <div class="result-bullet">●</div>
                                    <span>{{ analysis.health_benefits|default('Aucun bénéfice détaillé disponible.') }}</span>
                                </li>
                            {% endif %}
                        </ul>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <div class="card-title"><i class="bi bi-exclamation-triangle-fill"></i> Risques & avertissements</div>
                    </div>
                    <div class="card-body">
                        <ul class="result-card-list">
                            {% if analysis.health_risks is iterable %}
                                {% for item in analysis.health_risks %}
                                <li>
                                    <div class="result-bullet">●</div>
                                    <span>{{ item }}</span>
                                </li>
                                {% endfor %}
                            {% else %}
                                <li>
                                    <div class="result-bullet">●</div>
                                    <span>{{ analysis.health_risks|default('Aucun risque particulier détecté ou informations manquantes.') }}</span>
                                </li>
                            {% endif %}
                        </ul>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <div class="card-title"><i class="bi bi-magic"></i> Conseils pour l'améliorer</div>
                    </div>
                    <div class="card-body">
                        <ul class="result-card-list">
                            {% if analysis.tips is iterable %}
                                {% for item in analysis.tips %}
                                <li>
                                    <div class="result-bullet">●</div>
                                    <span>{{ item }}</span>
                                </li>
                                {% endfor %}
                            {% else %}
                                <li>
                                    <div class="result-bullet">●</div>
                                    <span>{{ analysis.tips|default('Aucun conseil spécifique disponible.') }}</span>
                                </li>
                            {% endif %}
                        </ul>
                    </div>
                </div>
            </div>

            {% endif %}

        </main>
    </div>

    <script>
        const menuToggle = document.getElementById('menuToggle');
        const sidebar    = document.getElementById('sidebar');
        const overlay    = document.getElementById('sidebarOverlay');
        if (menuToggle && sidebar && overlay) {
            menuToggle.addEventListener('click', () => {
                sidebar.classList.toggle('open');
                overlay.classList.toggle('open');
            });
            overlay.addEventListener('click', () => {
                sidebar.classList.remove('open');
                overlay.classList.remove('open');
            });
        }
        function showLoading() {
            var overlayEl = document.getElementById('loadingOverlay');
            if (overlayEl) {
                overlayEl.classList.add('active');
            }
        }
    </script>

</body>
</html>

