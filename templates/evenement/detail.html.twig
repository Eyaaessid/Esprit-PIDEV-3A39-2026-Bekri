{% extends 'base.html.twig' %}

{% block title %}{{ evenement.titre }} - BEKRI{% endblock %}

{% block body_class %}event-detail-page{% endblock %}

{% block main %}

    <!-- Page Title -->
    <div class="page-title" data-aos="fade">
        <div class="heading">
            <div class="container">
                <div class="row d-flex justify-content-center text-center">
                    <div class="col-lg-8">
                        <h1>{{ evenement.titre }}</h1>
                        <p class="mb-0">Détails de l'événement</p>
                    </div>
                </div>
            </div>
        </div>
        <nav class="breadcrumbs">
            <div class="container">
                <ol>
                    <li><a href="{{ path('home') }}">Accueil</a></li>
                    <li><a href="{{ path('evenement_liste') }}">Événements</a></li>
                    <li class="current">{{ evenement.titre }}</li>
                </ol>
            </div>
        </nav>
    </div><!-- End Page Title -->

    <!-- Flash Messages -->
    {% for label, messages in app.flashes %}
        <div class="container mt-4">
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        </div>
    {% endfor %}

    <!-- Event Detail Section -->
    <section id="event-detail" class="event-detail section">
        <div class="container">
            <div class="row gy-4">

                <!-- Main Content -->
                <div class="col-lg-8" data-aos="fade-up">
                    <div class="event-detail-card">
                        <div class="event-hero-image">
                            <img src="{{ asset(evenement.image ?: 'assets/img/health/consultation-3.webp') }}" alt="{{ evenement.titre }}" class="img-fluid">
                            <div class="event-type-badge {{ evenement.type }}">
                                {% if evenement.type == 'atelier' %}
                                    <i class="bi bi-people"></i> Atelier
                                {% elseif evenement.type == 'meditation' %}
                                    <i class="bi bi-heart-pulse"></i> Méditation
                                {% elseif evenement.type == 'defi' %}
                                    <i class="bi bi-trophy"></i> Défi Santé
                                {% else %}
                                    <i class="bi bi-calendar-event"></i> {{ evenement.type|capitalize }}
                                {% endif %}
                            </div>
                        </div>

                        <div class="event-detail-content">
                            <h2 class="event-title">{{ evenement.titre }}</h2>
                            
                            <div class="event-meta-info">
                                <div class="meta-item">
                                    <i class="bi bi-calendar3"></i>
                                    <div>
                                        <strong>Date de début</strong>
                                        <span>{{ evenement.dateDebut|date('d/m/Y à H:i') }}</span>
                                    </div>
                                </div>
                                <div class="meta-item">
                                    <i class="bi bi-calendar-check"></i>
                                    <div>
                                        <strong>Date de fin</strong>
                                        <span>{{ evenement.dateFin|date('d/m/Y à H:i') }}</span>
                                    </div>
                                </div>
                                <div class="meta-item">
                                    <i class="bi bi-geo-alt"></i>
                                    <div>
                                        <strong>Lieu</strong>
                                        <span>{{ evenement.lieu }}</span>
                                    </div>
                                </div>
                                <div class="meta-item">
                                    <i class="bi bi-people"></i>
                                    <div>
                                        <strong>Participants</strong>
                                        <span>{{ evenement.nombreParticipants }}/{{ evenement.capaciteMax }}</span>
                                    </div>
                                </div>
                            </div>

                            <div class="event-description">
                                <h3>À propos de cet événement</h3>
                                <p>{{ evenement.description }}</p>
                            </div>

                            <div class="event-benefits">
                                <h3>Bénéfices de cet événement</h3>
                                <ul>
                                    <li><i class="bi bi-check-circle-fill"></i> Amélioration du bien-être général</li>
                                    <li><i class="bi bi-check-circle-fill"></i> Rencontre avec des professionnels de santé</li>
                                    <li><i class="bi bi-check-circle-fill"></i> Apprentissage de nouvelles techniques</li>
                                    <li><i class="bi bi-check-circle-fill"></i> Échange avec la communauté</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Participants Section -->
                    <div class="participants-section" data-aos="fade-up" data-aos-delay="100">
                        <h3><i class="bi bi-people-fill me-2"></i>Participants inscrits</h3>
                        <div class="participants-grid">
                            {% for participation in evenement.participations|slice(0, 12) %}
                                {% if participation.statut == 'confirmé' %}
                                    <div class="participant-avatar" title="{{ participation.utilisateur.nomComplet }}">
                                        <div class="avatar-circle">
                                            {{ participation.utilisateur.prenom|slice(0, 1) }}{{ participation.utilisateur.nom|slice(0, 1) }}
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                            {% if evenement.nombreParticipants > 12 %}
                                <div class="participant-avatar more">
                                    <div class="avatar-circle">
                                        +{{ evenement.nombreParticipants - 12 }}
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <!-- Sidebar -->
                <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="event-sidebar">
                        
                        <!-- Registration Card -->
                        <div class="registration-card">
                            <div class="card-header">
                                <h4>Inscription</h4>
                            </div>
                            <div class="card-body">
                                <div class="availability-status">
                                    {% if evenement.isComplet() %}
                                        <div class="status-badge complet">
                                            <i class="bi bi-x-circle"></i>
                                            <span>Événement complet</span>
                                        </div>
                                    {% else %}
                                        <div class="status-badge available">
                                            <i class="bi bi-check-circle"></i>
                                            <span>Places disponibles</span>
                                        </div>
                                    {% endif %}
                                </div>

                                <div class="capacity-info">
                                    <div class="capacity-bar">
                                        <div class="capacity-fill" style="width: {{ (evenement.nombreParticipants / evenement.capaciteMax * 100)|round }}%"></div>
                                    </div>
                                    <div class="capacity-text">
                                        <span class="places-left">{{ evenement.placesRestantes }} place(s) restante(s)</span>
                                        <span class="total-capacity">sur {{ evenement.capaciteMax }}</span>
                                    </div>
                                </div>

                                {% if isParticipant %}
                                    {# L'utilisateur est déjà inscrit #}
                                    <div class="alert alert-success mb-3">
                                        <i class="bi bi-check-circle-fill me-2"></i>
                                        Vous êtes inscrit à cet événement
                                    </div>
                                    <form method="post" action="{{ path('evenement_annuler', {id: evenement.id}) }}">
                                        <button type="submit" class="btn btn-cancel" onclick="return confirm('Êtes-vous sûr de vouloir annuler votre participation ?')">
                                            <i class="bi bi-x-lg me-2"></i>Annuler ma participation
                                        </button>
                                    </form>
                                {% else %}
                                    {# L'utilisateur n'est pas inscrit #}
                                    {% if not evenement.isComplet() %}
                                        <form method="post" action="{{ path('evenement_participer', {id: evenement.id}) }}">
                                            <button type="submit" class="btn btn-register">
                                                <i class="bi bi-calendar-check me-2"></i>Participer à cet événement
                                            </button>
                                        </form>
                                    {% else %}
                                        <button class="btn btn-register" disabled>
                                            <i class="bi bi-x-circle me-2"></i>Complet
                                        </button>
                                    {% endif %}
                                {% endif %}
                            </div>
                        </div>

                        <!-- Ticket Card - Only show if user is registered -->
                        {% if isParticipant %}
                        <div class="qr-code-card text-center">
                            <h4><i class="bi bi-ticket-perforated me-2"></i>Votre Ticket Événement</h4>
                            <p class="small text-muted mb-3">Scannez ou partagez ce ticket</p>
                            <div class="qr-wrapper p-2 bg-light rounded-3 d-inline-block w-100">
                                <img src="{{ path('evenement_qr_code', {id: evenement.id}) }}" alt="Event Ticket" class="img-fluid rounded shadow-sm" style="width: 100%; border: 1px solid #eee;">
                            </div>
                            <div class="mt-3">
                                <a href="{{ path('evenement_qr_code', {id: evenement.id}) }}" download="Ticket-{{ evenement.titre|slug }}.png" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-download me-1"></i>Télécharger le Ticket
                                </a>
                            </div>
                        </div>
                        {% endif %}

                        <!-- Event Info Card -->
                        <div class="info-card">
                            <h4><i class="bi bi-info-circle me-2"></i>Informations pratiques</h4>
                            <ul class="info-list">
                                <li>
                                    <i class="bi bi-clock"></i>
                                    <div>
                                        <strong>Durée</strong>
                                        <span>
                                            {% set duration = date(evenement.dateFin).diff(date(evenement.dateDebut)) %}
                                            {% if duration.h > 0 %}
                                                {{ duration.h }}h{% if duration.i > 0 %}{{ duration.i }}{% endif %}
                                            {% else %}
                                                {{ duration.i }} minutes
                                            {% endif %}
                                        </span>
                                    </div>
                                </li>
                                <li>
                                    <i class="bi bi-tag"></i>
                                    <div>
                                        <strong>Type</strong>
                                        <span>{{ evenement.type|capitalize }}</span>
                                    </div>
                                </li>
                                <li>
                                    <i class="bi bi-shield-check"></i>
                                    <div>
                                        <strong>Statut</strong>
                                        <span class="badge bg-success">{{ evenement.statut|capitalize }}</span>
                                    </div>
                                </li>
                            </ul>
                        </div>

                        <!-- Share Card -->
                        <div class="share-card">
                            <h4><i class="bi bi-share me-2"></i>Partager</h4>
                            <div class="share-buttons">
                                <a href="#" class="share-btn facebook" title="Partager sur Facebook">
                                    <i class="bi bi-facebook"></i>
                                </a>
                                <a href="#" class="share-btn twitter" title="Partager sur Twitter">
                                    <i class="bi bi-twitter-x"></i>
                                </a>
                                <a href="#" class="share-btn linkedin" title="Partager sur LinkedIn">
                                    <i class="bi bi-linkedin"></i>
                                </a>
                                <a href="#" class="share-btn email" title="Partager par email">
                                    <i class="bi bi-envelope"></i>
                                </a>
                            </div>
                        </div>

                        <!-- Contact Card -->
                        <div class="contact-card">
                            <h4><i class="bi bi-question-circle me-2"></i>Besoin d'aide ?</h4>
                            <p>Contactez notre équipe pour toute question concernant cet événement.</p>
                            <a href="{{ path('contact') }}" class="btn btn-contact">
                                <i class="bi bi-envelope me-2"></i>Nous contacter
                            </a>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </section>

{% endblock %}

{% block head_extra %}
<style>
.event-detail-card {
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 5px 25px rgba(0,0,0,0.08);
    margin-bottom: 30px;
}

.event-hero-image {
    position: relative;
    height: 400px;
    overflow: hidden;
}

.event-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.event-type-badge {
    position: absolute;
    top: 20px;
    left: 20px;
    background: rgba(255,255,255,0.95);
    padding: 12px 25px;
    border-radius: 50px;
    font-size: 15px;
    font-weight: 600;
    color: var(--accent-color);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

.event-detail-content {
    padding: 40px;
}

.event-title {
    font-size: 32px;
    font-weight: 700;
    color: var(--heading-color);
    margin-bottom: 30px;
}

.event-meta-info {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 40px;
    padding: 30px;
    background: #f8f9fa;
    border-radius: 15px;
}

.event-meta-info .meta-item {
    display: flex;
    gap: 15px;
    align-items: flex-start;
}

.event-meta-info .meta-item i {
    font-size: 24px;
    color: var(--accent-color);
    margin-top: 5px;
}

.event-meta-info .meta-item div {
    display: flex;
    flex-direction: column;
}

.event-meta-info .meta-item strong {
    font-size: 14px;
    color: #666;
    margin-bottom: 5px;
}

.event-meta-info .meta-item span {
    font-size: 16px;
    color: var(--heading-color);
    font-weight: 600;
}

.event-description,
.event-benefits {
    margin-bottom: 30px;
}

.event-description h3,
.event-benefits h3 {
    font-size: 24px;
    font-weight: 700;
    color: var(--heading-color);
    margin-bottom: 20px;
}

.event-description p {
    font-size: 16px;
    line-height: 1.8;
    color: #666;
}

.event-benefits ul {
    list-style: none;
    padding: 0;
}

.event-benefits ul li {
    padding: 12px 0;
    font-size: 16px;
    color: #666;
    display: flex;
    align-items: center;
    gap: 10px;
}

.event-benefits ul li i {
    color: var(--accent-color);
    font-size: 20px;
}

.participants-section {
    background: #fff;
    padding: 30px;
    border-radius: 20px;
    box-shadow: 0 5px 25px rgba(0,0,0,0.08);
}

.participants-section h3 {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 20px;
    color: var(--heading-color);
}

.participants-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
}

.participant-avatar .avatar-circle {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: var(--accent-color);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 16px;
    text-transform: uppercase;
    box-shadow: 0 3px 10px rgba(0,0,0,0.1);
}

.participant-avatar.more .avatar-circle {
    background: #6c757d;
    font-size: 14px;
}

.event-sidebar > div {
    background: #fff;
    border-radius: 15px;
    padding: 25px;
    box-shadow: 0 5px 25px rgba(0,0,0,0.08);
    margin-bottom: 20px;
}

.event-sidebar h4 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 20px;
    color: var(--heading-color);
}

.registration-card .card-header {
    margin: -25px -25px 20px -25px;
    padding: 20px 25px;
    background: linear-gradient(135deg, var(--accent-color), var(--contrast-color));
    border-radius: 15px 15px 0 0;
}

.registration-card .card-header h4 {
    color: #fff;
    margin: 0;
}

.status-badge {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 15px;
    border-radius: 10px;
    margin-bottom: 20px;
    font-weight: 600;
}

.status-badge.available {
    background: rgba(40, 167, 69, 0.1);
    color: #28a745;
}

.status-badge.complet {
    background: rgba(220, 53, 69, 0.1);
    color: #dc3545;
}

.capacity-info {
    margin-bottom: 20px;
}

.capacity-bar {
    height: 10px;
    background: #e9ecef;
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 10px;
}

.capacity-fill {
    height: 100%;
    background: var(--accent-color);
    transition: width 0.3s;
}

.capacity-text {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
}

.places-left {
    font-weight: 600;
    color: var(--heading-color);
}

.total-capacity {
    color: #666;
}

.btn-register,
.btn-cancel,
.btn-contact {
    width: 100%;
    padding: 15px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 16px;
    border: none;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
}

.btn-register {
    background: var(--accent-color);
    color: #fff;
}

.btn-register:hover:not(:disabled) {
    background: var(--contrast-color);
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
}

.btn-register:disabled {
    background: #6c757d;
    cursor: not-allowed;
}

.btn-cancel {
    background: #fff;
    color: #dc3545;
    border: 2px solid #dc3545;
}

.btn-cancel:hover {
    background: #dc3545;
    color: #fff;
}

.info-list {
    list-style: none;
    padding: 0;
}

.info-list li {
    display: flex;
    gap: 15px;
    padding: 15px 0;
    border-bottom: 1px solid #eee;
}

.info-list li:last-child {
    border-bottom: none;
}

.info-list li i {
    font-size: 20px;
    color: var(--accent-color);
    margin-top: 2px;
}

.info-list li div {
    flex: 1;
}

.info-list li strong {
    display: block;
    font-size: 14px;
    color: #666;
    margin-bottom: 5px;
}

.info-list li span {
    font-size: 15px;
    color: var(--heading-color);
    font-weight: 600;
}

.share-buttons {
    display: flex;
    gap: 10px;
}

.share-btn {
    flex: 1;
    padding: 12px;
    border-radius: 10px;
    color: #fff;
    text-align: center;
    text-decoration: none;
    transition: all 0.3s;
}

.share-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
}

.share-btn.facebook { background: #3b5998; }
.share-btn.twitter { background: #000; }
.share-btn.linkedin { background: #0077b5; }
.share-btn.email { background: #6c757d; }

.contact-card p {
    font-size: 14px;
    color: #666;
    margin-bottom: 20px;
}

@media (max-width: 768px) {
    .event-meta-info {
        grid-template-columns: 1fr;
    }
}
</style>
{% endblock %}
