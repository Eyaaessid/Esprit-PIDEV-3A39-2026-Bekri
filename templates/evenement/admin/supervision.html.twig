<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Supervision des événements — Bekri</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --dark:       #1a2332;
            --dark2:      #1e3a5f;
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --light:      #f8fafc;
            --white:      #ffffff;
            --gray:       #64748b;
            --sidebar-w:  260px;
            --shadow-sm:  0 2px 12px rgba(0,0,0,0.06);
            --shadow:     0 8px 30px rgba(0,0,0,0.10);
            --radius:     16px;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior:smooth; }
        body { font-family:'Inter',sans-serif; background:var(--light); color:var(--dark); display:flex; min-height:100vh; }

        /* ── SIDEBAR ── */
        .sidebar { width:var(--sidebar-w); background:var(--dark); min-height:100vh; position:fixed; top:0; left:0; display:flex; flex-direction:column; z-index:100; }
        .sidebar-logo { padding:28px 24px 20px; display:flex; align-items:center; gap:10px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-logo-text { font-size:20px; font-weight:800; background:linear-gradient(135deg,var(--teal),#a78bfa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .sidebar-user { padding:20px 24px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-avatar { width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:16px; flex-shrink:0; overflow:hidden; position:relative; }
        .sidebar-avatar img { width:100%; height:100%; object-fit:cover; }
        .avatar-dot { width:10px; height:10px; background:#22c55e; border-radius:50%; border:2px solid var(--dark); position:absolute; bottom:1px; right:1px; }
        .sidebar-user-name { font-size:14px; font-weight:600; color:white; }
        .sidebar-user-role { font-size:11px; color:rgba(255,255,255,0.4); margin-top:2px; }
        .sidebar-nav { flex:1; padding:16px 0; overflow-y:auto; }
        .nav-section-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:rgba(255,255,255,0.25); padding:12px 24px 6px; }
        .nav-item { display:flex; align-items:center; gap:12px; padding:11px 24px; color:rgba(255,255,255,0.6); text-decoration:none; font-size:14px; font-weight:500; transition:all 0.2s; border-left:3px solid transparent; }
        .nav-item:hover { color:white; background:rgba(255,255,255,0.05); }
        .nav-item.active { color:var(--teal); background:rgba(32,178,170,0.1); border-left-color:var(--teal); }
        .nav-item i { width:20px; text-align:center; font-size:16px; }
        .sidebar-footer { padding:16px 0; border-top:1px solid rgba(255,255,255,0.07); }

        /* ── MAIN ── */
        .main { margin-left:var(--sidebar-w); flex:1; display:flex; flex-direction:column; min-height:100vh; }

        /* ── TOPBAR ── */
        .topbar { background:white; padding:0 32px; height:68px; display:flex; align-items:center; justify-content:space-between; box-shadow:var(--shadow-sm); position:sticky; top:0; z-index:50; }
        .topbar-title { font-size:18px; font-weight:700; color:var(--dark); }
        .topbar-sub { font-size:13px; color:var(--gray); margin-top:1px; }
        .topbar-right { display:flex; align-items:center; gap:12px; }
        .topbar-icon-btn { width:38px; height:38px; border-radius:10px; background:var(--light); border:1px solid #e2e8f0; display:flex; align-items:center; justify-content:center; color:var(--gray); font-size:16px; text-decoration:none; transition:all 0.2s; }
        .topbar-icon-btn:hover { background:var(--teal-light); color:var(--teal-dark); border-color:var(--teal); }
        .topbar-avatar { width:38px; height:38px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:14px; text-decoration:none; overflow:hidden; flex-shrink:0; }
        .topbar-avatar img { width:100%; height:100%; object-fit:cover; }

        /* ── PAGE HEADER ── */
        .page-header { background:linear-gradient(135deg,var(--dark) 0%,#1e3a5f 60%,#0d9488 100%); padding:36px 40px 28px; position:relative; overflow:hidden; }
        .page-header::before { content:''; position:absolute; top:-60px; right:-60px; width:260px; height:260px; background:rgba(32,178,170,0.08); border-radius:50%; }
        .page-header::after { content:''; position:absolute; bottom:-40px; right:200px; width:160px; height:160px; background:rgba(102,126,234,0.06); border-radius:50%; }
        .page-header-inner { max-width:1200px; margin:0 auto; position:relative; z-index:1; }
        .page-header-tag { display:inline-flex; align-items:center; gap:6px; background:rgba(32,178,170,0.2); border:1px solid rgba(32,178,170,0.35); color:#7fffd4; padding:4px 12px; border-radius:50px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:10px; }
        .page-header-title { font-size:26px; font-weight:800; color:white; margin-bottom:4px; }
        .page-header-sub { font-size:14px; color:rgba(255,255,255,0.55); }

        /* ── CONTENT ── */
        .content { flex:1; padding:32px 40px; max-width:1280px; margin:0 auto; width:100%; }

        /* ── STAT CARDS ── */
        .stats-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:20px; margin-bottom:28px; }
        .stat-card { background:white; border-radius:var(--radius); padding:22px; box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; display:flex; align-items:center; gap:16px; transition:all 0.3s; }
        .stat-card:hover { transform:translateY(-4px); box-shadow:var(--shadow); }
        .stat-icon { width:52px; height:52px; border-radius:14px; display:flex; align-items:center; justify-content:center; font-size:22px; flex-shrink:0; }
        .stat-icon.teal   { background:var(--teal-light); color:var(--teal-dark); }
        .stat-icon.green  { background:#f0fdf4; color:#16a34a; }
        .stat-icon.blue   { background:#eff6ff; color:#2563eb; }
        .stat-icon.gray   { background:#f1f5f9; color:var(--gray); }
        .stat-label { font-size:12px; color:var(--gray); font-weight:600; text-transform:uppercase; letter-spacing:0.4px; margin-bottom:4px; }
        .stat-value { font-size:26px; font-weight:800; color:var(--dark); line-height:1; }

        /* ── CARD ── */
        .card { background:white; border-radius:var(--radius); box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; overflow:hidden; }
        .card-header { padding:20px 24px; border-bottom:1px solid #f1f5f9; }
        .card-title { font-size:15px; font-weight:700; color:var(--dark); }
        .card-sub { font-size:12px; color:var(--gray); margin-top:2px; }

        /* ── TABLE ── */
        .table-wrap { overflow-x:auto; }
        table { width:100%; border-collapse:collapse; }
        thead th { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; color:var(--gray); padding:12px 16px; background:#f8fafc; border-bottom:1px solid #f1f5f9; text-align:left; white-space:nowrap; }
        tbody td { padding:14px 16px; font-size:14px; color:var(--dark); border-bottom:1px solid #f8fafc; vertical-align:middle; }
        tbody tr:last-child td { border-bottom:none; }
        tbody tr:hover td { background:#fafbfc; }
        .event-title { font-weight:600; font-size:14px; }
        .event-location { font-size:12px; color:var(--gray); margin-top:2px; }
        .organizer-name  { font-weight:600; font-size:14px; }
        .organizer-email { font-size:12px; color:var(--gray); }
        .date-main { font-size:14px; font-weight:500; }
        .date-time { font-size:12px; color:var(--gray); }

        /* ── STATUS BADGES ── */
        .badge { display:inline-flex; align-items:center; gap:4px; padding:4px 10px; border-radius:50px; font-size:11px; font-weight:700; }
        .badge-open     { background:#f0fdf4; color:#16a34a; }
        .badge-full     { background:#fff1f2; color:#dc2626; }
        .badge-planned  { background:#eff6ff; color:#2563eb; }
        .badge-cancelled{ background:#f1f5f9; color:var(--gray); }
        .badge-finished { background:#1e293b; color:#94a3b8; }
        .badge-type     { background:var(--teal-light); color:var(--teal-dark); }

        /* ── CAPACITY ── */
        .capacity-cell { display:flex; align-items:center; gap:6px; font-size:14px; font-weight:500; }

        /* ── ACTION BTN ── */
        .btn-icon { width:32px; height:32px; border-radius:8px; display:inline-flex; align-items:center; justify-content:center; font-size:14px; border:none; cursor:pointer; text-decoration:none; transition:all 0.2s; }
        .btn-icon.view   { background:#eff6ff; color:#2563eb; }
        .btn-icon.view:hover { background:#2563eb; color:white; }

        /* ── EMPTY STATE ── */
        .empty-state { text-align:center; padding:60px 20px; }
        .empty-state i { font-size:40px; color:#cbd5e1; display:block; margin-bottom:12px; }
        .empty-state p { font-size:14px; color:var(--gray); }

        @media (max-width:1200px) { .stats-grid { grid-template-columns:repeat(2,1fr); } }
        @media (max-width:768px)  { .main { margin-left:0; } .content { padding:20px 16px; } .page-header { padding:24px 20px; } }
    </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
    <div class="sidebar-logo">
        <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'" style="height:36px;">
        <span class="sidebar-logo-text">Bekri Admin</span>
    </div>
    <div class="sidebar-user">
        <div class="sidebar-avatar">
            {% if app.user and app.user.avatar %}
                <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
            {% else %}
                {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
            {% endif %}
            <div class="avatar-dot"></div>
        </div>
        <div>
            <div class="sidebar-user-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
            <div class="sidebar-user-role">{{ app.user.role.getLabel() }}</div>
        </div>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-section-label">Principal</div>
        <a href="{{ path('admin_dashboard') }}" class="nav-item"><i class="bi bi-grid-fill"></i> Dashboard</a>
        <a href="{{ path('admin_profile') }}" class="nav-item"><i class="bi bi-person-fill"></i> Mon profil</a>

        <div class="nav-section-label">Gestion</div>
        <a href="{{ path('admin_users_list') }}" class="nav-item"><i class="bi bi-people-fill"></i> Utilisateurs</a>
        <a href="{{ path('admin_reactivation_requests') }}" class="nav-item"><i class="bi bi-person-check-fill"></i> Réactivations</a>
        <a href="{{ path('admin_question_index') }}" class="nav-item"><i class="bi bi-clipboard2-pulse-fill"></i> Questions de suivi</a>
        <a href="{{ path('admin_post_list') }}" class="nav-item"><i class="bi bi-newspaper"></i> Publications</a>
        <a href="{{ path('admin_comment_list') }}" class="nav-item"><i class="bi bi-chat-dots-fill"></i> Commentaires</a>
        <a href="{{ path('evenements_admin_supervision') }}" class="nav-item active"><i class="bi bi-calendar-event-fill"></i> Événements</a>

        <div class="nav-section-label">Compte</div>
        <a href="{{ path('app_login') }}" class="nav-item"><i class="bi bi-box-arrow-in-right"></i> Connexion</a>
        <a href="{{ path('app_register') }}" class="nav-item"><i class="bi bi-person-plus-fill"></i> Inscription</a>
    </nav>
    <div class="sidebar-footer">
        <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;">
            <i class="bi bi-box-arrow-left"></i> Se déconnecter
        </a>
    </div>
</aside>

<!-- MAIN -->
<div class="main">

    <!-- TOPBAR -->
    <header class="topbar">
        <div>
            <div class="topbar-title">Supervision des événements</div>
            <div class="topbar-sub">Vue d'ensemble et gestion de tous les événements</div>
        </div>
        <div class="topbar-right">
            <a href="{{ path('admin_dashboard') }}" class="topbar-icon-btn" title="Dashboard"><i class="bi bi-grid"></i></a>
            <a href="{{ path('admin_users_list') }}" class="topbar-icon-btn" title="Utilisateurs"><i class="bi bi-people"></i></a>
            <a href="{{ path('admin_profile') }}" class="topbar-avatar">
                {% if app.user and app.user.avatar %}
                    <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
                {% else %}
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                {% endif %}
            </a>
        </div>
    </header>

    <!-- PAGE HEADER -->
    <div class="page-header">
        <div class="page-header-inner">
            <div class="page-header-tag"><i class="bi bi-calendar-event-fill"></i> Supervision</div>
            <div class="page-header-title">Supervision des événements</div>
            <div class="page-header-sub">Vue d'ensemble et gestion de tous les événements de la plateforme</div>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="content">

        <!-- Stat Cards -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon teal"><i class="bi bi-calendar-event-fill"></i></div>
                <div>
                    <div class="stat-label">Total événements</div>
                    <div class="stat-value">{{ stats.total }}</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green"><i class="bi bi-door-open-fill"></i></div>
                <div>
                    <div class="stat-label">Ouverts</div>
                    <div class="stat-value">{{ stats.ouverts }}</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon blue"><i class="bi bi-people-fill"></i></div>
                <div>
                    <div class="stat-label">Participations actives</div>
                    <div class="stat-value">{{ stats.totalParticipations }}</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon gray"><i class="bi bi-check-circle-fill"></i></div>
                <div>
                    <div class="stat-label">Terminés</div>
                    <div class="stat-value">{{ stats.termines }}</div>
                </div>
            </div>
        </div>

        <!-- Events Table -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">Tous les événements</div>
                <div class="card-sub">{{ evenements|length }} événement(s) sur la plateforme</div>
            </div>

            <div class="table-wrap">
                {% if evenements|length > 0 %}
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Titre</th>
                            <th>Organisateur</th>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Statut</th>
                            <th>Capacité</th>
                            <th style="text-align:center;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for evenement in evenements %}
                        <tr>
                            <td style="color:var(--gray);font-size:13px;font-weight:600;">#{{ evenement.id }}</td>
                            <td>
                                <div class="event-title">{{ evenement.titre }}</div>
                                {% if evenement.lienSession %}
                                    <div class="event-location">
                                        <i class="bi bi-geo-alt"></i>
                                        {{ evenement.lienSession|length > 30 ? evenement.lienSession|slice(0, 30) ~ '…' : evenement.lienSession }}
                                    </div>
                                {% endif %}
                            </td>
                            <td>
                                {% if evenement.coach %}
                                    <div class="organizer-name">{{ evenement.coach.prenom }} {{ evenement.coach.nom }}</div>
                                    <div class="organizer-email">{{ evenement.coach.email }}</div>
                                {% else %}
                                    <span style="color:var(--gray);font-size:13px;">N/A</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="date-main">{{ evenement.dateDebut|date('d/m/Y') }}</div>
                                <div class="date-time">{{ evenement.dateDebut|date('H:i') }}</div>
                            </td>
                            <td>
                                <span class="badge badge-type">{{ evenement.type.value }}</span>
                            </td>
                            <td>
                                {% if evenement.statut.value == 'OPEN' %}
                                    <span class="badge badge-open"><i class="bi bi-circle-fill" style="font-size:7px;"></i> Ouvert</span>
                                {% elseif evenement.statut.value == 'FULL' %}
                                    <span class="badge badge-full"><i class="bi bi-circle-fill" style="font-size:7px;"></i> Complet</span>
                                {% elseif evenement.statut.value == 'PLANNED' %}
                                    <span class="badge badge-planned"><i class="bi bi-circle-fill" style="font-size:7px;"></i> Planifié</span>
                                {% elseif evenement.statut.value == 'CANCELLED' %}
                                    <span class="badge badge-cancelled"><i class="bi bi-circle-fill" style="font-size:7px;"></i> Annulé</span>
                                {% elseif evenement.statut.value == 'FINISHED' %}
                                    <span class="badge badge-finished"><i class="bi bi-circle-fill" style="font-size:7px;"></i> Terminé</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="capacity-cell">
                                    <i class="bi bi-people" style="color:var(--gray);"></i>
                                    {{ evenement.capaciteMax }}
                                </div>
                            </td>
                            <td style="text-align:center;">
                                <a href="{{ path('evenements_show', {id: evenement.id}) }}" class="btn-icon view" title="Voir les détails">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
                {% else %}
                <div class="empty-state">
                    <i class="bi bi-calendar-x"></i>
                    <p>Aucun événement n'a été créé sur la plateforme.</p>
                </div>
                {% endif %}
            </div>
        </div>

    </div>
</div>

</body>
</html>
