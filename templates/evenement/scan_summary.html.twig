{% extends 'base.html.twig' %}

{% block title %}Résumé - {{ evenement.titre }}{% endblock %}

{% block body_class %}scan-summary-page{% endblock %}

{% block main %}
    <div class="summary-mobile-container">
        <!-- Hero Section -->
        <div class="summary-hero" style="background-image: url('{{ asset(evenement.image ?: 'assets/img/health/consultation-3.webp') }}');">
            <div class="summary-overlay"></div>
            <div class="summary-header-badge">{{ evenement.type|capitalize }}</div>
            <div class="summary-hero-content">
                <h1>{{ evenement.titre }}</h1>
                <div class="summary-quick-info">
                    <span class="badge {{ evenement.statut == 'ouvert' ? 'bg-success' : 'bg-secondary' }}">
                        {{ evenement.statut|capitalize }}
                    </span>
                </div>
            </div>
        </div>

        <!-- Main Info Cards -->
        <div class="summary-content">
            <div class="info-card-group">
                <div class="summary-info-card">
                    <div class="card-icon"><i class="bi bi-calendar-event"></i></div>
                    <div class="card-text">
                        <strong>Date</strong>
                        <span>{{ evenement.dateDebut|date('d F Y') }}</span>
                    </div>
                </div>
                <div class="summary-info-card">
                    <div class="card-icon"><i class="bi bi-clock"></i></div>
                    <div class="card-text">
                        <strong>Heure</strong>
                        <span>{{ evenement.dateDebut|date('H:i') }} - {{ evenement.dateFin|date('H:i') }}</span>
                    </div>
                </div>
            </div>

            <div class="summary-info-card full-width">
                <div class="card-icon"><i class="bi bi-geo-alt"></i></div>
                <div class="card-text">
                    <strong>Lieu</strong>
                    <span>{{ evenement.lieu }}</span>
                </div>
            </div>

            <div class="summary-description">
                <h3>À propos</h3>
                <p>{{ evenement.description|u.truncate(200, '...') }}</p>
            </div>

            <!-- Capacity Info -->
            <div class="summary-capacity">
                <div class="capacity-stats">
                    <span>{{ evenement.placesRestantes }} places restantes</span>
                    <span>{{ evenement.nombreParticipants }}/{{ evenement.capaciteMax }}</span>
                </div>
                <div class="progress" style="height: 8px;">
                    <div class="progress-bar" role="progressbar" style="width: {{ (evenement.nombreParticipants / evenement.capaciteMax * 100)|round }}%; background-color: var(--accent-color);"></div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="summary-actions sticky-bottom-actions">
                {% if isParticipant %}
                    <div class="alert alert-success text-center mb-3">
                        <i class="bi bi-patch-check-fill me-2"></i> Vous êtes déjà inscrit
                    </div>
                    <a href="{{ path('evenement_detail', {id: evenement.id}) }}" class="btn btn-primary-outline w-100">
                        Voir les détails complets
                    </a>
                {% elseif evenement.isComplet() %}
                    <button class="btn btn-secondary w-100" disabled>
                        Événement complet
                    </button>
                    <a href="{{ path('evenement_liste') }}" class="btn btn-link w-100 mt-2">Voir d'autres événements</a>
                {% else %}
                    <form method="post" action="{{ path('evenement_participer', {id: evenement.id}) }}" class="w-100">
                        <button type="submit" class="btn btn-summary-join w-100">
                            Rejoindre l'événement
                        </button>
                    </form>
                    <a href="{{ path('evenement_detail', {id: evenement.id}) }}" class="btn btn-link w-100 mt-2">Plus d'informations</a>
                {% endif %}
            </div>
        </div>
    </div>

    <style>
        .scan-summary-page .page-title, 
        .scan-summary-page .breadcrumbs,
        .scan-summary-page footer {
            display: none !important;
        }

        .summary-mobile-container {
            max-width: 500px;
            margin: 0 auto;
            background: #fff;
            min-height: 100vh;
            padding-bottom: 120px;
            position: relative;
        }

        .summary-hero {
            height: 35vh;
            background-size: cover;
            background-position: center;
            position: relative;
            display: flex;
            align-items: flex-end;
            padding: 20px;
        }

        .summary-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.8));
        }

        .summary-header-badge {
            position: absolute;
            top: 20px;
            left: 20px;
            background: var(--accent-color);
            color: #fff;
            padding: 5px 15px;
            border-radius: 50px;
            font-size: 13px;
            font-weight: 600;
            z-index: 10;
        }

        .summary-hero-content {
            position: relative;
            z-index: 10;
            color: #fff;
            width: 100%;
        }

        .summary-hero-content h1 {
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 10px;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        }

        .summary-content {
            padding: 25px 20px;
            background: #fff;
            border-radius: 30px 30px 0 0;
            margin-top: -30px;
            position: relative;
            z-index: 20;
        }

        .info-card-group {
            display: flex;
            gap: 15px;
            margin-bottom: 15px;
        }

        .summary-info-card {
            flex: 1;
            background: #f8f9fa;
            padding: 15px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .summary-info-card.full-width {
            width: 100%;
            margin-bottom: 25px;
        }

        .card-icon {
            width: 40px;
            height: 40px;
            background: rgba(var(--accent-color-rgb), 0.1);
            color: var(--accent-color);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .card-text {
            display: flex;
            flex-direction: column;
        }

        .card-text strong {
            font-size: 12px;
            color: #888;
            text-transform: uppercase;
        }

        .card-text span {
            font-size: 15px;
            font-weight: 600;
            color: #333;
        }

        .summary-description {
            margin-bottom: 30px;
        }

        .summary-description h3 {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .summary-description p {
            font-size: 15px;
            color: #666;
            line-height: 1.6;
        }

        .summary-capacity {
            margin-bottom: 40px;
        }

        .capacity-stats {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
            margin-bottom: 8px;
            font-weight: 600;
        }

        .sticky-bottom-actions {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            max-width: 500px;
            margin: 0 auto;
            background: #fff;
            padding: 20px;
            box-shadow: 0 -10px 30px rgba(0,0,0,0.05);
            border-radius: 20px 20px 0 0;
            z-index: 100;
        }

        .btn-summary-join {
            background: var(--accent-color);
            color: #fff;
            padding: 16px;
            border-radius: 15px;
            font-weight: 700;
            font-size: 17px;
            border: none;
            transition: all 0.3s;
        }

        .btn-summary-join:active {
            transform: scale(0.98);
        }

        .btn-primary-outline {
            border: 2px solid var(--accent-color);
            color: var(--accent-color);
            padding: 14px;
            border-radius: 15px;
            font-weight: 600;
            text-decoration: none;
            text-align: center;
            display: block;
        }
    </style>
{% endblock %}
