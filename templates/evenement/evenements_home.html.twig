<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Événements Bien-être — Bekri</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --dark:       #1a2332;
            --gray:       #64748b;
            --light:      #f8fafc;
            --white:      #ffffff;
            --sidebar-w:  260px;
            --shadow-sm:  0 2px 12px rgba(0,0,0,0.06);
            --shadow:     0 8px 30px rgba(0,0,0,0.10);
            --radius:     16px;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior:smooth; }
        body { font-family:'Inter',sans-serif; background:var(--light); color:var(--dark); display:flex; min-height:100vh; }

        /* ── SIDEBAR ─────────────────────────────────────────────── */
        .sidebar { width:var(--sidebar-w); background:var(--dark); min-height:100vh; position:fixed; top:0; left:0; display:flex; flex-direction:column; z-index:100; transition:transform 0.3s ease; }
        .sidebar-logo { padding:28px 24px 20px; display:flex; align-items:center; gap:10px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-logo-text { font-size:20px; font-weight:800; background:linear-gradient(135deg,var(--teal),#a78bfa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .sidebar-user { padding:20px 24px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-avatar { width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:16px; flex-shrink:0; overflow:hidden; }
        .sidebar-avatar img { width:100%; height:100%; object-fit:cover; }
        .sidebar-user-name { font-size:14px; font-weight:600; color:white; }
        .sidebar-user-role { font-size:11px; color:rgba(255,255,255,0.4); margin-top:2px; }
        .sidebar-nav { flex:1; padding:16px 0; overflow-y:auto; }
        .nav-section-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:rgba(255,255,255,0.25); padding:12px 24px 6px; }
        .nav-item { display:flex; align-items:center; gap:12px; padding:11px 24px; color:rgba(255,255,255,0.6); text-decoration:none; font-size:14px; font-weight:500; transition:all 0.2s; border-left:3px solid transparent; }
        .nav-item:hover { color:white; background:rgba(255,255,255,0.05); }
        .nav-item.active { color:var(--teal); background:rgba(32,178,170,0.1); border-left-color:var(--teal); }
        .nav-item i { width:20px; text-align:center; font-size:16px; }
        .sidebar-footer { padding:16px 0; border-top:1px solid rgba(255,255,255,0.07); }

        /* ── MAIN ────────────────────────────────────────────────── */
        .main { margin-left:var(--sidebar-w); flex:1; display:flex; flex-direction:column; min-height:100vh; }

        /* ── TOPBAR ──────────────────────────────────────────────── */
        .topbar { background:white; padding:0 32px; height:68px; display:flex; align-items:center; justify-content:space-between; box-shadow:var(--shadow-sm); position:sticky; top:0; z-index:50; }
        .topbar-left { display:flex; align-items:center; gap:16px; }
        .topbar-title { font-size:18px; font-weight:700; color:var(--dark); }
        .topbar-sub { font-size:13px; color:var(--gray); margin-top:2px; }
        .topbar-right { display:flex; align-items:center; gap:12px; }
        .topbar-btn { width:40px; height:40px; border-radius:10px; background:var(--light); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; color:var(--gray); font-size:16px; text-decoration:none; transition:all 0.2s; }
        .topbar-btn:hover { background:var(--teal-light); color:var(--teal-dark); }
        .topbar-avatar-sm { width:40px; height:40px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:14px; text-decoration:none; overflow:hidden; }
        .topbar-avatar-sm img { width:100%; height:100%; object-fit:cover; }
        .menu-toggle { display:none; background:none; border:none; font-size:22px; color:var(--dark); cursor:pointer; }
        .sidebar-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:99; }

        /* ── HERO ────────────────────────────────────────────────── */
        .hero {
            background: linear-gradient(135deg, var(--dark) 0%, #1e3a5f 50%, #0d9488 100%);
            padding: 60px 40px;
            position: relative;
            overflow: hidden;
        }
        .hero::before { content:''; position:absolute; top:-100px; right:-100px; width:400px; height:400px; background:rgba(32,178,170,0.08); border-radius:50%; }
        .hero::after  { content:''; position:absolute; bottom:-80px; left:-80px; width:300px; height:300px; background:rgba(102,126,234,0.08); border-radius:50%; }
        .hero-inner { max-width:900px; margin:0 auto; position:relative; z-index:1; }

        .role-badge { display:inline-flex; align-items:center; gap:7px; padding:6px 14px; border-radius:50px; font-size:12px; font-weight:700; margin-bottom:16px; text-transform:uppercase; letter-spacing:0.5px; }
        .role-badge.user  { background:rgba(32,178,170,0.2); border:1px solid rgba(32,178,170,0.4); color:#7fffd4; }
        .role-badge.coach { background:rgba(102,126,234,0.2); border:1px solid rgba(102,126,234,0.4); color:#c4b5fd; }
        .role-badge.admin { background:rgba(248,113,113,0.2); border:1px solid rgba(248,113,113,0.4); color:#fca5a5; }

        .hero-title { font-size:32px; font-weight:800; color:white; line-height:1.25; margin-bottom:12px; }
        .hero-title span { background:linear-gradient(135deg,var(--teal),#a78bfa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .hero-desc { font-size:15px; color:rgba(255,255,255,0.65); line-height:1.75; margin-bottom:32px; max-width:600px; }

        /* ── ACTION CARDS ────────────────────────────────────────── */
        .actions-grid { display:grid; gap:16px; margin-bottom:32px; }
        .actions-grid.cols-2 { grid-template-columns:repeat(2,1fr); }
        .actions-grid.cols-3 { grid-template-columns:repeat(3,1fr); }
        .actions-grid.cols-4 { grid-template-columns:repeat(4,1fr); }

        .action-card { background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.12); border-radius:14px; padding:22px; text-decoration:none; display:flex; flex-direction:column; gap:12px; transition:all 0.25s; }
        .action-card:hover { background:rgba(255,255,255,0.14); border-color:rgba(32,178,170,0.5); transform:translateY(-3px); }
        .action-card.primary { background:linear-gradient(135deg,rgba(32,178,170,0.25),rgba(13,148,136,0.25)); border-color:rgba(32,178,170,0.4); }
        .action-card.primary:hover { background:linear-gradient(135deg,rgba(32,178,170,0.35),rgba(13,148,136,0.35)); }

        .action-icon { width:44px; height:44px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:20px; }
        .action-icon.teal   { background:rgba(32,178,170,0.25); color:#7fffd4; }
        .action-icon.purple { background:rgba(102,126,234,0.25); color:#c4b5fd; }
        .action-icon.orange { background:rgba(251,146,60,0.25); color:#fed7aa; }
        .action-icon.red    { background:rgba(248,113,113,0.25); color:#fca5a5; }
        .action-icon.green  { background:rgba(74,222,128,0.25); color:#bbf7d0; }
        .action-icon.blue   { background:rgba(96,165,250,0.25); color:#bfdbfe; }

        .action-title { font-size:15px; font-weight:700; color:white; }
        .action-desc  { font-size:12px; color:rgba(255,255,255,0.55); line-height:1.5; }
        .action-arrow { font-size:13px; color:var(--teal); font-weight:600; display:flex; align-items:center; gap:4px; margin-top:auto; }

        /* ── CONTENT SECTION ─────────────────────────────────────── */
        .page-content { padding:40px; max-width:1100px; margin:0 auto; width:100%; }

        /* ── INFO CARDS ──────────────────────────────────────────── */
        .info-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin-bottom:32px; }
        .info-card { background:white; border-radius:var(--radius); padding:24px; box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; display:flex; align-items:center; gap:16px; }
        .info-card-icon { width:52px; height:52px; border-radius:14px; display:flex; align-items:center; justify-content:center; font-size:24px; flex-shrink:0; }
        .info-card-icon.teal   { background:var(--teal-light); color:var(--teal-dark); }
        .info-card-icon.purple { background:#ede9fe; color:#7c3aed; }
        .info-card-icon.orange { background:#fff7ed; color:#ea580c; }
        .info-card-num   { font-size:26px; font-weight:800; color:var(--dark); line-height:1; }
        .info-card-label { font-size:13px; color:var(--gray); margin-top:3px; }

        /* ── SECTION TITLE ───────────────────────────────────────── */
        .content-section { margin-bottom:36px; }
        .content-section-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; }
        .content-section-title { font-size:18px; font-weight:700; color:var(--dark); display:flex; align-items:center; gap:10px; }
        .content-section-title i { color:var(--teal); }
        .section-link { font-size:13px; font-weight:600; color:var(--teal); text-decoration:none; display:flex; align-items:center; gap:4px; }
        .section-link:hover { color:var(--teal-dark); }

        /* ── FEATURE LIST ────────────────────────────────────────── */
        .feature-list { display:flex; flex-direction:column; gap:10px; }
        .feature-item { display:flex; align-items:center; gap:12px; background:white; border-radius:12px; padding:14px 18px; box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; }
        .feature-item-icon { width:32px; height:32px; border-radius:8px; background:var(--teal-light); display:flex; align-items:center; justify-content:center; color:var(--teal-dark); font-size:15px; flex-shrink:0; }
        .feature-item-text { font-size:14px; color:#475569; font-weight:500; }

        /* ── ROLE BANNER ─────────────────────────────────────────── */
        .role-banner { border-radius:var(--radius); padding:20px 24px; display:flex; align-items:center; gap:16px; margin-bottom:32px; }
        .role-banner.user  { background:linear-gradient(135deg,#e0f7f6,#f0fdf9); border:1px solid #6ee7b7; }
        .role-banner.coach { background:linear-gradient(135deg,#ede9fe,#f5f3ff); border:1px solid #c4b5fd; }
        .role-banner.admin { background:linear-gradient(135deg,#fee2e2,#fef2f2); border:1px solid #fca5a5; }
        .role-banner-icon { width:48px; height:48px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:22px; flex-shrink:0; }
        .role-banner.user  .role-banner-icon { background:var(--teal-light); color:var(--teal-dark); }
        .role-banner.coach .role-banner-icon { background:#ede9fe; color:#7c3aed; }
        .role-banner.admin .role-banner-icon { background:#fee2e2; color:#dc2626; }
        .role-banner-title { font-size:15px; font-weight:700; color:var(--dark); margin-bottom:3px; }
        .role-banner-desc  { font-size:13px; color:var(--gray); line-height:1.5; }

        /* ── RESPONSIVE ──────────────────────────────────────────── */
        @media (max-width:768px) {
            .sidebar { transform:translateX(-100%); }
            .sidebar.open { transform:translateX(0); }
            .sidebar-overlay.open { display:block; }
            .main { margin-left:0; }
            .menu-toggle { display:block; }
            .hero { padding:36px 20px; }
            .page-content { padding:24px 16px; }
            .topbar { padding:0 16px; }
            .actions-grid.cols-2,
            .actions-grid.cols-3,
            .actions-grid.cols-4 { grid-template-columns:1fr; }
            .info-grid { grid-template-columns:1fr; }
        }
        @media (max-width:1024px) {
            .actions-grid.cols-4 { grid-template-columns:repeat(2,1fr); }
            .info-grid { grid-template-columns:1fr 1fr; }
        }
    </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
        <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'">
        <span class="sidebar-logo-text">Bekri</span>
    </div>
    <div class="sidebar-user">
        <div class="sidebar-avatar">
            {% if app.user and app.user.avatar %}
                <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
            {% elseif app.user %}
                {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
            {% else %}
                <i class="bi bi-person-fill" style="font-size:20px;"></i>
            {% endif %}
        </div>
        <div>
            <div class="sidebar-user-name">{{ app.user ? app.user.prenom ~ ' ' ~ app.user.nom : 'Invité' }}</div>
            <div class="sidebar-user-role">
                {% if is_granted('ROLE_ADMIN') %}Administrateur
                {% elseif is_granted('ROLE_COACH') %}Coach
                {% else %}Membre Bekri{% endif %}
            </div>
        </div>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-section-label">Principal</div>
        <a href="{{ path('user_dashboard') }}"    class="nav-item"><i class="bi bi-grid-fill"></i> Tableau de bord</a>
        <a href="{{ path('suivi_today') }}"        class="nav-item"><i class="bi bi-clipboard2-pulse-fill"></i> Check-in quotidien</a>
        <a href="{{ path('insight_weekly') }}"     class="nav-item"><i class="bi bi-graph-up-arrow"></i> Insights hebdo</a>
        <a href="{{ path('chat_index') }}"         class="nav-item"><i class="bi bi-robot"></i> Coach Eya IA</a>
        <div class="nav-section-label">Bien-être</div>
        <a href="{{ path('user_analyse') }}"       class="nav-item"><i class="bi bi-heart-pulse-fill"></i> Mon analyse</a>
        <a href="{{ path('objectif_index') }}"     class="nav-item"><i class="bi bi-trophy-fill"></i> Mes objectifs</a>
        <div class="nav-section-label">Communauté</div>
        <a href="{{ path('posts_list') }}"         class="nav-item"><i class="bi bi-newspaper"></i> Publications</a>
        <a href="{{ path('evenements_home') }}"    class="nav-item active"><i class="bi bi-calendar-event-fill"></i> Événements</a>
        <div class="nav-section-label">Mon compte</div>
        <a href="{{ path('user_profile') }}"       class="nav-item"><i class="bi bi-person-fill"></i> Mon profil</a>
        <a href="{{ path('user_profile_edit') }}"  class="nav-item"><i class="bi bi-gear-fill"></i> Paramètres</a>
    </nav>
    <div class="sidebar-footer">
        <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;"><i class="bi bi-box-arrow-left"></i> Se déconnecter</a>
    </div>
</aside>
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- MAIN -->
<div class="main">
    <header class="topbar">
        <div class="topbar-left">
            <button class="menu-toggle" id="menuToggle"><i class="bi bi-list"></i></button>
            <div>
                <div class="topbar-title">Événements Bien-être</div>
                <div class="topbar-sub">
                    {% if is_granted('ROLE_ADMIN') %}Vue Administrateur
                    {% elseif is_granted('ROLE_COACH') %}Vue Coach
                    {% else %}Découvrez et participez aux événements{% endif %}
                </div>
            </div>
        </div>
        <div class="topbar-right">
            <a href="{{ path('evenements_list') }}" class="topbar-btn" title="Voir les événements">
                <i class="bi bi-calendar-event-fill"></i>
            </a>
            <a href="{{ path('user_profile') }}" class="topbar-avatar-sm">
                {% if app.user and app.user.avatar %}
                    <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
                {% elseif app.user %}
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                {% else %}
                    <i class="bi bi-person-fill"></i>
                {% endif %}
            </a>
        </div>
    </header>

    <main>

        <!-- ── HERO ──────────────────────────────────────────────── -->
        <div class="hero">
            <div class="hero-inner">

                {# ── USER HERO ── #}
                {% if not is_granted('ROLE_COACH') and not is_granted('ROLE_ADMIN') %}
                    <div class="role-badge user"><i class="bi bi-person-fill"></i> Espace Utilisateur</div>
                    <h1 class="hero-title">Bienvenue, <span>{{ app.user ? app.user.prenom : 'Utilisateur' }}</span> 👋</h1>
                    <p class="hero-desc">Découvrez les événements bien-être disponibles, inscrivez-vous en un clic et suivez toutes vos participations depuis votre espace personnel.</p>
                    <div class="actions-grid cols-2">
                        <a href="{{ path('evenements_list') }}" class="action-card primary">
                            <div class="action-icon teal"><i class="bi bi-calendar-event-fill"></i></div>
                            <div class="action-title">Voir les Événements</div>
                            <div class="action-desc">Parcourez tous les événements disponibles et inscrivez-vous</div>
                            <div class="action-arrow"><i class="bi bi-arrow-right"></i> Accéder</div>
                        </a>
                        <a href="{{ path('evenements_mes_participations') }}" class="action-card">
                            <div class="action-icon purple"><i class="bi bi-calendar-check-fill"></i></div>
                            <div class="action-title">Mes Participations</div>
                            <div class="action-desc">Consultez et gérez vos inscriptions aux événements</div>
                            <div class="action-arrow"><i class="bi bi-arrow-right"></i> Accéder</div>
                        </a>
                    </div>

                {# ── COACH HERO ── #}
                {% elseif is_granted('ROLE_COACH') and not is_granted('ROLE_ADMIN') %}
                    <div class="role-badge coach"><i class="bi bi-person-workspace"></i> Espace Coach</div>
                    <h1 class="hero-title">Bonjour, <span>Coach {{ app.user ? app.user.prenom : '' }}</span> 👋</h1>
                    <p class="hero-desc">Créez et gérez vos événements bien-être, suivez vos participants et analysez vos statistiques en temps réel.</p>
                    <div class="actions-grid cols-3">
                        <a href="{{ path('evenements_coach_dashboard') }}" class="action-card primary">
                            <div class="action-icon teal"><i class="bi bi-speedometer2"></i></div>
                            <div class="action-title">Mon Dashboard</div>
                            <div class="action-desc">Statistiques et vue d'ensemble de vos événements</div>
                            <div class="action-arrow"><i class="bi bi-arrow-right"></i> Accéder</div>
                        </a>
                        <a href="{{ path('evenements_coach_create') }}" class="action-card">
                            <div class="action-icon green"><i class="bi bi-plus-circle-fill"></i></div>
                            <div class="action-title">Créer un Événement</div>
                            <div class="action-desc">Planifiez un nouvel atelier, conférence ou session</div>
                            <div class="action-arrow"><i class="bi bi-arrow-right"></i> Créer</div>
                        </a>
                        <a href="{{ path('evenements_coach_list') }}" class="action-card">
                            <div class="action-icon purple"><i class="bi bi-list-ul"></i></div>
                            <div class="action-title">Mes Événements</div>
                            <div class="action-desc">Gérez, modifiez et supprimez vos événements</div>
                            <div class="action-arrow"><i class="bi bi-arrow-right"></i> Gérer</div>
                        </a>
                    </div>

                {# ── ADMIN HERO ── #}
                {% elseif is_granted('ROLE_ADMIN') %}
                    <div class="role-badge admin"><i class="bi bi-shield-fill-check"></i> Espace Administrateur</div>
                    <h1 class="hero-title">Tableau de bord <span>Admin</span> 🛡️</h1>
                    <p class="hero-desc">Supervisez l'ensemble des événements de la plateforme, gérez les statuts et exportez les rapports.</p>
                    <div class="actions-grid cols-4">
                        <a href="{{ path('evenements_admin_supervision') }}" class="action-card primary">
                            <div class="action-icon teal"><i class="bi bi-shield-fill-check"></i></div>
                            <div class="action-title">Supervision</div>
                            <div class="action-desc">Vue globale de tous les événements</div>
                            <div class="action-arrow"><i class="bi bi-arrow-right"></i> Accéder</div>
                        </a>
                        <a href="{{ path('evenements_list') }}" class="action-card">
                            <div class="action-icon blue"><i class="bi bi-calendar-event-fill"></i></div>
                            <div class="action-title">Tous les Événements</div>
                            <div class="action-desc">Liste complète des événements</div>
                            <div class="action-arrow"><i class="bi bi-arrow-right"></i> Voir</div>
                        </a>
                        <a href="{{ path('evenements_coach_dashboard') }}" class="action-card">
                            <div class="action-icon purple"><i class="bi bi-graph-up-arrow"></i></div>
                            <div class="action-title">Statistiques</div>
                            <div class="action-desc">Analytiques et performances</div>
                            <div class="action-arrow"><i class="bi bi-arrow-right"></i> Voir</div>
                        </a>
                        <a href="{{ path('evenements_mes_participations') }}" class="action-card">
                            <div class="action-icon orange"><i class="bi bi-people-fill"></i></div>
                            <div class="action-title">Participants</div>
                            <div class="action-desc">Gestion des inscriptions</div>
                            <div class="action-arrow"><i class="bi bi-arrow-right"></i> Gérer</div>
                        </a>
                    </div>
                {% endif %}

            </div>
        </div>

        <!-- ── PAGE CONTENT ──────────────────────────────────────── -->
        <div class="page-content">

            {# ── USER CONTENT ── #}
            {% if not is_granted('ROLE_COACH') and not is_granted('ROLE_ADMIN') %}

                <div class="role-banner user">
                    <div class="role-banner-icon"><i class="bi bi-info-circle-fill"></i></div>
                    <div>
                        <div class="role-banner-title">Votre espace événements</div>
                        <div class="role-banner-desc">En tant qu'utilisateur, vous pouvez parcourir les événements disponibles, vous inscrire et gérer vos participations.</div>
                    </div>
                </div>

