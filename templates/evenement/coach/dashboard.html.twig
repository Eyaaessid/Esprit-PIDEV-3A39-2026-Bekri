<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Coach — Bekri</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --dark:       #1a2332;
            --gray:       #64748b;
            --light:      #f8fafc;
            --white:      #ffffff;
            --sidebar-w:  260px;
            --shadow-sm:  0 2px 12px rgba(0,0,0,0.06);
            --shadow:     0 8px 30px rgba(0,0,0,0.10);
            --radius:     16px;
            --orange:     #f59e0b;
            --green:      #10b981;
            --red:        #ef4444;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior:smooth; }
        body { font-family:'Inter',sans-serif; background:var(--light); color:var(--dark); display:flex; min-height:100vh; }

        /* ── SIDEBAR ─────────────────────────────────────────────── */
        .sidebar { width:var(--sidebar-w); background:var(--dark); min-height:100vh; position:fixed; top:0; left:0; display:flex; flex-direction:column; z-index:100; transition:transform 0.3s ease; }
        .sidebar-logo { padding:28px 24px 20px; display:flex; align-items:center; gap:10px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-logo img { height:36px; width:auto; }
        .sidebar-logo-text { font-size:20px; font-weight:800; background:linear-gradient(135deg,var(--teal),#a78bfa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .sidebar-user { padding:20px 24px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-avatar { width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:16px; flex-shrink:0; overflow:hidden; }
        .sidebar-avatar img { width:100%; height:100%; object-fit:cover; }
        .sidebar-user-name { font-size:14px; font-weight:600; color:white; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        .sidebar-user-role { font-size:11px; color:rgba(255,255,255,0.4); margin-top:2px; }
        .sidebar-nav { flex:1; padding:16px 0; overflow-y:auto; }
        .nav-section-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:rgba(255,255,255,0.25); padding:12px 24px 6px; }
        .nav-item { display:flex; align-items:center; gap:12px; padding:11px 24px; color:rgba(255,255,255,0.6); text-decoration:none; font-size:14px; font-weight:500; transition:all 0.2s; border-left:3px solid transparent; }
        .nav-item:hover { color:white; background:rgba(255,255,255,0.05); }
        .nav-item.active { color:var(--teal); background:rgba(32,178,170,0.1); border-left-color:var(--teal); }
        .nav-item i { width:20px; text-align:center; font-size:16px; }
        .nav-badge { margin-left:auto; background:var(--teal); color:white; font-size:10px; font-weight:700; padding:2px 7px; border-radius:50px; }
        .nav-badge.orange { background:var(--orange); }
        .sidebar-footer { padding:16px 0; border-top:1px solid rgba(255,255,255,0.07); }

        /* ── COACH BADGE in sidebar ──────────────────────────────── */
        .coach-badge-sidebar { margin:12px 24px; background:linear-gradient(135deg,rgba(32,178,170,0.15),rgba(102,126,234,0.15)); border:1px solid rgba(32,178,170,0.3); border-radius:10px; padding:10px 14px; display:flex; align-items:center; gap:10px; }
        .coach-badge-sidebar i { color:var(--teal); font-size:18px; }
        .coach-badge-sidebar span { font-size:12px; font-weight:600; color:rgba(255,255,255,0.8); }

        /* ── MAIN ────────────────────────────────────────────────── */
        .main { margin-left:var(--sidebar-w); flex:1; display:flex; flex-direction:column; min-height:100vh; }

        /* ── TOPBAR ──────────────────────────────────────────────── */
        .topbar { background:white; padding:0 32px; height:68px; display:flex; align-items:center; justify-content:space-between; box-shadow:var(--shadow-sm); position:sticky; top:0; z-index:50; }
        .topbar-left { display:flex; align-items:center; gap:16px; }
        .topbar-greeting h2 { font-size:18px; font-weight:700; color:var(--dark); }
        .topbar-greeting p  { font-size:13px; color:var(--gray); }
        .topbar-right { display:flex; align-items:center; gap:10px; }
        .topbar-btn { width:40px; height:40px; border-radius:10px; background:var(--light); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; color:var(--gray); font-size:16px; transition:all 0.2s; text-decoration:none; }
        .topbar-btn:hover { background:var(--teal-light); color:var(--teal-dark); }
        .topbar-avatar { width:40px; height:40px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:14px; cursor:pointer; overflow:hidden; text-decoration:none; }
        .topbar-avatar img { width:100%; height:100%; object-fit:cover; }

        /* ── CONTENT ─────────────────────────────────────────────── */
        .content { padding:32px; flex:1; }

        /* ── WELCOME BANNER ─────────��────────────────────────────── */
        .welcome-banner { background:linear-gradient(135deg,var(--dark) 0%,#1e3a5f 50%,var(--teal-dark) 100%); border-radius:var(--radius); padding:32px 36px; display:flex; align-items:center; justify-content:space-between; margin-bottom:28px; position:relative; overflow:hidden; }
        .welcome-banner::before { content:''; position:absolute; top:-50px; right:-50px; width:200px; height:200px; background:rgba(255,255,255,0.04); border-radius:50%; }
        .welcome-banner::after  { content:''; position:absolute; bottom:-30px; right:120px; width:120px; height:120px; background:rgba(32,178,170,0.08); border-radius:50%; }
        .welcome-text h1 { font-size:24px; font-weight:800; color:white; margin-bottom:6px; }
        .welcome-text p  { color:rgba(255,255,255,0.7); font-size:14px; }
        .welcome-role-badge { display:inline-flex; align-items:center; gap:6px; background:rgba(32,178,170,0.25); border:1px solid rgba(32,178,170,0.4); color:#7fffd4; padding:4px 12px; border-radius:50px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:10px; }
        .welcome-actions { display:flex; gap:12px; position:relative; z-index:1; flex-wrap:wrap; }
        .btn-banner { padding:11px 22px; border-radius:50px; font-size:14px; font-weight:600; text-decoration:none; display:inline-flex; align-items:center; gap:8px; transition:all 0.3s; white-space:nowrap; }
        .btn-banner-primary { background:white; color:var(--teal-dark); }
        .btn-banner-primary:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(0,0,0,0.15); color:var(--teal-dark); }
        .btn-banner-secondary { background:rgba(255,255,255,0.15); color:white; border:1px solid rgba(255,255,255,0.3); backdrop-filter:blur(8px); }
        .btn-banner-secondary:hover { background:rgba(255,255,255,0.25); transform:translateY(-2px); color:white; }

        /* ── STATS ROW ───────────────────────────────────────────── */
        .stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:20px; margin-bottom:28px; }
        .stat-card { background:white; border-radius:var(--radius); padding:22px 24px; box-shadow:var(--shadow-sm); display:flex; align-items:center; gap:16px; transition:all 0.3s; border:1px solid #f1f5f9; }
        .stat-card:hover { transform:translateY(-3px); box-shadow:var(--shadow); }
        .stat-icon { width:50px; height:50px; border-radius:14px; display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0; }
        .icon-teal   { background:var(--teal-light); color:var(--teal-dark); }
        .icon-purple { background:#ede9fe; color:#7c3aed; }
        .icon-amber  { background:#fef3c7; color:#d97706; }
        .icon-rose   { background:#ffe4e6; color:#e11d48; }
        .icon-blue   { background:#dbeafe; color:#2563eb; }
        .icon-green  { background:#d1fae5; color:#059669; }
        .icon-orange { background:#ffedd5; color:#ea580c; }
        .stat-info { flex:1; }
        .stat-value { font-size:28px; font-weight:800; color:var(--dark); line-height:1; }
        .stat-label { font-size:12px; color:var(--gray); margin-top:4px; }

        /* ── SECTION TITLE ─────────��─────────────────────────────── */
        .section-title { font-size:16px; font-weight:700; color:var(--dark); margin-bottom:16px; display:flex; align-items:center; gap:8px; }
        .section-title i { color:var(--teal); }

        /* ── COACH FEATURES GRID ─────────────────────────────────── */
        .features-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:28px; }
        .feature-card { background:white; border-radius:var(--radius); padding:24px 20px; box-shadow:var(--shadow-sm); text-align:center; text-decoration:none; transition:all 0.3s; border:2px solid transparent; display:flex; flex-direction:column; align-items:center; gap:12px; position:relative; overflow:hidden; }
        .feature-card::before { content:''; position:absolute; bottom:0; left:0; right:0; height:3px; opacity:0; transition:opacity 0.3s; }
        .feature-card:hover { transform:translateY(-6px); box-shadow:var(--shadow); }
        .feature-card:hover::before { opacity:1; }
        .fc-teal::before   { background:linear-gradient(90deg,var(--teal),#3ecdc7); }
        .fc-purple::before { background:linear-gradient(90deg,var(--purple),#764ba2); }
        .fc-amber::before  { background:linear-gradient(90deg,#f59e0b,#ef4444); }
        .fc-blue::before   { background:linear-gradient(90deg,#3b82f6,#06b6d4); }
        .fc-green::before  { background:linear-gradient(90deg,#10b981,#34d399); }
        .fc-rose::before   { background:linear-gradient(90deg,#f43f5e,#ec4899); }
        .fc-orange::before { background:linear-gradient(90deg,#f59e0b,#f97316); }
        .feature-card:hover.fc-teal   { border-color:var(--teal-light); }
        .feature-card:hover.fc-purple { border-color:#ede9fe; }
        .feature-card:hover.fc-amber  { border-color:#fef3c7; }
        .feature-card:hover.fc-blue   { border-color:#dbeafe; }
        .feature-card:hover.fc-green  { border-color:#d1fae5; }
        .feature-card:hover.fc-rose   { border-color:#ffe4e6; }
        .feature-card:hover.fc-orange { border-color:#ffedd5; }
        .feature-icon { width:60px; height:60px; border-radius:18px; display:flex; align-items:center; justify-content:center; font-size:24px; transition:transform 0.3s; }
        .feature-card:hover .feature-icon { transform:scale(1.1); }
        .feature-name { font-size:13px; font-weight:700; color:var(--dark); }
        .feature-desc { font-size:11px; color:var(--gray); line-height:1.5; }
        .feature-badge { position:absolute; top:12px; right:12px; background:var(--teal); color:white; font-size:10px; font-weight:700; padding:2px 8px; border-radius:50px; }
        .feature-badge.new { background:linear-gradient(135deg,#f59e0b,#ef4444); }

        /* ── DASHBOARD GRID ──────────────────────────────────────── */
        .dashboard-grid { display:grid; grid-template-columns:2fr 1fr; gap:24px; margin-bottom:28px; }
        .card { background:white; border-radius:var(--radius); box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; overflow:hidden; }
        .card-header { padding:20px 24px 0; display:flex; align-items:center; justify-content:space-between; }
        .card-title { font-size:15px; font-weight:700; color:var(--dark); display:flex; align-items:center; gap:8px; }
        .card-title i { color:var(--teal); }
        .card-link { font-size:13px; color:var(--teal); text-decoration:none; font-weight:500; }
        .card-link:hover { text-decoration:underline; }
        .card-body { padding:20px 24px; }

        /* ── RECENT EVENTS TABLE ─────────────────────────────────── */
        .events-table { width:100%; border-collapse:collapse; }
        .events-table th { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; color:var(--gray); padding:8px 12px; border-bottom:2px solid #f1f5f9; text-align:left; }
        .events-table td { padding:14px 12px; border-bottom:1px solid #f8f9fa; font-size:14px; color:var(--dark); vertical-align:middle; }
        .events-table tr:last-child td { border-bottom:none; }
        .events-table tr:hover td { background:#f8fafc; }
        .event-row-title { font-weight:600; color:var(--dark); }
        .event-row-date  { font-size:12px; color:var(--gray); margin-top:2px; }
        .badge-status { display:inline-flex; align-items:center; gap:4px; padding:4px 10px; border-radius:50px; font-size:11px; font-weight:700; text-transform:uppercase; }
        .badge-open     { background:#d1fae5; color:#065f46; }
        .badge-full     { background:#fee2e2; color:#991b1b; }
        .badge-finished { background:#f1f5f9; color:var(--gray); }
        .badge-planned  { background:#dbeafe; color:#1e40af; }
        .table-actions { display:flex; gap:6px; }
        .btn-table { height:30px; padding:0 12px; border-radius:7px; font-size:12px; font-weight:600; text-decoration:none; display:inline-flex; align-items:center; gap:5px; transition:all 0.2s; border:none; cursor:pointer; }
        .btn-edit   { background:#f1f5f9; color:var(--gray); }
        .btn-edit:hover { background:var(--teal-light); color:var(--teal-dark); }
        .btn-view   { background:var(--teal-light); color:var(--teal-dark); }
        .btn-view:hover { background:var(--teal); color:white; }
        .btn-parts  { background:#ede9fe; color:#7c3aed; }
        .btn-parts:hover { background:#7c3aed; color:white; }
        .empty-table { text-align:center; padding:40px 20px; color:var(--gray); font-size:14px; }
        .empty-table i { font-size:36px; color:#cbd5e1; display:block; margin-bottom:10px; }

        /* ── QUICK LINKS ─────────────────────────────────────────── */
        .quick-link-item { display:flex; align-items:center; gap:14px; padding:14px 0; border-bottom:1px solid #f1f5f9; text-decoration:none; transition:all 0.2s; }
        .quick-link-item:last-child { border-bottom:none; }
        .quick-link-item:hover { padding-left:6px; }
        .quick-link-icon { width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:16px; flex-shrink:0; }
        .quick-link-text { flex:1; }
        .quick-link-name { font-size:14px; font-weight:600; color:var(--dark); }
        .quick-link-desc { font-size:12px; color:var(--gray); }
        .quick-link-arrow { color:var(--gray); font-size:14px; transition:transform 0.2s; }
        .quick-link-item:hover .quick-link-arrow { transform:translateX(4px); color:var(--teal); }

        /* ── USER FEATURES (same as normal user) ────────────────── */
        .user-features-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:28px; }

        /* ── COACH ALERT CARD ────────────────────────────────────── */
        .coach-alert { background:linear-gradient(135deg,#f0fdfa,#e0f7f6); border:2px dashed var(--teal); border-radius:var(--radius); padding:24px 28px; margin-bottom:28px; display:flex; align-items:center; justify-content:space-between; gap:20px; flex-wrap:wrap; }
        .coach-alert-left { display:flex; align-items:center; gap:16px; }
        .coach-alert-icon { width:52px; height:52px; background:linear-gradient(135deg,var(--teal),var(--teal-dark)); border-radius:14px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
        .coach-alert-icon i { color:white; font-size:20px; }
        .coach-alert-text h3 { font-size:15px; font-weight:700; color:var(--dark); margin-bottom:4px; }
        .coach-alert-text p  { font-size:13px; color:var(--gray); margin:0; }
        .btn-create-event { display:inline-flex; align-items:center; gap:8px; padding:11px 22px; background:linear-gradient(135deg,var(--teal),var(--teal-dark)); color:white; border-radius:50px; font-weight:600; font-size:13px; text-decoration:none; white-space:nowrap; transition:all 0.3s; box-shadow:0 4px 15px rgba(32,178,170,0.3); }
        .btn-create-event:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(32,178,170,0.4); color:white; }

        /* ── CHAT / INSIGHT CARDS ────────────────────────────────── */
        .insight-preview { background:linear-gradient(135deg,var(--purple) 0%,#764ba2 100%); border-radius:var(--radius); padding:28px; color:white; position:relative; overflow:hidden; }
        .insight-preview::before { content:''; position:absolute; top:-20px; right:-20px; width:100px; height:100px; background:rgba(255,255,255,0.08); border-radius:50%; }
        .insight-preview h3 { font-size:16px; font-weight:700; margin-bottom:6px; }
        .insight-preview p  { font-size:13px; color:rgba(255,255,255,0.8); margin-bottom:16px; }
        .btn-insight { display:inline-flex; align-items:center; gap:8px; padding:10px 20px; background:rgba(255,255,255,0.2); color:white; border-radius:50px; font-weight:600; font-size:13px; text-decoration:none; border:1px solid rgba(255,255,255,0.3); transition:all 0.3s; }
        .btn-insight:hover { background:rgba(255,255,255,0.3); transform:translateY(-2px); color:white; }
        .chat-card { background:var(--dark); border-radius:var(--radius); padding:28px; color:white; position:relative; overflow:hidden; }
        .chat-card::before { content:''; position:absolute; bottom:-30px; right:-30px; width:120px; height:120px; background:rgba(32,178,170,0.1); border-radius:50%; }
        .chat-card h3 { font-size:16px; font-weight:700; margin-bottom:6px; }
        .chat-card p  { font-size:13px; color:rgba(255,255,255,0.6); margin-bottom:16px; line-height:1.6; }
        .chat-online { display:flex; align-items:center; gap:6px; font-size:12px; color:#4ade80; margin-bottom:16px; }
        .online-dot  { width:8px; height:8px; background:#4ade80; border-radius:50%; animation:pulse 2s infinite; }
        @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.6;transform:scale(1.3)} }
        .btn-chat { display:inline-flex; align-items:center; gap:8px; padding:11px 22px; background:linear-gradient(135deg,var(--teal),var(--teal-dark)); color:white; border-radius:50px; font-weight:600; font-size:13px; text-decoration:none; transition:all 0.3s; box-shadow:0 4px 15px rgba(32,178,170,0.3); }
        .btn-chat:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(32,178,170,0.4); color:white; }

        /* ── MENU TOGGLE ─────────────────────────────────────────── */
        .menu-toggle { display:none; background:none; border:none; font-size:22px; color:var(--dark); cursor:pointer; }
        .sidebar-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:99; }

        /* ── RESPONSIVE ──────────────────────────────────────────── */
        @media (max-width:1200px) { .stats-row{grid-template-columns:repeat(2,1fr);} .features-grid{grid-template-columns:repeat(3,1fr);} .user-features-grid{grid-template-columns:repeat(3,1fr);} }
        @media (max-width:1024px) { .dashboard-grid{grid-template-columns:1fr;} .features-grid{grid-template-columns:repeat(2,1fr);} .user-features-grid{grid-template-columns:repeat(2,1fr);} }
        @media (max-width:768px) {
            .sidebar{transform:translateX(-100%);} .sidebar.open{transform:translateX(0);} .sidebar-overlay.open{display:block;}
            .main{margin-left:0;} .menu-toggle{display:block;} .content{padding:20px 16px;} .topbar{padding:0 16px;}
            .features-grid{grid-template-columns:repeat(2,1fr);} .user-features-grid{grid-template-columns:repeat(2,1fr);}
            .welcome-banner{flex-direction:column;gap:20px;} .welcome-actions{flex-wrap:wrap;} .stats-row{grid-template-columns:1fr 1fr;}
            .coach-alert{flex-direction:column;align-items:flex-start;}
        }
        @media (max-width:480px) { .stats-row{grid-template-columns:1fr;} .features-grid{grid-template-columns:1fr 1fr;} .user-features-grid{grid-template-columns:1fr 1fr;} }
    </style>
</head>
<body>

<!-- ═══════════════ SIDEBAR ═══════════════ -->
<aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
        <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'">
        <span class="sidebar-logo-text">Bekri</span>
    </div>
    <div class="sidebar-user">
        <div class="sidebar-avatar">
            {% if coach.photo is defined and coach.photo %}
                <img src="{{ asset('uploads/photos/' ~ coach.photo) }}" alt="avatar">
            {% else %}
                {{ coach.prenom|first|upper }}{{ coach.nom|first|upper }}
            {% endif %}
        </div>
        <div>
            <div class="sidebar-user-name">{{ coach.prenom }} {{ coach.nom }}</div>
            <div class="sidebar-user-role">Coach Bekri</div>
        </div>
    </div>

    {# Coach privilege badge #}
    <div class="coach-badge-sidebar">
        <i class="bi bi-shield-fill-check"></i>
        <span>Accès Coach activé</span>
    </div>

    <nav class="sidebar-nav">

        <div class="nav-section-label">Principal</div>
        <a href="{{ path('evenements_coach_dashboard') }}" class="nav-item active">
            <i class="bi bi-grid-fill"></i> Tableau de bord
        </a>
        <a href="{{ path('suivi_today') }}" class="nav-item">
            <i class="bi bi-clipboard2-pulse-fill"></i> Check-in quotidien
            <span class="nav-badge">!</span>
        </a>
        <a href="{{ path('insight_weekly') }}" class="nav-item">
            <i class="bi bi-graph-up-arrow"></i> Insights hebdo
        </a>
        <a href="{{ path('chat_index') }}" class="nav-item">
            <i class="bi bi-robot"></i> Coach Eya IA
        </a>

        <div class="nav-section-label">Gestion Événements</div>
        <a href="{{ path('evenements_coach_create') }}" class="nav-item">
            <i class="bi bi-plus-circle-fill"></i> Créer un événement
            <span class="nav-badge new orange">NEW</span>
        </a>
        <a href="{{ path('evenements_coach_list') }}" class="nav-item">
            <i class="bi bi-calendar-week-fill"></i> Mes événements
        </a>

        <div class="nav-section-label">Bien-être</div>
        <a href="{{ path('user_analyse') }}" class="nav-item">
            <i class="bi bi-heart-pulse-fill"></i> Mon analyse
        </a>
        <a href="{{ path('objectif_index') }}" class="nav-item">
            <i class="bi bi-trophy-fill"></i> Mes objectifs
        </a>
        <a href="{{ path('food_analyzer_index') }}" class="nav-item">
            <i class="bi bi-egg-fried"></i> Analyseur Alimentaire
        </a>

        <div class="nav-section-label">Communauté</div>
        <a href="{{ path('posts_list') }}" class="nav-item">
            <i class="bi bi-newspaper"></i> Publications
        </a>
        <a href="{{ path('evenements_list') }}" class="nav-item">
            <i class="bi bi-calendar-event-fill"></i> Tous les événements
        </a>
        <a href="{{ path('evenements_mes_participations') }}" class="nav-item">
            <i class="bi bi-calendar-check-fill"></i> Mes participations
        </a>

        <div class="nav-section-label">Mon compte</div>
        <a href="{{ path('user_profile') }}" class="nav-item">
            <i class="bi bi-person-fill"></i> Mon profil
        </a>
        <a href="{{ path('user_profile_edit') }}" class="nav-item">
            <i class="bi bi-gear-fill"></i> Paramètres
        </a>
    </nav>

    <div class="sidebar-footer">
        <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;">
            <i class="bi bi-box-arrow-left"></i> Se déconnecter
        </a>
    </div>
</aside>
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- ═══════════════ MAIN ═══════════════ -->
<div class="main">

    <!-- TOPBAR -->
    <header class="topbar">
        <div class="topbar-left">
            <button class="menu-toggle" id="menuToggle"><i class="bi bi-list"></i></button>
            <div class="topbar-greeting">
                <h2>Bonjour, Coach {{ coach.prenom }} 👋</h2>
                <p>{{ "now"|date("d/m/Y") }} — Gérez vos événements et votre bien-être</p>
            </div>
        </div>
        <div class="topbar-right">
            <a href="{{ path('evenements_coach_create') }}" class="topbar-btn" title="Créer un événement" style="background:var(--teal-light);color:var(--teal-dark);">
                <i class="bi bi-plus-circle-fill"></i>
            </a>
            <a href="{{ path('suivi_today') }}" class="topbar-btn" title="Check-in du jour">
                <i class="bi bi-clipboard2-pulse"></i>
            </a>
            <a href="{{ path('chat_index') }}" class="topbar-btn" title="Chat Eya IA">
                <i class="bi bi-robot"></i>
            </a>
            <a href="{{ path('user_profile') }}" class="topbar-avatar" title="Mon profil">
                {% if coach.photo is defined and coach.photo %}
                    <img src="{{ asset('uploads/photos/' ~ coach.photo) }}" alt="avatar">
                {% else %}
                    {{ coach.prenom|first|upper }}{{ coach.nom|first|upper }}
                {% endif %}
            </a>
        </div>
    </header>

    <main class="content">

        <!-- ── WELCOME BANNER ──────────────────────────────────── -->
        <div class="welcome-banner">
            <div class="welcome-text">
                <div class="welcome-role-badge">
                    <i class="bi bi-shield-fill-check"></i> Coach Bekri
                </div>
                <h1>Bienvenue sur votre espace Coach ✨</h1>
                <p>Créez et gérez vos événements, suivez vos participants et continuez votre parcours bien-être.</p>
            </div>
            <div class="welcome-actions">
                <a href="{{ path('evenements_coach_create') }}" class="btn-banner btn-banner-primary">
                    <i class="bi bi-plus-circle-fill"></i> Créer un événement
                </a>
                <a href="{{ path('evenements_coach_list') }}" class="btn-banner btn-banner-secondary">
                    <i class="bi bi-calendar-week-fill"></i> Mes événements
                </a>
            </div>
        </div>

        <!-- ── STATS ROW ───────────────────────────────────────── -->
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon icon-teal">
                    <i class="bi bi-calendar-event-fill"></i>
                </div>
                <div class="stat-info">
                    <div class="stat-value">{{ totalEvenements }}</div>
                    <div class="stat-label">Mes événements</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon icon-green">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div class="stat-info">
                    <div class="stat-value">{{ totalParticipations }}</div>
                    <div class="stat-label">Total participants</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon icon-purple">
                    <i class="bi bi-calendar-check-fill"></i>
                </div>
                <div class="stat-info">
                    <div class="stat-value">{{ evenementsAVenir }}</div>
                    <div class="stat-label">Événements à venir</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon icon-amber">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <div class="stat-info">
                    <div class="stat-value">{{ evenementsTermines }}</div>
                    <div class="stat-label">Événements terminés</div>
                </div>
            </div>
        </div>

        <!-- ── COACH QUICK CREATE ALERT ───────────────────────── -->
        <div class="coach-alert">
            <div class="coach-alert-left">
                <div class="coach-alert-icon">
                    <i class="bi bi-plus-circle-fill"></i>
                </div>
                <div class="coach-alert-text">
                    <h3>Prêt à animer un nouvel événement ?</h3>
                    <p>Créez un atelier, une session bien-être ou un défi santé pour votre communauté.</p>
                </div>
            </div>
            <a href="{{ path('evenements_coach_create') }}" class="btn-create-event">
                <i class="bi bi-plus-circle-fill"></i> Créer un événement
            </a>
        </div>

        <!-- ── COACH FEATURES GRID ────────────────────────────── -->
        <div class="section-title">
            <i class="bi bi-shield-fill-check"></i> Outils Coach
        </div>
        <div class="features-grid" style="margin-bottom:28px;">
            <a href="{{ path('evenements_coach_create') }}" class="feature-card fc-teal">
                <span class="feature-badge new">Coach</span>
                <div class="feature-icon icon-teal"><i class="bi bi-plus-circle-fill"></i></div>
                <div class="feature-name">Créer un événement</div>
                <div class="feature-desc">Planifier un atelier ou session</div>
            </a>
            <a href="{{ path('evenements_coach_list') }}" class="feature-card fc-purple">
                <div class="feature-icon icon-purple"><i class="bi bi-calendar-week-fill"></i></div>
                <div class="feature-name">Mes événements</div>
                <div class="feature-desc">Gérer et modifier vos événements</div>
            </a>
            <a href="{{ path('evenements_list') }}" class="feature-card fc-blue">
                <div class="feature-icon icon-blue"><i class="bi bi-calendar-event-fill"></i></div>
                <div class="feature-name">Tous les événements</div>
                <div class="feature-desc">Parcourir le catalogue complet</div>
            </a>
            <a href="{{ path('evenements_mes_participations') }}" class="feature-card fc-green">
                <div class="feature-icon icon-green"><i class="bi bi-calendar-check-fill"></i></div>
                <div class="feature-name">Mes participations</div>
                <div class="feature-desc">Événements auxquels vous participez</div>
            </a>
        </div>

        <!-- ── USER FEATURES GRID ─────────────────────────────── -->
        <div class="section-title">
            <i class="bi bi-grid-fill"></i> Accès rapide — Espace membre
        </div>
        <div class="features-grid" style="margin-bottom:28px;">
            <a href="{{ path('suivi_today') }}" class="feature-card fc-teal">
                <div class="feature-icon icon-teal"><i class="bi bi-clipboard2-pulse-fill"></i></div>
                <div class="feature-name">Check-in quotidien</div>
                <div class="feature-desc">Suivez votre humeur & bien-être</div>
            </a>
            <a href="{{ path('insight_weekly') }}" class="feature-card fc-purple">
                <div class="feature-icon icon-purple"><i class="bi bi-graph-up-arrow"></i></div>
                <div class="feature-name">Insights hebdo</div>
                <div class="feature-desc">Analyses IA de votre semaine</div>
            </a>
            <a href="{{ path('chat_index') }}" class="feature-card fc-teal">
                <div class="feature-icon icon-teal"><i class="bi bi-robot"></i></div>
                <div class="feature-name">Coach Eya IA</div>
                <div class="feature-desc">Votre coach bien-être personnel</div>
            </a>
            <a href="{{ path('objectif_index') }}" class="feature-card fc-amber">
                <div class="feature-icon icon-amber"><i class="bi bi-trophy-fill"></i></div>
                <div class="feature-name">Mes objectifs</div>
                <div class="feature-desc">Définissez et suivez vos progrès</div>
            </a>
            <a href="{{ path('posts_list') }}" class="feature-card fc-blue">
                <div class="feature-icon icon-blue"><i class="bi bi-newspaper"></i></div>
                <div class="feature-name">Publications</div>
                <div class="feature-desc">Lisez et partagez des posts</div>
            </a>
            <a href="{{ path('user_analyse') }}" class="feature-card fc-rose">
                <div class="feature-icon icon-rose"><i class="bi bi-heart-pulse-fill"></i></div>
                <div class="feature-name">Mon analyse</div>
                <div class="feature-desc">Voir votre analyse bien-être IA</div>
            </a>
            <a href="{{ path('user_profile') }}" class="feature-card fc-purple">
                <div class="feature-icon icon-purple"><i class="bi bi-person-fill"></i></div>
                <div class="feature-name">Mon profil</div>
                <div class="feature-desc">Consultez et modifiez votre profil</div>
            </a>
            <a href="{{ path('evenements_stats') }}" class="feature-card fc-orange">
                <div class="feature-icon icon-orange"><i class="bi bi-bar-chart-fill"></i></div>
                <div class="feature-name">Statistiques</div>
                <div class="feature-desc">Analyse de vos événements</div>
            </a>
        </div>

        <!-- ── DASHBOARD BOTTOM GRID ──────────────────────────── -->
        <div class="dashboard-grid">

            <!-- Recent Events Table -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title">
                        <i class="bi bi-calendar-event-fill"></i> Mes événements récents
                    </div>
                    <a href="{{ path('evenements_coach_list') }}" class="card-link">Voir tout →</a>
                </div>
                <div class="card-body" style="padding:0;">
                    {% if evenementsRecents is not empty %}
                    <table class="events-table">
                        <thead>
                            <tr>
                                <th>Événement</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for ev in evenementsRecents %}
                            <tr>
                                <td>
                                    <div class="event-row-title">{{ ev.titre }}</div>
                                    <div class="event-row-date">
                                        <i class="bi bi-calendar3"></i>
                                        {{ ev.dateDebut|date('d/m/Y à H:i') }}
                                    </div>
                                </td>
                                <td>
                                    {% set s = ev.statut.value %}
                                    <span class="badge-status badge-{{ s == 'OPEN' ? 'open' : s == 'FULL' ? 'full' : s == 'FINISHED' ? 'finished' : 'planned' }}">
                                        {{ s }}
                                    </span>
                                </td>
                                <td>
                                    <div class="table-actions">
                                        <a href="{{ path('evenements_show', {id: ev.id}) }}" class="btn-table btn-view">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="{{ path('evenements_coach_edit', {id: ev.id}) }}" class="btn-table btn-edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a href="{{ path('evenements_coach_participants', {id: ev.id}) }}" class="btn-table btn-parts">
                                            <i class="bi bi-people"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                    {% else %}
                    <div class="empty-table">
                        <i class="bi bi-calendar-x"></i>
                        Aucun événement créé pour le moment.<br>
                        <a href="{{ path('evenements_coach_create') }}" style="color:var(--teal);font-weight:600;">Créer votre premier événement →</a>
                    </div>
                    {% endif %}
                </div>
            </div>

            <!-- Quick Links -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title">
                        <i class="bi bi-lightning-charge-fill"></i> Accès rapide
                    </div>
                </div>
                <div class="card-body">
                    <a href="{{ path('evenements_coach_create') }}" class="quick-link-item">
                        <div class="quick-link-icon icon-teal"><i class="bi bi-plus-circle-fill"></i></div>
                        <div class="quick-link-text">
                            <div class="quick-link-name">Créer un événement</div>
                            <div class="quick-link-desc">Nouvel atelier ou session</div>
                        </div>
                        <i class="bi bi-chevron-right quick-link-arrow"></i>
                    </a>
                    <a href="{{ path('evenements_coach_list') }}" class="quick-link-item">
                        <div class="quick-link-icon icon-purple"><i class="bi bi-calendar-week-fill"></i></div>
                        <div class="quick-link-text">
                            <div class="quick-link-name">Mes événements</div>
                            <div class="quick-link-desc">Gérer mes {{ totalEvenements }} événements</div>
                        </div>
                        <i class="bi bi-chevron-right quick-link-arrow"></i>
                    </a>
                    <a href="{{ path('suivi_today') }}" class="quick-link-item">
                        <div class="quick-link-icon icon-teal"><i class="bi bi-clipboard2-pulse-fill"></i></div>
                        <div class="quick-link-text">
                            <div class="quick-link-name">Check-in du jour</div>
                            <div class="quick-link-desc">Évaluer mon bien-être</div>
                        </div>
                        <i class="bi bi-chevron-right quick-link-arrow"></i>
                    </a>
                    <a href="{{ path('objectif_new') }}" class="quick-link-item">
                        <div class="quick-link-icon icon-amber"><i class="bi bi-plus-circle-fill"></i></div>
                        <div class="quick-link-text">
                            <div class="quick-link-name">Nouvel objectif</div>
                            <div class="quick-link-desc">Créer un objectif bien-être</div>
                        </div>
                        <i class="bi bi-chevron-right quick-link-arrow"></i>
                    </a>
                    <a href="{{ path('evenements_stats') }}" class="quick-link-item">
                        <div class="quick-link-icon icon-blue"><i class="bi bi-bar-chart-fill"></i></div>
                        <div class="quick-link-text">
                            <div class="quick-link-name">Statistiques</div>
                            <div class="quick-link-desc">Analyse de vos événements</div>
                        </div>
                        <i class="bi bi-chevron-right quick-link-arrow"></i>
                    </a>
                    <a href="{{ path('app_logout') }}" class="quick-link-item" style="color:#f87171;">
                        <div class="quick-link-icon icon-rose"><i class="bi bi-box-arrow-left"></i></div>
                        <div class="quick-link-text">
                            <div class="quick-link-name" style="color:#f87171;">Se déconnecter</div>
                            <div class="quick-link-desc">Quitter mon espace</div>
                        </div>
                        <i class="bi bi-chevron-right quick-link-arrow"></i>
                    </a>
                </div>
            </div>

        </div>

        <!-- ── BOTTOM CARDS ────────────────────────────────────── -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">
            <div class="insight-preview">
                <h3><i class="bi bi-graph-up-arrow"></i> Résumé de la semaine</h3>
                <p>Consultez votre analyse hebdomadaire générée par IA basée sur vos suivis quotidiens.</p>
                <a href="{{ path('insight_weekly') }}" class="btn-insight">
                    <i class="bi bi-eye-fill"></i> Voir mon résumé
                </a>
            </div>
            <div class="chat-card">
                <div class="chat-online">
                    <div class="online-dot"></div> Eya est disponible maintenant
                </div>
                <h3><i class="bi bi-robot"></i> Coach Eya — IA bien-être</h3>
                <p>Posez vos questions sur la santé mentale et physique. Eya vous répond 24h/24.</p>
                <a href="{{ path('chat_index') }}" class="btn-chat">
                    <i class="bi bi-chat-dots-fill"></i> Démarrer une conversation
                </a>
            </div>
        </div>

    </main>
</div>

<script>
    const menuToggle = document.getElementById('menuToggle');
    const sidebar    = document.getElementById('sidebar');
    const overlay    = document.getElementById('sidebarOverlay');
    menuToggle.addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('open'); });
    overlay.addEventListener('click',   () => { sidebar.classList.remove('open'); overlay.classList.remove('open'); });
</script>
</body>
</html>