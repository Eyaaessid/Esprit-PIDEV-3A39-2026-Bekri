{% extends 'base.html.twig' %}

{% block title %}Mes Événements - MediNest{% endblock %}

{% block body_class %}coach-list-page{% endblock %}

{% block main %}

    <!-- Page Title -->
    <div class="page-title">
      <div class="heading">
        <div class="container">
          <div class="row d-flex justify-content-center text-center">
            <div class="col-lg-8">
              <h1 class="heading-title">Mes Événements</h1>
              <p class="mb-0">
                Gérez tous vos événements en un seul endroit.
              </p>
            </div>
          </div>
        </div>
      </div>
      <nav class="breadcrumbs">
        <div class="container">
          <ol>
            <li><a href="{{ path('home') }}">Home</a></li>
            <li><a href="{{ path('evenements_coach_dashboard') }}">Dashboard</a></li>
            <li class="current">Mes Événements</li>
          </ol>
        </div>
      </nav>
    </div><!-- End Page Title -->

    <!-- Flash Messages -->
    {% for message in app.flashes('success') %}
    <div class="container mt-4">
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>{{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    </div>
    {% endfor %}

    <!-- Events List Section -->
    <section id="coach-events-list" class="coach-events-list section">

      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <!-- Header -->
        <div class="row mb-4">
          <div class="col-12">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
              <h4 class="mb-0">{{ evenements|length }} événement(s)</h4>
              <div class="d-flex gap-2">
                <a href="{{ path('evenements_coach_create') }}" class="btn btn-primary">
                  <i class="bi bi-plus-circle me-2"></i>Créer un événement
                </a>
                <a href="{{ path('evenements_coach_dashboard') }}" class="btn btn-outline-primary">
                  <i class="bi bi-speedometer2 me-2"></i>Dashboard
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Events Table -->
        <div class="row">
          <div class="col-12">
            <div class="card shadow-sm">
              <div class="card-body p-0">
                {% if evenements|length > 0 %}
                  <div class="table-responsive">
                    <table class="table table-hover mb-0">
                      <thead class="table-light">
                        <tr>
                          <th>Titre</th>
                          <th>Date</th>
                          <th>Type</th>
                          <th>Statut</th>
                          <th>Capacité</th>
                          <th class="text-center">Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for evenement in evenements %}
                        <tr>
                          <td>
                            <strong>{{ evenement.titre }}</strong>
                            {% if evenement.lienSession %}
                            <br>
                            <small class="text-muted">
                              <i class="bi bi-geo-alt"></i>
                              {{ evenement.lienSession|length > 30 ? evenement.lienSession|slice(0, 30) ~ '...' : evenement.lienSession }}
                            </small>
                            {% endif %}
                          </td>
                          <td>
                            <i class="bi bi-calendar3 text-muted"></i>
                            {{ evenement.dateDebut|date('d/m/Y') }}
                            <br>
                            <small class="text-muted">{{ evenement.dateDebut|date('H:i') }}</small>
                          </td>
                          <td>
                            <span class="badge bg-primary">{{ evenement.type.value }}</span>
                          </td>
                          <td>
                            {% if evenement.statut.value == 'OPEN' %}
                              <span class="badge bg-success">Ouvert</span>
                            {% elseif evenement.statut.value == 'FULL' %}
                              <span class="badge bg-danger">Complet</span>
                            {% elseif evenement.statut.value == 'PLANNED' %}
                              <span class="badge bg-info">Planifié</span>
                            {% elseif evenement.statut.value == 'CANCELLED' %}
                              <span class="badge bg-secondary">Annulé</span>
                            {% elseif evenement.statut.value == 'FINISHED' %}
                              <span class="badge bg-dark">Terminé</span>
                            {% endif %}
                          </td>
                          <td>
                            <i class="bi bi-people text-muted"></i>
                            {{ evenement.capaciteMax }}
                          </td>
                          <td class="text-center">
                            <a href="{{ path('evenements_show', {id: evenement.id}) }}" 
                               class="btn btn-sm btn-outline-info" 
                               title="Voir">
                              <i class="bi bi-eye"></i>
                            </a>
                            <a href="{{ path('evenements_coach_participants', {id: evenement.id}) }}" 
                               class="btn btn-sm btn-outline-primary" 
                               title="Participants">
                              <i class="bi bi-people"></i>
                            </a>
                            <a href="{{ path('evenements_coach_edit', {id: evenement.id}) }}" 
                               class="btn btn-sm btn-outline-secondary" 
                               title="Modifier">
                              <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" 
                                  action="{{ path('evenements_coach_delete', {id: evenement.id}) }}" 
                                  class="d-inline"
                                  onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet événement ?');">
                              <button type="submit" 
                                      class="btn btn-sm btn-outline-danger" 
                                      title="Supprimer">
                                <i class="bi bi-trash"></i>
                              </button>
                            </form>
                          </td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                {% else %}
                  <div class="text-center py-5">
                    <i class="bi bi-calendar-x fs-1 text-muted mb-3 d-block"></i>
                    <h5 class="text-muted">Aucun événement créé</h5>
                    <p class="text-muted mb-4">Commencez par créer votre premier événement.</p>
                    <a href="{{ path('evenements_coach_create') }}" class="btn btn-primary">
                      <i class="bi bi-plus-circle me-2"></i>Créer un événement
                    </a>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        </div>

      </div>

    </section><!-- End Events List Section -->

{% endblock %}
