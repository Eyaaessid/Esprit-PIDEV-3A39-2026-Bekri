{% extends 'base.html.twig' %}

{% block title %}Calendrier des Événements - BEKRI{% endblock %}

{% block body_class %}calendar-page{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css' rel='stylesheet' />
{% endblock %}

{% block head_extra %}
<style>
    .fc {
        --fc-border-color: #dee2e6;
        --fc-button-bg-color: #009cff;
        --fc-button-border-color: #009cff;
        --fc-button-hover-bg-color: #0082d6;
        --fc-button-hover-border-color: #0082d6;
        --fc-today-bg-color: rgba(0, 156, 255, 0.1);
    }
    .fc-event {
        cursor: pointer;
        padding: 2px 5px;
        border-radius: 4px;
        border: none;
        transition: transform 0.2s;
    }
    .fc-event:hover {
        transform: scale(1.02);
    }
    .fc-toolbar-title {
        font-weight: 700 !important;
    }
    .calendar-section {
        background: #f8f9fa;
        padding: 60px 0;
    }
    .calendar-section .bg-light {
        background: #fff !important;
        box-shadow: 0 5px 25px rgba(0,0,0,0.08);
        border-radius: 20px;
    }
</style>
{% endblock %}

{% block main %}

    <!-- Page Title -->
    <div class="page-title" data-aos="fade">
        <div class="heading">
            <div class="container">
                <div class="row d-flex justify-content-center text-center">
                    <div class="col-lg-8">
                        <h1>Calendrier des Événements</h1>
                        <p class="mb-0">Visualisez tous les événements dans un calendrier interactif</p>
                    </div>
                </div>
            </div>
        </div>
        <nav class="breadcrumbs">
            <div class="container">
                <ol>
                    <li><a href="{{ path('home') }}">Accueil</a></li>
                    <li><a href="{{ path('evenement_liste') }}">Événements</a></li>
                    <li class="current">Calendrier</li>
                </ol>
            </div>
        </nav>
    </div><!-- End Page Title -->

    <section class="calendar-section section">
        <div class="container">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h4 class="mb-0"><i class="bi bi-calendar3 me-2"></i>Calendrier des Événements</h4>
                <div class="calendar-legend d-none d-md-flex gap-3">
                    <span class="small"><i class="bi bi-circle-fill me-1" style="color: #4e73df;"></i> Atelier</span>
                    <span class="small"><i class="bi bi-circle-fill me-1" style="color: #1cc88a;"></i> Méditation</span>
                    <span class="small"><i class="bi bi-circle-fill me-1" style="color: #f6c23e;"></i> Défi Santé</span>
                    <span class="small"><i class="bi bi-circle-fill me-1" style="color: #36b9cc;"></i> Conférence</span>
                </div>
            </div>

            <div class="bg-light rounded h-100 p-4">
                <div id="calendar" style="min-height: 700px;"></div>
            </div>
        </div>
    </section>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js'></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        var calendarEl = document.getElementById('calendar');
        var calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek,listMonth'
            },
            locale: 'fr',
            events: '{{ path('evenement_calendar_data') }}',
            eventClick: function(info) {
                if (info.event.url) {
                    window.location.href = info.event.url;
                    info.jsEvent.preventDefault();
                }
            },
            eventTimeFormat: {
                hour: '2-digit',
                minute: '2-digit',
                meridiem: false
            }
        });
        calendar.render();
    });
</script>
{% endblock %}
