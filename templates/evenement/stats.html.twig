{% extends 'base.html.twig' %}

{% block title %}Statistiques des Événements - BEKRI{% endblock %}

{% block body_class %}stats-page{% endblock %}

{% block head_extra %}
<style>
.stats-section {
    background: #f8f9fa;
    padding: 60px 0;
}
.stats-section .bg-light,
.stats-section .bg-primary {
    box-shadow: 0 5px 25px rgba(0,0,0,0.08);
    border-radius: 20px;
}
.stats-section .bg-light {
    background: #fff !important;
}
</style>
{% endblock %}

{% block main %}

    <!-- Page Title -->
    <div class="page-title" data-aos="fade">
        <div class="heading">
            <div class="container">
                <div class="row d-flex justify-content-center text-center">
                    <div class="col-lg-8">
                        <h1>Statistiques des Événements</h1>
                        <p class="mb-0">Découvrez les événements les plus populaires et les tendances</p>
                    </div>
                </div>
            </div>
        </div>
        <nav class="breadcrumbs">
            <div class="container">
                <ol>
                    <li><a href="{{ path('home') }}">Accueil</a></li>
                    <li><a href="{{ path('evenement_liste') }}">Événements</a></li>
                    <li class="current">Statistiques</li>
                </ol>
            </div>
        </nav>
    </div><!-- End Page Title -->

    <section class="stats-section section">
        <div class="container">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h4 class="mb-0"><i class="bi bi-graph-up-arrow me-2"></i>Statistiques des Événements</h4>
            </div>

        <div class="row g-4 mb-4">
            <!-- Most Popular Chart -->
            <div class="col-lg-8">
                <div class="bg-light rounded h-100 p-4">
                    <h5 class="mb-4">Événements les Plus Demandés</h5>
                    <div style="height: 400px;">
                        <canvas id="popularityChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Statistics Summary -->
            <div class="col-lg-4">
                <div class="bg-primary rounded p-4 mb-4 text-white text-center">
                    <div class="display-4 fw-bold mb-2">{{ mostPopularData|length }}</div>
                    <div class="text-uppercase small">Total des Événements Analysés</div>
                </div>

                <div class="bg-light rounded p-4">
                    <h5 class="mb-4"><i class="bi bi-list-stars me-2"></i>Top 5 Engagement</h5>
                    <div class="list-group list-group-flush bg-transparent">
                        {% for item in mostPopularData|slice(0, 5) %}
                        <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center px-0 py-3">
                            <div class="d-flex align-items-center">
                                <span class="badge bg-primary rounded-circle me-3" style="width: 24px; height: 24px; display: flex; align-items: center; justify-content: center;">{{ loop.index }}</span>
                                <span class="fw-medium text-dark">{{ item.evenement.titre|u.truncate(25, '...') }}</span>
                            </div>
                            <span class="badge bg-secondary rounded-pill text-white">{{ item.participantCount }} inscrits</span>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Category Distribution -->
            <div class="col-md-6">
                <div class="bg-light rounded p-4 h-100">
                    <h5 class="mb-4">Distribution par Catégorie</h5>
                    <div style="height: 300px;">
                        <canvas id="categoryChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Monthly Trends -->
            <div class="col-md-6">
                <div class="bg-light rounded p-4 h-100">
                    <h5 class="mb-4">Tendances Mensuelles (6 Derniers Mois)</h5>
                    <div style="height: 300px;">
                        <canvas id="monthlyChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        </div>
    </section>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // 1. Popularity Chart
    const popCtx = document.getElementById('popularityChart').getContext('2d');
    new Chart(popCtx, {
        type: 'bar',
        data: {
            labels: [{% for item in mostPopularData %}"{{ item.evenement.titre|u.truncate(15, '...') }}"{% if not loop.last %}, {% endif %}{% endfor %}],
            datasets: [{
                label: 'Inscriptions',
                data: [{% for item in mostPopularData %}{{ item.participantCount }}{% if not loop.last %}, {% endif %}{% endfor %}],
                backgroundColor: 'rgba(0, 156, 255, .7)',
                borderColor: 'rgba(0, 156, 255, 1)',
                borderWidth: 1,
                borderRadius: 5
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
    });

    // 2. Category Chart
    const catCtx = document.getElementById('categoryChart').getContext('2d');
    new Chart(catCtx, {
        type: 'doughnut',
        data: {
            labels: [{% for item in categoryData %}"{{ item.type }}"{% if not loop.last %}, {% endif %}{% endfor %}],
            datasets: [{
                data: [{% for item in categoryData %}{{ item.count }}{% if not loop.last %}, {% endif %}{% endfor %}],
                backgroundColor: [
                    'rgba(0, 156, 255, .7)',
                    'rgba(0, 156, 255, .5)',
                    'rgba(0, 156, 255, .3)',
                    'rgba(0, 156, 255, .1)'
                ],
                borderWidth: 1
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { position: 'bottom' } }
        }
    });

    // 3. Monthly Trends Chart
    const monthCtx = document.getElementById('monthlyChart').getContext('2d');
    const monthNames = ["Jan", "Fév", "Mar", "Avr", "Mai", "Juin", "Juil", "Août", "Sep", "Oct", "Nov", "Déc"];
    new Chart(monthCtx, {
        type: 'line',
        data: {
            labels: [{% for item in monthlyData %}monthNames[{{ item.month }} - 1]{% if not loop.last %}, {% endif %}{% endfor %}],
            datasets: [{
                label: 'Événements Créés',
                data: [{% for item in monthlyData %}{{ item.count }}{% if not loop.last %}, {% endif %}{% endfor %}],
                fill: true,
                backgroundColor: 'rgba(0, 156, 255, .2)',
                borderColor: 'rgba(0, 156, 255, 1)',
                borderWidth: 2,
                tension: 0.4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
    });
});
</script>
{% endblock %}
