<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Événements Bien-être — Bekri</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --dark:       #1a2332;
            --gray:       #64748b;
            --light:      #f8fafc;
            --white:      #ffffff;
            --sidebar-w:  260px;
            --shadow-sm:  0 2px 12px rgba(0,0,0,0.06);
            --shadow:     0 8px 30px rgba(0,0,0,0.10);
            --radius:     16px;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior:smooth; }
        body { font-family:'Inter',sans-serif; background:var(--light); color:var(--dark); display:flex; min-height:100vh; }

        /* ── SIDEBAR ─────────────────────────────────────────────── */
        .sidebar { width:var(--sidebar-w); background:var(--dark); min-height:100vh; position:fixed; top:0; left:0; display:flex; flex-direction:column; z-index:100; transition:transform 0.3s ease; }
        .sidebar-logo { padding:28px 24px 20px; display:flex; align-items:center; gap:10px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-logo-text { font-size:20px; font-weight:800; background:linear-gradient(135deg,var(--teal),#a78bfa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .sidebar-user { padding:20px 24px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-avatar { width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:16px; flex-shrink:0; overflow:hidden; }
        .sidebar-avatar img { width:100%; height:100%; object-fit:cover; }
        .sidebar-user-name { font-size:14px; font-weight:600; color:white; }
        .sidebar-user-role { font-size:11px; color:rgba(255,255,255,0.4); margin-top:2px; }
        .sidebar-nav { flex:1; padding:16px 0; overflow-y:auto; }
        .nav-section-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:rgba(255,255,255,0.25); padding:12px 24px 6px; }
        .nav-item { display:flex; align-items:center; gap:12px; padding:11px 24px; color:rgba(255,255,255,0.6); text-decoration:none; font-size:14px; font-weight:500; transition:all 0.2s; border-left:3px solid transparent; }
        .nav-item:hover { color:white; background:rgba(255,255,255,0.05); }
        .nav-item.active { color:var(--teal); background:rgba(32,178,170,0.1); border-left-color:var(--teal); }
        .nav-item i { width:20px; text-align:center; font-size:16px; }
        .sidebar-footer { padding:16px 0; border-top:1px solid rgba(255,255,255,0.07); }

        /* ── MAIN ────────────────────────────────────────────────── */
        .main { margin-left:var(--sidebar-w); flex:1; display:flex; flex-direction:column; min-height:100vh; }

        /* ── TOPBAR ──────────────────────────────────────────────── */
        .topbar { background:white; padding:0 32px; height:68px; display:flex; align-items:center; justify-content:space-between; box-shadow:var(--shadow-sm); position:sticky; top:0; z-index:50; }
        .topbar-left { display:flex; align-items:center; gap:16px; }
        .topbar-title { font-size:18px; font-weight:700; color:var(--dark); }
        .topbar-sub { font-size:13px; color:var(--gray); margin-top:2px; }
        .topbar-right { display:flex; align-items:center; gap:10px; }
        .topbar-btn { height:38px; padding:0 16px; border-radius:10px; background:var(--light); border:1px solid #e2e8f0; cursor:pointer; display:flex; align-items:center; gap:7px; color:var(--gray); font-size:13px; font-weight:500; text-decoration:none; transition:all 0.2s; white-space:nowrap; }
        .topbar-btn:hover { background:var(--teal-light); color:var(--teal-dark); border-color:var(--teal); }
        .topbar-btn.primary { background:linear-gradient(135deg,var(--teal),var(--teal-dark)); color:white; border-color:transparent; }
        .topbar-btn.primary:hover { opacity:0.9; }
        .topbar-btn.pdf-all { background:linear-gradient(135deg,#dc2626,#b91c1c); color:white; border-color:transparent; }
        .topbar-btn.pdf-all:hover { opacity:0.9; color:white; }
        .topbar-btn.scan { background:linear-gradient(135deg,#7c3aed,#6d28d9); color:white; border-color:transparent; }
        .topbar-btn.scan:hover { opacity:0.9; color:white; }
        .topbar-avatar-sm { width:38px; height:38px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:14px; text-decoration:none; overflow:hidden; flex-shrink:0; }
        .topbar-avatar-sm img { width:100%; height:100%; object-fit:cover; }
        .menu-toggle { display:none; background:none; border:none; font-size:22px; color:var(--dark); cursor:pointer; }
        .sidebar-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:99; }

        /* ── PAGE HEADER ─────────────────────────────────────────── */
        .page-header { background:linear-gradient(135deg,var(--dark) 0%,#1e3a5f 60%,#0d9488 100%); padding:40px 40px 32px; position:relative; overflow:hidden; }
        .page-header::before { content:''; position:absolute; top:-60px; right:-60px; width:260px; height:260px; background:rgba(32,178,170,0.08); border-radius:50%; }
        .page-header-inner { max-width:1100px; margin:0 auto; position:relative; z-index:1; display:flex; align-items:center; justify-content:space-between; gap:24px; flex-wrap:wrap; }
        .page-header-tag { display:inline-flex; align-items:center; gap:6px; background:rgba(32,178,170,0.2); border:1px solid rgba(32,178,170,0.35); color:#7fffd4; padding:4px 12px; border-radius:50px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:10px; }
        .page-header-title { font-size:26px; font-weight:800; color:white; margin-bottom:6px; }
        .page-header-sub { font-size:14px; color:rgba(255,255,255,0.6); }
        .page-header-count { background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.15); border-radius:14px; padding:16px 24px; text-align:center; flex-shrink:0; }
        .page-header-count-num { font-size:28px; font-weight:800; color:white; line-height:1; }
        .page-header-count-label { font-size:12px; color:rgba(255,255,255,0.55); margin-top:4px; }

        /* ── CONTENT ─────────────────────────────────────────────── */
        .content { flex:1; padding:32px 40px; max-width:calc(1100px + 80px); margin:0 auto; width:100%; }

        /* ── FLASH MESSAGES ──────────────────────────────────────── */
        .flash { border-radius:12px; padding:14px 18px; margin-bottom:16px; display:flex; align-items:center; gap:12px; font-size:14px; font-weight:500; }
        .flash.success { background:#f0fdf4; border:1px solid #86efac; color:#166534; }
        .flash.error, .flash.danger { background:#fef2f2; border:1px solid #fca5a5; color:#991b1b; }
        .flash.warning { background:#fffbeb; border:1px solid #fcd34d; color:#92400e; }
        .flash.info    { background:#eff6ff; border:1px solid #93c5fd; color:#1e40af; }
        .flash i { font-size:18px; flex-shrink:0; }

        /* ── SEARCH BAR ──────────────────────────────────────────── */
        .search-wrap { margin-bottom:24px; }
        .search-box { display:flex; align-items:center; gap:12px; background:white; border:2px solid #e2e8f0; border-radius:14px; padding:12px 18px; box-shadow:var(--shadow-sm); transition:border-color 0.2s; }
        .search-box:focus-within { border-color:var(--teal); }
        .search-box i { font-size:18px; color:var(--gray); flex-shrink:0; }
        .search-box input { border:none; outline:none; font-size:15px; color:var(--dark); width:100%; font-family:'Inter',sans-serif; background:transparent; }
        .search-box input::placeholder { color:#94a3b8; }
        .search-info { text-align:center; margin-top:10px; font-size:13px; color:var(--gray); }

        /* ── FILTER TABS ─────────────────────────────────────────── */
        .filter-tabs { display:flex; gap:8px; flex-wrap:wrap; background:white; padding:16px; border-radius:14px; box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; margin-bottom:28px; }
        .filter-tab { display:flex; align-items:center; gap:7px; padding:9px 20px; border-radius:50px; font-size:13px; font-weight:600; cursor:pointer; border:2px solid transparent; background:var(--light); color:var(--gray); transition:all 0.2s; }
        .filter-tab:hover { background:var(--teal-light); color:var(--teal-dark); }
        .filter-tab.active { background:linear-gradient(135deg,var(--teal),var(--teal-dark)); color:white; border-color:transparent; box-shadow:0 4px 12px rgba(32,178,170,0.3); }

        /* ── EVENTS GRID ─────────────────────────────────────────── */
        .events-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:24px; }

        /* ── EVENT CARD ──────────────────────────────────────────── */
        .event-card { background:white; border-radius:var(--radius); overflow:hidden; box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; display:flex; flex-direction:column; transition:all 0.3s; }
        .event-card:hover { transform:translateY(-6px); box-shadow:var(--shadow); border-color:#dbe3ea; }
        .event-img { position:relative; height:200px; overflow:hidden; }
        .event-img img { width:100%; height:100%; object-fit:cover; transition:transform 0.4s; }
        .event-card:hover .event-img img { transform:scale(1.06); }
        .event-type-badge { position:absolute; top:14px; left:14px; padding:5px 13px; border-radius:50px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; background:rgba(255,255,255,0.95); color:var(--teal-dark); display:flex; align-items:center; gap:5px; }
        .event-status-badge { position:absolute; top:14px; right:14px; padding:5px 13px; border-radius:50px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; display:flex; align-items:center; gap:5px; }
        .event-status-badge.ouvert  { background:rgba(22,163,74,0.92);  color:white; }
        .event-status-badge.complet { background:rgba(220,38,38,0.92);  color:white; }
        .event-status-badge.termine { background:rgba(100,116,139,0.92);color:white; }
        .event-body { padding:22px; flex:1; display:flex; flex-direction:column; }
        .event-date-row { display:flex; align-items:center; gap:6px; color:var(--teal-dark); font-size:13px; font-weight:600; margin-bottom:10px; }
        .event-title { font-size:17px; font-weight:700; color:var(--dark); margin-bottom:10px; line-height:1.35; }
        .event-title a { color:inherit; text-decoration:none; transition:color 0.2s; }
        .event-title a:hover { color:var(--teal-dark); }
        .event-desc { font-size:13px; color:var(--gray); line-height:1.65; margin-bottom:16px; flex:1; }
        .event-meta { display:flex; gap:16px; margin-bottom:16px; padding-bottom:16px; border-bottom:1px solid #f1f5f9; flex-wrap:wrap; }
        .meta-item { display:flex; align-items:center; gap:5px; font-size:13px; color:var(--gray); }
        .meta-item i { color:var(--teal); font-size:14px; }
        .event-progress-wrap { margin-bottom:14px; }
        .event-progress-bar { height:6px; background:#e2e8f0; border-radius:50px; overflow:hidden; margin-bottom:5px; }
        .event-progress-fill { height:100%; background:linear-gradient(90deg,var(--teal),var(--teal-dark)); border-radius:50px; transition:width 0.4s; }
        .event-progress-label { font-size:12px; color:var(--gray); }
        .event-actions { display:flex; gap:8px; margin-top:auto; flex-wrap:wrap; }
        .btn-details { flex:1; display:flex; align-items:center; justify-content:center; gap:6px; padding:10px 16px; background:linear-gradient(135deg,var(--teal),var(--teal-dark)); color:white; border-radius:10px; font-size:13px; font-weight:600; text-decoration:none; transition:all 0.2s; }
        .btn-details:hover { opacity:0.9; color:white; transform:translateY(-1px); }
        .btn-participate { display:flex; align-items:center; justify-content:center; gap:6px; padding:10px 16px; background:#f0fdf4; color:#166534; border:1px solid #86efac; border-radius:10px; font-size:13px; font-weight:600; cursor:pointer; transition:all 0.2s; white-space:nowrap; }
        .btn-participate:hover { background:#16a34a; color:white; border-color:#16a34a; }

        /* ── PDF BUTTON on card ──────────────────────────────────── */
        .btn-pdf { display:flex; align-items:center; justify-content:center; gap:6px; padding:10px 14px; background:#fef2f2; color:#dc2626; border:1px solid #fca5a5; border-radius:10px; font-size:13px; font-weight:600; text-decoration:none; transition:all 0.2s; white-space:nowrap; }
        .btn-pdf:hover { background:#dc2626; color:white; border-color:#dc2626; }
        .btn-scan { display:flex; align-items:center; justify-content:center; gap:6px; padding:10px 14px; background:#f5f3ff; color:#7c3aed; border:1px solid #c4b5fd; border-radius:10px; font-size:13px; font-weight:600; text-decoration:none; transition:all 0.2s; white-space:nowrap; }
        .btn-scan:hover { background:#7c3aed; color:white; border-color:#7c3aed; }

        /* ── EMPTY STATE ─────────────────────────────────────────── */
        .empty-state { text-align:center; padding:60px 24px; background:white; border-radius:var(--radius); box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; grid-column:1/-1; }
        .empty-state-icon { font-size:48px; color:#cbd5e1; margin-bottom:16px; }
        .empty-state-title { font-size:17px; font-weight:700; color:var(--dark); margin-bottom:8px; }
        .empty-state-desc { font-size:14px; color:var(--gray); }

        /* ── RESPONSIVE ──────────────────────────────────────────── */
        @media (max-width:1024px) { .events-grid { grid-template-columns:repeat(2,1fr); } }
        @media (max-width:768px) {
            .sidebar { transform:translateX(-100%); }
            .sidebar.open { transform:translateX(0); }
            .sidebar-overlay.open { display:block; }
            .main { margin-left:0; }
            .menu-toggle { display:block; }
            .topbar { padding:0 16px; }
            .topbar-btn span { display:none; }
            .page-header { padding:28px 20px; }
            .content { padding:20px 16px; }
            .events-grid { grid-template-columns:1fr; }
            .page-header-inner { flex-direction:column; align-items:flex-start; }
            .filter-tabs { gap:6px; }
            .filter-tab { padding:8px 14px; font-size:12px; }
        }
    </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
        <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'" style="height:36px;">
        <span class="sidebar-logo-text">Bekri</span>
    </div>
    <div class="sidebar-user">
        <div class="sidebar-avatar">
            {% if app.user and app.user.avatar %}
                <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
            {% elseif app.user %}
                {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
            {% else %}
                <i class="bi bi-person-fill" style="font-size:20px;"></i>
            {% endif %}
        </div>
        <div>
            <div class="sidebar-user-name">{{ app.user ? app.user.prenom ~ ' ' ~ app.user.nom : 'Invité' }}</div>
            <div class="sidebar-user-role">
                {% if is_granted('ROLE_ADMIN') %}Administrateur
                {% elseif is_granted('ROLE_COACH') %}Coach
                {% else %}Membre Bekri{% endif %}
            </div>
        </div>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-section-label">Principal</div>
        <a href="{{ path('user_dashboard') }}"  class="nav-item"><i class="bi bi-grid-fill"></i> Tableau de bord</a>
        <a href="{{ path('suivi_today') }}"       class="nav-item"><i class="bi bi-clipboard2-pulse-fill"></i> Check-in quotidien</a>
        <a href="{{ path('insight_weekly') }}"    class="nav-item"><i class="bi bi-graph-up-arrow"></i> Insights hebdo</a>
        <a href="{{ path('chat_index') }}"        class="nav-item"><i class="bi bi-robot"></i> Coach Eya IA</a>
        <div class="nav-section-label">Bien-être</div>
        <a href="{{ path('user_analyse') }}"      class="nav-item"><i class="bi bi-heart-pulse-fill"></i> Mon analyse</a>
        <a href="{{ path('objectif_index') }}"    class="nav-item"><i class="bi bi-trophy-fill"></i> Mes objectifs</a>
        <div class="nav-section-label">Communauté</div>
        <a href="{{ path('posts_list') }}"        class="nav-item"><i class="bi bi-newspaper"></i> Publications</a>
        <a href="{{ path('evenements_home') }}"   class="nav-item active"><i class="bi bi-calendar-event-fill"></i> Événements</a>
        <div class="nav-section-label">Mon compte</div>
        <a href="{{ path('user_profile') }}"      class="nav-item"><i class="bi bi-person-fill"></i> Mon profil</a>
        <a href="{{ path('user_profile_edit') }}" class="nav-item"><i class="bi bi-gear-fill"></i> Paramètres</a>
    </nav>
    <div class="sidebar-footer">
        <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;"><i class="bi bi-box-arrow-left"></i> Se déconnecter</a>
    </div>
</aside>
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- MAIN -->
<div class="main">
    <header class="topbar">
        <div class="topbar-left">
            <button class="menu-toggle" id="menuToggle"><i class="bi bi-list"></i></button>
            <div>
                <div class="topbar-title">Événements Bien-être</div>
                <div class="topbar-sub">{{ evenements|length }} événement(s) disponible(s)</div>
            </div>
        </div>
        <div class="topbar-right">
            <a href="{{ path('evenements_calendrier') }}" class="topbar-btn">
                <i class="bi bi-calendar-range"></i><span>Calendrier</span>
            </a>
            <a href="{{ path('evenements_stats') }}" class="topbar-btn">
                <i class="bi bi-graph-up"></i><span>Statistiques</span>
            </a>
            <a href="{{ path('evenements_mes_participations') }}" class="topbar-btn primary">
                <i class="bi bi-calendar-check"></i><span>Mes Participations</span>
            </a>
{# ── EXPORT ALL PDF BUTTON ── #}
            <a href="{{ path('evenements_export_all_pdf') }}" class="topbar-btn pdf-all" title="Exporter tous les événements en PDF">
                <i class="bi bi-file-earmark-pdf-fill"></i><span>Exporter tout</span>
            </a>
            <a href="{{ path('user_profile') }}" class="topbar-avatar-sm">
                {% if app.user and app.user.avatar %}
                    <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
                {% elseif app.user %}
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                {% else %}
                    <i class="bi bi-person-fill"></i>
                {% endif %}
            </a>
        </div>
    </header>

    <!-- PAGE HEADER -->
    <div class="page-header">
        <div class="page-header-inner">
            <div class="page-header-text">
                <div class="page-header-tag"><i class="bi bi-calendar-event-fill"></i> Événements & Participation</div>
                <div class="page-header-title">Rejoignez nos événements bien-être</div>
                <div class="page-header-sub">Ateliers, séances de méditation et défis santé pour votre communauté</div>
            </div>
            <div class="page-header-count">
                <div class="page-header-count-num">{{ evenements|length }}</div>
                <div class="page-header-count-label">Événements disponibles</div>
            </div>
        </div>
    </div>

    <main>
        <div class="content">

            <!-- FLASH MESSAGES -->
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash {{ label }}">
                        <i class="bi bi-{{ label == 'success' ? 'check-circle-fill' : label == 'error' or label == 'danger' ? 'x-circle-fill' : 'info-circle-fill' }}"></i>
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            <!-- SEARCH -->
            <div class="search-wrap" id="searchWrap">
                <div class="search-box">
                    <i class="bi bi-search"></i>
                    <input type="text" id="ajax-search" placeholder="Rechercher un événement (titre, type...)" autocomplete="off">
                </div>
                <div class="search-info d-none" id="search-results-info"></div>
            </div>

            <!-- FILTER TABS -->
            <div class="filter-tabs">
                <button class="filter-tab active" data-filter="all">
                    <i class="bi bi-calendar-event"></i> Tous les événements
                </button>
                <button class="filter-tab" data-filter="EVENT">
                    <i class="bi bi-people"></i> Événements
                </button>
                <button class="filter-tab" data-filter="SESSION">
                    <i class="bi bi-heart-pulse"></i> Sessions
                </button>
            </div>

            <!-- EVENTS GRID -->
            <div class="events-grid" id="events-container">
                {% for evenement in evenements %}
                    <div class="event-card" data-type="{{ evenement.type.value }}">
                        <div class="event-img">
                            <img src="{{ asset(evenement.image ?? 'assets/img/health/consultation-3.webp') }}"
                                 alt="{{ evenement.titre }}"
                                 onerror="this.src='{{ asset('assets/img/health/consultation-3.webp') }}'">
                            <div class="event-type-badge">
                                {% if evenement.type.value == 'EVENT' %}
                                    <i class="bi bi-people"></i> Événement
                                {% elseif evenement.type.value == 'SESSION' %}
                                    <i class="bi bi-heart-pulse"></i> Session
                                {% else %}
                                    <i class="bi bi-calendar-event"></i> {{ evenement.type.value }}
                                {% endif %}
                            </div>
                            {% if evenement.participations.count >= evenement.capaciteMax %}
                                <div class="event-status-badge complet"><i class="bi bi-x-circle-fill"></i> Complet</div>
                            {% elseif evenement.statut.value == 'FINISHED' %}
                                <div class="event-status-badge termine"><i class="bi bi-check-circle-fill"></i> Terminé</div>
                            {% else %}
                                <div class="event-status-badge ouvert"><i class="bi bi-circle-fill" style="font-size:8px;"></i> Ouvert</div>
                            {% endif %}
                        </div>
                        <div class="event-body">
                            <div class="event-date-row">
                                <i class="bi bi-calendar3"></i>
                                {{ evenement.dateDebut|date('d/m/Y à H:i') }}
                            </div>
                            <div class="event-title">
                                <a href="{{ path('evenements_show', {id: evenement.id}) }}">{{ evenement.titre }}</a>
                            </div>
                            <div class="event-desc">{{ evenement.description|slice(0,120) }}…</div>
                            <div class="event-meta">
                                <div class="meta-item"><i class="bi bi-link-45deg"></i> {{ evenement.lienSession ?? 'En ligne' }}</div>
                                <div class="meta-item"><i class="bi bi-people-fill"></i> {{ evenement.participations.count }}/{{ evenement.capaciteMax }}</div>
                            </div>
                            <div class="event-progress-wrap">
                                <div class="event-progress-bar">
                                    <div class="event-progress-fill" style="width:{{ (evenement.participations.count / evenement.capaciteMax * 100)|round }}%"></div>
                                </div>
                                <div class="event-progress-label">{{ (evenement.capaciteMax - evenement.participations.count) }} place(s) restante(s)</div>
                            </div>
                            <div class="event-actions">
                                <a href="{{ path('evenements_show', {id: evenement.id}) }}" class="btn-details">
                                    Voir détails <i class="bi bi-arrow-right"></i>
                                </a>
                                {% if evenement.participations.count < evenement.capaciteMax and evenement.statut.value == 'OPEN' %}
                                    <form method="post" action="{{ path('evenements_participer', {id: evenement.id}) }}">
                                        <button type="submit" class="btn-participate">
                                            <i class="bi bi-calendar-check"></i> Participer
                                        </button>
                                    </form>
                                {% endif %}
                                {# ── EXPORT SINGLE PDF BUTTON ── #}
                                <a href="{{ path('evenements_export_pdf', {id: evenement.id}) }}"
                                   class="btn-pdf"
                                   title="Exporter en PDF">
                                    <i class="bi bi-file-earmark-pdf-fill"></i> PDF
                                </a>
                                {# ── SCAN SUMMARY BUTTON ── #}
                                <a href="{{ path('evenements_scan_summary', {id: evenement.id}) }}"
                                   class="btn-scan"
                                   title="Résumé scan QR">
                                    <i class="bi bi-qr-code-scan"></i> Scan
                                </a>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="empty-state">
                        <div class="empty-state-icon"><i class="bi bi-calendar-x"></i></div>
                        <div class="empty-state-title">Aucun événement disponible</div>
                        <div class="empty-state-desc">Revenez bientôt pour découvrir nos prochains événements bien-être !</div>
                    </div>
                {% endfor %}
            </div>

        </div>
    </main>
</div>

<script>
    const menuToggle = document.getElementById('menuToggle');
    const sidebar    = document.getElementById('sidebar');
    const overlay    = document.getElementById('sidebarOverlay');
    menuToggle?.addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('open'); });
    overlay?.addEventListener('click',   () => { sidebar.classList.remove('open'); overlay.classList.remove('open'); });

    const filterTabs = document.querySelectorAll('.filter-tab');
    const allCards   = document.querySelectorAll('.event-card');
    filterTabs.forEach(tab => {
        tab.addEventListener('click', () => {
            filterTabs.forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            const filter = tab.dataset.filter;
            allCards.forEach(card => {
                card.style.display = (filter === 'all' || card.dataset.type === filter) ? '' : 'none';
            });
        });
    });

    const searchInput = document.getElementById('ajax-search');
    const container   = document.getElementById('events-container');
    const searchInfo  = document.getElementById('search-results-info');
    let debounceTimer;

    searchInput.addEventListener('input', function () {
        clearTimeout(debounceTimer);
        const query = this.value.trim();
        debounceTimer = setTimeout(() => {
            if (query.length > 0) {
                searchInfo.classList.remove('d-none');
                searchInfo.innerHTML = '<i class="bi bi-hourglass-split"></i> Recherche en cours…';
                fetch(`{{ path('evenements_list') }}?q=${encodeURIComponent(query)}`)
                    .then(r => r.json())
                    .then(data => {
                        renderResults(data);
                        searchInfo.innerHTML = `<i class="bi bi-info-circle"></i> ${data.length} résultat(s) pour "<strong>${query}</strong>"`;
                    });
            } else {
                searchInfo.classList.add('d-none');
                location.reload();
            }
        }, 300);
    });

    function renderResults(events) {
        if (events.length === 0) {
            container.innerHTML = `<div class="empty-state"><div class="empty-state-icon"><i class="bi bi-search"></i></div><div class="empty-state-title">Aucun résultat trouvé</div><div class="empty-state-desc">Essayez avec d'autres mots-clés.</div></div>`;
            return;
        }
        container.innerHTML = events.map(e => `
            <div class="event-card" data-type="${e.type}">
                <div class="event-img">
                    <img src="{{ asset('assets/img/health/consultation-3.webp') }}" alt="${e.titre}">
                    <div class="event-type-badge"><i class="bi bi-calendar-event"></i> ${e.type}</div>
                </div>
                <div class="event-body">
                    <div class="event-date-row"><i class="bi bi-calendar3"></i> ${e.dateDebut}</div>
                    <div class="event-title"><a href="${e.url}">${e.titre}</a></div>
                    <div class="event-actions">
                        <a href="${e.url}" class="btn-details">Voir détails <i class="bi bi-arrow-right"></i></a>
                        <a href="${e.url}/export-pdf" class="btn-pdf"><i class="bi bi-file-earmark-pdf-fill"></i> PDF</a>
                    </div>
                </div>
            </div>
        `).join('');
    }
</script>
</body>
</html>