<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mes Participations — Bekri</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --dark:       #1a2332;
            --gray:       #64748b;
            --light:      #f8fafc;
            --white:      #ffffff;
            --sidebar-w:  260px;
            --shadow-sm:  0 2px 12px rgba(0,0,0,0.06);
            --shadow:     0 8px 30px rgba(0,0,0,0.10);
            --radius:     16px;
            --green:      #16a34a;
            --green-light:#f0fdf4;
            --red:        #dc2626;
            --red-light:  #fef2f2;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:'Inter',sans-serif; background:var(--light); color:var(--dark); display:flex; min-height:100vh; }

        /* ── SIDEBAR ─────────────────────────────────────────────── */
        .sidebar { width:var(--sidebar-w); background:var(--dark); min-height:100vh; position:fixed; top:0; left:0; display:flex; flex-direction:column; z-index:100; transition:transform 0.3s ease; }
        .sidebar-logo { padding:28px 24px 20px; display:flex; align-items:center; gap:10px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-logo-text { font-size:20px; font-weight:800; background:linear-gradient(135deg,var(--teal),#a78bfa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .sidebar-user { padding:20px 24px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-avatar { width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:16px; flex-shrink:0; overflow:hidden; }
        .sidebar-avatar img { width:100%; height:100%; object-fit:cover; }
        .sidebar-user-name { font-size:14px; font-weight:600; color:white; }
        .sidebar-user-role { font-size:11px; color:rgba(255,255,255,0.4); margin-top:2px; }
        .sidebar-nav { flex:1; padding:16px 0; overflow-y:auto; }
        .nav-section-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:rgba(255,255,255,0.25); padding:12px 24px 6px; }
        .nav-item { display:flex; align-items:center; gap:12px; padding:11px 24px; color:rgba(255,255,255,0.6); text-decoration:none; font-size:14px; font-weight:500; transition:all 0.2s; border-left:3px solid transparent; }
        .nav-item:hover { color:white; background:rgba(255,255,255,0.05); }
        .nav-item.active { color:var(--teal); background:rgba(32,178,170,0.1); border-left-color:var(--teal); }
        .nav-item i { width:20px; text-align:center; font-size:16px; }
        .sidebar-footer { padding:16px 0; border-top:1px solid rgba(255,255,255,0.07); }

        /* ── MAIN ────────────────────────────────────────────────── */
        .main { margin-left:var(--sidebar-w); flex:1; display:flex; flex-direction:column; min-height:100vh; }

        /* ── TOPBAR ──────────────────────────────────────────────── */
        .topbar { background:white; padding:0 32px; height:68px; display:flex; align-items:center; justify-content:space-between; box-shadow:var(--shadow-sm); position:sticky; top:0; z-index:50; }
        .topbar-left { display:flex; align-items:center; gap:16px; }
        .topbar-title { font-size:18px; font-weight:700; color:var(--dark); }
        .topbar-sub { font-size:13px; color:var(--gray); margin-top:2px; }
        .topbar-right { display:flex; align-items:center; gap:10px; }
        .topbar-btn { height:38px; padding:0 16px; border-radius:10px; background:var(--light); border:1px solid #e2e8f0; cursor:pointer; display:flex; align-items:center; gap:7px; color:var(--gray); font-size:13px; font-weight:500; text-decoration:none; transition:all 0.2s; white-space:nowrap; }
        .topbar-btn:hover { background:var(--teal-light); color:var(--teal-dark); border-color:var(--teal); }
        .topbar-avatar-sm { width:38px; height:38px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:14px; text-decoration:none; overflow:hidden; flex-shrink:0; }
        .topbar-avatar-sm img { width:100%; height:100%; object-fit:cover; }
        .menu-toggle { display:none; background:none; border:none; font-size:22px; color:var(--dark); cursor:pointer; }
        .sidebar-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:99; }

        /* ── CONTENT ─────────────────────────────────────────────── */
        .content { flex:1; padding:32px 40px; }

        /* ── BREADCRUMB ──────────────────────────────────────────── */
        .breadcrumb { display:flex; align-items:center; gap:8px; font-size:13px; color:var(--gray); margin-bottom:24px; flex-wrap:wrap; }
        .breadcrumb a { color:var(--teal-dark); text-decoration:none; font-weight:500; }
        .breadcrumb a:hover { text-decoration:underline; }
        .breadcrumb i { font-size:11px; color:#cbd5e1; }

        /* ── FLASH ───────────────────────────────────────────────── */
        .flash { padding:14px 18px; border-radius:12px; font-size:14px; font-weight:500; margin-bottom:20px; display:flex; align-items:center; gap:10px; }
        .flash.success { background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0; }
        .flash.error   { background:#fef2f2; color:#dc2626; border:1px solid #fecaca; }
        .flash.warning { background:#fffbeb; color:#d97706; border:1px solid #fde68a; }

        /* ── USER HERO CARD ──────────────────────────────────────── */
        .user-hero { background:linear-gradient(135deg,var(--dark) 0%,#2d3f55 100%); border-radius:var(--radius); padding:32px; display:flex; align-items:center; gap:28px; margin-bottom:28px; position:relative; overflow:hidden; }
        .user-hero::before { content:''; position:absolute; top:-60px; right:-60px; width:220px; height:220px; border-radius:50%; background:rgba(32,178,170,0.12); }
        .user-hero::after  { content:''; position:absolute; bottom:-40px; right:120px; width:140px; height:140px; border-radius:50%; background:rgba(102,126,234,0.1); }
        .hero-avatar { width:80px; height:80px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; font-size:28px; font-weight:800; color:white; flex-shrink:0; border:3px solid rgba(255,255,255,0.15); z-index:1; }
        .hero-info { flex:1; z-index:1; }
        .hero-info h2 { font-size:22px; font-weight:800; color:white; margin-bottom:6px; }
        .hero-info p  { font-size:13px; color:rgba(255,255,255,0.55); display:flex; align-items:center; gap:6px; margin-bottom:4px; }
        .hero-stats { display:flex; gap:16px; z-index:1; }
        .hero-stat { background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:16px 24px; text-align:center; backdrop-filter:blur(10px); }
        .hero-stat-num   { font-size:26px; font-weight:800; color:white; line-height:1; }
        .hero-stat-label { font-size:11px; color:rgba(255,255,255,0.5); margin-top:5px; text-transform:uppercase; letter-spacing:0.5px; }

        /* ── SECTION HEADER ──────────────────────────────────────── */
        .section-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:24px; flex-wrap:wrap; gap:12px; }
        .section-header h3 { font-size:18px; font-weight:700; color:var(--dark); display:flex; align-items:center; gap:8px; }
        .section-header h3 i { color:var(--teal); }
        .btn-primary { height:40px; padding:0 20px; background:linear-gradient(135deg,var(--teal),var(--teal-dark)); color:white; border:none; border-radius:10px; font-size:13px; font-weight:600; text-decoration:none; display:inline-flex; align-items:center; gap:7px; cursor:pointer; transition:opacity 0.2s; }
        .btn-primary:hover { opacity:0.88; color:white; }

        /* ── EMPTY STATE ─────────────────────────────────────────── */
        .empty-state { background:white; border-radius:var(--radius); padding:80px 40px; text-align:center; box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; }
        .empty-icon { font-size:64px; color:#cbd5e1; margin-bottom:20px; }
        .empty-state h4 { font-size:20px; font-weight:700; color:var(--dark); margin-bottom:10px; }
        .empty-state p  { font-size:14px; color:var(--gray); margin-bottom:28px; max-width:400px; margin-inline:auto; }

        /* ── TIMELINE ────────────────────────────────────────────── */
        .timeline { position:relative; display:flex; flex-direction:column; gap:20px; }
        .timeline::before { content:''; position:absolute; left:27px; top:0; bottom:0; width:2px; background:linear-gradient(to bottom,var(--teal-light),#e2e8f0); }

        .timeline-item { display:flex; gap:20px; align-items:flex-start; position:relative; }
        .timeline-dot { width:56px; height:56px; border-radius:50%; background:white; border:3px solid #e2e8f0; display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0; z-index:1; transition:all 0.2s; }
        .timeline-item.INSCRIT  .timeline-dot { border-color:var(--green); color:var(--green); background:var(--green-light); }
        .timeline-item.ANNULE   .timeline-dot { border-color:var(--red);   color:var(--red);   background:var(--red-light); }
        .timeline-item.EN_ATTENTE .timeline-dot { border-color:#f59e0b; color:#f59e0b; background:#fffbeb; }

        /* ── PARTICIPATION CARD ──────────────────────────────────── */
        .part-card { flex:1; background:white; border-radius:var(--radius); box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; overflow:hidden; transition:transform 0.2s, box-shadow 0.2s; }
        .part-card:hover { transform:translateX(6px); box-shadow:var(--shadow); }

        .part-card-head { padding:20px 24px; background:var(--light); border-bottom:1px solid #f1f5f9; display:flex; align-items:flex-start; justify-content:space-between; gap:12px; flex-wrap:wrap; }
        .part-card-head h4 { font-size:16px; font-weight:700; color:var(--dark); margin-top:8px; }
        .badges { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }

        .badge-type { display:inline-flex; align-items:center; gap:5px; padding:5px 12px; border-radius:50px; font-size:12px; font-weight:600; background:linear-gradient(135deg,var(--teal),var(--teal-dark)); color:white; }
        .badge-status { display:inline-flex; align-items:center; gap:5px; padding:5px 12px; border-radius:50px; font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:0.3px; }
        .badge-status.INSCRIT   { background:var(--green-light); color:var(--green); }
        .badge-status.ANNULE    { background:var(--red-light);   color:var(--red); }
        .badge-status.EN_ATTENTE{ background:#fffbeb; color:#d97706; }

        .part-card-body { padding:20px 24px; display:flex; flex-direction:column; gap:10px; }
        .detail-row { display:flex; align-items:center; gap:10px; font-size:14px; color:var(--gray); }
        .detail-row i { color:var(--teal); font-size:15px; width:18px; text-align:center; }

        .part-card-foot { padding:16px 24px; border-top:1px solid #f1f5f9; display:flex; gap:10px; flex-wrap:wrap; }
        .btn-outline { height:36px; padding:0 16px; border-radius:9px; border:1.5px solid var(--teal); color:var(--teal-dark); background:white; font-size:13px; font-weight:600; text-decoration:none; display:inline-flex; align-items:center; gap:6px; transition:all 0.2s; cursor:pointer; }
        .btn-outline:hover { background:var(--teal-light); }
        .btn-cancel { height:36px; padding:0 16px; border-radius:9px; border:none; background:var(--red-light); color:var(--red); font-size:13px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:6px; transition:all 0.2s; }
        .btn-cancel:hover { background:#fecaca; }

        /* ── RESPONSIVE ──────────────────────────────────────────── */
        @media (max-width:768px) {
            .sidebar { transform:translateX(-100%); }
            .sidebar.open { transform:translateX(0); }
            .sidebar-overlay.open { display:block; }
            .main { margin-left:0; }
            .menu-toggle { display:block; }
            .topbar { padding:0 16px; }
            .topbar-btn span { display:none; }
            .content { padding:20px 16px; }
            .user-hero { flex-direction:column; text-align:center; padding:24px; }
            .user-hero::before, .user-hero::after { display:none; }
            .hero-stats { width:100%; justify-content:center; }
            .timeline::before { left:22px; }
            .timeline-dot { width:44px; height:44px; font-size:16px; }
            .part-card-foot { flex-direction:column; }
        }
    </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
        <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'" style="height:36px;">
        <span class="sidebar-logo-text">Bekri</span>
    </div>
    <div class="sidebar-user">
        <div class="sidebar-avatar">
            {% if app.user and app.user.avatar %}
                <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
            {% elseif app.user %}
                {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
            {% else %}
                <i class="bi bi-person-fill" style="font-size:20px;"></i>
            {% endif %}
        </div>
        <div>
            <div class="sidebar-user-name">{{ app.user ? app.user.prenom ~ ' ' ~ app.user.nom : 'Invité' }}</div>
            <div class="sidebar-user-role">
                {% if is_granted('ROLE_ADMIN') %}Administrateur
                {% elseif is_granted('ROLE_COACH') %}Coach
                {% else %}Membre Bekri{% endif %}
            </div>
        </div>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-section-label">Principal</div>
        <a href="{{ path('user_dashboard') }}"  class="nav-item"><i class="bi bi-grid-fill"></i> Tableau de bord</a>
        <a href="{{ path('suivi_today') }}"       class="nav-item"><i class="bi bi-clipboard2-pulse-fill"></i> Check-in quotidien</a>
        <a href="{{ path('insight_weekly') }}"    class="nav-item"><i class="bi bi-graph-up-arrow"></i> Insights hebdo</a>
        <a href="{{ path('chat_index') }}"        class="nav-item"><i class="bi bi-robot"></i> Coach Eya IA</a>
        <div class="nav-section-label">Bien-être</div>
        <a href="{{ path('user_analyse') }}"      class="nav-item"><i class="bi bi-heart-pulse-fill"></i> Mon analyse</a>
        <a href="{{ path('objectif_index') }}"    class="nav-item"><i class="bi bi-trophy-fill"></i> Mes objectifs</a>
        <div class="nav-section-label">Communauté</div>
        <a href="{{ path('posts_list') }}"        class="nav-item"><i class="bi bi-newspaper"></i> Publications</a>
        <a href="{{ path('evenements_list') }}"   class="nav-item"><i class="bi bi-calendar-event-fill"></i> Événements</a>
        <a href="{{ path('evenements_mes_participations') }}" class="nav-item active"><i class="bi bi-calendar-check-fill"></i> Mes participations</a>
        <div class="nav-section-label">Mon compte</div>
        <a href="{{ path('user_profile') }}"      class="nav-item"><i class="bi bi-person-fill"></i> Mon profil</a>
        <a href="{{ path('user_profile_edit') }}" class="nav-item"><i class="bi bi-gear-fill"></i> Paramètres</a>
    </nav>
    <div class="sidebar-footer">
        <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;"><i class="bi bi-box-arrow-left"></i> Se déconnecter</a>
    </div>
</aside>
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- MAIN -->
<div class="main">
    <header class="topbar">
        <div class="topbar-left">
            <button class="menu-toggle" id="menuToggle"><i class="bi bi-list"></i></button>
            <div>
                <div class="topbar-title">Mes Participations</div>
                <div class="topbar-sub">Historique de vos événements</div>
            </div>
        </div>
        <div class="topbar-right">
            <a href="{{ path('evenements_list') }}" class="topbar-btn">
                <i class="bi bi-calendar-event-fill"></i><span>Événements</span>
            </a>
            <a href="{{ path('user_profile') }}" class="topbar-avatar-sm">
                {% if app.user and app.user.avatar %}
                    <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
                {% elseif app.user %}
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                {% else %}
                    <i class="bi bi-person-fill"></i>
                {% endif %}
            </a>
        </div>
    </header>

    <main>
        <div class="content">

            <!-- BREADCRUMB -->
            <div class="breadcrumb">
                <a href="{{ path('evenements_list') }}"><i class="bi bi-calendar-event-fill"></i> Événements</a>
                <i class="bi bi-chevron-right"></i>
                <span>Mes participations</span>
            </div>

            <!-- FLASH MESSAGES -->
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash {{ label }}">
                        <i class="bi bi-{{ label == 'success' ? 'check-circle-fill' : label == 'error' ? 'x-circle-fill' : 'exclamation-triangle-fill' }}"></i>
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            <!-- USER HERO -->
            {% if utilisateur %}
            <div class="user-hero">
                <div class="hero-avatar">
                    {{ utilisateur.prenom|first|upper }}{{ utilisateur.nom|first|upper }}
                </div>
                <div class="hero-info">
                    <h2>{{ utilisateur.prenom }} {{ utilisateur.nom }}</h2>
                    <p><i class="bi bi-envelope-fill"></i> {{ utilisateur.email }}</p>
                    {% if utilisateur.telephone %}
                        <p><i class="bi bi-telephone-fill"></i> {{ utilisateur.telephone }}</p>
                    {% endif %}
                </div>
                <div class="hero-stats">
                    <div class="hero-stat">
                        <div class="hero-stat-num">{{ participations|length }}</div>
                        <div class="hero-stat-label">Total</div>
                    </div>
                    <div class="hero-stat">
                        <div class="hero-stat-num">
                            {{ participations|filter(p => p.statut.value == 'INSCRIT')|length }}
                        </div>
                        <div class="hero-stat-label">Confirmées</div>
                    </div>
                    <div class="hero-stat">
                        <div class="hero-stat-num">
                            {{ participations|filter(p => p.statut.value == 'ANNULE')|length }}
                        </div>
                        <div class="hero-stat-label">Annulées</div>
                    </div>
                </div>
            </div>
            {% endif %}

            <!-- SECTION HEADER -->
            <div class="section-header">
                <h3><i class="bi bi-calendar-check-fill"></i> Historique des participations</h3>
                <a href="{{ path('evenements_list') }}" class="btn-primary">
                    <i class="bi bi-plus-circle"></i> Découvrir des événements
                </a>
            </div>

            <!-- EMPTY STATE -->
            {% if participations is empty %}
                <div class="empty-state">
                    <div class="empty-icon"><i class="bi bi-calendar-x"></i></div>
                    <h4>Aucune participation pour le moment</h4>
                    <p>Vous n'avez pas encore participé à nos événements. Découvrez nos prochains ateliers et séances !</p>
                    <a href="{{ path('evenements_list') }}" class="btn-primary">
                        <i class="bi bi-calendar-event"></i> Voir les événements disponibles
                    </a>
                </div>

            {% else %}
                <!-- TIMELINE -->
                <div class="timeline">
                    {% for participation in participations %}
                    <div class="timeline-item {{ participation.statut.value }}">
                        <div class="timeline-dot">
                            {% if participation.statut.value == 'INSCRIT' %}
                                <i class="bi bi-check-circle-fill"></i>
                            {% elseif participation.statut.value == 'ANNULE' %}
                                <i class="bi bi-x-circle-fill"></i>
                            {% else %}
                                <i class="bi bi-clock-fill"></i>
                            {% endif %}
                        </div>
                        <div class="part-card">
                            <div class="part-card-head">
                                <div>
                                    <div class="badges">
                                        <span class="badge-type">
                                            <i class="bi bi-calendar-event"></i>
                                            {{ participation.evenement.type.value|capitalize }}
                                        </span>
                                        <span class="badge-status {{ participation.statut.value }}">
                                            {{ participation.statut.value }}
                                        </span>
                                    </div>
                                    <h4>{{ participation.evenement.titre }}</h4>
                                </div>
                            </div>
                            <div class="part-card-body">
                                <div class="detail-row">
                                    <i class="bi bi-calendar3"></i>
                                    <span>{{ participation.evenement.dateDebut|date('d/m/Y à H:i') }}</span>
                                </div>
                                {% if participation.evenement.lienSession %}
                                <div class="detail-row">
                                    <i class="bi bi-link-45deg"></i>
                                    <a href="{{ participation.evenement.lienSession }}" target="_blank" style="color:var(--teal-dark);font-weight:600;">Rejoindre la session</a>
                                </div>
                                {% endif %}
                                <div class="detail-row">
                                    <i class="bi bi-clock-history"></i>
                                    <span>Inscrit le {{ participation.dateInscription|date('d/m/Y') }}</span>
                                </div>
                            </div>
                            <div class="part-card-foot">
                                <a href="{{ path('evenements_show', {id: participation.evenement.id}) }}" class="btn-outline">
                                    <i class="bi bi-eye"></i> Voir l'événement
                                </a>
                                {% if participation.statut.value == 'INSCRIT' and participation.evenement.dateDebut > date() %}
                                    <form method="post" action="{{ path('evenements_annuler', {id: participation.evenement.id}) }}" style="display:inline;">
                                        <button type="submit" class="btn-cancel" onclick="return confirm('Êtes-vous sûr de vouloir annuler votre participation ?')">
                                            <i class="bi bi-x-lg"></i> Annuler
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            {% endif %}

        </div>
    </main>
</div>

<script>
    const menuToggle = document.getElementById('menuToggle');
    const sidebar    = document.getElementById('sidebar');
    const overlay    = document.getElementById('sidebarOverlay');
    menuToggle?.addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('open'); });
    overlay?.addEventListener('click',   () => { sidebar.classList.remove('open'); overlay.classList.remove('open'); });
</script>
</body>
</html>