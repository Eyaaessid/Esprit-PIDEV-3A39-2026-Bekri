<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Coach Eya — Bekri</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --dark:       #1a2332;
            --gray:       #64748b;
            --light:      #f8fafc;
            --white:      #ffffff;
            --sidebar-w:  260px;
            --shadow-sm:  0 2px 12px rgba(0,0,0,0.06);
            --shadow:     0 8px 30px rgba(0,0,0,0.10);
            --radius:     16px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { height: 100%; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--light);
            color: var(--dark);
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* ── SIDEBAR ─────────────────────────────────────────────── */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--dark);
            height: 100vh;
            position: fixed;
            top: 0; left: 0;
            display: flex;
            flex-direction: column;
            z-index: 100;
            transition: transform 0.3s ease;
        }

        .sidebar-logo {
            padding: 28px 24px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }

        .sidebar-logo img { height: 36px; width: auto; }

        .sidebar-logo-text {
            font-size: 20px;
            font-weight: 800;
            background: linear-gradient(135deg, var(--teal), #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .sidebar-user {
            padding: 20px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }

        .sidebar-avatar {
            width: 42px; height: 42px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--teal), var(--purple));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 16px;
            flex-shrink: 0;
        }

        .sidebar-user-name { font-size: 14px; font-weight: 600; color: white; }
        .sidebar-user-role { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 2px; }

        .sidebar-nav { flex: 1; padding: 16px 0; overflow-y: auto; }

        .nav-section-label {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: rgba(255,255,255,0.25);
            padding: 12px 24px 6px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 24px;
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s;
            border-left: 3px solid transparent;
        }

        .nav-item:hover { color: white; background: rgba(255,255,255,0.05); }

        .nav-item.active {
            color: var(--teal);
            background: rgba(32,178,170,0.1);
            border-left-color: var(--teal);
        }

        .nav-item i { width: 20px; text-align: center; font-size: 16px; }

        .sidebar-footer {
            padding: 16px 0;
            border-top: 1px solid rgba(255,255,255,0.07);
        }

        /* ── MAIN LAYOUT ─────────────────────────────────────────── */
        .main {
            margin-left: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
        }

        /* ── TOPBAR ──────────────────────────────────────────────── */
        .topbar {
            background: white;
            padding: 0 32px;
            height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: var(--shadow-sm);
            flex-shrink: 0;
            z-index: 50;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .eya-status {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .eya-avatar {
            width: 44px; height: 44px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--teal), var(--purple));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: 800;
            color: white;
            position: relative;
            flex-shrink: 0;
        }

        .eya-online-dot {
            position: absolute;
            bottom: 1px; right: 1px;
            width: 11px; height: 11px;
            background: #4ade80;
            border-radius: 50%;
            border: 2px solid white;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%,100% { opacity:1; transform:scale(1); }
            50%      { opacity:0.7; transform:scale(1.2); }
        }

        .eya-name { font-size: 16px; font-weight: 700; color: var(--dark); }
        .eya-sub  { font-size: 12px; color: #4ade80; font-weight: 500; }

        .topbar-right { display: flex; align-items: center; gap: 10px; }

        .topbar-btn {
            padding: 8px 16px;
            border-radius: 10px;
            background: var(--light);
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 6px;
            color: var(--gray);
            font-size: 13px;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.2s;
            font-family: 'Inter', sans-serif;
        }

        .topbar-btn:hover { background: var(--teal-light); color: var(--teal-dark); }

        .topbar-btn-danger:hover { background: #fee2e2; color: #dc2626; }

        .topbar-avatar {
            width: 40px; height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--teal), var(--purple));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 14px;
            text-decoration: none;
        }

        .menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 22px;
            color: var(--dark);
            cursor: pointer;
        }

        /* ── CHAT AREA ───────────────────────────────────────────── */
        .chat-area {
            flex: 1;
            overflow-y: auto;
            padding: 28px 32px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            background: var(--light);
        }

        .chat-area::-webkit-scrollbar { width: 6px; }
        .chat-area::-webkit-scrollbar-track { background: transparent; }
        .chat-area::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 3px; }
        .chat-area::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }

        /* ── MESSAGES ─────────────────────────────────────��──────── */
        .msg-row {
            display: flex;
            align-items: flex-end;
            gap: 10px;
            animation: msgIn 0.3s ease-out;
        }

        @keyframes msgIn {
            from { opacity:0; transform: translateY(10px); }
            to   { opacity:1; transform: translateY(0); }
        }

        .msg-row.user { flex-direction: row-reverse; }

        .msg-avatar {
            width: 36px; height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--teal), var(--purple));
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 13px;
            color: white;
            flex-shrink: 0;
        }

        .msg-avatar.user-av {
            background: linear-gradient(135deg, var(--purple), #764ba2);
        }

        .msg-bubble {
            max-width: 65%;
            padding: 14px 18px;
            border-radius: 18px;
            font-size: 14px;
            line-height: 1.6;
            position: relative;
        }

        .msg-bubble.bot {
            background: white;
            color: var(--dark);
            border-bottom-left-radius: 4px;
            box-shadow: var(--shadow-sm);
            border: 1px solid #f1f5f9;
        }

        .msg-bubble.user {
            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
            color: white;
            border-bottom-right-radius: 4px;
            box-shadow: 0 4px 15px rgba(32,178,170,0.25);
        }

        .msg-time {
            font-size: 11px;
            color: #94a3b8;
            margin-top: 4px;
            padding: 0 4px;
        }

        .msg-row.user .msg-time { text-align: right; }

        .msg-col {
            display: flex;
            flex-direction: column;
        }

        .msg-row.user .msg-col { align-items: flex-end; }

        /* ── TYPING INDICATOR ────────────────────────────────────── */
        .typing-row {
            display: flex;
            align-items: flex-end;
            gap: 10px;
        }

        .typing-bubble {
            background: white;
            border: 1px solid #f1f5f9;
            box-shadow: var(--shadow-sm);
            padding: 14px 18px;
            border-radius: 18px;
            border-bottom-left-radius: 4px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .typing-dot {
            width: 8px; height: 8px;
            background: var(--teal);
            border-radius: 50%;
            animation: typingBounce 1.2s infinite;
        }

        .typing-dot:nth-child(2) { animation-delay: 0.2s; }
        .typing-dot:nth-child(3) { animation-delay: 0.4s; }

        @keyframes typingBounce {
            0%,60%,100% { transform: translateY(0); }
            30%          { transform: translateY(-6px); }
        }

        /* ── WELCOME MESSAGE ─────────────────────────────────────── */
        .welcome-card {
            background: linear-gradient(135deg, var(--teal), var(--purple));
            border-radius: var(--radius);
            padding: 24px 28px;
            color: white;
            position: relative;
            overflow: hidden;
            margin-bottom: 8px;
        }

        .welcome-card::before {
            content: '';
            position: absolute;
            top: -30px; right: -30px;
            width: 120px; height: 120px;
            background: rgba(255,255,255,0.08);
            border-radius: 50%;
        }

        .welcome-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 6px; }
        .welcome-card p  { font-size: 14px; color: rgba(255,255,255,0.85); line-height: 1.6; }

        .quick-prompts {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 14px;
        }

        .quick-prompt {
            padding: 7px 14px;
            background: rgba(255,255,255,0.18);
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 50px;
            font-size: 13px;
            color: white;
            cursor: pointer;
            transition: all 0.2s;
            backdrop-filter: blur(8px);
        }

        .quick-prompt:hover { background: rgba(255,255,255,0.28); transform: translateY(-1px); }

        /* ── INPUT AREA ──────────────────────────────────────────── */
        .input-area {
            background: white;
            padding: 16px 32px 20px;
            border-top: 1px solid #f1f5f9;
            flex-shrink: 0;
        }

        .input-wrapper {
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--light);
            border: 2px solid #e2e8f0;
            border-radius: 50px;
            padding: 8px 8px 8px 20px;
            transition: all 0.25s;
        }

        .input-wrapper:focus-within {
            border-color: var(--teal);
            background: white;
            box-shadow: 0 0 0 4px rgba(32,178,170,0.1);
        }

        .chat-input {
            flex: 1;
            border: none;
            background: transparent;
            outline: none;
            font-size: 15px;
            color: var(--dark);
            font-family: 'Inter', sans-serif;
        }

        .chat-input::placeholder { color: #94a3b8; }

        .send-btn {
            width: 42px; height: 42px;
            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
            border: none;
            border-radius: 50%;
            color: white;
            font-size: 16px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            flex-shrink: 0;
            box-shadow: 0 3px 10px rgba(32,178,170,0.3);
        }

        .send-btn:hover { transform: scale(1.08); box-shadow: 0 5px 15px rgba(32,178,170,0.4); }
        .send-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

        .input-hint {
            text-align: center;
            font-size: 11px;
            color: #94a3b8;
            margin-top: 8px;
        }

        /* ── SIDEBAR OVERLAY ─────────────────────────────────────── */
        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            z-index: 99;
        }

        /* ── RESPONSIVE ──────────────────────────────────────────── */
        @media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main { margin-left: 0; }
            .menu-toggle { display: block; }
            .topbar { padding: 0 16px; }
            .chat-area { padding: 16px; }
            .input-area { padding: 12px 16px 16px; }
            .msg-bubble { max-width: 85%; }
        }
    </style>
</head>
<body>

    <!-- ═══════════════════════════════════════════════════════
         SIDEBAR
         ═══════════════════════════════════════════════════════ -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'">
            <span class="sidebar-logo-text">Bekri</span>
        </div>

        <div class="sidebar-user">
            <div class="sidebar-avatar">
                {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
            </div>
            <div>
                <div class="sidebar-user-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
                <div class="sidebar-user-role">Membre Bekri</div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-label">Principal</div>
            <a href="{{ path('user_dashboard') }}" class="nav-item"><i class="bi bi-grid-fill"></i> Tableau de bord</a>
            <a href="{{ path('suivi_today') }}"    class="nav-item"><i class="bi bi-clipboard2-pulse-fill"></i> Check-in quotidien</a>
            <a href="{{ path('insight_weekly') }}" class="nav-item"><i class="bi bi-graph-up-arrow"></i> Insights hebdo</a>
            <a href="{{ path('chat_index') }}"     class="nav-item active"><i class="bi bi-robot"></i> Coach Eya IA</a>

            <div class="nav-section-label">Bien-être</div>
            <a href="{{ path('objectif_index') }}" class="nav-item"><i class="bi bi-trophy-fill"></i> Mes objectifs</a>
             <a href="{{ path('plan_index') }}" class="nav-item"><i class="bi bi-trophy-fill"></i> Plan hebdomadaire</a>
            <a href="#"                            class="nav-item"><i class="bi bi-brain"></i> Test de santé mentale</a>

            <div class="nav-section-label">Communauté</div>
            <a href="{{ path('posts_list') }}"      class="nav-item"><i class="bi bi-newspaper"></i> Publications</a>
            <a href="{{ path('evenements_home') }}"  class="nav-item"><i class="bi bi-calendar-event-fill"></i> Événements</a>

            <div class="nav-section-label">Mon compte</div>
            <a href="{{ path('user_profile') }}"    class="nav-item"><i class="bi bi-person-fill"></i> Mon profil</a>
            <a href="{{ path('user_profile_edit') }}" class="nav-item"><i class="bi bi-gear-fill"></i> Paramètres</a>
        </nav>

        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;">
                <i class="bi bi-box-arrow-left"></i> Se déconnecter
            </a>
        </div>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- ═══════════════════════════════════════════════════════
         MAIN
         ═══════════════════════════════════════════════════════ -->
    <div class="main">

        <!-- TOPBAR -->
        <header class="topbar">
            <div class="topbar-left">
                <button class="menu-toggle" id="menuToggle"><i class="bi bi-list"></i></button>

                <div class="eya-status">
                    <div class="eya-avatar">
                        <i class="bi bi-robot"></i>
                        <div class="eya-online-dot"></div>
                    </div>
                    <div>
                        <div class="eya-name">Coach Eya</div>
                        <div class="eya-sub">● En ligne maintenant</div>
                    </div>
                </div>
            </div>

            <div class="topbar-right">
                <button class="topbar-btn topbar-btn-danger" id="clearBtn" title="Effacer la conversation">
                    <i class="bi bi-trash"></i>
                    <span>Effacer</span>
                </button>
                <a href="{{ path('user_dashboard') }}" class="topbar-btn">
                    <i class="bi bi-arrow-left"></i>
                    <span>Tableau de bord</span>
                </a>
                <a href="{{ path('user_profile') }}" class="topbar-avatar">
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                </a>
            </div>
        </header>

        <!-- CHAT AREA -->
        <div class="chat-area" id="chatMain">

            <!-- Welcome card -->
            <div class="welcome-card">
                <h3><i class="bi bi-robot" style="margin-right:8px;"></i>Bonjour {{ app.user.prenom }} ! Je suis Eya 👋</h3>
                <p>Votre coach bien-être personnel, disponible 24h/24. Je suis là pour vous accompagner sur votre santé mentale et physique — sans poser de diagnostic médical.</p>
                <div class="quick-prompts">
                    <span class="quick-prompt" onclick="usePrompt(this)">😊 Comment gérer le stress ?</span>
                    <span class="quick-prompt" onclick="usePrompt(this)">😴 Améliorer mon sommeil</span>
                    <span class="quick-prompt" onclick="usePrompt(this)">🏃 Conseils activité physique</span>
                    <span class="quick-prompt" onclick="usePrompt(this)">🍎 Nutrition & bien-être</span>
                    <span class="quick-prompt" onclick="usePrompt(this)">🧘 Techniques de relaxation</span>
                </div>
            </div>

            <!-- Messages will be injected here -->
            <div id="messages"></div>

        </div>

        <!-- INPUT AREA -->
        <div class="input-area">
            <div class="input-wrapper">
                <input
                    id="messageInput"
                    type="text"
                    class="chat-input"
                    placeholder="Posez votre question à Eya..."
                    autocomplete="off"
                >
                <button class="send-btn" id="sendBtn">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
            <div class="input-hint">
                <i class="bi bi-shield-check" style="margin-right:4px;color:var(--teal);"></i>
                Eya fournit des conseils préventifs — pas de diagnostic médical
            </div>
        </div>

    </div>

    <script>
        const messagesContainer = document.getElementById('messages');
        const chatMain          = document.getElementById('chatMain');
        const input             = document.getElementById('messageInput');
        const sendBtn           = document.getElementById('sendBtn');

        // ── Sidebar toggle ───────────────────────────────────────
        const menuToggle = document.getElementById('menuToggle');
        const sidebar    = document.getElementById('sidebar');
        const overlay    = document.getElementById('sidebarOverlay');
        menuToggle.addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('open'); });
        overlay.addEventListener('click',   () => { sidebar.classList.remove('open'); overlay.classList.remove('open'); });

        // ── Clear chat ───────────────────────────────────────────
        document.getElementById('clearBtn').addEventListener('click', () => {
            if (confirm('Effacer toute la conversation ?')) {
                messagesContainer.innerHTML = '';
            }
        });

        // ── Quick prompts ─────────────────────────────────────────
        function usePrompt(el) {
            input.value = el.textContent.replace(/^[^\s]+\s/, '');
            input.focus();
        }

        // ── Get current time ──────────────────────────────────────
        function getTime() {
            return new Date().toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
        }

        // ── Add message ───────────────────────────────────────────
        function addMessage(text, isBot = false) {
            const row = document.createElement('div');
            row.className = 'msg-row' + (isBot ? '' : ' user');

            const avatar = document.createElement('div');
            avatar.className = 'msg-avatar' + (isBot ? '' : ' user-av');
            avatar.innerHTML = isBot ? '<i class="bi bi-robot"></i>' : '{{ app.user.prenom|first|upper }}';

            const col = document.createElement('div');
            col.className = 'msg-col';

            const bubble = document.createElement('div');
            bubble.className = 'msg-bubble ' + (isBot ? 'bot' : 'user');
            bubble.innerHTML = text.replace(/\n/g, '<br>');

            const time = document.createElement('div');
            time.className = 'msg-time';
            time.textContent = getTime();

            col.appendChild(bubble);
            col.appendChild(time);

            if (isBot) {
                row.appendChild(avatar);
                row.appendChild(col);
            } else {
                row.appendChild(col);
                row.appendChild(avatar);
            }

            messagesContainer.appendChild(row);
            chatMain.scrollTop = chatMain.scrollHeight;
        }

        // ── Typing indicator ──────────────────────────────────────
        function showTyping() {
            const row = document.createElement('div');
            row.className = 'typing-row';
            row.id = 'typingIndicator';

            const avatar = document.createElement('div');
            avatar.className = 'msg-avatar';
            avatar.innerHTML = '<i class="bi bi-robot"></i>';

            const bubble = document.createElement('div');
            bubble.className = 'typing-bubble';
            bubble.innerHTML = '<div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>';

            row.appendChild(avatar);
            row.appendChild(bubble);
            messagesContainer.appendChild(row);
            chatMain.scrollTop = chatMain.scrollHeight;
        }

        function hideTyping() {
            const t = document.getElementById('typingIndicator');
            if (t) t.remove();
        }

        // ── Send message ──────────────────────────────────────────
        async function sendMessage() {
            const message = input.value.trim();
            if (!message) return;

            addMessage(message, false);
            input.value = '';
            input.disabled = true;
            sendBtn.disabled = true;
            sendBtn.innerHTML = '<i class="bi bi-hourglass-split"></i>';

            showTyping();

            try {
                const formData = new FormData();
                formData.append('message', message);

                const response = await fetch('{{ path('chat_send') }}', {
                    method: 'POST',
                    body: formData,
                    credentials: 'same-origin',
                });

                hideTyping();

                if (response.ok) {
                    const botReply = await response.text();
                    addMessage(botReply, true);
                } else {
                    addMessage('❌ Erreur ' + response.status + '. Veuillez réessayer.', true);
                }
            } catch (err) {
                hideTyping();
                addMessage('❌ Erreur réseau. Vérifiez votre connexion.', true);
            } finally {
                input.disabled = false;
                sendBtn.disabled = false;
                sendBtn.innerHTML = '<i class="bi bi-send-fill"></i>';
                input.focus();
            }
        }

        sendBtn.addEventListener('click', sendMessage);
        input.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') { e.preventDefault(); sendMessage(); }
        });
    </script>
</body>
</html>