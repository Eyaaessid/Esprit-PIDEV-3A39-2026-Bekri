{% extends 'base.html.twig' %}

{% block title %}Enable Two-Factor Authentication - Bekri Wellbeing{% endblock %}

{% block body_class %}profile-page{% endblock %}

{% block main %}
<div class="container" style="margin-top: 100px; margin-bottom: 80px;">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-4">
                    <h4 class="mb-0">
                        <i class="bi bi-shield-lock me-2"></i>Enable Two-Factor Authentication
                    </h4>
                </div>
                <div class="card-body p-4">
                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger alert-dismissible fade show">
                            <i class="bi bi-exclamation-circle me-2"></i>{{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}

                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success alert-dismissible fade show">
                            <i class="bi bi-check-circle me-2"></i>{{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>What is Two-Factor Authentication?</strong>
                        <p class="mb-0 mt-2">Two-factor authentication adds an extra layer of security to your account. After enabling it, you'll need both your password and a code from your authenticator app to log in.</p>
                    </div>

                    <hr class="my-4">

                    <h5 class="mb-3">Step 1: Install an Authenticator App</h5>
                    <p class="text-muted mb-4">Download one of these apps on your smartphone:</p>
                    <div class="row mb-4">
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center p-3 border rounded">
                                <i class="bi bi-google me-3" style="font-size: 2rem; color: #4285F4;"></i>
                                <div>
                                    <strong>Google Authenticator</strong>
                                    <br>
                                    <small class="text-muted">iOS & Android</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center p-3 border rounded">
                                <i class="bi bi-shield-check me-3" style="font-size: 2rem; color: #00A9E0;"></i>
                                <div>
                                    <strong>Authy</strong>
                                    <br>
                                    <small class="text-muted">iOS & Android</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <h5 class="mb-3">Step 2: Scan the QR Code</h5>
                    <p class="text-muted mb-3">Open your authenticator app and scan this QR code:</p>
                    
                    <div class="text-center mb-4">
                        <div class="d-inline-block p-3 bg-light border rounded">
                            <img src="{{ qrCodeDataUri }}" alt="QR Code" style="max-width: 250px; height: auto;">
                        </div>
                    </div>

                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Can't scan the QR code?</strong>
                        <p class="mb-0 mt-2">Enter this code manually in your app:</p>
                        <code class="d-block mt-2 p-2 bg-white border rounded" style="font-size: 1.1rem; letter-spacing: 2px;">{{ secret }}</code>
                    </div>

                    <hr class="my-4">

                    <h5 class="mb-3">Step 3: Verify Setup</h5>
                    <p class="text-muted mb-3">Enter the 6-digit code from your authenticator app and your password to complete setup:</p>

                    <form method="post" action="{{ path('app_2fa_verify') }}">
                        <div class="mb-3">
                            <label for="code" class="form-label">6-Digit Code</label>
                            <input 
                                type="text" 
                                class="form-control form-control-lg text-center" 
                                id="code" 
                                name="code" 
                                placeholder="000000"
                                maxlength="6"
                                pattern="[0-9]{6}"
                                required
                                autocomplete="off"
                                style="font-size: 1.5rem; letter-spacing: 0.5rem; font-weight: 600;"
                            >
                            <small class="text-muted">Enter the code shown in your authenticator app</small>
                        </div>

                        <div class="mb-4 position-relative">
                            <label for="password" class="form-label">Your Password</label>
                            <input 
                                type="password" 
                                class="form-control" 
                                id="password" 
                                name="password" 
                                placeholder="Enter your password"
                                required
                                autocomplete="current-password"
                            >
                            <i class="bi bi-eye toggle-password position-absolute" style="right: 15px; top: 38px; cursor: pointer; color: #6c757d;"></i>
                            <small class="text-muted d-block mt-1">We need to verify your identity to enable 2FA</small>
                        </div>

                        <input type="hidden" name="_token" value="{{ csrf_token('2fa_verify') }}">

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-shield-check me-2"></i>Enable Two-Factor Authentication
                            </button>
                            <a href="{{ path(app.user.role.value == 'admin' ? 'admin_profile' : (app.user.role.value == 'coach' ? 'coach_profile' : 'user_profile')) }}" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const codeInput = document.getElementById('code');
    if (codeInput) {
        codeInput.addEventListener('input', function(e) {
            // Only allow numbers
            e.target.value = e.target.value.replace(/[^0-9]/g, '');
        });

        codeInput.addEventListener('paste', function(e) {
            e.preventDefault();
            const pasted = (e.clipboardData || window.clipboardData).getData('text');
            const numbers = pasted.replace(/[^0-9]/g, '').substring(0, 6);
            e.target.value = numbers;
        });

        // Focus on page load
        codeInput.focus();
    }

    // Password visibility toggle
    document.querySelectorAll('.toggle-password').forEach(function(button) {
        button.addEventListener('click', function() {
            const input = document.getElementById('password');
            const icon = this;
            
            if (input && (input.type === 'password' || input.type === 'text')) {
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.remove('bi-eye');
                    icon.classList.add('bi-eye-slash');
                } else {
                    input.type = 'password';
                    icon.classList.remove('bi-eye-slash');
                    icon.classList.add('bi-eye');
                }
            }
        });
    });
});
</script>
{% endblock %}
