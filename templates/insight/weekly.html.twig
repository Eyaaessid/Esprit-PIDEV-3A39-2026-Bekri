<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Insights hebdomadaires — Bekri</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        :root {
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --dark:       #1a2332;
            --gray:       #64748b;
            --light:      #f8fafc;
            --white:      #ffffff;
            --sidebar-w:  260px;
            --shadow-sm:  0 2px 12px rgba(0,0,0,0.06);
            --shadow:     0 8px 30px rgba(0,0,0,0.10);
            --radius:     16px;
        }

        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior:smooth; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--light);
            color: var(--dark);
            display: flex;
            min-height: 100vh;
        }

        /* ── SIDEBAR ─────────────────────────────────────────────── */
        .sidebar { width:var(--sidebar-w); background:var(--dark); min-height:100vh; max-height:100vh; position:fixed; top:0; left:0; display:flex; flex-direction:column; z-index:100; transition:transform 0.3s ease; overflow:hidden; }
        .sidebar-logo { padding:28px 24px 20px; display:flex; align-items:center; gap:10px; border-bottom:1px solid rgba(255,255,255,0.07); flex-shrink:0; }
        .sidebar-logo img { height:36px; width:auto; }
        .sidebar-logo-text { font-size:20px; font-weight:800; background:linear-gradient(135deg, var(--teal), #a78bfa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .sidebar-user { padding:20px 24px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-avatar { width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg, var(--teal), var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:16px; flex-shrink:0; }
        .sidebar-user-name { font-size:14px; font-weight:600; color:white; }
        .sidebar-user-role { font-size:11px; color:rgba(255,255,255,0.4); margin-top:2px; }
        .sidebar-nav { flex:1; padding:16px 0; overflow-y:auto; min-height:0; }
        .sidebar-nav::-webkit-scrollbar { width:5px; }
        .sidebar-nav::-webkit-scrollbar-track { background:transparent; }
        .sidebar-nav::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.3); border-radius:10px; }
        .nav-section-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:rgba(255,255,255,0.25); padding:12px 24px 6px; }
        .nav-item { display:flex; align-items:center; gap:12px; padding:11px 24px; color:rgba(255,255,255,0.6); text-decoration:none; font-size:14px; font-weight:500; transition:all 0.2s; border-left:3px solid transparent; }
        .nav-item:hover { color:white; background:rgba(255,255,255,0.05); }
        .nav-item.active { color:var(--teal); background:rgba(32,178,170,0.1); border-left-color:var(--teal); }
        .nav-item i { width:20px; text-align:center; font-size:16px; }
        .sidebar-footer { padding:16px 0; border-top:1px solid rgba(255,255,255,0.07); flex-shrink:0; margin-top:auto; }

        /* ── MAIN ────────────────────────────────────────────────── */
        .main { margin-left:var(--sidebar-w); flex:1; display:flex; flex-direction:column; min-height:100vh; }

        /* ── TOPBAR ──────────────────────────────────────────────── */
        .topbar { background:white; padding:0 32px; height:68px; display:flex; align-items:center; justify-content:space-between; box-shadow:var(--shadow-sm); position:sticky; top:0; z-index:50; }
        .topbar-left { display:flex; align-items:center; gap:16px; }
        .topbar-title { font-size:18px; font-weight:700; color:var(--dark); }
        .topbar-sub   { font-size:13px; color:var(--gray); margin-top:2px; }
        .topbar-right { display:flex; align-items:center; gap:10px; }
        .topbar-btn { padding:9px 18px; border-radius:10px; background:var(--light); border:none; cursor:pointer; display:flex; align-items:center; gap:7px; color:var(--gray); font-size:13px; font-weight:600; text-decoration:none; transition:all 0.2s; font-family:'Inter',sans-serif; }
        .topbar-btn:hover { background:var(--teal-light); color:var(--teal-dark); }
        .topbar-btn-teal { background:linear-gradient(135deg, var(--teal), var(--teal-dark)); color:white; box-shadow:0 3px 10px rgba(32,178,170,0.25); }
        .topbar-btn-teal:hover { background:linear-gradient(135deg, var(--teal), var(--teal-dark)); color:white; transform:translateY(-1px); box-shadow:0 5px 15px rgba(32,178,170,0.35); }
        .topbar-avatar { width:40px; height:40px; border-radius:50%; background:linear-gradient(135deg, var(--teal), var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:14px; text-decoration:none; }
        .menu-toggle { display:none; background:none; border:none; font-size:22px; color:var(--dark); cursor:pointer; }

        /* ── CONTENT ─────────────────────────────────────────────── */
        .content { padding:32px; flex:1; }

        /* ── PAGE HEADER BANNER ──────────────────────────────────── */
        .page-banner {
            background: linear-gradient(135deg, var(--teal), var(--teal-dark), var(--purple));
            border-radius: var(--radius);
            padding: 28px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
            position: relative;
            overflow: hidden;
        }

        .page-banner::before { content:''; position:absolute; top:-40px; right:-40px; width:160px; height:160px; background:rgba(255,255,255,0.06); border-radius:50%; }
        .page-banner-text h1 { font-size:22px; font-weight:800; color:white; margin-bottom:4px; }
        .page-banner-text p  { font-size:14px; color:rgba(255,255,255,0.8); }
        .page-banner-right { display:flex; align-items:center; gap:10px; }

        .btn-pdf {
            display:inline-flex; align-items:center; gap:8px;
            padding:11px 20px; background:white; color:var(--teal-dark);
            border-radius:12px; font-size:14px; font-weight:700;
            text-decoration:none; transition:all 0.2s;
            box-shadow:0 4px 15px rgba(0,0,0,0.1);
        }

        .btn-pdf:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(0,0,0,0.15); }

        /* ── EMPTY STATE ─────────────────────────────────────────── */
        .empty-state { background:white; border-radius:var(--radius); padding:60px 40px; text-align:center; box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; }
        .empty-icon { width:80px; height:80px; background:#fef3c7; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-size:32px; }
        .empty-state h3 { font-size:20px; font-weight:700; color:var(--dark); margin-bottom:8px; }
        .empty-state p  { font-size:14px; color:var(--gray); margin-bottom:24px; }

        /* ── STAT CARDS ──────────────────────────────────────────── */
        .stats-grid { display:grid; grid-template-columns:repeat(4, 1fr); gap:16px; margin-bottom:28px; }

        .stat-card {
            background:white; border-radius:var(--radius);
            padding:22px; box-shadow:var(--shadow-sm);
            border:1px solid #f1f5f9;
            display:flex; flex-direction:column;
            position:relative; overflow:hidden;
            transition:all 0.3s;
        }

        .stat-card:hover { transform:translateY(-3px); box-shadow:var(--shadow); }

        .stat-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; }
        .stat-card.teal::before  { background:linear-gradient(90deg, var(--teal), var(--teal-dark)); }
        .stat-card.green::before { background:linear-gradient(90deg, #22c55e, #16a34a); }
        .stat-card.red::before   { background:linear-gradient(90deg, #ef4444, #dc2626); }
        .stat-card.purple::before{ background:linear-gradient(90deg, var(--purple), #764ba2); }

        .stat-label { font-size:12px; font-weight:600; color:var(--gray); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:8px; }
        .stat-value { font-size:32px; font-weight:800; line-height:1; margin-bottom:4px; }
        .stat-value.teal  { color:var(--teal-dark); }
        .stat-value.green { color:#16a34a; }
        .stat-value.red   { color:#dc2626; }
        .stat-value.purple{ color:var(--purple); }
        .stat-sub { font-size:12px; color:#94a3b8; }

        /* ── RECOMMENDATIONS ─────────────────────────────────────── */
        .reco-section {
            background: linear-gradient(135deg, var(--teal-light), #ede9fe);
            border-radius: var(--radius);
            padding: 28px;
            border: 1px solid rgba(32,178,170,0.2);
            margin-bottom: 28px;
        }

        .reco-section-title {
            font-size:18px; font-weight:800; color:var(--dark);
            display:flex; align-items:center; gap:10px; margin-bottom:20px;
        }

        .reco-grid { display:grid; grid-template-columns:repeat(3, 1fr); gap:16px; }

        .reco-card {
            background:white; border-radius:14px; padding:20px;
            box-shadow:var(--shadow-sm); border:1px solid #f1f5f9;
            transition:all 0.3s;
        }

        .reco-card:hover { transform:translateY(-3px); box-shadow:var(--shadow); }

        .reco-icon {
            width:44px; height:44px; border-radius:12px;
            background:var(--teal-light); color:var(--teal-dark);
            display:flex; align-items:center; justify-content:center;
            font-size:18px; margin-bottom:12px;
        }

        .reco-title { font-size:14px; font-weight:700; color:var(--dark); margin-bottom:6px; }
        .reco-desc  { font-size:13px; color:var(--gray); line-height:1.6; margin-bottom:12px; }
        .reco-link  { font-size:13px; font-weight:600; color:var(--teal-dark); text-decoration:none; display:flex; align-items:center; gap:5px; }
        .reco-link:hover { color:var(--teal); }

        /* ── CHART CARDS ─────────────────────────────────────────── */
        .charts-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:28px; }
        .chart-card-full { grid-column:1/-1; }

        .chart-card {
            background:white; border-radius:var(--radius);
            padding:24px; box-shadow:var(--shadow-sm); border:1px solid #f1f5f9;
        }

        .chart-card h2 { font-size:16px; font-weight:700; color:var(--dark); margin-bottom:4px; }
        .chart-card p  { font-size:13px; color:var(--gray); margin-bottom:20px; }

        /* ── TRENDS & HIGHLIGHTS ─────────────────────────────────── */
        .bottom-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:28px; }

        .trends-card, .highlights-card {
            background:white; border-radius:var(--radius);
            padding:24px; box-shadow:var(--shadow-sm); border:1px solid #f1f5f9;
        }

        .card-title { font-size:16px; font-weight:700; color:var(--dark); margin-bottom:16px; display:flex; align-items:center; gap:8px; }
        .card-title i { color:var(--teal); }

        .trend-row {
            display:flex; align-items:center; justify-content:space-between;
            padding:12px 16px; background:var(--light); border-radius:10px;
            margin-bottom:8px; border:1px solid #f1f5f9;
        }

        .trend-label { font-size:14px; font-weight:600; color:var(--dark); text-transform:capitalize; }

        .trend-badge {
            padding:4px 12px; border-radius:50px;
            font-size:12px; font-weight:700;
        }

        .trend-up   { background:#d1fae5; color:#065f46; }
        .trend-down { background:#fee2e2; color:#991b1b; }

        .highlight-box {
            padding:16px; border-radius:12px; margin-bottom:12px;
        }

        .highlight-box.green { background:#f0fdf4; border:1px solid #bbf7d0; }
        .highlight-box.red   { background:#fff1f2; border:1px solid #fecdd3; }
        .highlight-box h3 { font-size:14px; font-weight:700; margin-bottom:6px; }
        .highlight-box.green h3 { color:#15803d; }
        .highlight-box.red   h3 { color:#be123c; }
        .highlight-box p { font-size:13px; color:var(--gray); }

        /* ── ENCOURAGEMENT BANNER ────────────────────────────────── */
        .encouragement {
            background:linear-gradient(135deg, var(--teal), var(--teal-dark));
            border-radius:var(--radius); padding:32px;
            text-align:center; position:relative; overflow:hidden;
        }

        .encouragement::before { content:''; position:absolute; top:-40px; right:-40px; width:160px; height:160px; background:rgba(255,255,255,0.07); border-radius:50%; }
        .encouragement h2 { font-size:22px; font-weight:800; color:white; margin-bottom:10px; }
        .encouragement p  { font-size:15px; color:rgba(255,255,255,0.85); margin-bottom:24px; line-height:1.6; }

        .encouragement-btns { display:flex; align-items:center; justify-content:center; gap:12px; flex-wrap:wrap; }

        .btn-white {
            display:inline-flex; align-items:center; gap:8px;
            padding:13px 24px; background:white; color:var(--teal-dark);
            border-radius:12px; font-size:14px; font-weight:700;
            text-decoration:none; transition:all 0.25s;
            box-shadow:0 4px 15px rgba(0,0,0,0.1);
        }

        .btn-white:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(0,0,0,0.15); }

        .btn-outline-white {
            display:inline-flex; align-items:center; gap:8px;
            padding:13px 24px; background:transparent; color:white;
            border:2px solid rgba(255,255,255,0.6);
            border-radius:12px; font-size:14px; font-weight:700;
            text-decoration:none; transition:all 0.25s;
        }

        .btn-outline-white:hover { background:rgba(255,255,255,0.15); border-color:white; }

        /* ── CHAT FAB ────────────────────────────────────────────── */
        .chat-fab {
            position:fixed; bottom:28px; right:28px; z-index:200;
            width:58px; height:58px;
            background:linear-gradient(135deg, var(--teal), var(--teal-dark));
            color:white; border-radius:50%; border:none; cursor:pointer;
            display:flex; align-items:center; justify-content:center;
            font-size:22px; box-shadow:0 6px 25px rgba(32,178,170,0.4);
            transition:all 0.3s;
        }

        .chat-fab:hover { transform:scale(1.1); box-shadow:0 8px 30px rgba(32,178,170,0.5); }

        /* ── ALERTS ──────────────────────────────────────────────── */
        .alert { padding:14px 18px; border-radius:12px; font-size:14px; display:flex; align-items:flex-start; gap:10px; margin-bottom:20px; }
        .alert-warning { background:#fffbeb; color:#92400e; border-left:4px solid #f59e0b; }

        .btn { display:inline-flex; align-items:center; gap:8px; padding:12px 22px; border-radius:12px; font-size:14px; font-weight:700; text-decoration:none; transition:all 0.25s; border:none; cursor:pointer; font-family:'Inter',sans-serif; }
        .btn-teal { background:linear-gradient(135deg, var(--teal), var(--teal-dark)); color:white; box-shadow:0 3px 10px rgba(32,178,170,0.25); }
        .btn-teal:hover { transform:translateY(-1px); }

        /* ── SIDEBAR OVERLAY ─────────────────────────────────────── */
        .sidebar-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:99; }

        /* ── RESPONSIVE ────────────────────────────────────────���─── */
        @media (max-width:1200px) { .stats-grid { grid-template-columns:repeat(2,1fr); } .reco-grid { grid-template-columns:repeat(2,1fr); } }
        @media (max-width:1024px) { .charts-grid { grid-template-columns:1fr; } .chart-card-full { grid-column:1; } .bottom-grid { grid-template-columns:1fr; } }
        @media (max-width:768px) {
            .sidebar { transform:translateX(-100%); }
            .sidebar.open { transform:translateX(0); }
            .sidebar-overlay.open { display:block; }
            .main { margin-left:0; }
            .menu-toggle { display:block; }
            .content { padding:16px; }
            .topbar { padding:0 16px; }
            .stats-grid { grid-template-columns:1fr 1fr; }
            .reco-grid { grid-template-columns:1fr; }
            .page-banner { flex-direction:column; gap:16px; }
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'">
            <span class="sidebar-logo-text">Bekri</span>
        </div>
        <div class="sidebar-user">
            <div class="sidebar-avatar">{{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}</div>
            <div>
                <div class="sidebar-user-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
                <div class="sidebar-user-role">Membre Bekri</div>
            </div>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section-label">Principal</div>
            <a href="{{ path('user_dashboard') }}"  class="nav-item"><i class="bi bi-grid-fill"></i> Tableau de bord</a>
            <a href="{{ path('suivi_today') }}"     class="nav-item"><i class="bi bi-clipboard2-pulse-fill"></i> Check-in quotidien</a>
            <a href="{{ path('insight_weekly') }}"  class="nav-item active"><i class="bi bi-graph-up-arrow"></i> Insights hebdo</a>
            <a href="{{ path('chat_index') }}"      class="nav-item"><i class="bi bi-robot"></i> Coach Eya IA</a>
            <div class="nav-section-label">Bien-être</div>
            <a href="{{ path('objectif_index') }}"  class="nav-item"><i class="bi bi-trophy-fill"></i> Mes objectifs</a>
            <a href="{{ path('plan_index') }}" class="nav-item"><i class="bi bi-calendar2-week-fill"></i> Plan hebdomadaire</a>
            <a href="{{ path('food_analyzer_index') }}" class="nav-item"><i class="bi bi-egg-fried"></i> Analyseur Alimentaire</a>
            <a href="#" class="nav-item"><i class="bi bi-brain"></i> Test de santé mentale</a>
            <div class="nav-section-label">Communauté</div>
            <a href="{{ path('posts_list') }}"      class="nav-item"><i class="bi bi-newspaper"></i> Publications</a>
            <a href="{{ path('evenements_home') }}" class="nav-item"><i class="bi bi-calendar-event-fill"></i> Événements</a>
            <div class="nav-section-label">Mon compte</div>
            <a href="{{ path('user_profile') }}"    class="nav-item"><i class="bi bi-person-fill"></i> Mon profil</a>
            <a href="{{ path('user_profile_edit') }}" class="nav-item"><i class="bi bi-gear-fill"></i> Paramètres</a>
        </nav>
        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;"><i class="bi bi-box-arrow-left"></i> Se déconnecter</a>
        </div>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- MAIN -->
    <div class="main">

        <!-- TOPBAR -->
        <header class="topbar">
            <div class="topbar-left">
                <button class="menu-toggle" id="menuToggle"><i class="bi bi-list"></i></button>
                <div>
                    <div class="topbar-title">Insights hebdomadaires</div>
                    <div class="topbar-sub">{{ periodStart|date('d M Y') }} — {{ periodEnd|date('d M Y') }}</div>
                </div>
            </div>
            <div class="topbar-right">
                <a href="{{ path('insight_weekly_pdf') }}" class="topbar-btn topbar-btn-teal">
                    <i class="bi bi-file-earmark-pdf-fill"></i> Télécharger PDF
                </a>
                <a href="{{ path('user_profile') }}" class="topbar-avatar">
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                </a>
            </div>
        </header>

        <!-- CONTENT -->
        <main class="content">

            <!-- Banner -->
            <div class="page-banner">
                <div class="page-banner-text">
                    <h1><i class="bi bi-graph-up-arrow" style="margin-right:10px;"></i>Résumé des 7 derniers jours</h1>
                    <p>Analyse complète de votre bien-être — {{ periodStart|date('d M Y') }} au {{ periodEnd|date('d M Y') }}</p>
                </div>
                <div class="page-banner-right">
                    <a href="{{ path('insight_weekly_pdf') }}" class="btn-pdf">
                        <i class="bi bi-file-earmark-pdf-fill"></i> Exporter PDF
                    </a>
                </div>
            </div>

            {% if insights.totalDays == 0 %}
                <div class="empty-state">
                    <div class="empty-icon">📊</div>
                    <h3>Aucune donnée disponible</h3>
                    <p>Vous n'avez pas encore rempli de check-in cette semaine. Commencez dès aujourd'hui !</p>
                    <a href="{{ path('suivi_today') }}" class="btn btn-teal" style="width:auto;margin:0 auto;">
                        <i class="bi bi-clipboard2-pulse-fill"></i> Faire mon check-in
                    </a>
                </div>

            {% else %}

                {% set totalScore = 0 %}
                {% set catCount   = 0 %}
                {% for avg in insights.averageScores %}
                    {% set totalScore = totalScore + avg %}
                    {% set catCount = catCount + 1 %}
                {% endfor %}
                {% set globalAvg = catCount > 0 ? (totalScore / catCount)|round(1) : 0 %}

                <!-- Stat cards -->
                <div class="stats-grid">
                    <div class="stat-card teal">
                        <div class="stat-label">Jours complétés</div>
                        <div class="stat-value teal">{{ insights.totalDays }}<span style="font-size:18px;font-weight:600;color:#94a3b8;">/7</span></div>
                        <div class="stat-sub">Cette semaine</div>
                    </div>
                    <div class="stat-card purple">
                        <div class="stat-label">Score moyen global</div>
                        <div class="stat-value {% if globalAvg >= 66 %}teal{% elseif globalAvg >= 40 %}purple{% else %}red{% endif %}">{{ globalAvg }}%</div>
                        <div class="stat-sub">Toutes catégories</div>
                    </div>
                    <div class="stat-card green">
                        <div class="stat-label">Meilleur jour</div>
                        <div class="stat-value green" style="font-size:22px;">
                            {% if insights.highlights.bestDay %}{{ insights.highlights.bestDay|date('d M') }}{% else %}—{% endif %}
                        </div>
                        <div class="stat-sub">{% if insights.highlights.bestScore %}Score : {{ insights.highlights.bestScore }}%{% endif %}</div>
                    </div>
                    <div class="stat-card red">
                        <div class="stat-label">Jour difficile</div>
                        <div class="stat-value red" style="font-size:22px;">
                            {% if insights.highlights.worstDay %}{{ insights.highlights.worstDay|date('d M') }}{% else %}—{% endif %}
                        </div>
                        <div class="stat-sub">{% if insights.highlights.worstScore %}Score : {{ insights.highlights.worstScore }}%{% endif %}</div>
                    </div>
                </div>

                <!-- Recommendations -->
                {% if recommendations is not empty %}
                <div class="reco-section">
                    <div class="reco-section-title">
                        <i class="bi bi-lightbulb-fill" style="color:#f59e0b;font-size:22px;"></i>
                        Recommandations personnalisées IA
                    </div>
                    <div class="reco-grid">
                        {% for reco in recommendations %}
                        <div class="reco-card">
                            <div class="reco-icon"><i class="fas {{ reco.icon }}"></i></div>
                            <div class="reco-title">{{ reco.title }}</div>
                            <div class="reco-desc">{{ reco.description }}</div>
                            <a href="{{ path('objectif_new') }}" class="reco-link">
                                Ajouter comme objectif <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}

                <!-- Charts -->
                <div class="charts-grid">
                    <div class="chart-card">
                        <h2>Progression globale</h2>
                        <p>Score moyen toutes catégories</p>
                        <canvas id="progressChart" height="220"></canvas>
                    </div>
                    <div class="chart-card">
                        <h2>Scores par catégorie</h2>
                        <p>En pourcentage (0–100%)</p>
                        <canvas id="categoryChart" height="220"></canvas>
                    </div>
                    <div class="chart-card chart-card-full">
                        <h2>Évolution de l'humeur</h2>
                        <p>Score humeur quotidien en %</p>
                        <canvas id="moodTrendChart" height="90"></canvas>
                    </div>
                </div>

                <!-- Trends & Highlights -->
                <div class="bottom-grid">
                    <div class="trends-card">
                        <div class="card-title"><i class="bi bi-arrow-up-right-circle-fill"></i> Tendances observées</div>
                        {% if insights.trends is empty %}
                            <p style="font-size:14px;color:var(--gray);">Pas assez de données pour détecter des tendances.</p>
                        {% else %}
                            {% for category, trend in insights.trends %}
                            <div class="trend-row">
                                <span class="trend-label">{{ category }}</span>
                                <span class="trend-badge {{ trend == 'Improving' ? 'trend-up' : 'trend-down' }}">
                                    {{ trend == 'Improving' ? '↑ En amélioration' : '↓ En déclin' }}
                                </span>
                            </div>
                            {% endfor %}
                        {% endif %}
                    </div>

                    <div class="highlights-card">
                        <div class="card-title"><i class="bi bi-stars"></i> Points forts & à améliorer</div>
                        <div class="highlight-box green">
                            <h3>🏆 Meilleur jour</h3>
                            <p>{% if insights.highlights.bestDay %}Le {{ insights.highlights.bestDay|date('d M') }} — score : <strong>{{ insights.highlights.bestScore }}%</strong>{% else %}Pas encore de données suffisantes.{% endif %}</p>
                        </div>
                        <div class="highlight-box red">
                            <h3>💪 Jour le plus difficile</h3>
                            <p>{% if insights.highlights.worstDay %}Le {{ insights.highlights.worstDay|date('d M') }} — score : <strong>{{ insights.highlights.worstScore }}%</strong>{% else %}Pas encore de données suffisantes.{% endif %}</p>
                        </div>
                    </div>
                </div>

                <!-- Encouragement banner -->
                <div class="encouragement">
                    <h2>Continuez sur cette lancée ! 🚀</h2>
                    <p>
                        Vous avez rempli votre suivi {{ insights.totalDays }} jour{{ insights.totalDays > 1 ? 's' : '' }} sur les 7 derniers.
                        {% if globalAvg >= 66 %}Vous êtes en bonne forme cette semaine — bravo ! 🎉
                        {% elseif globalAvg >= 40 %}Vous progressez doucement — chaque jour compte. 💪
                        {% else %}C'est une semaine plus difficile, mais vous n'êtes pas seul(e). 🌱{% endif %}
                    </p>
                    <div class="encouragement-btns">
                        <a href="{{ path('suivi_today') }}" class="btn-white">
                            <i class="bi bi-clipboard2-pulse-fill"></i> Faire mon check-in
                        </a>
                        <a href="{{ path('insight_weekly_pdf') }}" class="btn-outline-white">
                            <i class="bi bi-file-earmark-pdf-fill"></i> Télécharger mon PDF
                        </a>
                    </div>
                </div>

            {% endif %}
        </main>
    </div>

    <!-- Chat FAB -->
    <button class="chat-fab" onclick="window.location.href='{{ path('chat_index') }}'">
        <i class="bi bi-robot"></i>
    </button>

    <script>
        // Sidebar
        const menuToggle = document.getElementById('menuToggle');
        const sidebar    = document.getElementById('sidebar');
        const overlay    = document.getElementById('sidebarOverlay');
        menuToggle.addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('open'); });
        overlay.addEventListener('click',   () => { sidebar.classList.remove('open'); overlay.classList.remove('open'); });

        {% if insights.totalDays > 0 %}
        const globalAvg = {{ globalAvg }};

        // Progress doughnut
        const progressCtx = document.getElementById('progressChart')?.getContext('2d');
        if (progressCtx) {
            new Chart(progressCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Score', 'Restant'],
                    datasets: [{ data: [globalAvg, 100 - globalAvg], backgroundColor: [globalAvg >= 66 ? '#20b2aa' : globalAvg >= 40 ? '#f59e0b' : '#ef4444', '#f1f5f9'], borderWidth: 0 }]
                },
                options: { cutout: '72%', plugins: { legend: { display: false }, tooltip: { enabled: false } } },
                plugins: [{
                    id: 'centerText',
                    beforeDraw(chart) {
                        const {ctx, chartArea: {width, height}} = chart;
                        ctx.restore();
                        ctx.font = 'bold 28px Inter, sans-serif';
                        ctx.fillStyle = globalAvg >= 66 ? '#0d9488' : globalAvg >= 40 ? '#d97706' : '#dc2626';
                        ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
                        ctx.fillText(globalAvg + '%', width / 2, height / 2);
                        ctx.save();
                    }
                }]
            });
        }

        // Category bars
        const categoryCtx = document.getElementById('categoryChart')?.getContext('2d');
        if (categoryCtx) {
            const catLabels = [{% for cat in insights.averageScores|keys %}'{{ cat|capitalize }}'{% if not loop.last %},{% endif %}{% endfor %}];
            const catData   = [{% for avg in insights.averageScores %}{{ avg }}{% if not loop.last %},{% endif %}{% endfor %}];
            const barColors = catData.map(v => v >= 66 ? '#20b2aa' : v >= 40 ? '#f59e0b' : '#ef4444');
            new Chart(categoryCtx, {
                type: 'bar',
                data: { labels: catLabels, datasets: [{ data: catData, backgroundColor: barColors, borderRadius: 8, borderSkipped: false }] },
                options: {
                    scales: {
                        y: { beginAtZero:true, max:100, ticks:{ callback: v => v+'%' }, grid:{ color:'#f1f5f9' } },
                        x: { grid:{ display:false } }
                    },
                    plugins: { legend:{ display:false }, tooltip:{ callbacks:{ label: ctx => ctx.parsed.y+'%' } } }
                }
            });
        }

        // Mood trend
        const moodCtx = document.getElementById('moodTrendChart')?.getContext('2d');
        if (moodCtx) {
            const moodLabels = [{% for daily in dailies %}'{{ daily.date|date('d M') }}'{% if not loop.last %},{% endif %}{% endfor %}];
            const moodData = [
                {% for daily in dailies %}
                    {% set moodResponses = daily.reponses|filter(r => r.question.category == 'humeur') %}
                    {% set moodCount = moodResponses|length %}
                    {% set moodSum = 0 %}
                    {% for r in moodResponses %}
                        {% set val = r.valeur|lower|trim %}
                        {% set score = 0 %}
                        {% if val in ['positive','positif','oui, plusieurs','très optimiste','oui, beaucoup','oui, très'] %}{% set score = 100 %}
                        {% elseif val in ['neutre','oui, un peu','moyennement'] %}{% set score = 66 %}
                        {% elseif val in ['négative','négatif','plutôt pessimiste','pas terrible'] %}{% set score = 33 %}
                        {% endif %}
                        {% set moodSum = moodSum + score %}
                    {% endfor %}
                    {{ moodCount > 0 ? (moodSum / moodCount)|round(1) : 0 }}{% if not loop.last %},{% endif %}
                {% endfor %}
            ];
            new Chart(moodCtx, {
                type: 'line',
                data: { labels: moodLabels, datasets: [{ data: moodData, borderColor: '#20b2aa', backgroundColor: 'rgba(32,178,170,0.12)', tension:0.4, fill:true, pointBackgroundColor:'#fff', pointBorderColor:'#20b2aa', pointBorderWidth:2, pointRadius:5 }] },
                options: {
                    responsive:true,
                    scales: {
                        y: { min:0, max:100, ticks:{ callback: v => v+'%' }, grid:{ color:'#f1f5f9' } },
                        x: { grid:{ display:false } }
                    },
                    plugins: { legend:{ display:false }, tooltip:{ callbacks:{ label: ctx => 'Humeur : '+ctx.parsed.y+'%' } } }
                }
            });
        }
        {% endif %}
    </script>
</body>
</html>