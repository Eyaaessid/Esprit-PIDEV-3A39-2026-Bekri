{% extends 'base.html.twig' %}

{% block title %}Privacy - MediNest Bootstrap Template{% endblock %}

{% block body_class %}privacy-page{% endblock %}

{% block main %}

    <!-- Page Title -->
    <div class="page-title">
      <div class="heading">
        <div class="container">
          <div class="row d-flex justify-content-center text-center">
            <div class="col-lg-8">
              <h1 class="heading-title">Privacy</h1>
              <p class="mb-0">
                Odio et unde deleniti. Deserunt numquam exercitationem. Officiis quo
                odio sint voluptas consequatur ut a odio voluptatem. Sit dolorum
                debitis veritatis natus dolores. Quasi ratione sint. Sit quaerat
                ipsum dolorem.
              </p>
            </div>
          </div>
        </div>
      </div>
      <nav class="breadcrumbs">
        <div class="container">
          <ol>
            <li><a href="{{ path('home') }}">Home</a></li>
            <li class="current">Privacy</li>
          </ol>
        </div>
      </nav>
    </div><!-- End Page Title -->

    <!-- Privacy Section -->
    <section id="privacy" class="privacy section">

      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="intro-section">
          <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
              <h2>Privacy Policy</h2>
              <p class="lead">We are committed to protecting your privacy. This Privacy Policy explains how we collect, use, and safeguard your personal information.</p>
              <div class="last-updated">Last Updated: January 15, 2024</div>
            </div>
          </div>
        </div>

        <div class="privacy-content">
          <div class="row gy-5">

            <div class="col-lg-6" data-aos="fade-up" data-aos-delay="200">
              <div class="privacy-item">
                <h3>1. Information We Collect</h3>
                <p>We collect personal information you provide, such as name, email, and health data. We also collect usage data automatically.</p>
                <ul class="list-unstyled">
                  <li><i class="bi bi-check2-circle"></i> Personal identification information</li>
                  <li><i class="bi bi-check2-circle"></i> Health and medical history (with consent)</li>
                  <li><i class="bi bi-check2-circle"></i> Device and usage information</li>
                </ul>
              </div>
            </div>

            <div class="col-lg-6" data-aos="fade-up" data-aos-delay="300">
              <div class="privacy-item">
                <h3>2. How We Use Information</h3>
                <p>Your information is used to provide services, improve our platform, and communicate with you.</p>
                <ul class="list-unstyled">
                  <li><i class="bi bi-check2-circle"></i> Service delivery and personalization</li>
                  <li><i class="bi bi-check2-circle"></i> Analytics and improvements</li>
                  <li><i class="bi bi-check2-circle"></i> Legal compliance</li>
                </ul>
              </div>
            </div>

            <div class="col-lg-6" data-aos="fade-up" data-aos-delay="400">
              <div class="privacy-item">
                <h3>3. Data Sharing</h3>
                <p>We do not sell your data. We may share with service providers or for legal reasons.</p>
                <ul class="list-unstyled">
                  <li><i class="bi bi-check2-circle"></i> With healthcare partners (with consent)</li>
                  <li><i class="bi bi-check2-circle"></i> For business transfers</li>
                  <li><i class="bi bi-check2-circle"></i> To comply with law</li>
                </ul>
              </div>
            </div>

            <div class="col-lg-6" data-aos="fade-up" data-aos-delay="500">
              <div class="privacy-item">
                <h3>4. Security</h3>
                <p>We implement security measures to protect your data, but no system is completely secure.</p>
                <ul class="list-unstyled">
                  <li><i class="bi bi-check2-circle"></i> Encryption of sensitive data</li>
                  <li><i class="bi bi-check2-circle"></i> Regular security audits</li>
                  <li><i class="bi bi-check2-circle"></i> Access controls</li>
                </ul>
              </div>
            </div>

            <div class="col-lg-6" data-aos="fade-up" data-aos-delay="600">
              <div class="privacy-item">
                <h3>5. Your Rights</h3>
                <p>You have rights to access, correct, or delete your data. Contact us to exercise these rights.</p>
                <ul class="list-unstyled">
                  <li><i class="bi bi-check2-circle"></i> Data access and portability</li>
                  <li><i class="bi bi-check2-circle"></i> Opt-out of marketing</li>
                  <li><i class="bi bi-check2-circle"></i> Account deletion</li>
                </ul>
              </div>
            </div>

            <div class="col-lg-6" data-aos="fade-up" data-aos-delay="700">
              <div class="privacy-item">
                <h3>6. Cookies</h3>
                <p>We use cookies for functionality and analytics. You can manage cookie preferences in your browser.</p>
                <ul class="list-unstyled">
                  <li><i class="bi bi-check2-circle"></i> Essential cookies</li>
                  <li><i class="bi bi-check2-circle"></i> Analytics cookies</li>
                  <li><i class="bi bi-check2-circle"></i> Marketing cookies</li>
                </ul>
              </div>
            </div>

          </div>
        </div>

        <div class="contact-section" data-aos="fade-up" data-aos-delay="800">
          <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
              <div class="contact-card">
                <h4>Privacy Questions?</h4>
                <p>If you have questions about our Privacy Policy, contact our Data Protection Officer.</p>
                <div class="contact-info">
                  <div class="contact-item">
                    <i class="bi bi-envelope"></i>
                    <span>privacy@example.com</span>
                  </div>
                  <div class="contact-item">
                    <i class="bi bi-geo-alt"></i>
                    <span>1234 Privacy Street, Legal City, LC 12345</span>
                  </div>
                  <div class="contact-item">
                    <i class="bi bi-telephone"></i>
                    <span>+1 (555) 123-4567</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>

    </section>

{% endblock %}