    {# AI Emotional Insight: score + profil + AI-generated analysis only (no static advice) #}
    {% if user is defined and user and user.profilPsychologique is not null %}
    <section class="ai-insight-section py-5">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-lg-10 col-xl-9">
            <div class="card border-0 shadow-sm overflow-hidden ai-insight-card">
              <div class="card-body p-4 p-lg-5">
                <div class="d-flex align-items-center flex-wrap gap-3 mb-4">
                  <div class="ai-insight-icon rounded-3 d-flex align-items-center justify-content-center">
                    <i class="bi bi-heart-pulse text-white fs-4"></i>
                  </div>
                  <div class="d-flex flex-wrap align-items-center gap-3">
                    <div>
                      <h2 class="h5 mb-1 fw-bold">Votre analyse bien-être</h2>
                      <p class="text-muted small mb-0">Analyse générée à partir de vos réponses au test initial.</p>
                    </div>
                    <div class="d-flex align-items-center gap-3 ms-auto">
                      <span class="badge bg-light text-dark border">Score : <strong class="text-primary">{{ user.profilPsychologique.scoreGlobal }}</strong> / 100</span>
                      <span class="badge bg-primary">{{ user.profilPsychologique.profilType }}</span>
                    </div>
                  </div>
                </div>
                {% if user.profilPsychologique.aiFeedback is not null and user.profilPsychologique.aiFeedback is not empty %}
                <div class="ai-feedback-text text-muted lh-lg mb-4">{{ user.profilPsychologique.aiFeedback|nl2br }}</div>
                <p class="small fst-italic text-secondary mb-4">Cette analyse ne remplace pas un avis médical.</p>
                {% else %}
                <p class="text-muted small mb-4">Votre analyse personnalisée n’a pas pu être générée. Cliquez ci-dessous pour la générer maintenant (connexion à l’IA requise).</p>
                <form method="post" action="{{ path('user_regenerate_insight') }}" class="mb-4">
                    <input type="hidden" name="_token" value="{{ csrf_token('regenerate_insight') }}">
                    <button type="submit" class="btn btn-outline-primary rounded-pill">
                        <i class="bi bi-stars me-2"></i>Générer l’analyse
                    </button>
                </form>
                {% endif %}
                <p class="mb-0 text-center">
                  <a href="{{ path('objectif_new') }}" class="btn btn-primary rounded-pill px-4">
                    <i class="bi bi-plus-circle me-2"></i>Cliquez ici pour définir vos objectifs
                  </a>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <style>
    .ai-insight-section { background: linear-gradient(180deg, #f8f9ff 0%, #fff 100%); }
    .ai-insight-card { border-radius: 1.25rem; background: linear-gradient(135deg, #f8f9ff 0%, #f0f4ff 100%) !important; }
    .ai-insight-icon { width: 56px; height: 56px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .ai-feedback-text { font-size: 1rem; }
    </style>
