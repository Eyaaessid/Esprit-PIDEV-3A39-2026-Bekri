{% extends 'base.html.twig' %}

{% block title %}Post Notifications - MediNest{% endblock %}

{% block main %}
  <div class="page-title">
    <div class="heading">
      <div class="container">
        <div class="row d-flex justify-content-center text-center">
          <div class="col-lg-8">
            <h1 class="heading-title">Your Notifications</h1>
            <p class="mb-0">Likes and comments on your posts appear here.</p>
          </div>
        </div>
      </div>
    </div>
    <nav class="breadcrumbs">
      <div class="container">
        <ol>
          <li><a href="{{ path('home') }}">Home</a></li>
          <li><a href="{{ path('posts_list') }}">Posts</a></li>
          <li class="current">Notifications</li>
        </ol>
      </div>
    </nav>
  </div>

  <section class="section">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h5 class="mb-1">Unread: {{ unreadNotificationsCount|default(0) }}</h5>
        </div>
        <form method="post" action="{{ path('posts_notifications_read_all') }}">
          <button class="btn btn-primary" type="submit">
            <i class="bi bi-check2-all me-1"></i> Mark all as read
          </button>
        </form>
      </div>

      {% if notifications is empty %}
        <div class="alert alert-info">No notifications yet.</div>
      {% else %}
        <div class="list-group">
          {% for notification in notifications %}
            <a href="{{ path('post_details', {'id': notification.post.id}) }}#comments"
               class="list-group-item list-group-item-action d-flex justify-content-between align-items-start {% if not notification.isRead %}list-group-item-light{% endif %}">
              <div class="me-3">
                <div class="fw-semibold">{{ notification.message }}</div>
                <small class="text-muted">{{ notification.createdAt|date('M d, Y H:i') }}</small>
              </div>
              {% if not notification.isRead %}
                <span class="badge text-bg-primary">new</span>
              {% endif %}
            </a>
          {% endfor %}
        </div>

        {% if notifications.pageCount is defined and notifications.pageCount > 1 %}
          <div class="mt-4">
            {{ knp_pagination_render(notifications) }}
          </div>
        {% endif %}
      {% endif %}
    </div>
  </section>
{% endblock %}
