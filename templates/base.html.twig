<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <title>{% block title %}Bekri Wellbeing - Your Journey to Mental Wellness{% endblock %}</title>
    <meta name="description" content="{% block meta_description 'Professional mental health and wellbeing platform offering personalized coaching, wellness programs, and community support.' %}">
    <meta name="keywords" content="{% block meta_keywords 'mental health, wellbeing, wellness, therapy, coaching, mental wellness' %}">

    <!-- Favicons -->
    <link href="{{ asset('assets/img/favicon.png') }}" rel="icon">
    <link href="{{ asset('assets/img/apple-touch-icon.png') }}" rel="apple-touch-icon">

    <!-- Modern Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Vendor CSS Files -->
    <link href="{{ asset('assets/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
    <link href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}" rel="stylesheet">
    <link href="{{ asset('assets/vendor/aos/aos.css') }}" rel="stylesheet">
    <link href="{{ asset('assets/vendor/glightbox/css/glightbox.min.css') }}" rel="stylesheet">
    <link href="{{ asset('assets/vendor/fontawesome-free/css/all.min.css') }}" rel="stylesheet">
    <link href="{{ asset('assets/vendor/swiper/swiper-bundle.min.css') }}" rel="stylesheet">

    <!-- Main CSS File -->
    <link href="{{ asset('assets/css/main.css') }}" rel="stylesheet">

    <!-- Enhanced Custom Styles -->
    <style>
        :root {
            --primary-color: #20b2aa;
            --primary-dark: #1a8f89;
            --secondary-color: #667eea;
            --text-dark: #2d3748;
            --text-light: #718096;
            --bg-light: #f8f9fa;
            --shadow: 0 2px 15px rgba(0,0,0,0.08);
            --shadow-hover: 0 8px 30px rgba(0,0,0,0.12);
        }

        /* Modern Typography */
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 16px;
            color: var(--text-dark);
            line-height: 1.6;
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
            font-weight: 700;
            color: var(--text-dark);
        }

        /* Enhanced Header */
        .header {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(10px);
            box-shadow: 0 2px 20px rgba(0,0,0,0.06);
            transition: all 0.3s ease;
        }

        .sitename {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 1.75rem;
            font-weight: 800;
            letter-spacing: -0.02em;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Modern Navigation */
        .navmenu ul li a {
            font-weight: 500;
            font-size: 15px;
            transition: all 0.3s ease;
            position: relative;
        }

        .navmenu ul li a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--primary-color);
            transition: width 0.3s ease;
        }

        .navmenu ul li a:hover::after,
        .navmenu ul li a.active::after {
            width: 100%;
        }

        /* Professional User Dropdown */
        .user-dropdown-modern {
            position: relative;
        }

        .btn-getstarted {
            background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
            color: white;
            padding: 10px 24px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 14px;
            border: none;
            box-shadow: 0 4px 15px rgba(32, 178, 170, 0.3);
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .btn-getstarted:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 25px rgba(32, 178, 170, 0.4);
            color: white;
        }

        .dropdown-menu {
            border: none;
            border-radius: 16px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.15);
            padding: 12px 0;
            margin-top: 12px;
            min-width: 250px;
            animation: slideDown 0.3s ease;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .dropdown-item {
            padding: 12px 20px;
            font-weight: 500;
            font-size: 14px;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
        }

        .dropdown-item i {
            width: 20px;
            margin-right: 10px;
            font-size: 16px;
        }

        .dropdown-item:hover {
            background: linear-gradient(to right, #f8f9fa, #e9ecef);
            color: var(--primary-color);
            padding-left: 24px;
        }

        .dropdown-divider {
            margin: 8px 0;
        }

        /* Flash Messages */
        .flash-messages {
            position: fixed;
            top: 90px;
            right: 20px;
            z-index: 9998;
            max-width: 400px;
        }

        .alert {
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.12);
            border: none;
            margin-bottom: 12px;
            animation: slideInRight 0.4s ease;
        }

        @keyframes slideInRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        /* Modern Footer */
        .footer {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            color: #fff;
            padding-top: 60px;
            position: relative;
            overflow: hidden;
        }

        .footer::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--primary-color), var(--secondary-color), var(--primary-color));
        }

        .footer h4 {
            color: #fff;
            font-weight: 700;
            font-size: 1.125rem;
            margin-bottom: 24px;
            position: relative;
            padding-bottom: 12px;
        }

        .footer h4::after {
            content: '';
            position: absolute;
            left: 0;
            bottom: 0;
            width: 50px;
            height: 3px;
            background: var(--primary-color);
            border-radius: 2px;
        }

        .footer-about p {
            color: rgba(255,255,255,0.85);
            line-height: 1.8;
            margin-bottom: 1rem;
        }

        .footer-contact p {
            color: rgba(255,255,255,0.85);
            margin-bottom: 10px;
            display: flex;
            align-items: center;
        }

        .footer-contact i {
            color: var(--primary-color);
            margin-right: 10px;
            font-size: 18px;
        }

        .footer-links a {
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            transition: all 0.3s ease;
            font-weight: 500;
            font-size: 15px;
            padding: 5px 0;
        }

        .footer-links a:hover {
            color: var(--primary-color);
            padding-left: 8px;
        }

        .footer-links a i {
            font-size: 12px;
            margin-right: 8px;
            opacity: 0.7;
        }

        .social-links {
            gap: 10px;
        }

        .social-links a {
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
            color: white;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
            text-decoration: none;
        }

        .social-links a:hover {
            background: var(--primary-color);
            transform: translateY(-5px);
            box-shadow: 0 5px 20px rgba(32,178,170,0.4);
            color: white;
        }

        .copyright {
            border-top: 1px solid rgba(255,255,255,0.1);
            padding: 30px 0;
            margin-top: 40px;
        }

        .copyright p {
            color: rgba(255,255,255,0.9);
            font-weight: 500;
            margin-bottom: 8px;
        }

        .copyright strong {
            color: var(--primary-color);
            font-weight: 700;
        }

        .credits {
            color: rgba(255,255,255,0.75);
            font-size: 0.9rem;
        }

        .credits a {
            color: var(--primary-color);
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .credits a:hover {
            color: #fff;
        }

        /* Enhanced Scroll Top Button */
        #scroll-top {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            box-shadow: 0 4px 15px rgba(32,178,170,0.3);
        }

        #scroll-top:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 25px rgba(32,178,170,0.4);
        }

        /* Mobile Responsive */
        @media (max-width: 768px) {
            .flash-messages {
                right: 10px;
                left: 10px;
                max-width: none;
            }

            .footer h4 {
                font-size: 1rem;
                margin-bottom: 16px;
            }

            .footer-links a {
                font-size: 14px;
            }

            .social-links a {
                width: 40px;
                height: 40px;
            }
        }
    </style>

    {% block head_extra %}{% endblock %}
</head>

<body class="{% block body_class '' %}">

    <!-- Flash Messages (Success/Error) -->
    {% for type, messages in app.flashes %}
        <div class="flash-messages">
            {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                    <strong>
                        {% if type == 'success' %}
                            <i class="bi bi-check-circle-fill me-2"></i>
                        {% elseif type == 'error' %}
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        {% else %}
                            <i class="bi bi-info-circle-fill me-2"></i>
                        {% endif %}
                    </strong>
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        </div>
    {% endfor %}

    <!-- ======= Header ======= -->
    <header id="header" class="header d-flex align-items-center fixed-top">
        <div class="container position-relative d-flex align-items-center justify-content-between">

            <a href="{{ path('home') }}" class="logo d-flex align-items-center me-auto me-xl-0">
                <h1 class="sitename mb-0">Bekri<span style="opacity: 0.8;">Wellbeing</span></h1>
            </a>

            <nav id="navmenu" class="navmenu">
                <ul>
                    <li><a href="{{ path('home') }}" class="{{ app.request.attributes.get('_route') == 'home' ? 'active' : '' }}">Home</a></li>
                    <li><a href="{{ path('objectif_index') }}" class="{{ app.request.attributes.get('_route') == 'mes objectifs' ? 'active' : '' }}">mes objectifs</a></li>
                    <li><a href="{{ path('evenements_home') }}" class="{{ app.request.attributes.get('_route') == 'les evenements' ? 'active' : '' }}">les evenements</a></li>
                    <li><a href="{{ path('posts_list') }}">Posts</a></li>

                    <li class="dropdown">
                        <a href="#"><span>Resources</span> <i class="bi bi-chevron-down toggle-dropdown"></i></a>
                        <ul>
                            <li><a href="{{ path('testimonials') }}"><i class="bi bi-chat-quote me-2"></i>Testimonials</a></li>
                            <li><a href="{{ path('faq') }}"><i class="bi bi-question-circle me-2"></i>FAQ</a></li>
                            <li><a href="{{ path('gallery') }}"><i class="bi bi-images me-2"></i>Gallery</a></li>
                            <li><a href="{{ path('appointment') }}"><i class="bi bi-calendar-check me-2"></i>Appointments</a></li>
                        </ul>
                    </li>

                    <li><a href="{{ path('contact') }}" class="{{ app.request.attributes.get('_route') == 'contact' ? 'active' : '' }}">Contact</a></li>
                </ul>
                <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
            </nav>

            {% if app.user %}
                <!-- User is logged in - NO CHANGES NEEDED HERE, base.html.twig doesn't show avatar -->
                <div class="dropdown user-dropdown-modern">
                    <a class="btn-getstarted dropdown-toggle" href="#" role="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-person-circle me-2"></i>
                        <span>{{ app.user.prenom }}</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                        <li class="px-3 py-2 border-bottom">
                            <div class="fw-bold text-dark">{{ app.user.nom }} {{ app.user.prenom }}</div>
                            <small class="text-muted">{{ app.user.email }}</small>
                        </li>
                        
                        <!-- Dashboard Link (Role-based) -->
                        {% if is_granted('ROLE_ADMIN') %}
                            <li><a class="dropdown-item" href="{{ path('admin_dashboard') }}"><i class="bi bi-speedometer2"></i>Dashboard</a></li>
                        {% elseif is_granted('ROLE_COACH') %}
                            <li><a class="dropdown-item" href="{{ path('coach_dashboard') }}"><i class="bi bi-speedometer2"></i>Dashboard</a></li>
                        {% else %}
                            <li><a class="dropdown-item" href="{{ path('user_dashboard') }}"><i class="bi bi-speedometer2"></i>Dashboard</a></li>
                        {% endif %}
                        
                        <!-- Profile Link (Role-based) -->
                        {% if is_granted('ROLE_ADMIN') %}
                            <li><a class="dropdown-item" href="{{ path('admin_profile') }}"><i class="bi bi-person"></i>My Profile</a></li>
                        {% elseif is_granted('ROLE_COACH') %}
                            <li><a class="dropdown-item" href="{{ path('coach_profile') }}"><i class="bi bi-person"></i>My Profile</a></li>
                        {% else %}
                            <li><a class="dropdown-item" href="{{ path('user_profile') }}"><i class="bi bi-person"></i>My Profile</a></li>
                        {% endif %}
                        
                        <li><a class="dropdown-item" href="#"><i class="bi bi-heart"></i>Wellness Goals</a></li>
                        <li><a class="dropdown-item" href="#"><i class="bi bi-calendar-event"></i>My Events</a></li>
                        <li><a class="dropdown-item" href="#"><i class="bi bi-gear"></i>Settings</a></li>
                        
                        {% if is_granted('ROLE_ADMIN') %}
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-primary" href="{{ path('admin_dashboard') }}"><i class="bi bi-shield-check"></i>Admin Panel</a></li>
                        {% endif %}
                        
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right"></i>Logout</a></li>
                    </ul>
                </div>
            {% else %}
                <!-- User is not logged in -->
                <a class="btn-getstarted" href="{{ path('app_login') }}">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Login / Sign Up
                </a>
            {% endif %}
        </div>
    </header><!-- End Header -->

    <main class="main">
        {% block main %}{% endblock %}
    </main>

    <!-- ======= Professional Footer ======= -->
    <footer id="footer" class="footer position-relative">
        <div class="container footer-top">
            <div class="row gy-4">
                
                <!-- Company Info -->
                <div class="col-lg-4 col-md-6 footer-about">
                    <a href="{{ path('home') }}" class="logo d-flex align-items-center mb-3">
                        <h3 class="text-white mb-0" style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800;">
                            Bekri<span style="color: var(--primary-color); opacity: 0.9;">Wellbeing</span>
                        </h3>
                    </a>
                    <p class="mb-3">
                        Your trusted partner in mental health and wellbeing. We provide professional support, personalized coaching, and community resources for your journey to wellness.
                    </p>
                    <div class="footer-contact">
                        <p><i class="bi bi-geo-alt"></i>Tunis, Tunisia</p>
                        <p><i class="bi bi-telephone"></i>+216 XX XXX XXX</p>
                        <p><i class="bi bi-envelope"></i>contact@bekriwellbeing.tn</p>
                    </div>
                    <div class="social-links d-flex mt-4">
                        <a href="#" title="Twitter"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" title="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" title="Instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" title="LinkedIn"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>

                <!-- Quick Links -->
                <div class="col-lg-2 col-md-3 col-6 footer-links">
                    <h4>Quick Links</h4>
                    <ul class="list-unstyled">
                        <li><a href="{{ path('home') }}"><i class="bi bi-chevron-right"></i>Home</a></li>
                        <li><a href="{{ path('about') }}"><i class="bi bi-chevron-right"></i>About Us</a></li>
                        <li><a href="{{ path('services') }}"><i class="bi bi-chevron-right"></i>Services</a></li>
                        <li><a href="{{ path('testimonials') }}"><i class="bi bi-chevron-right"></i>Testimonials</a></li>
                        <li><a href="{{ path('contact') }}"><i class="bi bi-chevron-right"></i>Contact</a></li>
                    </ul>
                </div>

                <!-- Services -->
                <div class="col-lg-3 col-md-3 col-6 footer-links">
                    <h4>Our Services</h4>
                    <ul class="list-unstyled">
                        <li><a href="#"><i class="bi bi-chevron-right"></i>Mental Health Assessment</a></li>
                        <li><a href="#"><i class="bi bi-chevron-right"></i>Personal Coaching</a></li>
                        <li><a href="#"><i class="bi bi-chevron-right"></i>Wellness Programs</a></li>
                        <li><a href="#"><i class="bi bi-chevron-right"></i>Group Sessions</a></li>
                        <li><a href="{{ path('appointment') }}"><i class="bi bi-chevron-right"></i>Book Appointment</a></li>
                    </ul>
                </div>

                <!-- Resources -->
                <div class="col-lg-3 col-md-6 footer-links">
                    <h4>Resources</h4>
                    <ul class="list-unstyled">
                        <li><a href="{{ path('faq') }}"><i class="bi bi-chevron-right"></i>FAQ</a></li>
                        <li><a href="{{ path('gallery') }}"><i class="bi bi-chevron-right"></i>Gallery</a></li>
                        <li><a href="{{ path('terms') }}"><i class="bi bi-chevron-right"></i>Terms of Service</a></li>
                        <li><a href="{{ path('privacy') }}"><i class="bi bi-chevron-right"></i>Privacy Policy</a></li>
                        {% if not app.user %}
                            <li><a href="{{ path('app_login') }}"><i class="bi bi-chevron-right"></i>Login / Register</a></li>
                        {% endif %}
                    </ul>
                </div>

            </div>
        </div>

        <!-- Copyright -->
        <div class="container copyright text-center">
            <p>© {{ "now"|date("Y") }} <strong>BekriWellbeing</strong> - All Rights Reserved</p>
            <div class="credits">
                Designed with <i class="bi bi-heart-fill" style="color: #ff6b6b;"></i> for Mental Health & Wellness
            </div>
        </div>
    </footer><!-- End Footer -->

    <!-- Scroll Top -->
    <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center">
        <i class="bi bi-arrow-up-short"></i>
    </a>

    <!-- Preloader -->
    <div id="preloader"></div>

    <!-- Vendor JS Files -->
    <script src="{{ asset('assets/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
    <script src="{{ asset('assets/vendor/php-email-form/validate.js') }}"></script>
    <script src="{{ asset('assets/vendor/aos/aos.js') }}"></script>
    <script src="{{ asset('assets/vendor/glightbox/js/glightbox.min.js') }}"></script>
    <script src="{{ asset('assets/vendor/purecounter/purecounter_vanilla.js') }}"></script>
    <script src="{{ asset('assets/vendor/imagesloaded/imagesloaded.pkgd.min.js') }}"></script>
    <script src="{{ asset('assets/vendor/isotope-layout/isotope.pkgd.min.js') }}"></script>
    <script src="{{ asset('assets/vendor/swiper/swiper-bundle.min.js') }}"></script>

    <!-- Main JS File -->
    <script src="{{ asset('assets/js/main.js') }}"></script>

    <!-- Auto-hide flash messages script -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                setTimeout(function() {
                    const bsAlert = bootstrap.Alert.getOrCreateInstance(alert);
                    bsAlert.close();
                }, 5000); // Auto-hide after 5 seconds
            });
        });
    </script>

    {% block scripts_extra %}{% endblock %}

    {# No importmap('app') on main site - keeps posts/list/detail fast; like & forms use vanilla JS #}
    {% block javascripts %}{% endblock %}
</body>
</html>