<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Plan Hebdomadaire — Bekri</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --teal:        #20b2aa;
            --teal-dark:   #0d9488;
            --teal-light:  #e0f7f6;
            --purple:      #667eea;
            --dark:        #1a2332;
            --gray:        #64748b;
            --light:       #f8fafc;
            --white:       #ffffff;
            --sidebar-w:   260px;
            --shadow-sm:   0 2px 12px rgba(0,0,0,0.06);
            --shadow:      0 8px 30px rgba(0,0,0,0.10);
            --radius:      16px;
        }

        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior: smooth; }

        body { font-family: 'Inter', sans-serif; background: var(--light); color: var(--dark); display: flex; min-height: 100vh; }

        /* ── SIDEBAR ── */
        .sidebar { width: var(--sidebar-w); background: var(--dark); min-height: 100vh; position: fixed; top: 0; left: 0; display: flex; flex-direction: column; z-index: 100; transition: transform 0.3s ease; }
        .sidebar-logo { padding: 28px 24px 20px; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid rgba(255,255,255,0.07); }
        .sidebar-logo img { height: 36px; width: auto; }
        .sidebar-logo-text { font-size: 20px; font-weight: 800; background: linear-gradient(135deg, var(--teal), #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .sidebar-user { padding: 20px 24px; display: flex; align-items: center; gap: 12px; border-bottom: 1px solid rgba(255,255,255,0.07); }
        .sidebar-avatar { width: 42px; height: 42px; border-radius: 50%; background: linear-gradient(135deg, var(--teal), var(--purple)); display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 16px; flex-shrink: 0; overflow: hidden; }
        .sidebar-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .sidebar-user-name { font-size: 14px; font-weight: 600; color: white; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .sidebar-user-role { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 2px; }
        .sidebar-nav { flex: 1; padding: 16px 0; overflow-y: auto; }
        .nav-section-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,0.25); padding: 12px 24px 6px; }
        .nav-item { display: flex; align-items: center; gap: 12px; padding: 11px 24px; color: rgba(255,255,255,0.6); text-decoration: none; font-size: 14px; font-weight: 500; transition: all 0.2s; border-left: 3px solid transparent; }
        .nav-item:hover { color: white; background: rgba(255,255,255,0.05); }
        .nav-item.active { color: var(--teal); background: rgba(32,178,170,0.1); border-left-color: var(--teal); }
        .nav-item i { width: 20px; text-align: center; font-size: 16px; }
        .nav-badge { margin-left: auto; background: var(--teal); color: white; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 50px; }
        .sidebar-footer { padding: 16px 0; border-top: 1px solid rgba(255,255,255,0.07); }

        /* ── MAIN ── */
        .main { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh; }

        /* ── TOPBAR ── */
        .topbar { background: white; padding: 0 32px; height: 68px; display: flex; align-items: center; justify-content: space-between; box-shadow: var(--shadow-sm); position: sticky; top: 0; z-index: 50; }
        .topbar-left { display: flex; align-items: center; gap: 16px; }
        .topbar-greeting h2 { font-size: 18px; font-weight: 700; color: var(--dark); }
        .topbar-greeting p { font-size: 13px; color: var(--gray); }
        .topbar-right { display: flex; align-items: center; gap: 12px; }
        .topbar-btn { width: 40px; height: 40px; border-radius: 10px; background: var(--light); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--gray); font-size: 16px; transition: all 0.2s; text-decoration: none; }
        .topbar-btn:hover { background: var(--teal-light); color: var(--teal-dark); }
        .topbar-avatar { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, var(--teal), var(--purple)); display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 14px; cursor: pointer; overflow: hidden; text-decoration: none; }
        .topbar-avatar img { width: 100%; height: 100%; object-fit: cover; }

        /* ── CONTENT ── */
        .content { padding: 32px; flex: 1; }

        /* ── ICON COLORS ── */
        .icon-teal   { background: var(--teal-light); color: var(--teal-dark); }
        .icon-purple { background: #ede9fe; color: #7c3aed; }
        .icon-amber  { background: #fef3c7; color: #d97706; }
        .icon-rose   { background: #ffe4e6; color: #e11d48; }
        .icon-blue   { background: #dbeafe; color: #2563eb; }
        .icon-green  { background: #d1fae5; color: #059669; }

        /* ── PAGE BANNER ── */
        .welcome-banner { background: linear-gradient(135deg, #059669 0%, var(--teal-dark) 50%, var(--purple) 100%); border-radius: var(--radius); padding: 32px 36px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; position: relative; overflow: hidden; color: white; }
        .welcome-banner::before { content: ''; position: absolute; top: -50px; right: -50px; width: 200px; height: 200px; background: rgba(255,255,255,0.06); border-radius: 50%; }
        .welcome-banner h1 { font-size: 22px; font-weight: 800; margin-bottom: 6px; }
        .welcome-banner p { font-size: 13px; color: rgba(255,255,255,0.8); }
        .banner-icon { width: 64px; height: 64px; background: rgba(255,255,255,0.15); border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 28px; flex-shrink: 0; }

        /* ── CARD ── */
        .card { background: white; border-radius: var(--radius); box-shadow: var(--shadow-sm); border: 1px solid #f1f5f9; overflow: hidden; margin-bottom: 24px; }
        .card-header { padding: 20px 24px 0; display: flex; align-items: center; justify-content: space-between; }
        .card-title { font-size: 15px; font-weight: 700; color: var(--dark); display: flex; align-items: center; gap: 8px; }
        .card-title i { color: var(--teal); }
        .card-body { padding: 20px 24px; }

        /* ── FORM ── */
        .form-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
        .form-grid .full-width { grid-column: 1 / -1; }
        .form-group label { display: block; font-size: 13px; font-weight: 600; color: var(--gray); margin-bottom: 6px; }
        .form-control { width: 100%; border: 1.5px solid #e2e8f0; border-radius: 10px; padding: 10px 14px; font-size: 14px; font-family: 'Inter', sans-serif; color: var(--dark); background: white; transition: all 0.2s; outline: none; }
        .form-control:focus { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(32,178,170,0.1); }

        /* ── BUTTONS ── */
        .btn-primary { display: inline-flex; align-items: center; gap: 8px; padding: 12px 28px; background: linear-gradient(135deg, var(--teal), var(--teal-dark)); color: white; border: none; border-radius: 50px; font-weight: 600; font-size: 14px; cursor: pointer; text-decoration: none; transition: all 0.3s; box-shadow: 0 4px 15px rgba(32,178,170,0.3); }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(32,178,170,0.4); color: white; }
        .btn-pdf { display: inline-flex; align-items: center; gap: 8px; padding: 12px 28px; background: linear-gradient(135deg, #ef4444, #dc2626); color: white; border: none; border-radius: 50px; font-weight: 600; font-size: 14px; cursor: pointer; transition: all 0.3s; box-shadow: 0 4px 15px rgba(239,68,68,0.3); }
        .btn-pdf:hover { transform: translateY(-2px); color: white; }

        /* ── STATS ROW ── */
        .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 24px; }
        .stat-card { background: white; border-radius: var(--radius); padding: 22px 24px; box-shadow: var(--shadow-sm); display: flex; align-items: center; gap: 16px; border: 1px solid #f1f5f9; }
        .stat-icon { width: 50px; height: 50px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
        .stat-value { font-size: 22px; font-weight: 800; color: var(--dark); line-height: 1; }
        .stat-label { font-size: 12px; color: var(--gray); margin-top: 4px; }

        /* ── TABLE ── */
        .plan-table { width: 100%; border-collapse: collapse; font-size: 13px; }
        .plan-table th { background: var(--teal-light); color: var(--teal-dark); padding: 12px 14px; text-align: left; font-weight: 700; font-size: 12px; }
        .plan-table td { padding: 11px 14px; border-bottom: 1px solid #f1f5f9; color: var(--gray); vertical-align: top; }
        .plan-table tr:hover td { background: #f8fafc; }
        .plan-table tr:last-child td { border-bottom: none; }
        .day-label { font-weight: 700; color: var(--dark); text-transform: capitalize; }

        /* ── EXERCISE GRID ── */
        .exercise-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 12px; }
        .exercise-box { background: var(--teal-light); border-radius: 12px; padding: 14px 10px; text-align: center; border: 1px solid #b2e8e6; }
        .exercise-box.repos { background: #f8fafc; border-color: #e2e8f0; }
        .exercise-day { font-size: 11px; font-weight: 700; text-transform: capitalize; color: var(--dark); margin-bottom: 6px; }
        .exercise-type { font-size: 12px; font-weight: 700; color: var(--teal-dark); margin-bottom: 4px; }
        .exercise-box.repos .exercise-type { color: var(--gray); }
        .exercise-meta { font-size: 11px; color: var(--gray); margin-bottom: 3px; }
        .exercise-desc { font-size: 11px; color: var(--gray); line-height: 1.4; }

        /* ── TIPS ── */
        .tips-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px; }
        .tips-card { border-radius: var(--radius); padding: 24px; box-shadow: var(--shadow-sm); }
        .tips-card.hydration { background: linear-gradient(135deg, #eff6ff, #dbeafe); border: 1px solid #bfdbfe; }
        .tips-card.sleep { background: linear-gradient(135deg, #faf5ff, #ede9fe); border: 1px solid #ddd6fe; }
        .tips-card-title { font-size: 15px; font-weight: 700; margin-bottom: 4px; display: flex; align-items: center; gap: 8px; }
        .tips-card.hydration .tips-card-title { color: #1d4ed8; }
        .tips-card.sleep .tips-card-title { color: #7c3aed; }
        .tips-card-subtitle { font-size: 13px; font-weight: 600; margin-bottom: 14px; }
        .tips-card.hydration .tips-card-subtitle { color: #2563eb; }
        .tips-card.sleep .tips-card-subtitle { color: #6d28d9; }
        .tips-list { list-style: none; }
        .tips-list li { font-size: 13px; padding: 5px 0; display: flex; align-items: flex-start; gap: 8px; color: var(--dark); border-bottom: 1px solid rgba(0,0,0,0.05); }
        .tips-list li:last-child { border-bottom: none; }

        /* ── CONSEILS ── */
        .conseils-list { list-style: none; }
        .conseils-list li { display: flex; align-items: flex-start; gap: 10px; padding: 10px 0; border-bottom: 1px solid #f1f5f9; font-size: 14px; color: var(--dark); }
        .conseils-list li:last-child { border-bottom: none; }
        .conseil-check { width: 22px; height: 22px; background: var(--teal-light); color: var(--teal-dark); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; flex-shrink: 0; margin-top: 1px; }

        /* ── LOADING ── */
        .loading-overlay { display: none; position: fixed; inset: 0; background: rgba(26,35,50,0.75); z-index: 999; align-items: center; justify-content: center; flex-direction: column; gap: 16px; }
        .loading-overlay.active { display: flex; }
        .loading-spinner { width: 52px; height: 52px; border: 4px solid rgba(255,255,255,0.2); border-top-color: var(--teal); border-radius: 50%; animation: spin 0.8s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }
        .loading-text { color: white; font-size: 15px; font-weight: 600; }

        /* ── ALERT ── */
        .alert-error { background: #ffe4e6; border: 1px solid #fecdd3; border-radius: 12px; padding: 14px 18px; color: #be123c; font-size: 14px; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }

        /* ── MOBILE ── */
        .menu-toggle { display: none; background: none; border: none; font-size: 22px; color: var(--dark); cursor: pointer; }
        .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 99; }

        @media (max-width: 1200px) {
            .stats-row { grid-template-columns: repeat(2, 1fr); }
            .form-grid { grid-template-columns: repeat(2, 1fr); }
            .exercise-grid { grid-template-columns: repeat(4, 1fr); }
        }
        @media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main { margin-left: 0; }
            .menu-toggle { display: block; }
            .content { padding: 20px 16px; }
            .topbar { padding: 0 16px; }
            .stats-row { grid-template-columns: repeat(2, 1fr); }
            .form-grid { grid-template-columns: 1fr; }
            .tips-grid { grid-template-columns: 1fr; }
            .exercise-grid { grid-template-columns: repeat(2, 1fr); }
            .welcome-banner { flex-direction: column; gap: 16px; }
        }
    </style>
</head>
<body>

    <!-- LOADING -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="loading-spinner"></div>
        <div class="loading-text">⚡ L'IA génère votre plan personnalisé...</div>
    </div>

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'">
            <span class="sidebar-logo-text">Bekri</span>
        </div>
        <div class="sidebar-user">
            <div class="sidebar-avatar">
                {% if app.user.photo is defined and app.user.photo %}
                    <img src="{{ asset('uploads/photos/' ~ app.user.photo) }}" alt="avatar">
                {% else %}
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                {% endif %}
            </div>
            <div>
                <div class="sidebar-user-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
                <div class="sidebar-user-role">Membre Bekri</div>
            </div>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section-label">Principal</div>
            <a href="{{ path('user_dashboard') }}" class="nav-item"><i class="bi bi-grid-fill"></i> Tableau de bord</a>
            <a href="{{ path('suivi_today') }}" class="nav-item"><i class="bi bi-clipboard2-pulse-fill"></i> Check-in quotidien <span class="nav-badge">!</span></a>
            <a href="{{ path('insight_weekly') }}" class="nav-item"><i class="bi bi-graph-up-arrow"></i> Insights hebdo</a>
            <a href="{{ path('chat_index') }}" class="nav-item"><i class="bi bi-robot"></i> Coach Eya IA</a>
            <div class="nav-section-label">Bien-être</div>
            <a href="{{ path('user_analyse') }}" class="nav-item"><i class="bi bi-heart-pulse-fill"></i> Mon analyse bien-être</a>
            <a href="{{ path('objectif_index') }}" class="nav-item"><i class="bi bi-trophy-fill"></i> Mes objectifs</a>
            <a href="{{ path('plan_index') }}" class="nav-item active"><i class="bi bi-calendar2-week-fill"></i> Plan hebdomadaire</a>
            <div class="nav-section-label">Communauté</div>
            <a href="{{ path('posts_list') }}" class="nav-item"><i class="bi bi-newspaper"></i> Publications</a>
            <a href="{{ path('evenements_home') }}" class="nav-item"><i class="bi bi-calendar-event-fill"></i> Événements</a>
            <div class="nav-section-label">Mon compte</div>
            <a href="{{ path('user_profile') }}" class="nav-item"><i class="bi bi-person-fill"></i> Mon profil</a>
            <a href="{{ path('user_profile_edit') }}" class="nav-item"><i class="bi bi-gear-fill"></i> Paramètres</a>
        </nav>
        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;"><i class="bi bi-box-arrow-left"></i> Se déconnecter</a>
        </div>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- MAIN -->
    <div class="main">

        <!-- TOPBAR -->
        <header class="topbar">
            <div class="topbar-left">
                <button class="menu-toggle" id="menuToggle"><i class="bi bi-list"></i></button>
                <div class="topbar-greeting">
                    <h2>Plan hebdomadaire 🗓️</h2>
                    <p>Générez un plan nutrition & sport personnalisé par IA</p>
                </div>
            </div>
            <div class="topbar-right">
                <a href="{{ path('suivi_today') }}" class="topbar-btn" title="Check-in du jour"><i class="bi bi-clipboard2-pulse"></i></a>
                <a href="{{ path('chat_index') }}" class="topbar-btn" title="Chat avec Eya"><i class="bi bi-robot"></i></a>
                <a href="{{ path('user_profile') }}" class="topbar-avatar">
                    {% if app.user.photo is defined and app.user.photo %}
                        <img src="{{ asset('uploads/photos/' ~ app.user.photo) }}" alt="avatar">
                    {% else %}
                        {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                    {% endif %}
                </a>
            </div>
        </header>

        <!-- CONTENT -->
        <main class="content">

            <!-- Banner -->
            <div class="welcome-banner">
                <div class="welcome-text">
                    <h1>🏋️ Votre Plan Bien-Être Personnalisé</h1>
                    <p>Renseignez votre profil et laissez l'IA générer un plan complet : alimentation, exercices, hydratation & sommeil.</p>
                </div>
                <div class="banner-icon"><i class="bi bi-calendar2-week-fill"></i></div>
            </div>

            {% if error %}
            <div class="alert-error"><i class="bi bi-exclamation-circle-fill"></i> {{ error }}</div>
            {% endif %}

            <!-- Form -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title"><i class="bi bi-person-fill"></i> Votre Profil</div>
                </div>
                <div class="card-body">
                    <form method="POST" action="{{ path('plan_index') }}" id="planForm">
                        <div class="form-grid">
                            <div class="form-group">
                                <label>Poids (kg)</label>
                                <input type="number" name="poids" min="30" max="300" step="0.1" required value="{{ formData.poids|default('') }}" class="form-control" placeholder="Ex: 75">
                            </div>
                            <div class="form-group">
                                <label>Taille (cm)</label>
                                <input type="number" name="taille" min="100" max="250" required value="{{ formData.taille|default('') }}" class="form-control" placeholder="Ex: 175">
                            </div>
                            <div class="form-group">
                                <label>Âge</label>
                                <input type="number" name="age" min="10" max="100" required value="{{ formData.age|default('') }}" class="form-control" placeholder="Ex: 25">
                            </div>
                            <div class="form-group">
                                <label>Sexe</label>
                                <select name="sexe" required class="form-control">
                                    <option value="">-- Choisir --</option>
                                    <option value="homme" {{ (formData.sexe|default('')) == 'homme' ? 'selected' : '' }}>Homme</option>
                                    <option value="femme" {{ (formData.sexe|default('')) == 'femme' ? 'selected' : '' }}>Femme</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Objectif</label>
                                <select name="objectif" required class="form-control">
                                    <option value="">-- Choisir --</option>
                                    <option value="perte_poids" {{ (formData.objectif|default('')) == 'perte_poids' ? 'selected' : '' }}>🔥 Perte de poids</option>
                                    <option value="prise_masse" {{ (formData.objectif|default('')) == 'prise_masse' ? 'selected' : '' }}>💪 Prise de masse</option>
                                    <option value="maintien"    {{ (formData.objectif|default('')) == 'maintien'    ? 'selected' : '' }}>⚖️ Maintien du poids</option>
                                    <option value="sante"       {{ (formData.objectif|default('')) == 'sante'       ? 'selected' : '' }}>❤️ Santé générale</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Niveau d'activité</label>
                                <select name="exercice" required class="form-control">
                                    <option value="">-- Choisir --</option>
                                    <option value="sedentaire" {{ (formData.exercice|default('')) == 'sedentaire' ? 'selected' : '' }}>🛋️ Sédentaire</option>
                                    <option value="leger"      {{ (formData.exercice|default('')) == 'leger'      ? 'selected' : '' }}>🚶 Légèrement actif</option>
                                    <option value="modere"     {{ (formData.exercice|default('')) == 'modere'     ? 'selected' : '' }}>🏃 Modérément actif</option>
                                    <option value="actif"      {{ (formData.exercice|default('')) == 'actif'      ? 'selected' : '' }}>⚡ Très actif</option>
                                </select>
                            </div>
                            <div class="form-group full-width">
                                <label>Restrictions alimentaires <span style="color:var(--gray); font-weight:400;">(optionnel)</span></label>
                                <input type="text" name="restrictions" value="{{ formData.restrictions|default('') }}" class="form-control" placeholder="Ex: végétarien, sans gluten, allergie aux noix...">
                            </div>
                        </div>
                        <div style="display:flex; gap:12px; margin-top:20px; flex-wrap:wrap; align-items:center;">
                            <button type="submit" class="btn-primary" onclick="showLoading()">
                                <i class="bi bi-stars"></i> Générer mon plan IA
                            </button>
                            {% if plan %}
                            <button type="submit" form="pdfForm" class="btn-pdf">
                                <i class="bi bi-file-earmark-pdf-fill"></i> Télécharger PDF
                            </button>
                            {% endif %}
                        </div>
                    </form>

                    {% if plan %}
                    <form id="pdfForm" method="POST" action="{{ path('plan_pdf') }}" style="display:none;">
                        <input type="hidden" name="poids"        value="{{ formData.poids|default('') }}">
                        <input type="hidden" name="taille"       value="{{ formData.taille|default('') }}">
                        <input type="hidden" name="age"          value="{{ formData.age|default('') }}">
                        <input type="hidden" name="sexe"         value="{{ formData.sexe|default('') }}">
                        <input type="hidden" name="objectif"     value="{{ formData.objectif|default('') }}">
                        <input type="hidden" name="exercice"     value="{{ formData.exercice|default('') }}">
                        <input type="hidden" name="restrictions" value="{{ formData.restrictions|default('') }}">
                    </form>
                    {% endif %}
                </div>
            </div>

            {% if plan %}

            <!-- Stats -->
            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-icon icon-teal"><i class="bi bi-speedometer2"></i></div>
                    <div><div class="stat-value">{{ plan.imc }}</div><div class="stat-label">IMC calculé</div></div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon icon-amber"><i class="bi bi-fire"></i></div>
                    <div><div class="stat-value">{{ plan.calories_journalieres }}</div><div class="stat-label">Calories / jour</div></div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon icon-blue"><i class="bi bi-droplet-fill"></i></div>
                    <div><div class="stat-value">{{ plan.hydratation.litres_par_jour }}L</div><div class="stat-label">Eau / jour</div></div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon icon-purple"><i class="bi bi-moon-stars-fill"></i></div>
                    <div><div class="stat-value">{{ plan.sommeil.heures_recommandees }}</div><div class="stat-label">Sommeil / nuit</div></div>
                </div>
            </div>

            <!-- Resume -->
            <div class="card">
                <div class="card-header"><div class="card-title"><i class="bi bi-stars"></i> Résumé de votre plan</div></div>
                <div class="card-body"><p style="font-size:14px; color:var(--dark); line-height:1.7;">{{ plan.resume }}</p></div>
            </div>

            <!-- Conseils généraux -->
            <div class="card">
                <div class="card-header"><div class="card-title"><i class="bi bi-lightbulb-fill"></i> Conseils Généraux</div></div>
                <div class="card-body">
                    <ul class="conseils-list">
                        {% for conseil in plan.conseils_generaux %}
                        <li>
                            <div class="conseil-check"><i class="bi bi-check"></i></div>
                            {{ conseil }}
                        </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>

            <!-- Meal plan -->
            <div class="card">
                <div class="card-header"><div class="card-title"><i class="bi bi-egg-fried"></i> Plan Alimentaire de la Semaine</div></div>
                <div class="card-body" style="padding: 0 0 4px 0; overflow-x: auto;">
                    <table class="plan-table">
                        <thead>
                            <tr>
                                <th style="padding-left:24px;">Jour</th>
                                <th>🌅 Petit-déjeuner</th>
                                <th>☀️ Déjeuner</th>
                                <th>🌙 Dîner</th>
                                <th style="padding-right:24px;">🍎 Collation</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% set jours = ['lundi','mardi','mercredi','jeudi','vendredi','samedi','dimanche'] %}
                            {% for jour in jours %}
                            <tr>
                                <td style="padding-left:24px;"><span class="day-label">{{ jour }}</span></td>
                                <td>{{ plan.repas[jour].petit_dejeuner|default('-') }}</td>
                                <td>{{ plan.repas[jour].dejeuner|default('-') }}</td>
                                <td>{{ plan.repas[jour].diner|default('-') }}</td>
                                <td style="padding-right:24px;">{{ plan.repas[jour].collation|default('-') }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Exercise plan -->
            <div class="card">
                <div class="card-header"><div class="card-title"><i class="bi bi-person-running"></i> Plan d'Exercices de la Semaine</div></div>
                <div class="card-body">
                    <div class="exercise-grid">
                        {% set jours = ['lundi','mardi','mercredi','jeudi','vendredi','samedi','dimanche'] %}
                        {% for jour in jours %}
                        {% set ex = plan.exercices[jour] %}
                        <div class="exercise-box {{ ex.type == 'repos' ? 'repos' : '' }}">
                            <div class="exercise-day">{{ jour }}</div>
                            <div class="exercise-type">{{ ex.type == 'repos' ? '😴 Repos' : ex.type }}</div>
                            {% if ex.type != 'repos' %}
                            <div class="exercise-meta">⏱ {{ ex.duree }}</div>
                            <div class="exercise-meta">{{ ex.intensite }}</div>
                            {% endif %}
                            <div class="exercise-desc">{{ ex.description }}</div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <!-- Hydration + Sleep -->
            <div class="tips-grid">
                <div class="tips-card hydration">
                    <div class="tips-card-title"><i class="bi bi-droplet-fill"></i> Hydratation</div>
                    <div class="tips-card-subtitle">Objectif : {{ plan.hydratation.litres_par_jour }}L par jour</div>
                    <ul class="tips-list">
                        {% for conseil in plan.hydratation.conseils %}
                        <li><span>💧</span> {{ conseil }}</li>
                        {% endfor %}
                    </ul>
                </div>
                <div class="tips-card sleep">
                    <div class="tips-card-title"><i class="bi bi-moon-stars-fill"></i> Sommeil</div>
                    <div class="tips-card-subtitle">Objectif : {{ plan.sommeil.heures_recommandees }} par nuit</div>
                    <ul class="tips-list">
                        {% for conseil in plan.sommeil.conseils %}
                        <li><span>🌙</span> {{ conseil }}</li>
                        {% endfor %}
                    </ul>
                </div>
            </div>

            {% endif %}

        </main>
    </div>

    <script>
        const menuToggle = document.getElementById('menuToggle');
        const sidebar    = document.getElementById('sidebar');
        const overlay    = document.getElementById('sidebarOverlay');
        menuToggle.addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('open'); });
        overlay.addEventListener('click',   () => { sidebar.classList.remove('open'); overlay.classList.remove('open'); });
        function showLoading() { document.getElementById('loadingOverlay').classList.add('active'); }
    </script>

</body>
</html>
