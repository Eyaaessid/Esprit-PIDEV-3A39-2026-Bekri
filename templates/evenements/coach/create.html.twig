{% extends 'base.html.twig' %}

{% block title %}Créer un événement - MediNest{% endblock %}

{% block body_class %}create-evenement-page{% endblock %}

{% block main %}

    <!-- Page Title -->
    <div class="page-title">
      <div class="heading">
        <div class="container">
          <div class="row d-flex justify-content-center text-center">
            <div class="col-lg-8">
              <h1 class="heading-title">Créer un événement</h1>
              <p class="mb-0">
                Organisez un nouvel événement bien-être pour votre communauté.
              </p>
            </div>
          </div>
        </div>
      </div>
      <nav class="breadcrumbs">
        <div class="container">
          <ol>
            <li><a href="{{ path('home') }}">Home</a></li>
            <li><a href="{{ path('evenements_coach_dashboard') }}">Dashboard</a></li>
            <li class="current">Créer un événement</li>
          </ol>
        </div>
      </nav>
    </div><!-- End Page Title -->

    <!-- Create Form Section -->
    <section id="create-evenement" class="create-evenement section">

      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="row justify-content-center">
          <div class="col-lg-8">
            
            <div class="card shadow-sm">
              <div class="card-body p-4">
                
                <form method="post" action="{{ path('evenements_coach_create') }}">
                  
                  <div class="row gy-4">
                    
                    <div class="col-md-12">
                      <label for="titre" class="form-label">Titre de l'événement *</label>
                      <input type="text" class="form-control" id="titre" name="titre" required 
                             placeholder="Ex: Atelier Méditation Pleine Conscience">
                    </div>

                    <div class="col-md-12">
                      <label for="description" class="form-label">Description *</label>
                      <textarea class="form-control" id="description" name="description" rows="5" required
                                placeholder="Décrivez votre événement en détail..."></textarea>
                    </div>

                    <div class="col-md-6">
                      <label for="type" class="form-label">Type d'événement *</label>
                      <select class="form-select" id="type" name="type" required>
                        <option value="">Sélectionner un type</option>
                        <option value="SESSION">Session</option>
                        <option value="EVENT">Événement</option>
                      </select>
                    </div>

                    <div class="col-md-6">
                      <label for="capaciteMax" class="form-label">Capacité maximale *</label>
                      <input type="number" class="form-control" id="capaciteMax" name="capaciteMax" 
                             min="1" required placeholder="Ex: 20">
                    </div>

                    <div class="col-md-6">
                      <label for="dateDebut" class="form-label">Date et heure de début *</label>
                      <input type="datetime-local" class="form-control" id="dateDebut" name="dateDebut" required>
                    </div>

                    <div class="col-md-6">
                      <label for="dateFin" class="form-label">Date et heure de fin</label>
                      <input type="datetime-local" class="form-control" id="dateFin" name="dateFin">
                    </div>

                    <div class="col-md-12">
                      <label for="lienSession" class="form-label">Lieu ou lien de session</label>
                      <input type="text" class="form-control" id="lienSession" name="lienSession"
                             placeholder="Ex: Salle Zen, Bâtiment A ou https://zoom.us/...">
                      <small class="text-muted">Indiquez le lieu physique ou le lien pour une session en ligne</small>
                    </div>

                    <div class="col-md-6">
                      <label for="statut" class="form-label">Statut *</label>
                      <select class="form-select" id="statut" name="statut" required>
                        <option value="PLANNED">Planifié</option>
                        <option value="OPEN" selected>Ouvert aux inscriptions</option>
                        <option value="FULL">Complet</option>
                        <option value="CANCELLED">Annulé</option>
                        <option value="FINISHED">Terminé</option>
                      </select>
                    </div>

                  </div>

                  <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                      <i class="bi bi-check-circle me-2"></i>Créer l'événement
                    </button>
                    <a href="{{ path('evenements_coach_dashboard') }}" class="btn btn-outline-secondary">
                      <i class="bi bi-x-circle me-2"></i>Annuler
                    </a>
                  </div>

                </form>

              </div>
            </div>

          </div>
        </div>

      </div>

    </section><!-- End Create Form Section -->

{% endblock %}
