{% extends 'base.html.twig' %}

{% block title %}Dashboard Coach - MediNest{% endblock %}

{% block body_class %}coach-dashboard-page{% endblock %}

{% block main %}

    <!-- Page Title -->
    <div class="page-title">
      <div class="heading">
        <div class="container">
          <div class="row d-flex justify-content-center text-center">
            <div class="col-lg-8">
              <h1 class="heading-title">Dashboard Coach</h1>
              <p class="mb-0">
                Gérez vos événements et suivez les participations en temps réel.
              </p>
            </div>
          </div>
        </div>
      </div>
      <nav class="breadcrumbs">
        <div class="container">
          <ol>
            <li><a href="{{ path('home') }}">Home</a></li>
            <li><a href="{{ path('evenements_list') }}">Événements</a></li>
            <li class="current">Dashboard Coach</li>
          </ol>
        </div>
      </nav>
    </div><!-- End Page Title -->

    <!-- Dashboard Section -->
    <section id="coach-dashboard" class="coach-dashboard section">

      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <!-- Quick Actions -->
        <div class="row mb-4">
          <div class="col-12">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
              <h4 class="mb-0">Vue d'ensemble</h4>
              <div class="d-flex gap-2">
                <a href="{{ path('evenements_coach_create') }}" class="btn btn-primary">
                  <i class="bi bi-plus-circle me-2"></i>Créer un événement
                </a>
                <a href="{{ path('evenements_coach_list') }}" class="btn btn-outline-primary">
                  <i class="bi bi-list-ul me-2"></i>Mes événements
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Statistics Cards -->
        <div class="row gy-4 mb-5">
          
          <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="100">
            <div class="card text-center shadow-sm h-100">
              <div class="card-body">
                <div class="mb-3">
                  <i class="bi bi-calendar-event fs-1 text-primary"></i>
                </div>
                <h3 class="mb-1">{{ totalEvenements }}</h3>
                <p class="text-muted mb-0">Total événements</p>
              </div>
            </div>
          </div>

          <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="200">
            <div class="card text-center shadow-sm h-100">
              <div class="card-body">
                <div class="mb-3">
                  <i class="bi bi-people fs-1 text-success"></i>
                </div>
                <h3 class="mb-1">{{ totalParticipations }}</h3>
                <p class="text-muted mb-0">Participants inscrits</p>
              </div>
            </div>
          </div>

          <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="300">
            <div class="card text-center shadow-sm h-100">
              <div class="card-body">
                <div class="mb-3">
                  <i class="bi bi-calendar-check fs-1 text-info"></i>
                </div>
                <h3 class="mb-1">{{ evenementsAVenir }}</h3>
                <p class="text-muted mb-0">Événements à venir</p>
              </div>
            </div>
          </div>

          <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="400">
            <div class="card text-center shadow-sm h-100">
              <div class="card-body">
                <div class="mb-3">
                  <i class="bi bi-check-circle fs-1 text-secondary"></i>
                </div>
                <h3 class="mb-1">{{ evenementsTermines }}</h3>
                <p class="text-muted mb-0">Événements terminés</p>
              </div>
            </div>
          </div>

        </div>

        <!-- Recent Events -->
        <div class="row">
          <div class="col-12">
            <div class="card shadow-sm">
              <div class="card-header bg-white">
                <h4 class="mb-0">
                  <i class="bi bi-clock-history text-primary me-2"></i>
                  Événements récents
                </h4>
              </div>
              <div class="card-body p-0">
                {% if evenementsRecents|length > 0 %}
                  <div class="table-responsive">
                    <table class="table table-hover mb-0">
                      <thead class="table-light">
                        <tr>
                          <th>Titre</th>
                          <th>Date</th>
                          <th>Type</th>
                          <th>Statut</th>
                          <th>Capacité</th>
                          <th class="text-center">Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for evenement in evenementsRecents %}
                        <tr>
                          <td><strong>{{ evenement.titre }}</strong></td>
                          <td>
                            <i class="bi bi-calendar3 text-muted"></i>
                            {{ evenement.dateDebut|date('d/m/Y H:i') }}
                          </td>
                          <td>
                            <span class="badge bg-primary">{{ evenement.type.value }}</span>
                          </td>
                          <td>
                            {% if evenement.statut.value == 'OPEN' %}
                              <span class="badge bg-success">Ouvert</span>
                            {% elseif evenement.statut.value == 'FULL' %}
                              <span class="badge bg-danger">Complet</span>
                            {% elseif evenement.statut.value == 'PLANNED' %}
                              <span class="badge bg-info">Planifié</span>
                            {% elseif evenement.statut.value == 'FINISHED' %}
                              <span class="badge bg-secondary">Terminé</span>
                            {% endif %}
                          </td>
                          <td>
                            <i class="bi bi-people text-muted"></i>
                            {{ evenement.capaciteMax }}
                          </td>
                          <td class="text-center">
                            <a href="{{ path('evenements_coach_participants', {id: evenement.id}) }}" 
                               class="btn btn-sm btn-outline-primary" 
                               title="Participants">
                              <i class="bi bi-people"></i>
                            </a>
                            <a href="{{ path('evenements_coach_edit', {id: evenement.id}) }}" 
                               class="btn btn-sm btn-outline-secondary" 
                               title="Modifier">
                              <i class="bi bi-pencil"></i>
                            </a>
                          </td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                {% else %}
                  <div class="text-center py-5">
                    <i class="bi bi-calendar-x fs-1 text-muted mb-3 d-block"></i>
                    <h5 class="text-muted">Aucun événement créé</h5>
                    <p class="text-muted mb-4">Commencez par créer votre premier événement.</p>
                    <a href="{{ path('evenements_coach_create') }}" class="btn btn-primary">
                      <i class="bi bi-plus-circle me-2"></i>Créer un événement
                    </a>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        </div>

      </div>

    </section><!-- End Dashboard Section -->

{% endblock %}
