{% extends 'base.html.twig' %}

{% block title %}Mes Participations - MediNest{% endblock %}

{% block body_class %}mes-participations-page{% endblock %}

{% block main %}

    <!-- Page Title -->
    <div class="page-title">
      <div class="heading">
        <div class="container">
          <div class="row d-flex justify-content-center text-center">
            <div class="col-lg-8">
              <h1 class="heading-title">Mes Participations</h1>
              <p class="mb-0">
                Consultez l'historique de vos participations aux événements bien-être.
                Gérez vos inscriptions en cours et à venir.
              </p>
            </div>
          </div>
        </div>
      </div>
      <nav class="breadcrumbs">
        <div class="container">
          <ol>
            <li><a href="{{ path('home') }}">Home</a></li>
            <li><a href="{{ path('evenements_list') }}">Événements</a></li>
            <li class="current">Mes Participations</li>
          </ol>
        </div>
      </nav>
    </div><!-- End Page Title -->

    <!-- Flash Messages -->
    {% for message in app.flashes('success') %}
    <div class="container mt-4">
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>{{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    </div>
    {% endfor %}

    <!-- Participations Section -->
    <section id="mes-participations" class="mes-participations section">

      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <!-- Stats Cards -->
        <div class="row mb-4">
          {% set inscritCount = participations|filter(p => p.statut.value == 'INSCRIT')|length %}
          {% set annuleCount = participations|filter(p => p.statut.value == 'ANNULE')|length %}
          {% set presentCount = participations|filter(p => p.statut.value == 'PRESENT')|length %}

          <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
            <div class="card text-center shadow-sm">
              <div class="card-body">
                <i class="bi bi-calendar-check fs-1 text-success mb-3"></i>
                <h3 class="mb-0">{{ inscritCount }}</h3>
                <p class="text-muted mb-0">Inscriptions actives</p>
              </div>
            </div>
          </div>

          <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
            <div class="card text-center shadow-sm">
              <div class="card-body">
                <i class="bi bi-check-circle fs-1 text-primary mb-3"></i>
                <h3 class="mb-0">{{ presentCount }}</h3>
                <p class="text-muted mb-0">Événements complétés</p>
              </div>
            </div>
          </div>

          <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
            <div class="card text-center shadow-sm">
              <div class="card-body">
                <i class="bi bi-x-circle fs-1 text-danger mb-3"></i>
                <h3 class="mb-0">{{ annuleCount }}</h3>
                <p class="text-muted mb-0">Annulations</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Participations List -->
        <div class="row">
          <div class="col-12">
            <div class="card shadow-sm">
              <div class="card-header bg-white">
                <div class="d-flex justify-content-between align-items-center">
                  <h4 class="mb-0">
                    <i class="bi bi-list-ul text-primary me-2"></i>
                    Historique des participations
                  </h4>
                  <a href="{{ path('evenements_list') }}" class="btn btn-primary btn-sm">
                    <i class="bi bi-plus-circle me-1"></i>
                    Découvrir les événements
                  </a>
                </div>
              </div>
              <div class="card-body p-0">
                {% if participations|length > 0 %}
                  <div class="table-responsive">
                    <table class="table table-hover mb-0">
                      <thead class="table-light">
                        <tr>
                          <th>Événement</th>
                          <th>Date</th>
                          <th>Type</th>
                          <th>Statut</th>
                          <th>Inscription</th>
                          <th class="text-center">Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for participation in participations %}
                        <tr>
                          <td>
                            <strong>{{ participation.evenement.titre }}</strong>
                            {% if participation.evenement.lienSession %}
                            <br>
                            <small class="text-muted">
                              <i class="bi bi-geo-alt"></i>
                              {{ participation.evenement.lienSession|length > 40 ? participation.evenement.lienSession|slice(0, 40) ~ '...' : participation.evenement.lienSession }}
                            </small>
                            {% endif %}
                          </td>
                          <td>
                            <i class="bi bi-calendar3 text-muted"></i>
                            {{ participation.evenement.dateDebut|date('d/m/Y') }}
                            <br>
                            <small class="text-muted">{{ participation.evenement.dateDebut|date('H:i') }}</small>
                          </td>
                          <td>
                            <span class="badge bg-primary">
                              {{ participation.evenement.type.value }}
                            </span>
                          </td>
                          <td>
                            {% if participation.statut.value == 'INSCRIT' %}
                              <span class="badge bg-success">
                                <i class="bi bi-check-circle"></i> Inscrit
                              </span>
                            {% elseif participation.statut.value == 'ANNULE' %}
                              <span class="badge bg-danger">
                                <i class="bi bi-x-circle"></i> Annulé
                              </span>
                            {% elseif participation.statut.value == 'PRESENT' %}
                              <span class="badge bg-info">
                                <i class="bi bi-person-check"></i> Présent
                              </span>
                            {% elseif participation.statut.value == 'ABSENT' %}
                              <span class="badge bg-warning">
                                <i class="bi bi-person-x"></i> Absent
                              </span>
                            {% endif %}
                          </td>
                          <td>
                            <small class="text-muted">
                              {{ participation.dateInscription|date('d/m/Y H:i') }}
                            </small>
                          </td>
                          <td class="text-center">
                            <a href="{{ path('evenements_show', {id: participation.evenement.id}) }}" 
                               class="btn btn-sm btn-outline-primary" 
                               title="Voir les détails">
                              <i class="bi bi-eye"></i>
                            </a>
                            
                            {% if participation.statut.value == 'INSCRIT' and participation.evenement.dateDebut > date() %}
                              <form method="post" 
                                    action="{{ path('evenements_annuler', {id: participation.evenement.id}) }}" 
                                    class="d-inline"
                                    onsubmit="return confirm('Êtes-vous sûr de vouloir annuler cette participation ?');">
                                <button type="submit" 
                                        class="btn btn-sm btn-outline-danger" 
                                        title="Annuler">
                                  <i class="bi bi-x-circle"></i>
                                </button>
                              </form>
                            {% endif %}
                          </td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                {% else %}
                  <div class="text-center py-5">
                    <i class="bi bi-calendar-x fs-1 text-muted mb-3 d-block"></i>
                    <h5 class="text-muted">Aucune participation enregistrée</h5>
                    <p class="text-muted mb-4">Vous n'avez pas encore participé à un événement.</p>
                    <a href="{{ path('evenements_list') }}" class="btn btn-primary">
                      <i class="bi bi-calendar-plus me-2"></i>
                      Découvrir les événements
                    </a>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        </div>

      </div>

    </section><!-- End Participations Section -->

{% endblock %}
