{% extends 'base.html.twig' %}

{% block title %}Événements Bien-être - MediNest{% endblock %}

{% block body_class %}index-page{% endblock %}

{% block main %}

    <!-- Hero Section -->
    <section id="hero" class="hero section">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-lg-5">
            <div class="hero-image" data-aos="fade-right" data-aos-delay="100">
              <img src="{{ asset('assets/img/health/staff-8.webp') }}" alt="Événements Bien-être" class="img-fluid main-image">
              <div class="floating-card emergency-card" data-aos="fade-up" data-aos-delay="300">
                <div class="card-content">
                  <i class="bi bi-calendar-event-fill"></i>
                  <div class="text">
                    <span class="label">Événements Disponibles</span>
                    <span class="number">6 Événements</span>
                  </div>
                </div>
              </div>
              <div class="floating-card stats-card" data-aos="fade-up" data-aos-delay="400">
                <div class="stat-item">
                  <span class="number">100+</span>
                  <span class="label">Participants</span>
                </div>
                <div class="stat-item">
                  <span class="number">98%</span>
                  <span class="label">Satisfaction</span>
                </div>
              </div>
            </div>
          </div>

          <div class="col-lg-7">
            <div class="hero-content" data-aos="fade-left" data-aos-delay="200">
              <div class="badge-container">
                <span class="hero-badge">Module Événements & Participation</span>
              </div>

              <h1 class="hero-title">Participez aux Événements Bien-être</h1>
              <p class="hero-description">Découvrez nos ateliers, conférences et sessions guidées pour améliorer votre santé mentale et votre bien-être. Rejoignez une communauté engagée.</p>

              <div class="hero-stats">
                <div class="stat-group">
                  <div class="stat">
                    <i class="bi bi-calendar-check"></i>
                    <div class="stat-text">
                      <span class="number">6</span>
                      <span class="label">Événements Actifs</span>
                    </div>
                  </div>
                  <div class="stat">
                    <i class="bi bi-people"></i>
                    <div class="stat-text">
                      <span class="number">150+</span>
                      <span class="label">Participants</span>
                    </div>
                  </div>
                  <div class="stat">
                    <i class="bi bi-award"></i>
                    <div class="stat-text">
                      <span class="number">100%</span>
                      <span class="label">Gratuit</span>
                    </div>
                  </div>
                </div>
              </div>

              <div class="cta-section">
                <div class="cta-buttons">
                  <a href="{{ path('evenements_list') }}" class="btn btn-primary">Voir les Événements</a>
                  <a href="{{ path('evenements_mes_participations') }}" class="btn btn-secondary">
                    <i class="bi bi-calendar-check"></i>
                    Mes Participations
                  </a>
                </div>

                <div class="quick-actions">
                  <a href="{{ path('evenements_coach_dashboard') }}" class="action-link">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard Coach</span>
                  </a>
                  <a href="{{ path('evenements_coach_create') }}" class="action-link">
                    <i class="bi bi-plus-circle"></i>
                    <span>Créer un Événement</span>
                  </a>
                  <a href="{{ path('evenements_admin_supervision') }}" class="action-link">
                    <i class="bi bi-shield-check"></i>
                    <span>Supervision Admin</span>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="background-elements">
        <div class="bg-shape shape-1"></div>
        <div class="bg-shape shape-2"></div>
        <div class="bg-pattern"></div>
      </div>
    </section>

    <!-- Featured Services Section -->
    <section id="featured-services" class="featured-services section">

      <!-- Section Title -->
      <div class="container section-title" data-aos="fade-up">
        <h2>Espaces d'Accès</h2>
        <p>Choisissez votre espace selon votre rôle dans la plateforme</p>
      </div><!-- End Section Title -->

      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="row gy-4">

          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="200">
            <div class="service-card">
              <div class="service-icon">
                <i class="fas fa-user-circle"></i>
              </div>
              <div class="service-image">
                <img src="{{ asset('assets/img/health/consultation-3.webp') }}" alt="Espace Utilisateur" class="img-fluid" loading="lazy">
              </div>
              <div class="service-content">
                <h3>Espace Utilisateur</h3>
                <p>Consultez les événements disponibles, inscrivez-vous et gérez vos participations. Accédez à votre historique complet.</p>
                <a href="{{ path('evenements_list') }}" class="service-link">Accéder <i class="fas fa-arrow-right"></i></a>
              </div>
            </div>
          </div><!-- End Service Card -->

          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="300">
            <div class="service-card">
              <div class="service-icon">
                <i class="fas fa-user-tie"></i>
              </div>
              <div class="service-image">
                <img src="{{ asset('assets/img/health/staff-3.webp') }}" alt="Espace Coach" class="img-fluid" loading="lazy">
              </div>
              <div class="service-content">
                <h3>Espace Coach</h3>
                <p>Créez et gérez vos événements, consultez les participants et suivez les statistiques en temps réel via votre dashboard.</p>
                <a href="{{ path('evenements_coach_dashboard') }}" class="service-link">Accéder <i class="fas fa-arrow-right"></i></a>
              </div>
            </div>
          </div><!-- End Service Card -->

          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="400">
            <div class="service-card">
              <div class="service-icon">
                <i class="fas fa-shield-alt"></i>
              </div>
              <div class="service-image">
                <img src="{{ asset('assets/img/health/staff-1.webp') }}" alt="Espace Admin" class="img-fluid" loading="lazy">
              </div>
              <div class="service-content">
                <h3>Espace Administrateur</h3>
                <p>Supervisez tous les événements de la plateforme avec une vue globale et des statistiques complètes.</p>
                <a href="{{ path('evenements_admin_supervision') }}" class="service-link">Accéder <i class="fas fa-arrow-right"></i></a>
              </div>
            </div>
          </div><!-- End Service Card -->

        </div>

      </div>

    </section>

    <!-- Home About Section -->
    <section id="home-about" class="home-about section">

      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="row">
          <div class="col-lg-8 mx-auto text-center mb-5" data-aos="fade-up" data-aos-delay="150">
            <h2 class="section-heading">Fonctionnalités du Module</h2>
            <p class="lead-description">Un système complet de gestion d'événements bien-être avec inscription, participation et supervision.</p>
          </div>
        </div>

        <div class="row align-items-center gy-5">
          <div class="col-lg-7" data-aos="fade-right" data-aos-delay="200">
            <div class="image-grid">
              <div class="primary-image">
                <img src="{{ asset('assets/img/health/facilities-6.webp') }}" alt="Événements bien-être" class="img-fluid">
                <div class="certification-badge">
                  <i class="bi bi-award"></i>
                  <span>Module Complet</span>
                </div>
              </div>
              <div class="secondary-images">
                <div class="small-image">
                  <img src="{{ asset('assets/img/health/consultation-4.webp') }}" alt="Participation" class="img-fluid">
                </div>
                <div class="small-image">
                  <img src="{{ asset('assets/img/health/staff-5.webp') }}" alt="Gestion" class="img-fluid">
                </div>
              </div>
            </div>
          </div>

          <div class="col-lg-5" data-aos="fade-left" data-aos-delay="300">
            <div class="content-wrapper">
              <div class="highlight-box">
                <div class="highlight-icon">
                  <i class="bi bi-calendar-event-fill"></i>
                </div>
                <div class="highlight-content">
                  <h4>Gestion Complète</h4>
                  <p>Créez, modifiez et gérez vos événements avec un système CRUD complet et intuitif.</p>
                </div>
              </div>

              <div class="feature-list">
                <div class="feature-item">
                  <div class="feature-icon">
                    <i class="bi bi-check-circle-fill"></i>
                  </div>
                  <div class="feature-text">Inscription et annulation en un clic</div>
                </div>
                <div class="feature-item">
                  <div class="feature-icon">
                    <i class="bi bi-check-circle-fill"></i>
                  </div>
                  <div class="feature-text">Dashboard avec statistiques en temps réel</div>
                </div>
                <div class="feature-item">
                  <div class="feature-icon">
                    <i class="bi bi-check-circle-fill"></i>
                  </div>
                  <div class="feature-text">Gestion automatique des capacités</div>
                </div>
                <div class="feature-item">
                  <div class="feature-icon">
                    <i class="bi bi-check-circle-fill"></i>
                  </div>
                  <div class="feature-text">Supervision administrative complète</div>
                </div>
              </div>

              <div class="metrics-row">
                <div class="metric-box">
                  <div class="metric-number">
                    <span class="purecounter" data-purecounter-start="0" data-purecounter-end="6" data-purecounter-duration="0">6</span>
                  </div>
                  <div class="metric-label">Événements Actifs</div>
                </div>
                <div class="metric-box">
                  <div class="metric-number">
                    <span class="purecounter" data-purecounter-start="0" data-purecounter-end="150" data-purecounter-duration="0">150</span>+
                  </div>
                  <div class="metric-label">Participants</div>
                </div>
              </div>

              <div class="action-buttons">
                <a href="{{ path('evenements_list') }}" class="btn-explore">Découvrir les Événements</a>
                <a href="{{ path('evenements_coach_create') }}" class="btn-contact">
                  <i class="bi bi-plus-circle"></i>
                  Créer un Événement
                </a>
              </div>
            </div>
          </div>
        </div>

      </div>

    </section>

{% endblock %}
