<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mes Objectifs — Bekri</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --dark:       #1a2332;
            --gray:       #64748b;
            --light:      #f8fafc;
            --white:      #ffffff;
            --sidebar-w:  260px;
            --shadow-sm:  0 2px 12px rgba(0,0,0,0.06);
            --shadow:     0 8px 30px rgba(0,0,0,0.10);
            --radius:     16px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--light);
            color: var(--dark);
            display: flex;
            min-height: 100vh;
        }

        /* ── SIDEBAR ─────────────────────────────────────────────── */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--dark);
            min-height: 100vh;
            position: fixed;
            top: 0; left: 0;
            display: flex;
            flex-direction: column;
            z-index: 100;
            transition: transform 0.3s ease;
        }

        .sidebar-logo {
            padding: 28px 24px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }

        .sidebar-logo img { height: 36px; width: auto; }

        .sidebar-logo-text {
            font-size: 20px;
            font-weight: 800;
            background: linear-gradient(135deg, var(--teal), #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .sidebar-user {
            padding: 20px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }

        .sidebar-avatar {
            width: 42px; height: 42px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--teal), var(--purple));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 16px;
            flex-shrink: 0;
        }

        .sidebar-user-name { font-size: 14px; font-weight: 600; color: white; }
        .sidebar-user-role { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 2px; }

        .sidebar-nav { flex: 1; padding: 16px 0; overflow-y: auto; }

        .nav-section-label {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: rgba(255,255,255,0.25);
            padding: 12px 24px 6px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 24px;
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s;
            border-left: 3px solid transparent;
        }

        .nav-item:hover { color: white; background: rgba(255,255,255,0.05); }

        .nav-item.active {
            color: var(--teal);
            background: rgba(32,178,170,0.1);
            border-left-color: var(--teal);
        }

        .nav-item i { width: 20px; text-align: center; font-size: 16px; }

        .sidebar-footer {
            padding: 16px 0;
            border-top: 1px solid rgba(255,255,255,0.07);
        }

        /* ── MAIN ────────────────────────────────────────────────── */
        .main { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh; }

        /* ── TOPBAR ──────────────────────────────────────────────── */
        .topbar {
            background: white;
            padding: 0 32px;
            height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: var(--shadow-sm);
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .topbar-title { font-size: 18px; font-weight: 700; color: var(--dark); }
        .topbar-sub   { font-size: 13px; color: var(--gray); margin-top: 2px; }

        .topbar-right { display: flex; align-items: center; gap: 12px; }

        .topbar-btn {
            width: 40px; height: 40px;
            border-radius: 10px;
            background: var(--light);
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--gray);
            font-size: 16px;
            text-decoration: none;
            transition: all 0.2s;
        }

        .topbar-btn:hover { background: var(--teal-light); color: var(--teal-dark); }

        .topbar-avatar {
            width: 40px; height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--teal), var(--purple));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 14px;
            text-decoration: none;
        }

        /* ── CONTENT ─────────────────────────────────────────────── */
        .content { padding: 32px; flex: 1; }

        /* ── SEARCH BAR ──────────────────────────────────────────── */
        .toolbar {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
            background: white;
            padding: 20px 24px;
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            border: 1px solid #f1f5f9;
        }

        .toolbar-left { display: flex; gap: 10px; flex-wrap: wrap; flex: 1; }

        .form-select, .form-input-search {
            padding: 10px 14px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            font-size: 14px;
            color: var(--dark);
            font-family: 'Inter', sans-serif;
            background: var(--light);
            outline: none;
            transition: all 0.25s;
        }

        .form-select:focus, .form-input-search:focus {
            border-color: var(--teal);
            background: white;
            box-shadow: 0 0 0 3px rgba(32,178,170,0.1);
        }

        .form-input-search { flex: 1; min-width: 180px; }

        .btn {
            padding: 10px 18px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            transition: all 0.25s;
            font-family: 'Inter', sans-serif;
        }

        .btn-teal {
            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
            color: white;
            box-shadow: 0 3px 10px rgba(32,178,170,0.25);
        }

        .btn-teal:hover { transform: translateY(-1px); box-shadow: 0 5px 15px rgba(32,178,170,0.35); }

        .btn-ghost { background: var(--light); color: var(--gray); border: 1px solid #e2e8f0; }
        .btn-ghost:hover { background: #e2e8f0; color: var(--dark); }

        /* ── EMPTY STATE ─────────────────────────────────────────── */
        .empty-state {
            background: white;
            border-radius: var(--radius);
            padding: 80px 40px;
            text-align: center;
            box-shadow: var(--shadow-sm);
            border: 1px solid #f1f5f9;
        }

        .empty-icon {
            width: 88px; height: 88px;
            background: var(--teal-light);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            font-size: 36px;
            color: var(--teal-dark);
        }

        .empty-state h3 { font-size: 22px; font-weight: 700; color: var(--dark); margin-bottom: 10px; }
        .empty-state p  { font-size: 15px; color: var(--gray); margin-bottom: 28px; max-width: 400px; margin-left: auto; margin-right: auto; }

        /* ── CARDS GRID ──────────────────────────────────────────── */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        .obj-card {
            background: white;
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            border: 1px solid #f1f5f9;
            transition: all 0.3s;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .obj-card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }

        .obj-card-top {
            padding: 20px 20px 16px;
            border-bottom: 1px solid #f1f5f9;
        }

        .obj-card-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 10px;
        }

        .obj-title { font-size: 16px; font-weight: 700; color: var(--dark); line-height: 1.4; flex: 1; }
        .obj-desc  { font-size: 13px; color: var(--gray); line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

        .badge {
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 600;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .badge-amber  { background: #fef3c7; color: #d97706; }
        .badge-teal   { background: var(--teal-light); color: var(--teal-dark); }
        .badge-red    { background: #fee2e2; color: #dc2626; }

        /* Progress bar */
        .progress-wrap { padding: 14px 20px; border-bottom: 1px solid #f1f5f9; }

        .progress-label {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            color: var(--gray);
            margin-bottom: 6px;
        }

        .progress-bar {
            height: 6px;
            background: #e2e8f0;
            border-radius: 3px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--teal), var(--purple));
            border-radius: 3px;
            transition: width 1s ease;
        }

        .obj-card-meta { padding: 14px 20px; display: flex; flex-direction: column; gap: 6px; }

        .meta-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: var(--gray);
        }

        .meta-item i { color: var(--teal); font-size: 13px; width: 14px; }

        .obj-card-actions {
            padding: 14px 20px;
            border-top: 1px solid #f1f5f9;
            display: flex;
            gap: 10px;
            margin-top: auto;
        }

        .btn-edit {
            flex: 1;
            padding: 9px;
            background: var(--teal-light);
            color: var(--teal-dark);
            border: none;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            text-decoration: none;
            transition: all 0.2s;
        }

        .btn-edit:hover { background: var(--teal); color: white; }

        .btn-delete {
            flex: 1;
            padding: 9px;
            background: #fee2e2;
            color: #dc2626;
            border: none;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            transition: all 0.2s;
            font-family: 'Inter', sans-serif;
        }

        .btn-delete:hover { background: #dc2626; color: white; }

        /* Mobile */
        .menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 22px;
            color: var(--dark);
            cursor: pointer;
        }

        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            z-index: 99;
        }

        @media (max-width: 1200px) { .cards-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 1024px) { .cards-grid { grid-template-columns: 1fr; } }

        @media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main { margin-left: 0; }
            .menu-toggle { display: block; }
            .content { padding: 16px; }
            .topbar { padding: 0 16px; }
            .toolbar { flex-direction: column; align-items: stretch; }
            .toolbar-left { flex-direction: column; }
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'">
            <span class="sidebar-logo-text">Bekri</span>
        </div>

        <div class="sidebar-user">
            <div class="sidebar-avatar">
                {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
            </div>
            <div>
                <div class="sidebar-user-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
                <div class="sidebar-user-role">Membre Bekri</div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-label">Principal</div>
            <a href="{{ path('user_dashboard') }}" class="nav-item"><i class="bi bi-grid-fill"></i> Tableau de bord</a>
            <a href="{{ path('suivi_today') }}"    class="nav-item"><i class="bi bi-clipboard2-pulse-fill"></i> Check-in quotidien</a>
            <a href="{{ path('insight_weekly') }}" class="nav-item"><i class="bi bi-graph-up-arrow"></i> Insights hebdo</a>
            <a href="{{ path('chat_index') }}"     class="nav-item"><i class="bi bi-robot"></i> Coach Eya IA</a>

            <div class="nav-section-label">Bien-être</div>
            <a href="{{ path('objectif_index') }}" class="nav-item active"><i class="bi bi-trophy-fill"></i> Mes objectifs</a>
             <a href="{{ path('plan_index') }}" class="nav-item"><i class="bi bi-trophy-fill"></i> Plan hebdomadaire</a>
            <a href="#"                            class="nav-item"><i class="bi bi-brain"></i> Test de santé mentale</a>

            <div class="nav-section-label">Communauté</div>
            <a href="{{ path('posts_list') }}"     class="nav-item"><i class="bi bi-newspaper"></i> Publications</a>
            <a href="{{ path('evenements_home') }}" class="nav-item"><i class="bi bi-calendar-event-fill"></i> Événements</a>

            <div class="nav-section-label">Mon compte</div>
            <a href="{{ path('user_profile') }}"   class="nav-item"><i class="bi bi-person-fill"></i> Mon profil</a>
            <a href="{{ path('user_profile_edit') }}" class="nav-item"><i class="bi bi-gear-fill"></i> Paramètres</a>
        </nav>

        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;">
                <i class="bi bi-box-arrow-left"></i> Se déconnecter
            </a>
        </div>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- MAIN -->
    <div class="main">

        <!-- TOPBAR -->
        <header class="topbar">
            <div style="display:flex;align-items:center;gap:16px;">
                <button class="menu-toggle" id="menuToggle"><i class="bi bi-list"></i></button>
                <div>
                    <div class="topbar-title">Mes Objectifs</div>
                    <div class="topbar-sub">Suivez et gérez vos objectifs bien-être</div>
                </div>
            </div>
            <div class="topbar-right">
                <a href="{{ path('suivi_today') }}" class="topbar-btn" title="Check-in"><i class="bi bi-clipboard2-pulse"></i></a>
                <a href="{{ path('chat_index') }}"  class="topbar-btn" title="Coach Eya"><i class="bi bi-robot"></i></a>
                <a href="{{ path('user_profile') }}" class="topbar-avatar">
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                </a>
            </div>
        </header>

        <!-- CONTENT -->
        <main class="content">

            <!-- Toolbar -->
            <div class="toolbar">
                <div class="toolbar-left">
                    <form method="get" style="display:flex;gap:10px;flex-wrap:wrap;flex:1;">
                        <select name="searchField" class="form-select">
                            <option value="titre"  {% if searchField == 'titre'  %}selected{% endif %}>Titre</option>
                            <option value="type"   {% if searchField == 'type'   %}selected{% endif %}>Type</option>
                            <option value="statut" {% if searchField == 'statut' %}selected{% endif %}>Statut</option>
                        </select>
                        <input type="text" name="search" value="{{ search }}" placeholder="Rechercher un objectif..."
                               class="form-input-search">
                        <button type="submit" class="btn btn-teal">
                            <i class="bi bi-search"></i> Rechercher
                        </button>
                        {% if search %}
                            <a href="{{ path('objectif_index') }}" class="btn btn-ghost">
                                <i class="bi bi-x"></i> Effacer
                            </a>
                        {% endif %}
                    </form>

                    <form method="get" style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
                        <input type="hidden" name="search" value="{{ search }}">
                        <input type="hidden" name="searchField" value="{{ searchField }}">
                        <select name="sort" class="form-select">
                            <option value="createdAt"  {% if sort == 'createdAt'  %}selected{% endif %}>Récent</option>
                            <option value="titre"      {% if sort == 'titre'      %}selected{% endif %}>Alphabétique</option>
                            <option value="dateDebut"  {% if sort == 'dateDebut'  %}selected{% endif %}>Date début</option>
                            <option value="dateFin"    {% if sort == 'dateFin'    %}selected{% endif %}>Date fin</option>
                        </select>
                        <select name="direction" class="form-select">
                            <option value="desc" {% if direction == 'desc' %}selected{% endif %}>↓ Décroissant</option>
                            <option value="asc"  {% if direction == 'asc'  %}selected{% endif %}>↑ Croissant</option>
                        </select>
                        <button type="submit" class="btn btn-ghost">
                            <i class="bi bi-sort-down"></i> Trier
                        </button>
                    </form>
                </div>

                <a href="{{ path('objectif_new') }}" class="btn btn-teal">
                    <i class="bi bi-plus-lg"></i> Nouvel objectif
                </a>
            </div>

            {% if objectifs is empty %}
                <div class="empty-state">
                    <div class="empty-icon"><i class="bi bi-trophy-fill"></i></div>
                    <h3>Aucun objectif pour le moment</h3>
                    <p>Commencez votre parcours bien-être en créant votre premier objectif santé.</p>
                    <a href="{{ path('objectif_new') }}" class="btn btn-teal" style="margin:0 auto;">
                        <i class="bi bi-plus-lg"></i> Créer mon premier objectif
                    </a>
                </div>

            {% else %}
                <div class="cards-grid">
                    {% for objectif in objectifs %}
                        {% set pct = 0 %}
{% if objectif.valeurCible > 0 and objectif.valeurActuelle is not null %}
    {% set pct = ((objectif.valeurActuelle / objectif.valeurCible) * 100)|round %}
    {% if pct > 100 %}{% set pct = 100 %}{% endif %}
{% endif %}
                        <div class="obj-card">

                            <div class="obj-card-top">
                                <div class="obj-card-header">
                                    <div class="obj-title">{{ objectif.titre }}</div>
                                    <span class="badge
                                        {% if objectif.statut == 'en_cours' %}badge-amber
                                        {% elseif objectif.statut == 'atteint' %}badge-teal
                                        {% else %}badge-red{% endif %}">
                                        {{ objectif.statut|replace({'_': ' '})|capitalize }}
                                    </span>
                                </div>
                                <p class="obj-desc">{{ objectif.description }}</p>
                            </div>

                            <div class="progress-wrap">
                                <div class="progress-label">
                                    <span>Progression</span>
                                    <span style="font-weight:600;color:var(--teal-dark);">{{ pct }}%</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width:{{ pct }}%;"></div>
                                </div>
                            </div>

                            <div class="obj-card-meta">
                                <div class="meta-item">
                                    <i class="bi bi-tag-fill"></i>
                                    {{ objectif.type|capitalize }}
                                </div>
                                <div class="meta-item">
                                    <i class="bi bi-bullseye"></i>
                                    Cible : <strong>{{ objectif.valeurCible }}</strong>
                                    &nbsp;|&nbsp; Actuelle : <strong>{{ objectif.valeurActuelle ?? 'N/A' }}</strong>
                                </div>
                                <div class="meta-item">
                                    <i class="bi bi-calendar-range-fill"></i>
                                    {{ objectif.dateDebut|date('d/m/Y') }} → {{ objectif.dateFin|date('d/m/Y') }}
                                </div>
                                <div class="meta-item">
                                    <i class="bi bi-clock-fill"></i>
                                    Créé le {{ objectif.createdAt|date('d/m/Y') }}
                                </div>
                            </div>

                            <div class="obj-card-actions">
                                <a href="{{ path('objectif_edit', {id: objectif.id}) }}" class="btn-edit">
                                    <i class="bi bi-pencil-fill"></i> Modifier
                                </a>
                                <form method="post" action="{{ path('objectif_delete', {id: objectif.id}) }}"
                                      onsubmit="return confirm('Supprimer cet objectif ?');" style="flex:1;display:flex;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('objectif_delete_' ~ objectif.id) }}">
                                    <button type="submit" class="btn-delete" style="width:100%;">
                                        <i class="bi bi-trash-fill"></i> Supprimer
                                    </button>
                                </form>
                            </div>

                        </div>
                    {% endfor %}
                </div>
            {% endif %}

        </main>
    </div>

    <script>
        const menuToggle = document.getElementById('menuToggle');
        const sidebar    = document.getElementById('sidebar');
        const overlay    = document.getElementById('sidebarOverlay');
        menuToggle.addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('open'); });
        overlay.addEventListener('click',   () => { sidebar.classList.remove('open'); overlay.classList.remove('open'); });
    </script>
</body>
</html>