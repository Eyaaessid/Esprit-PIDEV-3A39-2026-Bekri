<!DOCTYPE html>
<html lang="fr" class="h-full bg-gray-50">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mes Objectifs - Bekri</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        teal: { 50:'#f0fdfa', 100:'#ccfbf1', 500:'#14b8a6', 600:'#0d9488', 700:'#0f766e' },
                        amber: { 100:'#fef3c7', 700:'#b45309' }
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="h-full antialiased">
<div class="flex h-screen overflow-hidden bg-gray-50">

    <!-- Sidebar -->
    <aside class="hidden md:flex md:w-64 md:flex-shrink-0">
        <div class="flex flex-col w-full">
            <div class="flex items-center justify-center h-16 bg-teal-600 text-white font-bold text-2xl tracking-tight">bekri</div>
            <nav class="flex-1 px-3 py-6 bg-white border-r border-gray-100 overflow-y-auto">
                <div class="space-y-1">
                    <a href="{{ path('home') }}" class="flex items-center px-3 py-2.5 text-sm font-medium rounded-lg text-gray-700 hover:bg-teal-50 hover:text-teal-700 transition-colors">
                        <i class="fas fa-home w-5 mr-3"></i> Accueil
                    </a>
                    <a href="#" class="flex items-center px-3 py-2.5 text-sm font-medium rounded-lg text-gray-700 hover:bg-teal-50 hover:text-teal-700 transition-colors">
                        <i class="fas fa-user w-5 mr-3"></i> Mon profil
                    </a>
                    <a href="{{ path('objectif_index') }}" class="flex items-center px-3 py-2.5 text-sm font-medium rounded-lg text-gray-700 hover:bg-teal-50 hover:text-teal-700 transition-colors">
                        <i class="fas fa-bullseye w-5 mr-3"></i> Mes objectifs
                    </a>
                    <a href="#" class="flex items-center px-3 py-2.5 text-sm font-medium rounded-lg text-gray-700 hover:bg-teal-50 hover:text-teal-700 transition-colors">
                        <i class="fas fa-calendar-day w-5 mr-3"></i> Suivis quotidiens
                    </a>
                    <a href="#" class="flex items-center px-3 py-2.5 text-sm font-medium rounded-lg text-gray-700 hover:bg-teal-50 hover:text-teal-700 transition-colors">
                        <i class="fas fa-chart-line w-5 mr-3"></i> Analyses hebdomadaires
                    </a>
                </div>
            </nav>
            <div class="p-4 border-t border-gray-100">
                <a href="{{ path('app_logout') }}" class="flex items-center px-3 py-2.5 text-sm font-medium rounded-lg text-red-600 hover:bg-red-50 transition-colors">
                    <i class="fas fa-sign-out-alt w-5 mr-3"></i> Déconnexion
                </a>
            </div>
        </div>
    </aside>

    <div class="flex flex-col flex-1 overflow-hidden">
        <header class="bg-white border-b border-gray-200 shadow-sm">
            <div class="px-6 py-4 flex items-center justify-between">
                <h1 class="text-xl font-semibold text-gray-900">Modifier l'objectif</h1>
                <div class="flex items-center space-x-4">
                    <button class="text-gray-500 hover:text-teal-600 transition"><i class="fas fa-bell text-lg"></i></button>
                    <div class="h-9 w-9 rounded-full bg-teal-100 flex items-center justify-center text-teal-700 font-medium">E</div>
                </div>
            </div>
        </header>

        <main class="flex-1 overflow-y-auto bg-gray-50 p-6 lg:p-8">
            <div class="max-w-3xl mx-auto">

                <!-- Flash messages -->
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="mb-6 flex items-center gap-3 p-4 rounded-xl border-l-4 shadow-sm
                            {% if label == 'success' %}bg-green-50 border-green-500 text-green-800
                            {% elseif label == 'error' %}bg-red-50 border-red-500 text-red-800
                            {% else %}bg-gray-50 border-gray-500 text-gray-700{% endif %}">
                            <i class="fas {% if label == 'success' %}fa-circle-check text-green-500{% else %}fa-circle-xmark text-red-500{% endif %}"></i>
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endfor %}

                <!-- Global form error summary -->
                {% if not form.vars.valid and form.vars.submitted %}
                <div class="mb-6 flex items-start gap-3 p-4 bg-red-50 border-l-4 border-red-500 text-red-800 rounded-xl">
                    <i class="fas fa-circle-xmark text-red-500 mt-0.5"></i>
                    <div>
                        <p class="font-semibold mb-1">Veuillez corriger les erreurs ci-dessous :</p>
                        <ul class="list-disc list-inside text-sm space-y-1">
                            {% for child in form %}
                                {% for error in child.vars.errors %}
                                    <li>{{ error.message }}</li>
                                {% endfor %}
                            {% endfor %}
                        </ul>
                    </div>
                </div>
                {% endif %}

                <div class="bg-white rounded-2xl shadow border border-gray-200 overflow-hidden">
                    <div class="px-8 py-8 lg:py-10">

                        <h2 class="text-2xl font-bold text-gray-900 mb-2">{{ objectif.titre }}</h2>
                        <p class="text-gray-600 mb-8">Modifiez les détails de votre objectif</p>

                        {{ form_start(form, {'attr': {'class': 'space-y-8', 'novalidate': 'novalidate'}}) }}

                        <!-- Titre & Type -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                {{ form_label(form.titre, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                                {{ form_widget(form.titre, {'attr': {'class': 'w-full px-4 py-3 border ' ~ (form.titre.vars.errors|length > 0 ? 'border-red-400 bg-red-50' : 'border-gray-300') ~ ' rounded-xl focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition'}}) }}
                                {% for error in form.titre.vars.errors %}
                                    <p class="mt-1 text-xs text-red-600 flex items-center gap-1"><i class="fas fa-circle-exclamation"></i> {{ error.message }}</p>
                                {% endfor %}
                            </div>
                            <div>
                                {{ form_label(form.type, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                                {{ form_widget(form.type, {'attr': {'class': 'w-full px-4 py-3 border ' ~ (form.type.vars.errors|length > 0 ? 'border-red-400 bg-red-50' : 'border-gray-300') ~ ' rounded-xl focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition'}}) }}
                                {% for error in form.type.vars.errors %}
                                    <p class="mt-1 text-xs text-red-600 flex items-center gap-1"><i class="fas fa-circle-exclamation"></i> {{ error.message }}</p>
                                {% endfor %}
                            </div>
                        </div>

                        <!-- Description -->
                        <div>
                            {{ form_label(form.description, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                            {{ form_widget(form.description, {'attr': {'class': 'w-full px-4 py-3 border ' ~ (form.description.vars.errors|length > 0 ? 'border-red-400 bg-red-50' : 'border-gray-300') ~ ' rounded-xl focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none min-h-[120px] transition', 'maxlength': '500'}}) }}
                            {% for error in form.description.vars.errors %}
                                <p class="mt-1 text-xs text-red-600 flex items-center gap-1"><i class="fas fa-circle-exclamation"></i> {{ error.message }}</p>
                            {% endfor %}
                        </div>

                        <!-- Valeurs -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                {{ form_label(form.valeurCible, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                                {{ form_widget(form.valeurCible, {'attr': {'class': 'w-full px-4 py-3 border ' ~ (form.valeurCible.vars.errors|length > 0 ? 'border-red-400 bg-red-50' : 'border-gray-300') ~ ' rounded-xl focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition'}}) }}
                                {% for error in form.valeurCible.vars.errors %}
                                    <p class="mt-1 text-xs text-red-600 flex items-center gap-1"><i class="fas fa-circle-exclamation"></i> {{ error.message }}</p>
                                {% endfor %}
                            </div>
                            <div>
                                {{ form_label(form.valeurActuelle, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                                {{ form_widget(form.valeurActuelle, {'attr': {'class': 'w-full px-4 py-3 border ' ~ (form.valeurActuelle.vars.errors|length > 0 ? 'border-red-400 bg-red-50' : 'border-gray-300') ~ ' rounded-xl focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition'}}) }}
                                {% for error in form.valeurActuelle.vars.errors %}
                                    <p class="mt-1 text-xs text-red-600 flex items-center gap-1"><i class="fas fa-circle-exclamation"></i> {{ error.message }}</p>
                                {% endfor %}
                            </div>
                        </div>

                        <!-- Dates -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                {{ form_label(form.dateDebut, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                                {{ form_widget(form.dateDebut, {'attr': {'class': 'w-full px-4 py-3 border ' ~ (form.dateDebut.vars.errors|length > 0 ? 'border-red-400 bg-red-50' : 'border-gray-300') ~ ' rounded-xl focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition'}}) }}
                                <p class="mt-1 text-xs text-gray-500">Ne peut pas être dans le passé</p>
                                {% for error in form.dateDebut.vars.errors %}
                                    <p class="mt-1 text-xs text-red-600 flex items-center gap-1"><i class="fas fa-circle-exclamation"></i> {{ error.message }}</p>
                                {% endfor %}
                            </div>
                            <div>
                                {{ form_label(form.dateFin, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                                {{ form_widget(form.dateFin, {'attr': {'class': 'w-full px-4 py-3 border ' ~ (form.dateFin.vars.errors|length > 0 ? 'border-red-400 bg-red-50' : 'border-gray-300') ~ ' rounded-xl focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition'}}) }}
                                <p class="mt-1 text-xs text-gray-500">Doit être après la date de début</p>
                                {% for error in form.dateFin.vars.errors %}
                                    <p class="mt-1 text-xs text-red-600 flex items-center gap-1"><i class="fas fa-circle-exclamation"></i> {{ error.message }}</p>
                                {% endfor %}
                            </div>
                        </div>

                        <!-- Statut -->
                        <div>
                            {{ form_label(form.statut, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                            {{ form_widget(form.statut, {'attr': {'class': 'w-full px-4 py-3 border ' ~ (form.statut.vars.errors|length > 0 ? 'border-red-400 bg-red-50' : 'border-gray-300') ~ ' rounded-xl focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition'}}) }}
                            {% for error in form.statut.vars.errors %}
                                <p class="mt-1 text-xs text-red-600 flex items-center gap-1"><i class="fas fa-circle-exclamation"></i> {{ error.message }}</p>
                            {% endfor %}
                        </div>

                        <!-- Actions -->
                        <div class="pt-8 flex justify-end gap-4 border-t border-gray-100 mt-8">
                            <a href="{{ path('objectif_index') }}" class="inline-flex items-center px-6 py-3 bg-white border border-gray-300 rounded-xl text-gray-700 font-medium hover:bg-gray-50 transition">
                                Annuler
                            </a>
                            <button type="submit" class="inline-flex items-center px-8 py-3 bg-teal-600 text-white font-medium rounded-xl hover:bg-teal-700 shadow-md hover:shadow-lg transition-all">
                                <i class="fas fa-save mr-2"></i> Enregistrer les modifications
                            </button>
                        </div>

                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
</body>
</html>
