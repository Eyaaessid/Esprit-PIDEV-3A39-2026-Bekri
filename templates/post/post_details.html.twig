<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ post.titre }} — Bekri</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --dark:       #1a2332;
            --gray:       #64748b;
            --light:      #f8fafc;
            --white:      #ffffff;
            --sidebar-w:  260px;
            --shadow-sm:  0 2px 12px rgba(0,0,0,0.06);
            --shadow:     0 8px 30px rgba(0,0,0,0.10);
            --radius:     16px;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior:smooth; }
        body { font-family:'Inter',sans-serif; background:var(--light); color:var(--dark); display:flex; min-height:100vh; }

        /* ── SIDEBAR (same as posts.html.twig) ───────────────────── */
        .sidebar { width:var(--sidebar-w); background:var(--dark); min-height:100vh; position:fixed; top:0; left:0; display:flex; flex-direction:column; z-index:100; transition:transform 0.3s ease; }
        .sidebar-logo { padding:28px 24px 20px; display:flex; align-items:center; gap:10px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-logo img { height:36px; width:auto; }
        .sidebar-logo-text { font-size:20px; font-weight:800; background:linear-gradient(135deg,var(--teal),#a78bfa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .sidebar-user { padding:20px 24px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-avatar { width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:16px; flex-shrink:0; overflow:hidden; }
        .sidebar-avatar img { width:100%; height:100%; object-fit:cover; }
        .sidebar-user-name { font-size:14px; font-weight:600; color:white; }
        .sidebar-user-role { font-size:11px; color:rgba(255,255,255,0.4); margin-top:2px; }
        .sidebar-nav { flex:1; padding:16px 0; overflow-y:auto; }
        .nav-section-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:rgba(255,255,255,0.25); padding:12px 24px 6px; }
        .nav-item { display:flex; align-items:center; gap:12px; padding:11px 24px; color:rgba(255,255,255,0.6); text-decoration:none; font-size:14px; font-weight:500; transition:all 0.2s; border-left:3px solid transparent; }
        .nav-item:hover { color:white; background:rgba(255,255,255,0.05); }
        .nav-item.active { color:var(--teal); background:rgba(32,178,170,0.1); border-left-color:var(--teal); }
        .nav-item i { width:20px; text-align:center; font-size:16px; }
        .sidebar-footer { padding:16px 0; border-top:1px solid rgba(255,255,255,0.07); }

        /* ── MAIN ────────────────────────────────────────────────── */
        .main { margin-left:var(--sidebar-w); flex:1; display:flex; flex-direction:column; min-height:100vh; }
        .topbar { background:white; padding:0 32px; height:68px; display:flex; align-items:center; justify-content:space-between; box-shadow:var(--shadow-sm); position:sticky; top:0; z-index:50; }
        .topbar-left { display:flex; align-items:center; gap:16px; }
        .topbar-title { font-size:18px; font-weight:700; color:var(--dark); }
        .topbar-sub   { font-size:13px; color:var(--gray); margin-top:2px; }
        .topbar-right { display:flex; align-items:center; gap:12px; }
        .topbar-btn { width:40px; height:40px; border-radius:10px; background:var(--light); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; color:var(--gray); font-size:16px; text-decoration:none; transition:all 0.2s; }
        .topbar-btn:hover { background:var(--teal-light); color:var(--teal-dark); }
        .topbar-avatar-sm { width:40px; height:40px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:14px; text-decoration:none; overflow:hidden; }
        .topbar-avatar-sm img { width:100%; height:100%; object-fit:cover; }
        .menu-toggle { display:none; background:none; border:none; font-size:22px; color:var(--dark); cursor:pointer; }
        .sidebar-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:99; }

        /* ── CONTENT ─────────────────────────────────────────────── */
        .content { padding:32px; flex:1; }

        /* ── LAYOUT ──────────────────────────────────────────────── */
        .detail-layout { display:grid; grid-template-columns:1fr 320px; gap:24px; align-items:start; }

        /* ── ARTICLE ─────────────────────────────────────────────── */
        .article-card { background:white; border-radius:var(--radius); box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; overflow:hidden; margin-bottom:24px; }

        .article-head { padding:24px 28px; border-bottom:1px solid #f8fafc; display:flex; justify-content:space-between; align-items:flex-start; }
        .author-row { display:flex; align-items:center; gap:14px; }
        .author-avatar { width:52px; height:52px; border-radius:50%; overflow:hidden; flex-shrink:0; }
        .author-avatar img { width:100%; height:100%; object-fit:cover; }
        .avatar-initials { width:100%; height:100%; background:linear-gradient(135deg,var(--purple),#764ba2); color:white; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:20px; }
        .author-name { font-size:16px; font-weight:700; color:var(--dark); margin-bottom:4px; }
        .post-meta  { font-size:12px; color:var(--gray); display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
        .meta-dot   { color:#cbd5e1; }

        .article-actions { display:flex; gap:8px; }
        .btn-edit   { background:var(--teal); color:white; border:none; padding:8px 16px; border-radius:8px; font-size:13px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; display:flex; align-items:center; gap:6px; transition:all 0.2s; }
        .btn-edit:hover   { background:var(--teal-dark); }
        .btn-delete { background:#ef4444; color:white; border:none; padding:8px 16px; border-radius:8px; font-size:13px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; display:flex; align-items:center; gap:6px; transition:all 0.2s; }
        .btn-delete:hover { background:#dc2626; }

        .article-media { overflow:hidden; max-height:420px; }
        .article-media img { width:100%; object-fit:cover; }

        .article-body { padding:28px; }
        .post-category-tag { display:inline-flex; align-items:center; padding:4px 12px; border-radius:50px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:14px; }
        .cat-health    { background:#dcfce7; color:#166534; }
        .cat-nutrition { background:#fef3c7; color:#92400e; }
        .cat-mental    { background:#dbeafe; color:#1e40af; }
        .cat-fitness   { background:#fce7f3; color:#9d174d; }
        .article-title { font-size:24px; font-weight:800; color:var(--dark); margin-bottom:16px; line-height:1.3; }
        .article-content { font-size:15px; line-height:1.9; color:#475569; }

        /* ── ENGAGEMENT ──────────────────────────────────────────── */
        .engagement-bar { padding:16px 28px; border-top:1px solid #f8fafc; display:flex; justify-content:space-between; align-items:center; }
        .engage-left { display:flex; gap:10px; align-items:center; }
        .engage-btn {
            background:var(--light); border:1px solid #e2e8f0;
            padding:8px 16px; border-radius:50px;
            display:flex; align-items:center; gap:6px;
            color:var(--gray); cursor:pointer;
            font-size:13px; font-weight:600; font-family:'Inter',sans-serif;
            transition:all 0.25s;
        }
        .engage-btn:hover { border-color:#cbd5e1; background:#f1f5f9; color:var(--dark); }
        .engage-btn.liked { color:#e74c3c; border-color:#fecaca; background:#fff5f5; }
        .engage-btn.saved { color:#059669; border-color:#6ee7b7; background:#ecfdf5; }
        .engage-info { font-size:13px; color:var(--gray); display:flex; align-items:center; gap:6px; }
        .btn-share { background:var(--teal); color:white; border:none; padding:8px 16px; border-radius:50px; font-size:13px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; display:flex; align-items:center; gap:6px; transition:all 0.25s; }
        .btn-share:hover { background:var(--teal-dark); }

        /* ── COMMENTS ────────────────────────────────────────────── */
        .comments-card { background:white; border-radius:var(--radius); box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; overflow:hidden; }
        .comments-head { padding:20px 24px; border-bottom:1px solid #f8fafc; display:flex; align-items:center; gap:10px; }
        .comments-head h4 { font-size:16px; font-weight:700; color:var(--dark); margin:0; }
        .comments-count { background:var(--teal-light); color:var(--teal-dark); font-size:12px; font-weight:700; padding:3px 10px; border-radius:50px; }
        .comments-body { padding:24px; }

        .comment-form textarea { width:100%; padding:12px 14px; border:2px solid #e2e8f0; border-radius:10px; font-size:14px; font-family:'Inter',sans-serif; color:var(--dark); resize:vertical; min-height:100px; outline:none; transition:all 0.25s; background:var(--light); margin-bottom:12px; }
        .comment-form textarea:focus { border-color:var(--teal); background:white; box-shadow:0 0 0 3px rgba(32,178,170,0.1); }
        .btn-comment { background:linear-gradient(135deg,var(--teal),var(--teal-dark)); color:white; border:none; padding:10px 22px; border-radius:10px; font-size:14px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; display:inline-flex; align-items:center; gap:7px; transition:all 0.25s; }
        .btn-comment:hover { transform:translateY(-1px); }

        .comment-divider { height:1px; background:#f1f5f9; margin:20px 0; }

        .comment-item { display:flex; gap:12px; margin-bottom:20px; }
        .comment-item:last-child { margin-bottom:0; }
        .comment-avatar { width:40px; height:40px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--teal-dark)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:15px; flex-shrink:0; }
        .comment-bubble { flex:1; background:var(--light); border-radius:12px; padding:14px 16px; }
        .comment-meta  { display:flex; align-items:center; justify-content:space-between; margin-bottom:6px; flex-wrap:wrap; gap:6px; }
        .comment-author { font-size:14px; font-weight:700; color:var(--dark); }
        .comment-date   { font-size:12px; color:var(--gray); }
        .comment-text   { font-size:14px; color:#475569; line-height:1.6; }
        .comment-actions-row { display:flex; gap:8px; margin-top:8px; }
        .btn-comment-action { background:none; border:none; font-size:12px; color:var(--gray); cursor:pointer; font-family:'Inter',sans-serif; padding:4px 8px; border-radius:6px; transition:all 0.2s; display:flex; align-items:center; gap:4px; }
        .btn-comment-action:hover { background:#e2e8f0; color:var(--dark); }
        .btn-comment-action.danger:hover { background:#fee2e2; color:#dc2626; }

        /* ── SIDEBAR WIDGETS ─────────────────────────────────────── */
        .widget-card { background:white; border-radius:var(--radius); box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; padding:22px; margin-bottom:20px; }
        .widget-title { font-size:14px; font-weight:700; color:var(--dark); margin-bottom:16px; padding-bottom:12px; border-bottom:1px solid #f8fafc; display:flex; align-items:center; gap:8px; }
        .widget-title i { color:var(--teal); }

        .author-widget-body { text-align:center; }
        .author-widget-avatar { width:64px; height:64px; border-radius:50%; overflow:hidden; margin:0 auto 12px; background:linear-gradient(135deg,var(--purple),#764ba2); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:24px; }
        .author-widget-avatar img { width:100%; height:100%; object-fit:cover; }
        .author-widget-name { font-size:15px; font-weight:700; color:var(--dark); margin-bottom:12px; }
        .author-widget-stats { display:flex; justify-content:space-around; padding-top:12px; border-top:1px solid #f1f5f9; }
        .widget-stat strong { display:block; font-size:20px; font-weight:800; color:var(--dark); }
        .widget-stat span   { font-size:11px; color:var(--gray); }

        .related-item { display:block; padding:10px 0; border-bottom:1px solid #f8fafc; text-decoration:none; transition:all 0.2s; }
        .related-item:last-child { border-bottom:none; }
        .related-item:hover { padding-left:4px; }
        .related-item-title { font-size:13px; font-weight:600; color:var(--dark); margin-bottom:3px; }
        .related-item-meta  { font-size:12px; color:var(--gray); }

        .categories-list { list-style:none; }
        .categories-list li { margin-bottom:8px; }
        .categories-list a { display:flex; align-items:center; gap:8px; padding:8px 12px; border-radius:8px; font-size:13px; font-weight:500; color:var(--gray); text-decoration:none; transition:all 0.2s; }
        .categories-list a:hover { background:var(--teal-light); color:var(--teal-dark); }

        /* ── MODALS ──────────────────────────────────────────────── */
        .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); backdrop-filter:blur(6px); z-index:9999; align-items:center; justify-content:center; padding:20px; overflow-y:auto; }
        .modal-overlay.open { display:flex; }
        .modal-box { background:white; border-radius:20px; max-width:620px; width:100%; box-shadow:0 24px 70px rgba(0,0,0,0.2); animation:modalIn 0.3s ease-out; margin:auto; }
        @keyframes modalIn { from{opacity:0;transform:translateY(-20px)} to{opacity:1;transform:translateY(0)} }
        .modal-head { padding:24px 28px 16px; border-bottom:1px solid #f1f5f9; display:flex; align-items:center; justify-content:space-between; }
        .modal-head h5 { font-size:17px; font-weight:700; color:var(--dark); margin:0; }
        .modal-close { background:none; border:none; font-size:20px; color:var(--gray); cursor:pointer; width:32px; height:32px; border-radius:8px; display:flex; align-items:center; justify-content:center; }
        .modal-close:hover { background:var(--light); }
        .modal-body-custom { padding:24px 28px; }
        .modal-foot { padding:16px 28px 24px; border-top:1px solid #f1f5f9; display:flex; gap:10px; justify-content:flex-end; }
        .form-group { margin-bottom:16px; }
        .form-label { font-size:13px; font-weight:600; color:var(--dark); display:block; margin-bottom:6px; }
        .form-input, .form-select, .form-textarea { width:100%; padding:10px 14px; border:2px solid #e2e8f0; border-radius:10px; font-size:14px; font-family:'Inter',sans-serif; color:var(--dark); outline:none; transition:all 0.25s; background:var(--light); }
        .form-input:focus, .form-select:focus, .form-textarea:focus { border-color:var(--teal); background:white; box-shadow:0 0 0 3px rgba(32,178,170,0.1); }
        .form-textarea { resize:vertical; min-height:140px; }
        .btn-primary-custom { background:linear-gradient(135deg,var(--teal),var(--teal-dark)); color:white; padding:10px 22px; border-radius:10px; border:none; font-size:14px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; display:inline-flex; align-items:center; gap:7px; transition:all 0.25s; }
        .btn-ghost { background:var(--light); color:var(--gray); border:2px solid #e2e8f0; padding:10px 22px; border-radius:10px; font-size:14px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; transition:all 0.25s; }
        .btn-ghost:hover { background:#e2e8f0; color:var(--dark); }

        @media (max-width:1024px) { .detail-layout { grid-template-columns:1fr; } }
        @media (max-width:768px) {
            .sidebar { transform:translateX(-100%); }
            .sidebar.open { transform:translateX(0); }
            .sidebar-overlay.open { display:block; }
            .main { margin-left:0; }
            .menu-toggle { display:block; }
            .content { padding:16px; }
            .topbar { padding:0 16px; }
            .article-head { flex-direction:column; gap:12px; }
            .article-actions { width:100%; }
            .engagement-bar { flex-direction:column; gap:12px; align-items:flex-start; }
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'">
            <span class="sidebar-logo-text">Bekri</span>
        </div>
        <div class="sidebar-user">
            <div class="sidebar-avatar">
                {% if app.user and app.user.avatar %}<img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
                {% elseif app.user %}{{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                {% else %}<i class="bi bi-person-fill" style="font-size:20px;"></i>{% endif %}
            </div>
            <div>
                <div class="sidebar-user-name">{{ app.user ? app.user.prenom ~ ' ' ~ app.user.nom : 'Invité' }}</div>
                <div class="sidebar-user-role">Membre Bekri</div>
            </div>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section-label">Principal</div>
            <a href="{{ path('user_dashboard') }}"   class="nav-item"><i class="bi bi-grid-fill"></i> Tableau de bord</a>
            <a href="{{ path('suivi_today') }}"       class="nav-item"><i class="bi bi-clipboard2-pulse-fill"></i> Check-in quotidien</a>
            <a href="{{ path('insight_weekly') }}"    class="nav-item"><i class="bi bi-graph-up-arrow"></i> Insights hebdo</a>
            <a href="{{ path('chat_index') }}"        class="nav-item"><i class="bi bi-robot"></i> Coach Eya IA</a>
            <div class="nav-section-label">Bien-être</div>
            <a href="{{ path('user_analyse') }}"      class="nav-item"><i class="bi bi-heart-pulse-fill"></i> Mon analyse bien-être</a>
            <a href="{{ path('objectif_index') }}"    class="nav-item"><i class="bi bi-trophy-fill"></i> Mes objectifs</a>
            <div class="nav-section-label">Communauté</div>
            <a href="{{ path('posts_list') }}"        class="nav-item active"><i class="bi bi-newspaper"></i> Publications</a>
            <a href="{{ path('evenements_home') }}"   class="nav-item"><i class="bi bi-calendar-event-fill"></i> Événements</a>
            <div class="nav-section-label">Mon compte</div>
            <a href="{{ path('user_profile') }}"      class="nav-item"><i class="bi bi-person-fill"></i> Mon profil</a>
            <a href="{{ path('user_profile_edit') }}" class="nav-item"><i class="bi bi-gear-fill"></i> Paramètres</a>
        </nav>
        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;"><i class="bi bi-box-arrow-left"></i> Se déconnecter</a>
        </div>
    </aside>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="main">
        <header class="topbar">
            <div class="topbar-left">
                <button class="menu-toggle" id="menuToggle"><i class="bi bi-list"></i></button>
                <div>
                    <div class="topbar-title">{{ post.titre|slice(0,40) }}{% if post.titre|length > 40 %}...{% endif %}</div>
                    <div class="topbar-sub"><a href="{{ path('posts_list') }}" style="color:var(--teal);text-decoration:none;">← Retour aux publications</a></div>
                </div>
            </div>
            <div class="topbar-right">
                <a href="{{ path('posts_list') }}" class="topbar-btn" title="Publications"><i class="bi bi-newspaper"></i></a>
                <a href="{{ path('user_profile') }}" class="topbar-avatar-sm">
                    {% if app.user and app.user.avatar %}<img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
                    {% elseif app.user %}{{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                    {% else %}<i class="bi bi-person-fill"></i>{% endif %}
                </a>
            </div>
        </header>

        <main class="content">
            <div class="detail-layout">

                <!-- LEFT: Article -->
                <div>
                    <article class="article-card">
                        <div class="article-head">
                            <div class="author-row">
                                <div class="author-avatar">
                                    {% if post.utilisateur.avatar %}
                                        <img src="{{ asset('uploads/avatars/' ~ post.utilisateur.avatar) }}" alt="{{ post.utilisateur.nom }}">
                                    {% else %}
                                        <div class="avatar-initials">{{ post.utilisateur.nom|first|upper }}</div>
                                    {% endif %}
                                </div>
                                <div>
                                    <div class="author-name">{{ post.utilisateur.nom }} {{ post.utilisateur.prenom }}</div>
                                    <div class="post-meta">
                                        <i class="bi bi-calendar3"></i> {{ post.createdAt|date('d/m/Y') }}
                                        <span class="meta-dot">·</span>
                                        <i class="bi bi-clock"></i> {{ post.createdAt|date('H:i') }}
                                        {% if post.updatedAt %}<span class="meta-dot">·</span><i class="bi bi-pencil"></i> modifié{% endif %}
                                    </div>
                                </div>
                            </div>
                            <div class="article-actions">
                                <button class="btn-edit" onclick="document.getElementById('editPostModal').classList.add('open')"><i class="bi bi-pencil"></i> Modifier</button>
                                <button class="btn-delete" onclick="confirmDelete()"><i class="bi bi-trash"></i> Supprimer</button>
                            </div>
                        </div>

                        {% if post.mediaUrl %}
                            <div class="article-media"><img src="{{ post.mediaUrl }}" alt="{{ post.titre }}"></div>
                        {% endif %}

                        <div class="article-body">
                            {% if post.categorie %}
                                <span class="post-category-tag cat-{{ post.categorie|lower }}">{{ post.categorie }}</span>
                            {% endif %}
                            <h1 class="article-title">{{ post.titre }}</h1>
                            <div class="article-content">{{ post.contenu|nl2br }}</div>
                        </div>

                        <div class="engagement-bar">
                            <div class="engage-left">
                                <button class="engage-btn like-btn {% if userHasLiked %}liked{% endif %}" data-post-id="{{ post.id }}" data-like-token="{{ csrf_token('like' ~ post.id) }}">
                                    <i class="bi {% if userHasLiked %}bi-heart-fill{% else %}bi-heart{% endif %}"></i>
                                    <span class="like-count">{{ post.likes|length }}</span> J'aime
                                </button>
                                <button class="engage-btn save-btn {% if userHasSaved is defined and userHasSaved %}saved{% endif %}" data-post-id="{{ post.id }}" data-save-token="{{ csrf_token('save' ~ post.id) }}">
                                    <i class="bi {% if userHasSaved is defined and userHasSaved %}bi-bookmark-check-fill{% else %}bi-bookmark{% endif %}"></i>
                                    Sauvegarder
                                </button>
                                <span class="engage-info"><i class="bi bi-chat-left-text"></i> {{ post.commentaires|length }} commentaires</span>
                            </div>
                            <button class="btn-share" onclick="sharePost()"><i class="bi bi-share"></i> Partager</button>
                        </div>
                    </article>

                    {# Comments #}
                    <div class="comments-card" id="comments">
                        <div class="comments-head">
                            <h4><i class="bi bi-chat-left-text-fill" style="color:var(--teal);"></i> Commentaires</h4>
                            <span class="comments-count">{{ post.commentaires|length }}</span>
                        </div>
                        <div class="comments-body">
                            <form action="{{ path('comment_create', {'postId': post.id}) }}" method="post" class="comment-form">
                                <textarea name="contenu" placeholder="Votre commentaire..." required></textarea>
                                <input type="hidden" name="_token" value="{{ csrf_token('create_comment') }}">
                                <button type="submit" class="btn-comment"><i class="bi bi-send-fill"></i> Publier</button>
                            </form>

                            {% if post.commentaires|length > 0 %}
                                <div class="comment-divider"></div>
                                {% for commentaire in post.commentaires %}
                                    <div class="comment-item">
                                        <div class="comment-avatar">{{ commentaire.utilisateur.nom|first|upper }}</div>
                                        <div class="comment-bubble">
                                            <div class="comment-meta">
                                                <span class="comment-author">{{ commentaire.utilisateur.nom }} {{ commentaire.utilisateur.prenom }}</span>
                                                <span class="comment-date">{{ commentaire.createdAt|date('d/m/Y H:i') }}</span>
                                            </div>
                                            <div class="comment-text">{{ commentaire.contenu|nl2br }}</div>
                                            {% if app.user and (is_granted('ROLE_ADMIN') or app.user.id == commentaire.utilisateur.id) %}
                                                <div class="comment-actions-row">
                                                    <button type="button" class="btn-comment-action" onclick="document.getElementById('editCommentModal{{ commentaire.id }}').classList.add('open')">
                                                        <i class="bi bi-pencil"></i> Modifier
                                                    </button>
                                                    <form action="{{ path('comment_delete', {'id': commentaire.id}) }}" method="post" style="display:inline;">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_comment' ~ commentaire.id) }}">
                                                        <button type="submit" class="btn-comment-action danger" onclick="return confirm('Supprimer ce commentaire ?')">
                                                            <i class="bi bi-trash"></i> Supprimer
                                                        </button>
                                                    </form>
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>

                                    {# Edit Comment Modal #}
                                    {% if app.user and (is_granted('ROLE_ADMIN') or app.user.id == commentaire.utilisateur.id) %}
                                        <div class="modal-overlay" id="editCommentModal{{ commentaire.id }}">
                                            <div class="modal-box" style="max-width:480px;">
                                                <div class="modal-head">
                                                    <h5><i class="bi bi-pencil-fill" style="color:var(--teal);margin-right:8px;"></i>Modifier le commentaire</h5>
                                                    <button class="modal-close" onclick="document.getElementById('editCommentModal{{ commentaire.id }}').classList.remove('open')"><i class="bi bi-x"></i></button>
                                                </div>
                                                <form action="{{ path('comment_edit', {'id': commentaire.id}) }}" method="post">
                                                    <div class="modal-body-custom">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('edit_comment' ~ commentaire.id) }}">
                                                        <textarea name="contenu" class="form-textarea" rows="5">{{- commentaire.contenu -}}</textarea>
                                                    </div>
                                                    <div class="modal-foot">
                                                        <button type="button" class="btn-ghost" onclick="document.getElementById('editCommentModal{{ commentaire.id }}').classList.remove('open')">Annuler</button>
                                                        <button type="submit" class="btn-primary-custom"><i class="bi bi-check-circle-fill"></i> Enregistrer</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            {% else %}
                                <div style="text-align:center;padding:40px;color:var(--gray);">
                                    <i class="bi bi-chat-left" style="font-size:40px;display:block;margin-bottom:12px;color:#cbd5e1;"></i>
                                    Soyez le premier à commenter !
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <!-- RIGHT: Sidebar widgets -->
                <div>
                    <div class="widget-card">
                        <div class="widget-title"><i class="bi bi-person-circle"></i> À propos de l'auteur</div>
                        <div class="author-widget-body">
                            <div class="author-widget-avatar">
                                {% if post.utilisateur.avatar %}
                                    <img src="{{ asset('uploads/avatars/' ~ post.utilisateur.avatar) }}" alt="{{ post.utilisateur.nom }}">
                                {% else %}
                                    {{ post.utilisateur.nom|first|upper }}
                                {% endif %}
                            </div>
                            <div class="author-widget-name">{{ post.utilisateur.nom }} {{ post.utilisateur.prenom }}</div>
                            <div class="author-widget-stats">
                                <div class="widget-stat"><strong>{{ post.utilisateur.posts|length }}</strong><span>Posts</span></div>
                                <div class="widget-stat"><strong>{{ post.utilisateur.commentaires|length }}</strong><span>Commentaires</span></div>
                            </div>
                        </div>
                    </div>

                    {% if relatedPosts is defined and relatedPosts|length > 0 %}
                        <div class="widget-card">
                            <div class="widget-title"><i class="bi bi-link-45deg"></i> Posts similaires</div>
                            {% for relPost in relatedPosts %}
                                <a href="{{ path('post_details', {'id': relPost.id}) }}" class="related-item">
                                    <div class="related-item-title">{{ relPost.titre|slice(0,50) }}{% if relPost.titre|length > 50 %}...{% endif %}</div>
                                    <div class="related-item-meta">{{ relPost.utilisateur.nom }} · {{ relPost.likes|length }} <i class="bi bi-heart-fill" style="color:#e74c3c;font-size:11px;"></i></div>
                                </a>
                            {% endfor %}
                        </div>
                    {% endif %}

                    <div class="widget-card">
                        <div class="widget-title"><i class="bi bi-tags-fill"></i> Catégories</div>
                        <ul class="categories-list">
                            <li><a href="{{ path('posts_list') }}?category=health"><i class="bi bi-heart-pulse"></i> Santé</a></li>
                            <li><a href="{{ path('posts_list') }}?category=nutrition"><i class="bi bi-egg-fried"></i> Nutrition</a></li>
                            <li><a href="{{ path('posts_list') }}?category=mental"><i class="bi bi-brain"></i> Santé mentale</a></li>
                            <li><a href="{{ path('posts_list') }}?category=fitness"><i class="bi bi-bicycle"></i> Fitness</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </main>
    </div>

    {# Delete form (hidden) #}
    <form id="deletePostForm" action="{{ path('post_delete', {'id': post.id}) }}" method="post" style="display:none;">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
    </form>

    {# Edit Post Modal #}
    <div class="modal-overlay" id="editPostModal">
        <div class="modal-box">
            <div class="modal-head">
                <h5><i class="bi bi-pencil-fill" style="color:var(--teal);margin-right:8px;"></i>Modifier le post</h5>
                <button class="modal-close" onclick="document.getElementById('editPostModal').classList.remove('open')"><i class="bi bi-x"></i></button>
            </div>
            <form action="{{ path('post_edit', {'id': post.id}) }}" method="post" enctype="multipart/form-data">
                <div class="modal-body-custom">
                    <input type="hidden" name="_token" value="{{ csrf_token('edit' ~ post.id) }}">
                    <div class="form-group"><label class="form-label">Titre *</label><input type="text" name="titre" class="form-input" value="{{ post.titre }}" required></div>
                    <div class="form-group">
                        <label class="form-label">Catégorie</label>
                        <select name="categorie" class="form-select">
                            <option value="">Choisir...</option>
                            <option value="Health" {% if post.categorie=='Health' %}selected{% endif %}>Santé</option>
                            <option value="Nutrition" {% if post.categorie=='Nutrition' %}selected{% endif %}>Nutrition</option>
                            <option value="Mental" {% if post.categorie=='Mental' %}selected{% endif %}>Santé mentale</option>
                            <option value="Fitness" {% if post.categorie=='Fitness' %}selected{% endif %}>Fitness</option>
                        </select>
                    </div>
                    <div class="form-group"><label class="form-label">Contenu *</label><textarea name="contenu" class="form-textarea" rows="8" required>{{ post.contenu }}</textarea></div>
                    <div class="form-group">
                        <label class="form-label">Mettre à jour l'image</label>
                        {% if post.mediaUrl %}<img src="{{ post.mediaUrl }}" style="max-width:100%;border-radius:8px;margin-bottom:8px;">{% endif %}
                        <input type="file" name="media" class="form-input" accept="image/*">
                    </div>
                </div>
                <div class="modal-foot">
                    <button type="button" class="btn-ghost" onclick="document.getElementById('editPostModal').classList.remove('open')">Annuler</button>
                    <button type="submit" class="btn-primary-custom"><i class="bi bi-check-circle-fill"></i> Mettre à jour</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const menuToggle = document.getElementById('menuToggle');
        const sidebar    = document.getElementById('sidebar');
        const overlay    = document.getElementById('sidebarOverlay');
        menuToggle?.addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('open'); });
        overlay?.addEventListener('click',   () => { sidebar.classList.remove('open'); overlay.classList.remove('open'); });

        function confirmDelete() {
            if (confirm('Supprimer ce post ? Cette action est irréversible.')) document.getElementById('deletePostForm').submit();
        }

        function sharePost() {
            if (navigator.share) { navigator.share({ title: document.title, url: window.location.href }); }
            else { navigator.clipboard.writeText(window.location.href); alert('Lien copié !'); }
        }

        document.querySelector('.like-btn')?.addEventListener('click', async function() {
            if (this.dataset.loading === '1') return;
            this.dataset.loading = '1';
            try {
                const res = await fetch('/posts/' + this.dataset.postId + '/like', { method:'POST', headers:{'X-Requested-With':'XMLHttpRequest','X-CSRF-TOKEN':this.dataset.likeToken}, credentials:'same-origin' });
                const data = await res.json();
                if (!res.ok) { if (res.status === 401) { window.location.href = '{{ path('app_login') }}'; return; } return; }
                this.classList.toggle('liked', !!data.liked);
                this.querySelector('.like-count').textContent = data.count;
                const icon = this.querySelector('i');
                icon.classList.toggle('bi-heart-fill', !!data.liked);
                icon.classList.toggle('bi-heart', !data.liked);
            } finally { this.dataset.loading = '0'; }
        });

        document.querySelector('.save-btn')?.addEventListener('click', async function() {
            if (this.dataset.loading === '1') return;
            this.dataset.loading = '1';
            try {
                const res = await fetch('/posts/' + this.dataset.postId + '/save', { method:'POST', headers:{'X-Requested-With':'XMLHttpRequest','X-CSRF-TOKEN':this.dataset.saveToken}, credentials:'same-origin' });
                const data = await res.json();
                if (!res.ok) { if (res.status === 401) { window.location.href = '{{ path('app_login') }}'; return; } return; }
                this.classList.toggle('saved', !!data.saved);
                const icon = this.querySelector('i');
                icon.classList.toggle('bi-bookmark-check-fill', !!data.saved);
                icon.classList.toggle('bi-bookmark', !data.saved);
            } finally { this.dataset.loading = '0'; }
        });
    </script>
</body>
</html>