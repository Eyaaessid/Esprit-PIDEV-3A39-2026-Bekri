<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Publications — Bekri</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --dark:       #1a2332;
            --gray:       #64748b;
            --light:      #f8fafc;
            --white:      #ffffff;
            --sidebar-w:  260px;
            --shadow-sm:  0 2px 12px rgba(0,0,0,0.06);
            --shadow:     0 8px 30px rgba(0,0,0,0.10);
            --radius:     16px;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior:smooth; }
        body { font-family:'Inter',sans-serif; background:var(--light); color:var(--dark); display:flex; min-height:100vh; }

        /* ── SIDEBAR ─────────────────────────────────────────────── */
        .sidebar { width:var(--sidebar-w); background:var(--dark); min-height:100vh; position:fixed; top:0; left:0; display:flex; flex-direction:column; z-index:100; transition:transform 0.3s ease; }
        .sidebar-logo { padding:28px 24px 20px; display:flex; align-items:center; gap:10px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-logo img { height:36px; width:auto; }
        .sidebar-logo-text { font-size:20px; font-weight:800; background:linear-gradient(135deg,var(--teal),#a78bfa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .sidebar-user { padding:20px 24px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-avatar { width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:16px; flex-shrink:0; overflow:hidden; }
        .sidebar-avatar img { width:100%; height:100%; object-fit:cover; }
        .sidebar-user-name { font-size:14px; font-weight:600; color:white; }
        .sidebar-user-role { font-size:11px; color:rgba(255,255,255,0.4); margin-top:2px; }
        .sidebar-nav { flex:1; padding:16px 0; overflow-y:auto; }
        .nav-section-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:rgba(255,255,255,0.25); padding:12px 24px 6px; }
        .nav-item { display:flex; align-items:center; gap:12px; padding:11px 24px; color:rgba(255,255,255,0.6); text-decoration:none; font-size:14px; font-weight:500; transition:all 0.2s; border-left:3px solid transparent; }
        .nav-item:hover { color:white; background:rgba(255,255,255,0.05); }
        .nav-item.active { color:var(--teal); background:rgba(32,178,170,0.1); border-left-color:var(--teal); }
        .nav-item i { width:20px; text-align:center; font-size:16px; }
        .nav-badge { margin-left:auto; background:var(--teal); color:white; font-size:10px; font-weight:700; padding:2px 7px; border-radius:50px; }
        .sidebar-footer { padding:16px 0; border-top:1px solid rgba(255,255,255,0.07); }

        /* ── MAIN ────────────────────────────────────────────────── */
        .main { margin-left:var(--sidebar-w); flex:1; display:flex; flex-direction:column; min-height:100vh; }

        /* ── TOPBAR ──────────────────────────────────────────────── */
        .topbar { background:white; padding:0 32px; height:68px; display:flex; align-items:center; justify-content:space-between; box-shadow:var(--shadow-sm); position:sticky; top:0; z-index:50; }
        .topbar-left { display:flex; align-items:center; gap:16px; }
        .topbar-title { font-size:18px; font-weight:700; color:var(--dark); }
        .topbar-sub { font-size:13px; color:var(--gray); margin-top:2px; }
        .topbar-right { display:flex; align-items:center; gap:12px; }
        .topbar-btn { width:40px; height:40px; border-radius:10px; background:var(--light); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; color:var(--gray); font-size:16px; text-decoration:none; transition:all 0.2s; position:relative; }
        .topbar-btn:hover { background:var(--teal-light); color:var(--teal-dark); }
        .topbar-avatar-sm { width:40px; height:40px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:14px; text-decoration:none; overflow:hidden; }
        .topbar-avatar-sm img { width:100%; height:100%; object-fit:cover; }
        .notif-badge { position:absolute; top:-4px; right:-4px; background:#ef4444; color:white; font-size:10px; font-weight:700; width:18px; height:18px; border-radius:50%; display:flex; align-items:center; justify-content:center; }

        /* ── CONTENT ─────────────────────────────────────────────── */
        .content { padding:32px; flex:1; }

        /* ── PAGE HEADER ─────────────────────────────────────────── */
        .page-header {
            background: linear-gradient(135deg, var(--teal) 0%, var(--teal-dark) 50%, var(--purple) 100%);
            border-radius: var(--radius);
            padding: 28px 32px;
            margin-bottom: 24px;
            color: white;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
        }
        .page-header::before { content:''; position:absolute; top:-50px; right:-50px; width:200px; height:200px; background:rgba(255,255,255,0.06); border-radius:50%; }
        .page-header h1 { font-size:22px; font-weight:800; margin-bottom:4px; }
        .page-header p  { color:rgba(255,255,255,0.8); font-size:13px; margin:0; }

        /* ── TOOLBAR ─────────────────────────────────────────────── */
        .toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 24px;
        }

        .filter-pills { display:flex; gap:8px; flex-wrap:wrap; }

        .filter-pill {
            padding: 8px 18px;
            border: 2px solid #e2e8f0;
            background: white;
            color: var(--gray);
            border-radius: 50px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            font-family: 'Inter', sans-serif;
            transition: all 0.25s;
        }
        .filter-pill:hover { border-color: var(--teal); color: var(--teal); }
        .filter-pill.active { background: var(--teal); border-color: var(--teal); color: white; }

        .toolbar-actions { display:flex; gap:10px; flex-wrap:wrap; }

        .btn-toolbar {
            display: inline-flex; align-items: center; gap: 7px;
            padding: 10px 18px; border-radius: 10px;
            font-size: 13px; font-weight: 600;
            cursor: pointer; border: none; text-decoration: none;
            transition: all 0.25s; font-family: 'Inter', sans-serif;
            position: relative;
        }
        .btn-teal { background: linear-gradient(135deg,var(--teal),var(--teal-dark)); color:white; box-shadow:0 3px 10px rgba(32,178,170,0.25); }
        .btn-teal:hover { transform:translateY(-1px); color:white; }
        .btn-outline { background:white; color:var(--gray); border:2px solid #e2e8f0; }
        .btn-outline:hover { background:var(--light); color:var(--dark); }

        /* ── FLASH ───────────────────────────────────────────────── */
        .flash { padding:12px 16px; border-radius:12px; font-size:13px; display:flex; align-items:center; gap:8px; margin-bottom:16px; }
        .flash-success { background:#f0fdf4; color:#166534; border-left:3px solid #22c55e; }
        .flash-error   { background:#fff5f5; color:#dc2626; border-left:3px solid #ef4444; }

        /* ── RECOMMENDED ─────────────────────────────────────────── */
        .recommended-section { margin-bottom:28px; }
        .section-title { font-size:15px; font-weight:700; color:var(--dark); margin-bottom:14px; display:flex; align-items:center; gap:8px; }
        .section-title i { color:var(--purple); }
        .recommended-grid { display:grid; grid-template-columns:repeat(6,1fr); gap:12px; }

        .rec-card {
            background: white; border-radius: 12px;
            overflow: hidden; box-shadow: var(--shadow-sm);
            border: 1px solid #f1f5f9;
            text-decoration: none; color: var(--dark);
            transition: all 0.25s;
            display: block;
        }
        .rec-card:hover { transform:translateY(-3px); box-shadow:var(--shadow); color:var(--dark); }
        .rec-card-img { aspect-ratio:1; overflow:hidden; background:#f1f5f9; }
        .rec-card-img img { width:100%; height:100%; object-fit:cover; }
        .rec-card-placeholder { aspect-ratio:1; background:linear-gradient(135deg,#e0e7ff,#fce7f3); display:flex; align-items:center; justify-content:center; font-size:1.8rem; color:#94a3b8; }
        .rec-card-body { padding:8px 10px; }
        .rec-card-title { font-size:12px; font-weight:600; line-height:1.3; display:block; margin-bottom:3px; }
        .rec-card-meta  { font-size:11px; color:var(--gray); }

        /* ── POSTS GRID ──────────────────────────────────────────── */
        .posts-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:20px; }

        /* ── POST CARD ───────────────────────────────────────────── */
        .post-card {
            background: white; border-radius: var(--radius);
            border: 1px solid #f1f5f9; box-shadow: var(--shadow-sm);
            overflow: hidden; display: flex; flex-direction: column;
            transition: all 0.3s;
        }
        .post-card:hover { transform:translateY(-4px); box-shadow:var(--shadow); border-color:#dbe3ea; }

        .post-card-header { padding:18px 20px; display:flex; justify-content:space-between; align-items:flex-start; border-bottom:1px solid #f8fafc; }
        .author-row { display:flex; align-items:center; gap:12px; }
        .author-avatar { width:44px; height:44px; border-radius:50%; overflow:hidden; flex-shrink:0; }
        .author-avatar img { width:100%; height:100%; object-fit:cover; }
        .avatar-initials { width:100%; height:100%; background:linear-gradient(135deg,var(--purple),#764ba2); color:white; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:18px; }
        .author-name { font-size:14px; font-weight:700; color:var(--dark); margin-bottom:2px; }
        .post-date  { font-size:12px; color:var(--gray); display:flex; align-items:center; gap:4px; }

        .post-actions-menu { position:relative; }
        .btn-dots { background:none; border:none; cursor:pointer; color:var(--gray); font-size:18px; padding:4px 8px; border-radius:8px; transition:all 0.2s; }
        .btn-dots:hover { background:var(--light); color:var(--dark); }
        .dropdown-menu-custom {
            display:none; position:absolute; right:0; top:100%; margin-top:4px;
            background:white; border-radius:10px; box-shadow:var(--shadow);
            border:1px solid #f1f5f9; min-width:140px; z-index:10;
            overflow:hidden;
        }
        .dropdown-menu-custom.open { display:block; }
        .dropdown-item-custom { display:flex; align-items:center; gap:8px; padding:10px 16px; font-size:13px; font-weight:500; color:var(--dark); text-decoration:none; cursor:pointer; background:none; border:none; width:100%; font-family:'Inter',sans-serif; transition:background 0.2s; }
        .dropdown-item-custom:hover { background:var(--light); }
        .dropdown-item-custom.danger { color:#dc2626; }
        .dropdown-item-custom.danger:hover { background:#fff5f5; }

        .post-card-media { overflow:hidden; max-height:220px; background:#f8fafc; }
        .post-card-media img { width:100%; height:100%; object-fit:cover; transition:transform 0.3s; }
        .post-card:hover .post-card-media img { transform:scale(1.04); }

        .post-card-body { padding:18px 20px; flex:1; }
        .post-category-tag {
            display:inline-flex; align-items:center;
            padding:3px 10px; border-radius:50px;
            font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px;
            margin-bottom:10px;
        }
        .cat-health    { background:#dcfce7; color:#166534; }
        .cat-nutrition { background:#fef3c7; color:#92400e; }
        .cat-mental    { background:#dbeafe; color:#1e40af; }
        .cat-fitness   { background:#fce7f3; color:#9d174d; }
        .cat-default   { background:#f1f5f9; color:var(--gray); }

        .post-title   { font-size:17px; font-weight:700; color:var(--dark); margin-bottom:8px; line-height:1.4; }
        .post-excerpt { font-size:13px; color:var(--gray); line-height:1.7; }

        .post-card-footer { padding:14px 20px; border-top:1px solid #f8fafc; display:flex; justify-content:space-between; align-items:center; }
        .post-stats { display:flex; gap:10px; }

        .stat-btn {
            background:var(--light); border:1px solid #e5e7eb;
            padding:6px 12px; border-radius:50px;
            display:flex; align-items:center; gap:5px;
            color:var(--gray); cursor:pointer;
            font-size:13px; font-weight:500;
            font-family:'Inter',sans-serif;
            transition:all 0.25s;
        }
        .stat-btn:hover { border-color:#cbd5e1; background:#f1f5f9; color:var(--dark); }
        .stat-btn i { font-size:16px; }
        .like-btn.liked { color:#e74c3c; border-color:#fecaca; background:#fff5f5; }
        .save-btn.saved { color:#059669; border-color:#6ee7b7; background:#ecfdf5; }

        .btn-read-more { color:var(--teal); font-weight:600; text-decoration:none; font-size:13px; display:flex; align-items:center; gap:5px; transition:gap 0.2s; }
        .btn-read-more:hover { gap:10px; color:var(--teal-dark); }

        /* ── EMPTY STATE ─────────────────────────────────────────── */
        .empty-state { text-align:center; padding:80px 20px; background:white; border-radius:var(--radius); box-shadow:var(--shadow-sm); }
        .empty-state i { font-size:64px; color:#cbd5e1; display:block; margin-bottom:16px; }
        .empty-state h3 { font-size:20px; font-weight:700; color:var(--dark); margin-bottom:8px; }
        .empty-state p  { font-size:14px; color:var(--gray); margin-bottom:24px; }

        /* ── PAGINATION ──────────────────────────────────────────── */
        .pagination-wrap { display:flex; justify-content:center; gap:8px; margin-top:32px; flex-wrap:wrap; }
        .page-btn { width:40px; height:40px; border-radius:10px; background:white; border:2px solid #e2e8f0; color:var(--gray); font-size:14px; font-weight:600; display:flex; align-items:center; justify-content:center; text-decoration:none; transition:all 0.25s; font-family:'Inter',sans-serif; cursor:pointer; }
        .page-btn:hover { border-color:var(--teal); color:var(--teal); }
        .page-btn.active { background:var(--teal); border-color:var(--teal); color:white; }
        .page-btn.disabled { opacity:0.4; pointer-events:none; }

        /* ── MODAL ───────────────────────────────────────────────── */
        .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); backdrop-filter:blur(6px); z-index:9999; align-items:center; justify-content:center; padding:20px; overflow-y:auto; }
        .modal-overlay.open { display:flex; }
        .modal-box { background:white; border-radius:20px; max-width:600px; width:100%; box-shadow:0 24px 70px rgba(0,0,0,0.2); animation:modalIn 0.3s ease-out; margin:auto; }
        @keyframes modalIn { from{opacity:0;transform:translateY(-20px)} to{opacity:1;transform:translateY(0)} }
        .modal-head { padding:24px 28px 16px; border-bottom:1px solid #f1f5f9; display:flex; align-items:center; justify-content:space-between; }
        .modal-head h5 { font-size:17px; font-weight:700; color:var(--dark); margin:0; }
        .modal-close { background:none; border:none; font-size:20px; color:var(--gray); cursor:pointer; width:32px; height:32px; border-radius:8px; display:flex; align-items:center; justify-content:center; transition:all 0.2s; }
        .modal-close:hover { background:var(--light); color:var(--dark); }
        .modal-body-custom { padding:24px 28px; }
        .modal-foot { padding:16px 28px 24px; border-top:1px solid #f1f5f9; display:flex; gap:10px; justify-content:flex-end; }
        .modal-foot .btn { margin:0; }

        .form-group { margin-bottom:16px; }
        .form-label { font-size:13px; font-weight:600; color:var(--dark); display:block; margin-bottom:6px; }
        .form-input, .form-select, .form-textarea {
            width:100%; padding:10px 14px;
            border:2px solid #e2e8f0; border-radius:10px;
            font-size:14px; font-family:'Inter',sans-serif; color:var(--dark);
            outline:none; transition:all 0.25s; background:var(--light);
        }
        .form-input:focus, .form-select:focus, .form-textarea:focus { border-color:var(--teal); background:white; box-shadow:0 0 0 3px rgba(32,178,170,0.1); }
        .form-textarea { resize:vertical; min-height:120px; }
        .form-hint { font-size:12px; color:var(--gray); margin-top:4px; }

        .btn-primary-custom { background:linear-gradient(135deg,var(--teal),var(--teal-dark)); color:white; padding:10px 22px; border-radius:10px; border:none; font-size:14px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; display:inline-flex; align-items:center; gap:7px; transition:all 0.25s; }
        .btn-primary-custom:hover { transform:translateY(-1px); }
        .btn-ghost { background:var(--light); color:var(--gray); border:2px solid #e2e8f0; padding:10px 22px; border-radius:10px; font-size:14px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; transition:all 0.25s; }
        .btn-ghost:hover { background:#e2e8f0; color:var(--dark); }

        .preview-box { position:relative; margin-top:12px; border-radius:10px; overflow:hidden; }
        .preview-box img { width:100%; border-radius:10px; }
        .preview-remove { position:absolute; top:8px; right:8px; background:rgba(220,38,38,0.9); color:white; border:none; width:28px; height:28px; border-radius:50%; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:14px; }

        /* ── MOBILE ──────────────────────────────────────────────── */
        .menu-toggle { display:none; background:none; border:none; font-size:22px; color:var(--dark); cursor:pointer; }
        .sidebar-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:99; }

        @media (max-width:1024px) { .posts-grid { grid-template-columns:1fr; } .recommended-grid { grid-template-columns:repeat(3,1fr); } }
        @media (max-width:768px) {
            .sidebar { transform:translateX(-100%); }
            .sidebar.open { transform:translateX(0); }
            .sidebar-overlay.open { display:block; }
            .main { margin-left:0; }
            .menu-toggle { display:block; }
            .content { padding:16px; }
            .topbar { padding:0 16px; }
            .recommended-grid { grid-template-columns:repeat(2,1fr); }
            .toolbar { flex-direction:column; align-items:flex-start; }
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'">
            <span class="sidebar-logo-text">Bekri</span>
        </div>
        <div class="sidebar-user">
            <div class="sidebar-avatar">
                {% if app.user and app.user.avatar %}
                    <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
                {% elseif app.user %}
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                {% else %}
                    <i class="bi bi-person-fill" style="font-size:20px;"></i>
                {% endif %}
            </div>
            <div>
                <div class="sidebar-user-name">{{ app.user ? app.user.prenom ~ ' ' ~ app.user.nom : 'Invité' }}</div>
                <div class="sidebar-user-role">Membre Bekri</div>
            </div>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section-label">Principal</div>
            <a href="{{ path('user_dashboard') }}"   class="nav-item"><i class="bi bi-grid-fill"></i> Tableau de bord</a>
            <a href="{{ path('suivi_today') }}"       class="nav-item"><i class="bi bi-clipboard2-pulse-fill"></i> Check-in quotidien</a>
            <a href="{{ path('insight_weekly') }}"    class="nav-item"><i class="bi bi-graph-up-arrow"></i> Insights hebdo</a>
            <a href="{{ path('chat_index') }}"        class="nav-item"><i class="bi bi-robot"></i> Coach Eya IA</a>
            <div class="nav-section-label">Bien-être</div>
            <a href="{{ path('user_analyse') }}"      class="nav-item"><i class="bi bi-heart-pulse-fill"></i> Mon analyse bien-être</a>
            <a href="{{ path('objectif_index') }}"    class="nav-item"><i class="bi bi-trophy-fill"></i> Mes objectifs</a>
            <div class="nav-section-label">Communauté</div>
            <a href="{{ path('posts_list') }}"        class="nav-item active"><i class="bi bi-newspaper"></i> Publications</a>
            <a href="{{ path('evenements_home') }}"   class="nav-item"><i class="bi bi-calendar-event-fill"></i> Événements</a>
            <div class="nav-section-label">Mon compte</div>
            <a href="{{ path('user_profile') }}"      class="nav-item"><i class="bi bi-person-fill"></i> Mon profil</a>
            <a href="{{ path('user_profile_edit') }}" class="nav-item"><i class="bi bi-gear-fill"></i> Paramètres</a>
        </nav>
        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;"><i class="bi bi-box-arrow-left"></i> Se déconnecter</a>
        </div>
    </aside>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- MAIN -->
    <div class="main">
        <header class="topbar">
            <div class="topbar-left">
                <button class="menu-toggle" id="menuToggle"><i class="bi bi-list"></i></button>
                <div>
                    <div class="topbar-title">Publications</div>
                    <div class="topbar-sub">Partagez et découvrez les posts de la communauté</div>
                </div>
            </div>
            <div class="topbar-right">
                {% if app.user %}
                    <a href="{{ path('posts_notifications') }}" class="topbar-btn" title="Notifications">
                        <i class="bi bi-bell-fill"></i>
                        {% if (unreadNotificationsCount|default(0)) > 0 %}
                            <span class="notif-badge">{{ unreadNotificationsCount }}</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('posts_saved') }}" class="topbar-btn" title="Posts sauvegardés">
                        <i class="bi bi-bookmark-heart-fill"></i>
                    </a>
                {% endif %}
                <a href="{{ path('user_profile') }}" class="topbar-avatar-sm">
                    {% if app.user and app.user.avatar %}
                        <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
                    {% elseif app.user %}
                        {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                    {% else %}
                        <i class="bi bi-person-fill"></i>
                    {% endif %}
                </a>
            </div>
        </header>

        <main class="content">

            {# Page Header #}
            <div class="page-header">
                <div>
                    <h1><i class="bi bi-newspaper"></i> Publications</h1>
                    <p>Partagez votre parcours, connectez-vous avec la communauté</p>
                </div>
                <button class="btn-toolbar btn-teal" onclick="document.getElementById('createPostModal').classList.add('open')">
                    <i class="bi bi-plus-circle-fill"></i> Créer un post
                </button>
            </div>

            {# Flash Messages #}
            {% for message in app.flashes('success') %}
                <div class="flash flash-success"><i class="bi bi-check-circle-fill"></i> {{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="flash flash-error"><i class="bi bi-exclamation-triangle-fill"></i> {{ message }}</div>
            {% endfor %}

            {# Toolbar #}
            <div class="toolbar">
                <div class="filter-pills">
                    <button class="filter-pill active" data-filter="all">Tous</button>
                    <button class="filter-pill" data-filter="health">Santé</button>
                    <button class="filter-pill" data-filter="nutrition">Nutrition</button>
                    <button class="filter-pill" data-filter="mental">Santé mentale</button>
                    <button class="filter-pill" data-filter="fitness">Fitness</button>
                </div>
            </div>

            {# Recommended #}
            {% if recommendedPosts is defined and recommendedPosts|length > 0 %}
                <div class="recommended-section">
                    <div class="section-title"><i class="bi bi-stars"></i> Recommandés pour vous</div>
                    <div class="recommended-grid">
                        {% for recPost in recommendedPosts %}
                            <a href="{{ path('post_details', {'id': recPost.id}) }}" class="rec-card" data-category="{{ recPost.categorie|default('')|lower }}">
                                {% if recPost.mediaUrl %}
                                    <div class="rec-card-img"><img src="{{ recPost.mediaUrl }}" alt="{{ recPost.titre }}"></div>
                                {% else %}
                                    <div class="rec-card-placeholder"><i class="bi bi-file-text"></i></div>
                                {% endif %}
                                <div class="rec-card-body">
                                    <span class="rec-card-title">{{ recPost.titre|slice(0,40) }}{% if recPost.titre|length > 40 %}...{% endif %}</span>
                                    <span class="rec-card-meta">{{ recPost.likes|length }} likes · {{ recPost.commentaires|length }} comments</span>
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Posts Grid #}
            {% if posts is empty %}
                <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <h3>Aucun post pour l'instant</h3>
                    <p>Soyez le premier à partager quelque chose avec la communauté !</p>
                    <button class="btn-primary-custom" onclick="document.getElementById('createPostModal').classList.add('open')">
                        <i class="bi bi-plus-circle-fill"></i> Créer le premier post
                    </button>
                </div>
            {% else %}
                <div class="posts-grid" id="postsContainer">
                    {% for post in posts %}
                        <article class="post-card" data-category="{{ post.categorie|lower }}">

                            <div class="post-card-header">
                                <div class="author-row">
                                    <div class="author-avatar">
                                        {% if post.utilisateur.avatar %}
                                            <img src="{{ asset('uploads/avatars/' ~ post.utilisateur.avatar) }}" alt="{{ post.utilisateur.nom }}">
                                        {% else %}
                                            <div class="avatar-initials">{{ post.utilisateur.nom|first|upper }}</div>
                                        {% endif %}
                                    </div>
                                    <div>
                                        <div class="author-name">{{ post.utilisateur.nom }} {{ post.utilisateur.prenom }}</div>
                                        <div class="post-date"><i class="bi bi-clock"></i> {{ post.createdAt|date('d/m/Y') }}{% if post.updatedAt %} <span style="color:#94a3b8;">(modifié)</span>{% endif %}</div>
                                    </div>
                                </div>
                                <div class="post-actions-menu">
                                    <button class="btn-dots" onclick="toggleDropdown(this)"><i class="bi bi-three-dots-vertical"></i></button>
                                    <div class="dropdown-menu-custom">
                                        <button class="dropdown-item-custom" onclick="openEditModal({{ post.id }})"><i class="bi bi-pencil"></i> Modifier</button>
                                        <button class="dropdown-item-custom danger" onclick="confirmDelete({{ post.id }})"><i class="bi bi-trash"></i> Supprimer</button>
                                    </div>
                                </div>
                            </div>

                            {% if post.mediaUrl %}
                                <div class="post-card-media"><img src="{{ post.mediaUrl }}" alt="{{ post.titre }}"></div>
                            {% endif %}

                            <div class="post-card-body">
                                {% if post.categorie %}
                                    <span class="post-category-tag cat-{{ post.categorie|lower }}">{{ post.categorie }}</span>
                                {% endif %}
                                <div class="post-title">{{ post.titre }}</div>
                                <div class="post-excerpt">{{ post.contenu|slice(0,180) }}{% if post.contenu|length > 180 %}...{% endif %}</div>
                            </div>

                            <div class="post-card-footer">
                                <div class="post-stats">
                                    {% set isLiked = false %}
                                    {% if app.user %}
                                        {% for like in post.likes %}
                                            {% if like.utilisateur and like.utilisateur.id == app.user.id %}{% set isLiked = true %}{% endif %}
                                        {% endfor %}
                                    {% endif %}
                                    <button class="stat-btn like-btn {% if isLiked %}liked{% endif %}" data-post-id="{{ post.id }}" data-like-token="{{ csrf_token('like' ~ post.id) }}">
                                        <i class="bi {% if isLiked %}bi-heart-fill{% else %}bi-heart{% endif %}"></i>
                                        <span>{{ post.likes|length }}</span>
                                    </button>
                                    {% set isSaved = app.user and post.id in (savedPostIds|default([])) %}
                                    <button class="stat-btn save-btn {% if isSaved %}saved{% endif %}" data-post-id="{{ post.id }}" data-save-token="{{ csrf_token('save' ~ post.id) }}">
                                        <i class="bi {% if isSaved %}bi-bookmark-check-fill{% else %}bi-bookmark{% endif %}"></i>
                                    </button>
                                    <a href="{{ path('post_details', {'id': post.id}) }}#comments" class="stat-btn">
    <i class="bi bi-chat"></i>
    <span>{{ post.commentaires|length }}</span>
</a>
                                </div>
                                <a href="{{ path('post_details', {'id': post.id}) }}" class="btn-read-more">Lire <i class="bi bi-arrow-right"></i></a>
                            </div>

                            <form id="deleteForm{{ post.id }}" action="{{ path('post_delete', {'id': post.id}) }}" method="post" style="display:none;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
                            </form>
                        </article>

                        {# Edit Modal #}
                        <div class="modal-overlay" id="editModal{{ post.id }}">
                            <div class="modal-box">
                                <div class="modal-head">
                                    <h5><i class="bi bi-pencil-fill" style="color:var(--teal);margin-right:8px;"></i>Modifier le post</h5>
                                    <button class="modal-close" onclick="document.getElementById('editModal{{ post.id }}').classList.remove('open')"><i class="bi bi-x"></i></button>
                                </div>
                                <form action="{{ path('post_edit', {'id': post.id}) }}" method="post" enctype="multipart/form-data">
                                    <div class="modal-body-custom">
                                        <input type="hidden" name="_token" value="{{ csrf_token('edit' ~ post.id) }}">
                                        <div class="form-group">
                                            <label class="form-label">Titre *</label>
                                            <input type="text" name="titre" class="form-input" value="{{ post.titre }}" required>
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">Catégorie</label>
                                            <select name="categorie" class="form-select">
                                                <option value="">Choisir...</option>
                                                <option value="Health" {% if post.categorie=='Health' %}selected{% endif %}>Santé</option>
                                                <option value="Nutrition" {% if post.categorie=='Nutrition' %}selected{% endif %}>Nutrition</option>
                                                <option value="Mental" {% if post.categorie=='Mental' %}selected{% endif %}>Santé mentale</option>
                                                <option value="Fitness" {% if post.categorie=='Fitness' %}selected{% endif %}>Fitness</option>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">Contenu *</label>
                                            <textarea name="contenu" class="form-textarea" rows="6" required>{{ post.contenu }}</textarea>
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">Mettre à jour l'image</label>
                                            {% if post.mediaUrl %}<img src="{{ post.mediaUrl }}" style="max-width:100%;border-radius:8px;margin-bottom:8px;">{% endif %}
                                            <input type="file" name="media" class="form-input" accept="image/*">
                                        </div>
                                    </div>
                                    <div class="modal-foot">
                                        <button type="button" class="btn-ghost" onclick="document.getElementById('editModal{{ post.id }}').classList.remove('open')">Annuler</button>
                                        <button type="submit" class="btn-primary-custom"><i class="bi bi-check-circle-fill"></i> Mettre à jour</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                {# Pagination #}
                {% if posts.pageCount is defined and posts.pageCount > 1 %}
                    <div class="pagination-wrap">
                        {% set currentPage = posts.currentPageNumber %}
                        {% set totalPages  = posts.pageCount %}
                        {% set queryParams = app.request.query.all %}
                        <a class="page-btn {% if currentPage <= 1 %}disabled{% endif %}" href="{{ currentPage > 1 ? path('posts_list', queryParams|merge({'page': currentPage - 1})) : '#' }}"><i class="bi bi-chevron-left"></i></a>
                        {% for page in 1..totalPages %}
                            <a class="page-btn {% if page == currentPage %}active{% endif %}" href="{{ path('posts_list', queryParams|merge({'page': page})) }}">{{ page }}</a>
                        {% endfor %}
                        <a class="page-btn {% if currentPage >= totalPages %}disabled{% endif %}" href="{{ currentPage < totalPages ? path('posts_list', queryParams|merge({'page': currentPage + 1})) : '#' }}"><i class="bi bi-chevron-right"></i></a>
                    </div>
                {% endif %}
            {% endif %}

        </main>
    </div>

    {# Create Post Modal #}
    <div class="modal-overlay" id="createPostModal">
        <div class="modal-box">
            <div class="modal-head">
                <h5><i class="bi bi-plus-circle-fill" style="color:var(--teal);margin-right:8px;"></i>Créer un post</h5>
                <button class="modal-close" onclick="document.getElementById('createPostModal').classList.remove('open')"><i class="bi bi-x"></i></button>
            </div>
            <form action="{{ path('post_create') }}" method="post" enctype="multipart/form-data">
                <div class="modal-body-custom">
                    <input type="hidden" name="_token" value="{{ csrf_token('create_post') }}">
                    <div class="form-group">
                        <label class="form-label">Titre *</label>
                        <input type="text" name="titre" class="form-input" placeholder="Donnez un titre à votre post..." required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Catégorie</label>
                        <select name="categorie" class="form-select">
                            <option value="">Choisir une catégorie...</option>
                            <option value="Health">Santé</option>
                            <option value="Nutrition">Nutrition</option>
                            <option value="Mental">Santé mentale</option>
                            <option value="Fitness">Fitness</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Contenu *</label>
                        <textarea name="contenu" class="form-textarea" rows="6" placeholder="Partagez vos pensées, expériences ou conseils..." required></textarea>
                        <div class="form-hint"><i class="bi bi-info-circle"></i> Soyez respectueux et constructif</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Ajouter une image (optionnel)</label>
                        <input type="file" name="media" class="form-input" accept="image/*" id="mediaInput">
                        <div class="form-hint">JPG, PNG, GIF — Max 5MB</div>
                        <div class="preview-box" id="imagePreview" style="display:none;">
                            <img src="" id="previewImage" alt="Preview">
                            <button type="button" class="preview-remove" onclick="removePreview()"><i class="bi bi-x"></i></button>
                        </div>
                    </div>
                </div>
                <div class="modal-foot">
                    <button type="button" class="btn-ghost" onclick="document.getElementById('createPostModal').classList.remove('open')">Annuler</button>
                    <button type="submit" class="btn-primary-custom"><i class="bi bi-send-fill"></i> Publier</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // Sidebar
        const menuToggle = document.getElementById('menuToggle');
        const sidebar    = document.getElementById('sidebar');
        const overlay    = document.getElementById('sidebarOverlay');
        menuToggle?.addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('open'); });
        overlay?.addEventListener('click',   () => { sidebar.classList.remove('open'); overlay.classList.remove('open'); });

        // Dropdown
        function toggleDropdown(btn) {
            const menu = btn.nextElementSibling;
            document.querySelectorAll('.dropdown-menu-custom.open').forEach(m => { if (m !== menu) m.classList.remove('open'); });
            menu.classList.toggle('open');
        }
        document.addEventListener('click', e => { if (!e.target.closest('.post-actions-menu')) document.querySelectorAll('.dropdown-menu-custom.open').forEach(m => m.classList.remove('open')); });

        function openEditModal(id)  { document.getElementById('editModal' + id).classList.add('open'); }
        function confirmDelete(id) {
            if (confirm('Supprimer ce post ?')) document.getElementById('deleteForm' + id).submit();
        }

        // Filter pills
        document.querySelectorAll('.filter-pill').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.filter-pill').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                const filter = this.dataset.filter;
                document.querySelectorAll('#postsContainer .post-card').forEach(card => {
                    card.parentElement.style.display = (filter === 'all' || card.dataset.category === filter) ? '' : 'none';
                });
            });
        });

        // Image preview
        document.getElementById('mediaInput')?.addEventListener('change', function() {
            const file = this.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('previewImage').src = e.target.result;
                document.getElementById('imagePreview').style.display = 'block';
            };
            reader.readAsDataURL(file);
        });
        function removePreview() {
            document.getElementById('mediaInput').value = '';
            document.getElementById('imagePreview').style.display = 'none';
        }

        // Like buttons
        document.querySelectorAll('.like-btn').forEach(btn => {
            btn.addEventListener('click', async function() {
                if (this.dataset.loading === '1') return;
                this.dataset.loading = '1';
                try {
                    const res  = await fetch('/posts/' + this.dataset.postId + '/like', { method:'POST', headers:{'X-Requested-With':'XMLHttpRequest','X-CSRF-TOKEN':this.dataset.likeToken}, credentials:'same-origin' });
                    const data = await res.json();
                    if (!res.ok) { if (res.status === 401) { window.location.href = '{{ path('app_login') }}'; return; } return; }
                    this.classList.toggle('liked', !!data.liked);
                    this.querySelector('span').textContent = data.count;
                    const icon = this.querySelector('i');
                    icon.classList.toggle('bi-heart-fill', !!data.liked);
                    icon.classList.toggle('bi-heart', !data.liked);
                } finally { this.dataset.loading = '0'; }
            });
        });

        // Save buttons
        document.querySelectorAll('.save-btn').forEach(btn => {
            btn.addEventListener('click', async function() {
                if (this.dataset.loading === '1') return;
                this.dataset.loading = '1';
                try {
                    const res  = await fetch('/posts/' + this.dataset.postId + '/save', { method:'POST', headers:{'X-Requested-With':'XMLHttpRequest','X-CSRF-TOKEN':this.dataset.saveToken}, credentials:'same-origin' });
                    const data = await res.json();
                    if (!res.ok) { if (res.status === 401) { window.location.href = '{{ path('app_login') }}'; return; } return; }
                    this.classList.toggle('saved', !!data.saved);
                    const icon = this.querySelector('i');
                    icon.classList.toggle('bi-bookmark-check-fill', !!data.saved);
                    icon.classList.toggle('bi-bookmark', !data.saved);
                } finally { this.dataset.loading = '0'; }
            });
        });
    </script>
</body>
</html>