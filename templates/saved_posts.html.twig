{% extends 'base.html.twig' %}

{% block title %}Saved Posts - MediNest{% endblock %}

{% block main %}
  <div class="page-title">
    <div class="heading">
      <div class="container">
        <div class="row d-flex justify-content-center text-center">
          <div class="col-lg-8">
            <h1 class="heading-title">Saved Posts</h1>
            <p class="mb-0">Posts you bookmarked for later.</p>
          </div>
        </div>
      </div>
    </div>
    <nav class="breadcrumbs">
      <div class="container">
        <ol>
          <li><a href="{{ path('home') }}">Home</a></li>
          <li><a href="{{ path('posts_list') }}">Posts</a></li>
          <li class="current">Saved</li>
        </ol>
      </div>
    </nav>
  </div>

  <section class="section">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0"><i class="bi bi-bookmarks me-2"></i>{{ posts|length }} saved post(s)</h4>
        <a href="{{ path('posts_list') }}" class="btn btn-outline-primary">
          <i class="bi bi-arrow-left me-1"></i>Back to Posts
        </a>
      </div>

      {% if posts is empty %}
        <div class="alert alert-info">You have no saved posts yet.</div>
      {% else %}
        <div class="row gy-4">
          {% for post in posts %}
            <div class="col-lg-6">
              <article class="card h-100 border-0 shadow-sm">
                {% if post.mediaUrl %}
                  <img src="{{ post.mediaUrl }}" class="card-img-top" alt="{{ post.titre }}" style="max-height:280px;object-fit:cover;">
                {% endif %}
                <div class="card-body">
                  {% if post.categorie %}
                    <span class="badge bg-light text-dark mb-2">{{ post.categorie }}</span>
                  {% endif %}
                  <h5 class="card-title">{{ post.titre }}</h5>
                  <p class="card-text text-muted">{{ post.contenu|slice(0, 180) }}{% if post.contenu|length > 180 %}...{% endif %}</p>
                  <small class="text-muted d-block mb-3">
                    <i class="bi bi-heart-fill text-danger"></i> {{ post.likes|length }}
                    <span class="mx-2">•</span>
                    <i class="bi bi-chat-left-text"></i> {{ post.commentaires|length }}
                  </small>
                  <div class="d-flex gap-2">
                    <a class="btn btn-primary btn-sm" href="{{ path('post_details', {'id': post.id}) }}">
                      Read
                    </a>
                    <button class="btn btn-outline-success btn-sm save-btn saved"
                            data-post-id="{{ post.id }}"
                            data-save-token="{{ csrf_token('save' ~ post.id) }}">
                      <i class="bi bi-bookmark-check-fill"></i> Saved
                    </button>
                  </div>
                </div>
              </article>
            </div>
          {% endfor %}
        </div>
      {% endif %}

      {% if recommendedPosts is defined and recommendedPosts|length > 0 %}
        <hr class="my-5">
        <h5 class="mb-3"><i class="bi bi-stars me-2"></i>Recommended for you</h5>
        <div class="row gy-3">
          {% for rec in recommendedPosts %}
            <div class="col-md-4 col-lg-3">
              <a class="text-decoration-none" href="{{ path('post_details', {'id': rec.id}) }}">
                <div class="card h-100 border-0 shadow-sm">
                  {% if rec.mediaUrl %}
                    <img src="{{ rec.mediaUrl }}" class="card-img-top" alt="{{ rec.titre }}" style="max-height:170px;object-fit:cover;">
                  {% endif %}
                  <div class="card-body">
                    <h6 class="card-title text-dark">{{ rec.titre|slice(0, 55) }}{% if rec.titre|length > 55 %}...{% endif %}</h6>
                    <small class="text-muted">{{ rec.likes|length }} likes • {{ rec.commentaires|length }} comments</small>
                  </div>
                </div>
              </a>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </section>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.querySelectorAll('.save-btn').forEach(btn => {
  btn.addEventListener('click', async function() {
    if (this.dataset.loading === '1') return;
    this.dataset.loading = '1';
    const postId = this.dataset.postId;
    const saveToken = this.dataset.saveToken;

    try {
      const response = await fetch('/posts/' + postId + '/save', {
        method: 'POST',
        headers: {
          'X-Requested-With': 'XMLHttpRequest',
          'X-CSRF-TOKEN': saveToken
        },
        credentials: 'same-origin'
      });
      const data = await response.json();
      if (!response.ok) {
        if (response.status === 401) {
          window.location.href = '{{ path('app_login') }}';
          return;
        }
        alert(data.error || 'Unable to update saved posts right now.');
        return;
      }
      if (!data.saved) {
        this.closest('.col-lg-6')?.remove();
      }
    } catch (e) {
      alert('Network error. Please try again.');
    } finally {
      this.dataset.loading = '0';
    }
  });
});
</script>
{% endblock %}
