{% block javascripts %}
{{ parent() }}
<script>
// Delete Post Confirmation
function confirmDelete() {
  if (confirm('Are you sure you want to delete this post? This action cannot be undone.')) {
    document.getElementById('deletePostForm').submit();
  }
}

function markFieldError(field, hasError) {
  field.classList.toggle('is-invalid', hasError);
}

function validateRequiredFields(form, names) {
  let ok = true;
  names.forEach(name => {
    const field = form.querySelector('[name="' + name + '"]');
    if (!field) {
      return;
    }
    const valid = field.value.trim().length > 0;
    markFieldError(field, !valid);
    if (!valid) {
      ok = false;
    }
  });
  return ok;
}

document.querySelectorAll('form[novalidate]').forEach(form => {
  form.addEventListener('submit', function(e) {
    let names = [];
    if (form.querySelector('[name="titre"]') || form.querySelector('[name="contenu"]')) {
      if (form.querySelector('[name="titre"]')) {
        names.push('titre');
      }
      if (form.querySelector('[name="contenu"]')) {
        names.push('contenu');
      }
    }
    if (names.length === 0) {
      return;
    }
    if (!validateRequiredFields(form, names)) {
      e.preventDefault();
      alert('Please fill in required fields.');
    }
  });
});

// Delete Comment
function deleteComment(commentId) {
  if (confirm('Are you sure you want to delete this comment?')) {
    document.getElementById('deleteCommentForm' + commentId).submit();
  }
}

// Like Button
document.querySelector('.like-btn')?.addEventListener('click', async function() {
  if (this.dataset.loading === '1') {
    return;
  }

  const postId = this.dataset.postId;
  const likeToken = this.dataset.likeToken;

  this.dataset.loading = '1';
  
  try {
    const response = await fetch('/posts/' + postId + '/like', {
      method: 'POST',
      headers: {
        'X-Requested-With': 'XMLHttpRequest',
        'X-CSRF-TOKEN': likeToken
      },
      credentials: 'same-origin'
    });

    const data = await response.json();
    if (!response.ok) {
      if (response.status === 401) {
        window.location.href = '{{ path('app_login') }}';
        return;
      }

      alert(data.error || 'Unable to update like right now.');
      return;
    }

    this.classList.toggle('liked', !!data.liked);
    this.querySelector('.like-count').textContent = data.count;
    const icon = this.querySelector('i');
    icon.classList.toggle('bi-heart-fill', !!data.liked);
    icon.classList.toggle('bi-heart', !data.liked);
  } catch (error) {
    console.error('Error:', error);
    alert('Network error. Please try again.');
  } finally {
    this.dataset.loading = '0';
  }
});

document.querySelector('.save-btn')?.addEventListener('click', async function() {
  if (this.dataset.loading === '1') {
    return;
  }

  const postId = this.dataset.postId;
  const saveToken = this.dataset.saveToken;
  this.dataset.loading = '1';

  try {
    const response = await fetch('/posts/' + postId + '/save', {
      method: 'POST',
      headers: {
        'X-Requested-With': 'XMLHttpRequest',
        'X-CSRF-TOKEN': saveToken
      },
      credentials: 'same-origin'
    });

    const data = await response.json();
    if (!response.ok) {
      if (response.status === 401) {
        window.location.href = '{{ path('app_login') }}';
        return;
      }

      alert(data.error || 'Unable to update saved posts right now.');
      return;
    }

    this.classList.toggle('saved', !!data.saved);
    this.title = data.saved ? 'Remove from saved' : 'Save post';
    const icon = this.querySelector('i');
    icon.classList.toggle('bi-bookmark-check-fill', !!data.saved);
    icon.classList.toggle('bi-bookmark', !data.saved);
  } catch (error) {
    console.error('Error:', error);
    alert('Network error. Please try again.');
  } finally {
    this.dataset.loading = '0';
  }
});

// Share Button
document.querySelector('.btn-share')?.addEventListener('click', function() {
  if (navigator.share) {
    navigator.share({
      title: document.title,
      url: window.location.href
    });
  } else {
    // Fallback: Copy to clipboard
    navigator.clipboard.writeText(window.location.href);
    alert('Link copied to clipboard!');
  }
});
</script>
{% endblock %}
