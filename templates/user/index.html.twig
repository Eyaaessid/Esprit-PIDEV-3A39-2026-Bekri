<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mon Tableau de Bord — Bekri</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --teal:        #20b2aa;
            --teal-dark:   #0d9488;
            --teal-light:  #e0f7f6;
            --purple:      #667eea;
            --dark:        #1a2332;
            --gray:        #64748b;
            --light:       #f8fafc;
            --white:       #ffffff;
            --sidebar-w:   260px;
            --shadow-sm:   0 2px 12px rgba(0,0,0,0.06);
            --shadow:      0 8px 30px rgba(0,0,0,0.10);
            --radius:      16px;
        }

        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior: smooth; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--light);
            color: var(--dark);
            display: flex;
            min-height: 100vh;
        }

        /* ── SIDEBAR ─────────────────────────────────────────────────── */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--dark);
            min-height: 100vh;
            position: fixed;
            top: 0; left: 0;
            display: flex;
            flex-direction: column;
            z-index: 100;
            transition: transform 0.3s ease;
        }

        .sidebar-logo {
            padding: 28px 24px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }

        .sidebar-logo img { height: 36px; width: auto; }

        .sidebar-logo-text {
            font-size: 20px;
            font-weight: 800;
            background: linear-gradient(135deg, var(--teal), #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .sidebar-user {
            padding: 20px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }

        .sidebar-avatar {
            width: 42px; height: 42px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--teal), var(--purple));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 16px;
            flex-shrink: 0;
            overflow: hidden;
        }

        .sidebar-avatar img { width: 100%; height: 100%; object-fit: cover; }

        .sidebar-user-name {
            font-size: 14px;
            font-weight: 600;
            color: white;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .sidebar-user-role {
            font-size: 11px;
            color: rgba(255,255,255,0.4);
            margin-top: 2px;
        }

        .sidebar-nav { flex: 1; padding: 16px 0; overflow-y: auto; }

        .nav-section-label {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: rgba(255,255,255,0.25);
            padding: 12px 24px 6px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 24px;
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s;
            border-left: 3px solid transparent;
            position: relative;
        }

        .nav-item:hover { color: white; background: rgba(255,255,255,0.05); }

        .nav-item.active {
            color: var(--teal);
            background: rgba(32,178,170,0.1);
            border-left-color: var(--teal);
        }

        .nav-item i { width: 20px; text-align: center; font-size: 16px; }

        .nav-badge {
            margin-left: auto;
            background: var(--teal);
            color: white;
            font-size: 10px;
            font-weight: 700;
            padding: 2px 7px;
            border-radius: 50px;
        }

        .sidebar-footer {
            padding: 16px 0;
            border-top: 1px solid rgba(255,255,255,0.07);
        }

        /* ── MAIN ────────────────────────────────────────────────────── */
        .main {
            margin-left: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* ── TOPBAR ──────────────────────────────────────────────────── */
        .topbar {
            background: white;
            padding: 0 32px;
            height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: var(--shadow-sm);
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .topbar-left { display: flex; align-items: center; gap: 16px; }
        .topbar-greeting h2 { font-size: 18px; font-weight: 700; color: var(--dark); }
        .topbar-greeting p  { font-size: 13px; color: var(--gray); }
        .topbar-right { display: flex; align-items: center; gap: 12px; }

        .topbar-btn {
            width: 40px; height: 40px;
            border-radius: 10px;
            background: var(--light);
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--gray);
            font-size: 16px;
            transition: all 0.2s;
            text-decoration: none;
        }

        .topbar-btn:hover { background: var(--teal-light); color: var(--teal-dark); }

        .topbar-avatar {
            width: 40px; height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--teal), var(--purple));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            overflow: hidden;
            text-decoration: none;
        }

        .topbar-avatar img { width: 100%; height: 100%; object-fit: cover; }

        /* ── CONTENT ─────────────────────────────────────────────────── */
        .content { padding: 32px; flex: 1; }

        /* ── WELCOME BANNER ──────────────────────────────────────────── */
        .welcome-banner {
            background: linear-gradient(135deg, var(--teal) 0%, var(--teal-dark) 50%, var(--purple) 100%);
            border-radius: var(--radius);
            padding: 32px 36px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
            position: relative;
            overflow: hidden;
        }

        .welcome-banner::before {
            content: '';
            position: absolute;
            top: -50px; right: -50px;
            width: 200px; height: 200px;
            background: rgba(255,255,255,0.06);
            border-radius: 50%;
        }

        .welcome-banner::after {
            content: '';
            position: absolute;
            bottom: -30px; right: 120px;
            width: 120px; height: 120px;
            background: rgba(255,255,255,0.04);
            border-radius: 50%;
        }

        .welcome-text h1 { font-size: 26px; font-weight: 800; color: white; margin-bottom: 6px; }
        .welcome-text p  { color: rgba(255,255,255,0.8); font-size: 14px; }

        .welcome-actions {
            display: flex;
            gap: 12px;
            position: relative;
            z-index: 1;
        }

        .btn-banner {
            padding: 11px 22px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
        }

        .btn-banner-primary { background: white; color: var(--teal-dark); }
        .btn-banner-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.15); }

        .btn-banner-secondary {
            background: rgba(255,255,255,0.18);
            color: white;
            border: 1px solid rgba(255,255,255,0.3);
            backdrop-filter: blur(8px);
        }

        .btn-banner-secondary:hover { background: rgba(255,255,255,0.28); transform: translateY(-2px); }

        /* ── AI ANALYSE TEASER ───────────────────────────────────────── */
        .analyse-teaser {
            background: linear-gradient(135deg, #f8f9ff 0%, #f0f4ff 100%);
            border-radius: var(--radius);
            padding: 24px 28px;
            margin-bottom: 28px;
            box-shadow: var(--shadow-sm);
            border: 1px solid #e8ecff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            flex-wrap: wrap;
        }

        .analyse-teaser-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .analyse-teaser-icon {
            width: 52px; height: 52px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .analyse-teaser-icon i { color: white; font-size: 20px; }

        .analyse-teaser-text h3 {
            font-size: 15px;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 4px;
        }

        .analyse-teaser-text p {
            font-size: 13px;
            color: var(--gray);
            margin: 0;
        }

        .analyse-teaser-badges {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .badge-score {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 50px;
            padding: 6px 14px;
            font-size: 13px;
            color: var(--dark);
        }

        .badge-score strong { color: var(--purple); }

        .badge-profil {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border-radius: 50px;
            padding: 6px 14px;
            font-size: 13px;
            font-weight: 600;
        }

        .btn-analyse {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 11px 22px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border-radius: 50px;
            font-weight: 600;
            font-size: 13px;
            text-decoration: none;
            white-space: nowrap;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(102,126,234,0.3);
        }

        .btn-analyse:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102,126,234,0.4);
            color: white;
        }

        /* ── STATS ROW ───────────────────────────────────────────────── */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: white;
            border-radius: var(--radius);
            padding: 22px 24px;
            box-shadow: var(--shadow-sm);
            display: flex;
            align-items: center;
            gap: 16px;
            transition: all 0.3s;
            border: 1px solid #f1f5f9;
        }

        .stat-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); }

        .stat-icon {
            width: 50px; height: 50px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

        .icon-teal   { background: var(--teal-light);  color: var(--teal-dark); }
        .icon-purple { background: #ede9fe; color: #7c3aed; }
        .icon-amber  { background: #fef3c7; color: #d97706; }
        .icon-rose   { background: #ffe4e6; color: #e11d48; }
        .icon-blue   { background: #dbeafe; color: #2563eb; }
        .icon-green  { background: #d1fae5; color: #059669; }

        .stat-info { flex: 1; }
        .stat-value { font-size: 24px; font-weight: 800; color: var(--dark); line-height: 1; }
        .stat-label { font-size: 12px; color: var(--gray); margin-top: 4px; }

        /* ── GRID ────────────────────────────────────────────────────── */
        .dashboard-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 24px;
            margin-bottom: 28px;
        }

        .card {
            background: white;
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            border: 1px solid #f1f5f9;
            overflow: hidden;
        }

        .card-header {
            padding: 20px 24px 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .card-title {
            font-size: 15px;
            font-weight: 700;
            color: var(--dark);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .card-title i { color: var(--teal); }
        .card-link { font-size: 13px; color: var(--teal); text-decoration: none; font-weight: 500; }
        .card-link:hover { text-decoration: underline; }
        .card-body { padding: 20px 24px; }

        /* ── FEATURES GRID ───────────────────────────────────────────── */
        .features-section { margin-bottom: 28px; }

        .features-section-title {
            font-size: 16px;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .features-section-title i { color: var(--teal); }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
        }

        .feature-card {
            background: white;
            border-radius: var(--radius);
            padding: 24px 20px;
            box-shadow: var(--shadow-sm);
            text-align: center;
            text-decoration: none;
            transition: all 0.3s;
            border: 2px solid transparent;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            position: relative;
            overflow: hidden;
        }

        .feature-card::before {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 3px;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .feature-card:hover { transform: translateY(-6px); box-shadow: var(--shadow); }
        .feature-card:hover::before { opacity: 1; }

        .fc-teal::before   { background: linear-gradient(90deg, var(--teal), #3ecdc7); }
        .fc-purple::before { background: linear-gradient(90deg, var(--purple), #764ba2); }
        .fc-amber::before  { background: linear-gradient(90deg, #f59e0b, #ef4444); }
        .fc-blue::before   { background: linear-gradient(90deg, #3b82f6, #06b6d4); }
        .fc-green::before  { background: linear-gradient(90deg, #10b981, #34d399); }
        .fc-rose::before   { background: linear-gradient(90deg, #f43f5e, #ec4899); }

        .feature-card:hover.fc-teal   { border-color: var(--teal-light); }
        .feature-card:hover.fc-purple { border-color: #ede9fe; }
        .feature-card:hover.fc-amber  { border-color: #fef3c7; }
        .feature-card:hover.fc-blue   { border-color: #dbeafe; }
        .feature-card:hover.fc-green  { border-color: #d1fae5; }
        .feature-card:hover.fc-rose   { border-color: #ffe4e6; }

        .feature-icon {
            width: 60px; height: 60px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            transition: transform 0.3s;
        }

        .feature-card:hover .feature-icon { transform: scale(1.1); }
        .feature-name { font-size: 13px; font-weight: 700; color: var(--dark); }
        .feature-desc { font-size: 11px; color: var(--gray); line-height: 1.5; }

        /* ── MOOD CHECKIN CARD ───────────────────────────────────────── */
        .checkin-card {
            background: linear-gradient(135deg, #f0fdfa, #e0f7f6);
            border: 2px dashed var(--teal);
            border-radius: var(--radius);
            padding: 28px;
            text-align: center;
            margin-bottom: 28px;
        }

        .checkin-card h3 { font-size: 16px; font-weight: 700; color: var(--teal-dark); margin-bottom: 6px; }
        .checkin-card p  { font-size: 13px; color: var(--gray); margin-bottom: 16px; }

        .btn-checkin {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 28px;
            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
            color: white;
            border-radius: 50px;
            font-weight: 600;
            font-size: 14px;
            text-decoration: none;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(32,178,170,0.3);
        }

        .btn-checkin:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(32,178,170,0.4); }

        /* ── WEEKLY INSIGHT CARD ─────────────────────────────────────── */
        .insight-preview {
            background: linear-gradient(135deg, var(--purple) 0%, #764ba2 100%);
            border-radius: var(--radius);
            padding: 28px;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .insight-preview::before {
            content: '';
            position: absolute;
            top: -20px; right: -20px;
            width: 100px; height: 100px;
            background: rgba(255,255,255,0.08);
            border-radius: 50%;
        }

        .insight-preview h3 { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
        .insight-preview p  { font-size: 13px; color: rgba(255,255,255,0.8); margin-bottom: 16px; }

        .btn-insight {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            background: rgba(255,255,255,0.2);
            color: white;
            border-radius: 50px;
            font-weight: 600;
            font-size: 13px;
            text-decoration: none;
            border: 1px solid rgba(255,255,255,0.3);
            transition: all 0.3s;
        }

        .btn-insight:hover { background: rgba(255,255,255,0.3); transform: translateY(-2px); }

        /* ── AI CHAT CARD ────────────────────────────────────────────── */
        .chat-card {
            background: var(--dark);
            border-radius: var(--radius);
            padding: 28px;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .chat-card::before {
            content: '';
            position: absolute;
            bottom: -30px; right: -30px;
            width: 120px; height: 120px;
            background: rgba(32,178,170,0.1);
            border-radius: 50%;
        }

        .chat-card h3 { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
        .chat-card p  { font-size: 13px; color: rgba(255,255,255,0.6); margin-bottom: 16px; line-height: 1.6; }

        .chat-online {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: #4ade80;
            margin-bottom: 16px;
        }

        .online-dot {
            width: 8px; height: 8px;
            background: #4ade80;
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50%       { opacity: 0.6; transform: scale(1.3); }
        }

        .btn-chat {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 11px 22px;
            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
            color: white;
            border-radius: 50px;
            font-weight: 600;
            font-size: 13px;
            text-decoration: none;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(32,178,170,0.3);
        }

        .btn-chat:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(32,178,170,0.4); }

        /* ── BOTTOM GRID ─────────────────────────────────────────────── */
        .bottom-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }

        /* ── QUICK LINKS ─────────────────────────────────────────────── */
        .quick-link-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 0;
            border-bottom: 1px solid #f1f5f9;
            text-decoration: none;
            transition: all 0.2s;
        }

        .quick-link-item:last-child { border-bottom: none; }
        .quick-link-item:hover { padding-left: 6px; }

        .quick-link-icon {
            width: 40px; height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .quick-link-text { flex: 1; }
        .quick-link-name { font-size: 14px; font-weight: 600; color: var(--dark); }
        .quick-link-desc { font-size: 12px; color: var(--gray); }

        .quick-link-arrow {
            color: var(--gray);
            font-size: 14px;
            transition: transform 0.2s;
        }

        .quick-link-item:hover .quick-link-arrow { transform: translateX(4px); color: var(--teal); }

        /* ── MOBILE MENU TOGGLE ──────────────────────────────────────── */
        .menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 22px;
            color: var(--dark);
            cursor: pointer;
        }

        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            z-index: 99;
        }

        /* ── RESPONSIVE ──────────────────────────────────────────────── */
        @media (max-width: 1200px) {
            .stats-row     { grid-template-columns: repeat(2, 1fr); }
            .features-grid { grid-template-columns: repeat(3, 1fr); }
        }

        @media (max-width: 1024px) {
            .dashboard-grid { grid-template-columns: 1fr; }
            .features-grid  { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main        { margin-left: 0; }
            .menu-toggle { display: block; }
            .content     { padding: 20px 16px; }
            .topbar      { padding: 0 16px; }
            .features-grid  { grid-template-columns: repeat(2, 1fr); }
            .bottom-grid    { grid-template-columns: 1fr; }
            .welcome-banner { flex-direction: column; gap: 20px; }
            .welcome-actions { flex-wrap: wrap; }
            .stats-row      { grid-template-columns: 1fr 1fr; }
            .analyse-teaser { flex-direction: column; align-items: flex-start; }
        }

        @media (max-width: 480px) {
            .stats-row     { grid-template-columns: 1fr; }
            .features-grid { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
<body>

    <!-- ═══════════════════════════════════════════════════════
         SIDEBAR
         ═══════════════════════════════════════════════════════ -->
    <aside class="sidebar" id="sidebar">

        <div class="sidebar-logo">
            <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'">
            <span class="sidebar-logo-text">Bekri</span>
        </div>

        <div class="sidebar-user">
            <div class="sidebar-avatar">
                {% if user.photo is defined and user.photo %}
                    <img src="{{ asset('uploads/photos/' ~ user.photo) }}" alt="avatar">
                {% else %}
                    {{ user.prenom|first|upper }}{{ user.nom|first|upper }}
                {% endif %}
            </div>
            <div>
                <div class="sidebar-user-name">{{ user.prenom }} {{ user.nom }}</div>
                <div class="sidebar-user-role">Membre Bekri</div>
            </div>
        </div>

        <nav class="sidebar-nav">

            <div class="nav-section-label">Principal</div>

            <a href="{{ path('user_dashboard') }}" class="nav-item active">
                <i class="bi bi-grid-fill"></i>
                Tableau de bord
            </a>

            <a href="{{ path('suivi_today') }}" class="nav-item">
                <i class="bi bi-clipboard2-pulse-fill"></i>
                Check-in quotidien
                <span class="nav-badge">!</span>
            </a>

            <a href="{{ path('insight_weekly') }}" class="nav-item">
                <i class="bi bi-graph-up-arrow"></i>
                Insights hebdo
            </a>

            <a href="{{ path('chat_index') }}" class="nav-item">
                <i class="bi bi-robot"></i>
                Coach Eya IA
            </a>

            <div class="nav-section-label">Bien-être</div>

            <a href="{{ path('user_analyse') }}" class="nav-item">
                <i class="bi bi-heart-pulse-fill"></i>
                Mon analyse bien-être
            </a>

            <a href="{{ path('objectif_index') }}" class="nav-item">
                <i class="bi bi-trophy-fill"></i>
                Mes objectifs
            </a>

            <a href="{{ path('plan_index') }}" class="nav-item">
                <i class="bi bi-trophy-fill"></i>
                Plan hebdomadaire
            </a>

            <a href="#" class="nav-item">
                <i class="bi bi-brain"></i>
                Test de santé mentale
            </a>

            <div class="nav-section-label">Communauté</div>

            <a href="{{ path('posts_list') }}" class="nav-item">
                <i class="bi bi-newspaper"></i>
                Publications
            </a>

            <a href="{{ path('evenements_home') }}" class="nav-item">
                <i class="bi bi-calendar-event-fill"></i>
                Événements
            </a>

            <div class="nav-section-label">Mon compte</div>

            <a href="{{ path('user_profile') }}" class="nav-item">
                <i class="bi bi-person-fill"></i>
                Mon profil
            </a>

            <a href="{{ path('user_profile_edit') }}" class="nav-item">
                <i class="bi bi-gear-fill"></i>
                Paramètres
            </a>

        </nav>

        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="nav-item" style="color: #f87171;">
                <i class="bi bi-box-arrow-left"></i>
                Se déconnecter
            </a>
        </div>

    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- ═══════════════════════════════════════════════════════
         MAIN
         ═══════════════════════════════════════════════════════ -->
    <div class="main">

        <!-- TOPBAR -->
        <header class="topbar">
            <div class="topbar-left">
                <button class="menu-toggle" id="menuToggle">
                    <i class="bi bi-list"></i>
                </button>
                <div class="topbar-greeting">
                    <h2>Bonjour, {{ user.prenom }} 👋</h2>
                    <p>{{ "now"|date("l d MMMM yyyy") }} — Prenez soin de vous aujourd'hui</p>
                </div>
            </div>
            <div class="topbar-right">
                <a href="{{ path('suivi_today') }}" class="topbar-btn" title="Check-in du jour">
                    <i class="bi bi-clipboard2-pulse"></i>
                </a>
                <a href="{{ path('chat_index') }}" class="topbar-btn" title="Chat avec Eya">
                    <i class="bi bi-robot"></i>
                </a>
                <a href="{{ path('user_profile') }}" class="topbar-avatar" title="Mon profil">
                    {% if user.photo is defined and user.photo %}
                        <img src="{{ asset('uploads/photos/' ~ user.photo) }}" alt="avatar">
                    {% else %}
                        {{ user.prenom|first|upper }}{{ user.nom|first|upper }}
                    {% endif %}
                </a>
            </div>
        </header>

        <!-- CONTENT -->
        <main class="content">

            <!-- Welcome Banner -->
            <div class="welcome-banner">
                <div class="welcome-text">
                    <h1>Bienvenue sur votre espace bien-être ✨</h1>
                    <p>Suivez votre santé mentale et physique, atteignez vos objectifs et progressez chaque jour.</p>
                </div>
                <div class="welcome-actions">
                    <a href="{{ path('suivi_today') }}" class="btn-banner btn-banner-primary">
                        <i class="bi bi-clipboard2-pulse-fill"></i>
                        Check-in du jour
                    </a>
                    <a href="{{ path('insight_weekly') }}" class="btn-banner btn-banner-secondary">
                        <i class="bi bi-graph-up-arrow"></i>
                        Voir mes insights
                    </a>
                </div>
            </div>

            {# ── AI ANALYSE TEASER (links to dedicated page) ──────────── #}
            {% if user.profilPsychologique is not null %}
            <div class="analyse-teaser">
                <div class="analyse-teaser-left">
                    <div class="analyse-teaser-icon">
                        <i class="bi bi-heart-pulse-fill"></i>
                    </div>
                    <div class="analyse-teaser-text">
                        <h3>Votre analyse bien-être est disponible</h3>
                        <p>Score initial calculé · Analyse IA personnalisée générée</p>
                    </div>
                </div>
                <div class="analyse-teaser-badges">
                    <span class="badge-score">
                        Score : <strong>{{ user.profilPsychologique.scoreGlobal }}</strong> / 100
                    </span>
                    <span class="badge-profil">{{ user.profilPsychologique.profilType }}</span>
                    <a href="{{ path('user_analyse') }}" class="btn-analyse">
                        <i class="bi bi-arrow-right-circle-fill"></i>
                        Voir mon analyse
                    </a>
                </div>
            </div>
            {% endif %}

            <!-- Stats Row -->
            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-icon icon-teal">
                        <i class="bi bi-calendar-check-fill"></i>
                    </div>
                    <div class="stat-info">
                        <div class="stat-value">7</div>
                        <div class="stat-label">Jours consécutifs</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon icon-purple">
                        <i class="bi bi-trophy-fill"></i>
                    </div>
                    <div class="stat-info">
                        <div class="stat-value">{{ user.objectifs is defined ? user.objectifs|length : 0 }}</div>
                        <div class="stat-label">Objectifs actifs</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon icon-amber">
                        <i class="bi bi-emoji-smile-fill"></i>
                    </div>
                    <div class="stat-info">
                        <div class="stat-value">😊</div>
                        <div class="stat-label">Humeur du jour</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon icon-blue">
                        <i class="bi bi-graph-up"></i>
                    </div>
                    <div class="stat-info">
                        <div class="stat-value">78%</div>
                        <div class="stat-label">Score bien-être</div>
                    </div>
                </div>
            </div>

            <!-- Daily Check-in Reminder -->
            <div class="checkin-card">
                <h3><i class="bi bi-sun-fill" style="color:#f59e0b;"></i> C'est l'heure de votre check-in quotidien !</h3>
                <p>Prenez 2 minutes pour évaluer votre humeur, sommeil et activité du jour.</p>
                <a href="{{ path('suivi_today') }}" class="btn-checkin">
                    <i class="bi bi-clipboard2-pulse-fill"></i>
                    Faire mon check-in maintenant
                </a>
            </div>

            <!-- Main Features Grid -->
            <div class="features-section">
                <div class="features-section-title">
                    <i class="bi bi-grid-fill"></i>
                    Accès rapide
                </div>
                <div class="features-grid">

                    <a href="{{ path('suivi_today') }}" class="feature-card fc-teal">
                        <div class="feature-icon icon-teal">
                            <i class="bi bi-clipboard2-pulse-fill"></i>
                        </div>
                        <div class="feature-name">Check-in quotidien</div>
                        <div class="feature-desc">Suivez votre humeur & bien-être chaque jour</div>
                    </a>

                    <a href="{{ path('insight_weekly') }}" class="feature-card fc-purple">
                        <div class="feature-icon icon-purple">
                            <i class="bi bi-graph-up-arrow"></i>
                        </div>
                        <div class="feature-name">Insights hebdo</div>
                        <div class="feature-desc">Analyses IA de votre semaine</div>
                    </a>

                    <a href="{{ path('chat_index') }}" class="feature-card fc-teal">
                        <div class="feature-icon icon-teal">
                            <i class="bi bi-robot"></i>
                        </div>
                        <div class="feature-name">Coach Eya IA</div>
                        <div class="feature-desc">Votre coach bien-être personnel</div>
                    </a>

                    <a href="{{ path('objectif_index') }}" class="feature-card fc-amber">
                        <div class="feature-icon icon-amber">
                            <i class="bi bi-trophy-fill"></i>
                        </div>
                        <div class="feature-name">Mes objectifs</div>
                        <div class="feature-desc">Définissez et suivez vos progrès</div>
                    </a>

                    <a href="{{ path('posts_list') }}" class="feature-card fc-blue">
                        <div class="feature-icon icon-blue">
                            <i class="bi bi-newspaper"></i>
                        </div>
                        <div class="feature-name">Publications</div>
                        <div class="feature-desc">Lisez et partagez des posts</div>
                    </a>

                    <a href="{{ path('evenements_home') }}" class="feature-card fc-green">
                        <div class="feature-icon icon-green">
                            <i class="bi bi-calendar-event-fill"></i>
                        </div>
                        <div class="feature-name">Événements</div>
                        <div class="feature-desc">Découvrez les événements bien-être</div>
                    </a>

                    <a href="{{ path('user_analyse') }}" class="feature-card fc-rose">
                        <div class="feature-icon icon-rose">
                            <i class="bi bi-heart-pulse-fill"></i>
                        </div>
                        <div class="feature-name">Mon analyse</div>
                        <div class="feature-desc">Voir votre analyse bien-être IA</div>
                    </a>

                    <a href="{{ path('plan_index') }}" class="feature-card fc-green">
                        <div class="feature-icon icon-green">
                            <i class="bi bi-calendar2-week-fill"></i>
                        </div>
                        <div class="feature-name">Plan hebdomadaire</div>
                        <div class="feature-desc">Repas, exercices & conseils IA personnalisés</div>
                    </a>

                    <a href="{{ path('user_profile') }}" class="feature-card fc-purple">
                        <div class="feature-icon icon-purple">
                            <i class="bi bi-person-fill"></i>
                        </div>
                        <div class="feature-name">Mon profil</div>
                        <div class="feature-desc">Consultez et modifiez votre profil</div>
                    </a>

                </div>
            </div>

            <!-- Dashboard Bottom Grid -->
            <div class="dashboard-grid">

                <!-- Left: Weekly Insight + Chat -->
                <div style="display:flex; flex-direction:column; gap:24px;">

                    <div class="insight-preview">
                        <h3><i class="bi bi-graph-up-arrow"></i> Résumé de la semaine</h3>
                        <p>Consultez votre analyse hebdomadaire générée par intelligence artificielle basée sur vos suivis quotidiens.</p>
                        <a href="{{ path('insight_weekly') }}" class="btn-insight">
                            <i class="bi bi-eye-fill"></i>
                            Voir mon résumé hebdomadaire
                        </a>
                    </div>

                    <div class="chat-card">
                        <div class="chat-online">
                            <div class="online-dot"></div>
                            Eya est disponible maintenant
                        </div>
                        <h3><i class="bi bi-robot"></i> Coach Eya — IA bien-être</h3>
                        <p>Posez vos questions sur votre santé mentale et physique. Eya vous répond en français ou en anglais, 24h/24.</p>
                        <a href="{{ path('chat_index') }}" class="btn-chat">
                            <i class="bi bi-chat-dots-fill"></i>
                            Démarrer une conversation
                        </a>
                    </div>

                </div>

                <!-- Right: Quick Links -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-title">
                            <i class="bi bi-lightning-charge-fill"></i>
                            Accès rapide
                        </div>
                    </div>
                    <div class="card-body">

                        <a href="{{ path('suivi_today') }}" class="quick-link-item">
                            <div class="quick-link-icon icon-teal">
                                <i class="bi bi-clipboard2-pulse-fill"></i>
                            </div>
                            <div class="quick-link-text">
                                <div class="quick-link-name">Check-in du jour</div>
                                <div class="quick-link-desc">Évaluer mon bien-être</div>
                            </div>
                            <i class="bi bi-chevron-right quick-link-arrow"></i>
                        </a>

                        <a href="{{ path('user_analyse') }}" class="quick-link-item">
                            <div class="quick-link-icon icon-purple">
                                <i class="bi bi-heart-pulse-fill"></i>
                            </div>
                            <div class="quick-link-text">
                                <div class="quick-link-name">Mon analyse bien-être</div>
                                <div class="quick-link-desc">Voir l'analyse IA initiale</div>
                            </div>
                            <i class="bi bi-chevron-right quick-link-arrow"></i>
                        </a>

                        <a href="{{ path('objectif_new') }}" class="quick-link-item">
                            <div class="quick-link-icon icon-amber">
                                <i class="bi bi-plus-circle-fill"></i>
                            </div>
                            <div class="quick-link-text">
                                <div class="quick-link-name">Nouvel objectif</div>
                                <div class="quick-link-desc">Créer un objectif bien-être</div>
                            </div>
                            <i class="bi bi-chevron-right quick-link-arrow"></i>
                        </a>

                        <a href="{{ path('plan_index') }}" class="quick-link-item">
                            <div class="quick-link-icon icon-green">
                                <i class="bi bi-calendar2-week-fill"></i>
                            </div>
                            <div class="quick-link-text">
                                <div class="quick-link-name">Mon plan hebdomadaire</div>
                                <div class="quick-link-desc">Générer mon plan IA</div>
                            </div>
                            <i class="bi bi-chevron-right quick-link-arrow"></i>
                        </a>

                        <a href="{{ path('evenements_mes_participations') }}" class="quick-link-item">
                            <div class="quick-link-icon icon-green">
                                <i class="bi bi-calendar-check-fill"></i>
                            </div>
                            <div class="quick-link-text">
                                <div class="quick-link-name">Mes participations</div>
                                <div class="quick-link-desc">Événements inscrits</div>
                            </div>
                            <i class="bi bi-chevron-right quick-link-arrow"></i>
                        </a>

                        <a href="{{ path('user_profile_edit') }}" class="quick-link-item">
                            <div class="quick-link-icon icon-purple">
                                <i class="bi bi-pencil-fill"></i>
                            </div>
                            <div class="quick-link-text">
                                <div class="quick-link-name">Modifier le profil</div>
                                <div class="quick-link-desc">Mettre à jour mes infos</div>
                            </div>
                            <i class="bi bi-chevron-right quick-link-arrow"></i>
                        </a>

                        <a href="{{ path('app_logout') }}" class="quick-link-item" style="color:#f87171;">
                            <div class="quick-link-icon icon-rose">
                                <i class="bi bi-box-arrow-left"></i>
                            </div>
                            <div class="quick-link-text">
                                <div class="quick-link-name" style="color:#f87171;">Se déconnecter</div>
                                <div class="quick-link-desc">Quitter mon espace</div>
                            </div>
                            <i class="bi bi-chevron-right quick-link-arrow"></i>
                        </a>

                    </div>
                </div>

            </div>

        </main>
    </div>

    <script>
        const menuToggle = document.getElementById('menuToggle');
        const sidebar    = document.getElementById('sidebar');
        const overlay    = document.getElementById('sidebarOverlay');

        menuToggle.addEventListener('click', () => {
            sidebar.classList.toggle('open');
            overlay.classList.toggle('open');
        });

        overlay.addEventListener('click', () => {
            sidebar.classList.remove('open');
            overlay.classList.remove('open');
        });
    </script>

</body>
</html>