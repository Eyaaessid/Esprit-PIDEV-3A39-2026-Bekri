{% extends 'base.html.twig' %}

{% block title %}Edit Profile - Bekri Wellbeing{% endblock %}

{% block body_class %}profile-edit-page{% endblock %}

{% block main %}
<div class="container" style="margin-top: 100px; margin-bottom: 80px;">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Profile</h5>
                        <a href="{{ path('user_profile') }}" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Back to Profile
                        </a>
                    </div>
                </div>
                <div class="card-body p-4">
                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle me-2"></i>{{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                    
                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>{{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}

                    <form method="post" action="{{ path('user_profile_edit') }}" enctype="multipart/form-data" id="profileForm">
                        {{ form_widget(form._token) }}
                        
                        <!-- Profile Picture Section -->
                        <div class="mb-4 text-center">
                            <div class="mb-3">
                                <div id="imagePreview">
                                    {% if app.user.avatar %}
                                        <img id="profileImage" src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" 
                                             alt="{{ app.user.prenom }}" 
                                             class="rounded-circle"
                                             style="width: 120px; height: 120px; object-fit: cover; border: 4px solid #667eea;">
                                    {% else %}
                                        <div id="profileImage" class="rounded-circle mx-auto d-flex align-items-center justify-content-center" 
                                             style="width: 120px; height: 120px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                            <i class="bi bi-person-fill text-white" style="font-size: 60px;"></i>
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="row justify-content-center">
                                <div class="col-md-8">
                                    {{ form_row(form.avatarFile) }}
                                    <small class="text-muted d-block mt-1">Maximum file size: 2MB. Accepted formats: JPG, PNG, GIF, WebP</small>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4">

                        <!-- Personal Information -->
                        <h6 class="mb-3"><i class="bi bi-person-badge me-2"></i>Personal Information</h6>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.prenom) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.nom) }}
                            </div>
                        </div>

                        <div class="mb-3">
                            {{ form_row(form.email) }}
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.telephone) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.dateNaissance) }}
                            </div>
                        </div>

                        <hr class="my-4">

                        <!-- Password Change Section -->
                        <h6 class="mb-3"><i class="bi bi-shield-lock me-2"></i>Change Password</h6>
                        <p class="text-muted small mb-3">Leave these fields empty if you don't want to change your password.</p>
                        
                        {{ form_row(form.plainPassword.first) }}
                        {{ form_row(form.plainPassword.second) }}

                        <hr class="my-4">

                        <!-- Submit Buttons -->
                        <div class="d-flex justify-content-between align-items-center">
                            <a href="{{ path('user_profile') }}" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-2"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const profileForm = document.getElementById('profileForm');
    const fileInput = document.querySelector('input[type="file"]');
    
    console.log('✅ Form found:', profileForm);
    console.log('✅ File input found:', fileInput);
    console.log('📋 Form action:', profileForm?.action);
    console.log('📋 Form method:', profileForm?.method);
    console.log('📋 Form enctype:', profileForm?.enctype);
    
    if (profileForm) {
        profileForm.addEventListener('submit', function(e) {
            console.log('🚀 FORM SUBMITTING...');
            const formData = new FormData(this);
            for (let [key, value] of formData.entries()) {
                if (value instanceof File) {
                    console.log('📎', key, ':', value.name, '-', value.size, 'bytes');
                } else {
                    console.log('📝', key, ':', value);
                }
            }
        });
    }
    
    if (fileInput) {
        fileInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            console.log('📸 File selected:', file?.name, file?.size, 'bytes');
        });
    }
});
</script>
{% endblock %}