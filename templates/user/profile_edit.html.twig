{% extends 'base.html.twig' %}

{% block title %}Edit Profile - Bekri Wellbeing{% endblock %}

{% block body_class %}profile-edit-page{% endblock %}

{% block main %}
<div class="container" style="margin-top: 100px; margin-bottom: 80px;">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Page Header -->
            <div class="mb-4">
                <h2 class="mb-2"><i class="bi bi-pencil-square me-2"></i>Edit Profile</h2>
                <p class="text-muted">Update your personal information and settings</p>
            </div>

            <!-- Flash Messages -->
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

            <!-- Profile Picture Section -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0"><i class="bi bi-camera me-2"></i>Profile Picture</h5>
                </div>
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-3 text-center mb-3 mb-md-0">
                            <div class="avatar-preview mb-3">
                                {% if user.avatar %}
                                    <img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" 
                                         alt="{{ user.prenom }}" 
                                         class="rounded-circle"
                                         id="avatarPreview"
                                         style="width: 120px; height: 120px; object-fit: cover; border: 4px solid #667eea;">
                                {% else %}
                                    <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center" 
                                         id="avatarPreview"
                                         style="width: 120px; height: 120px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                        <i class="bi bi-person-fill text-white" style="font-size: 60px;"></i>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                        <div class="col-md-9">
                            {{ form_row(form.avatarFile) }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Personal Information -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0"><i class="bi bi-person-badge me-2"></i>Personal Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.prenom) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.nom) }}
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.email) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.telephone) }}
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.dateNaissance) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.pays) }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Change Password -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0"><i class="bi bi-shield-lock me-2"></i>Change Password</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">Leave blank to keep your current password</p>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.plainPassword.first) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.plainPassword.second) }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="d-flex justify-content-between">
                <a href="{{ path('user_profile') }}" class="btn btn-secondary">
                    <i class="bi bi-x-circle me-2"></i>Cancel
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle me-2"></i>Save Changes
                </button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>

<script>
// Preview uploaded avatar
document.addEventListener('DOMContentLoaded', function() {
    const avatarInput = document.querySelector('input[type="file"]');
    if (avatarInput) {
        avatarInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const preview = document.getElementById('avatarPreview');
                    preview.innerHTML = '<img src="' + e.target.result + '" class="rounded-circle" style="width: 120px; height: 120px; object-fit: cover; border: 4px solid #667eea;">';
                };
                reader.readAsDataURL(file);
            }
        });
    }
});
</script>
{% endblock %}