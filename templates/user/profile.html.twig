{% extends 'base.html.twig' %}

{% block title %}My Profile - Bekri Wellbeing{% endblock %}

{% block body_class %}profile-page{% endblock %}

{% block main %}
<div class="container" style="margin-top: 100px; margin-bottom: 80px;">
    <div class="row">
        <!-- Profile Header -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center p-4">
                    <div class="mb-3 position-relative">
                        {% if user.avatar %}
                            <img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" 
                                 alt="{{ user.prenom }}" 
                                 class="rounded-circle mx-auto d-block"
                                 style="width: 120px; height: 120px; object-fit: cover; border: 4px solid #667eea;">
                        {% else %}
                            <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center" 
                                 style="width: 120px; height: 120px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                <i class="bi bi-person-fill text-white" style="font-size: 60px;"></i>
                            </div>
                        {% endif %}
                    </div>
                    <h4 class="mb-1">{{ user.nom }} {{ user.prenom }}</h4>
                    <p class="text-muted mb-3">{{ user.email }}</p>
                    
                    {% if is_granted('ROLE_ADMIN') %}
                        <span class="badge bg-danger">Administrator</span>
                    {% elseif is_granted('ROLE_COACH') %}
                        <span class="badge bg-primary">Coach</span>
                    {% else %}
                        <span class="badge bg-success">User</span>
                    {% endif %}
                    
                    <hr class="my-4">
                    
                    <a href="{{ path('user_profile_edit') }}" class="btn btn-primary w-100 mb-2">
                        <i class="bi bi-pencil-square me-2"></i>Edit Profile
                    </a>
                    <button type="button" class="btn btn-outline-danger w-100 mb-3" data-bs-toggle="modal" data-bs-target="#deactivateAccountModal">
                        <i class="bi bi-x-circle me-2"></i>Désactiver mon compte
                    </button>

                    <hr class="my-4">

                    <!-- 2FA Section -->
                    <div class="two-factor-section">
                        <h6 class="mb-3 text-start">
                            <i class="bi bi-shield-lock me-2"></i>Two-Factor Authentication
                        </h6>
                        
                        <div id="totp-status">
                            {% if user.isTotpAuthenticationEnabled() %}
                                <div class="alert alert-success d-flex align-items-start text-start">
                                    <i class="bi bi-check-circle-fill me-2 mt-1"></i>
                                    <div>
                                        <strong>Enabled</strong>
                                        <br>
                                        <small>Your account is protected with 2FA</small>
                                    </div>
                                </div>
                                <button type="button" class="btn btn-outline-danger w-100" data-bs-toggle="modal" data-bs-target="#disable2FAModal">
                                    <i class="bi bi-x-circle me-2"></i>Disable 2FA
                                </button>
                            {% else %}
                                <div class="alert alert-info text-start">
                                    <i class="bi bi-info-circle me-2"></i>
                                    <small>Add an extra layer of security to your account.</small>
                                </div>
                                <a href="{{ path('app_2fa_enable') }}" class="btn btn-primary w-100">
                                    <i class="bi bi-shield-plus me-2"></i>Enable 2FA
                                </a>
                            {% endif %}
                        </div>
                    </div>

                    <hr class="my-4">

                    <!-- Face Authentication Section -->
                    <div class="face-auth-section">
                        <h6 class="mb-3 text-start">
                            <i class="bi bi-shield-check me-2"></i>Face Authentication
                        </h6>
                        
                        <div id="face-auth-status">
                            {% if user.isFaceAuthEnabled() %}
                                <div class="alert alert-success d-flex align-items-start text-start">
                                    <i class="bi bi-check-circle-fill me-2 mt-1"></i>
                                    <div>
                                        <strong>Enabled</strong>
                                        <br>
                                        <small>Registered: {{ user.faceRegisteredAt|date('M d, Y') }}</small>
                                    </div>
                                </div>
                                <button type="button" class="btn btn-outline-danger w-100" id="disable-face-auth-btn">
                                    <i class="bi bi-x-circle me-2"></i>Disable Face Login
                                </button>
                            {% else %}
                                <div class="alert alert-info text-start">
                                    <i class="bi bi-info-circle me-2"></i>
                                    <small>Enable face login for faster, passwordless authentication.</small>
                                </div>
                                <button type="button" class="btn btn-success w-100" data-bs-toggle="modal" data-bs-target="#faceRegistrationModal">
                                    <i class="bi bi-camera-video me-2"></i>Enable Face Login
                                </button>
                            {% endif %}
                        </div>
                    </div>

                    <hr class="my-4">

                    <a href="{{ path('avatar_generator') }}" class="btn btn-gradient-purple w-100 mb-2">
                        <i class="bi bi-stars me-2"></i>Generate AI Avatar
                    </a>
                </div>
            </div>
        </div>

        <!-- Profile Information -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0"><i class="bi bi-person-badge me-2"></i>Personal Information</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong>First Name:</strong>
                        </div>
                        <div class="col-sm-8">
                            {{ user.prenom }}
                        </div>
                    </div>
                    <hr>
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong>Last Name:</strong>
                        </div>
                        <div class="col-sm-8">
                            {{ user.nom }}
                        </div>
                    </div>
                    <hr>
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong>Email:</strong>
                        </div>
                        <div class="col-sm-8">
                            {{ user.email }}
                        </div>
                    </div>
                    <hr>
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong>Phone:</strong>
                        </div>
                        <div class="col-sm-8">
                            {{ user.telephone ?? 'Not provided' }}
                        </div>
                    </div>
                    <hr>
                    <div class="row">
                        <div class="col-sm-4">
                            <strong>Date of Birth:</strong>
                        </div>
                        <div class="col-sm-8">
                            {{ user.dateNaissance ? user.dateNaissance|date('F d, Y') : 'Not provided' }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Wellbeing Assessment (read-only) -->
            {% if user.profilPsychologique is not null %}
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0"><i class="bi bi-heart-pulse me-2"></i>Évaluation du bien-être</h5>
                    <span class="badge bg-secondary ms-2">Informations en lecture seule</span>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong>Score global :</strong>
                        </div>
                        <div class="col-sm-8">
                            <span class="fw-semibold text-primary">{{ user.profilPsychologique.scoreGlobal }}</span> / 100
                        </div>
                    </div>
                    <hr>
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong>Profil :</strong>
                        </div>
                        <div class="col-sm-8">
                            {{ user.profilPsychologique.profilType }}
                        </div>
                    </div>
                    <hr>
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong>Date d'évaluation :</strong>
                        </div>
                        <div class="col-sm-8">
                            {{ user.profilPsychologique.dateEvaluation ? user.profilPsychologique.dateEvaluation|date('d/m/Y') : '—' }}
                        </div>
                    </div>
                    {% if user.profilPsychologique.aiFeedback is not null and user.profilPsychologique.aiFeedback is not empty %}
                    <hr>
                    <div class="row">
                        <div class="col-12">
                            <strong class="d-block mb-2"><i class="bi bi-stars me-2"></i>Analyse émotionnelle (IA)</strong>
                            <p class="mb-0 text-muted small lh-lg">{{ user.profilPsychologique.aiFeedback|nl2br }}</p>
                            <p class="mt-3 mb-0 small fst-italic text-secondary border-start border-2 border-secondary ps-2">
                                Cette analyse ne remplace pas un avis médical.
                            </p>
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>
            {% endif %}

            <!-- Account Information -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0"><i class="bi bi-shield-lock me-2"></i>Account Details</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong>Account Created:</strong>
                        </div>
                        <div class="col-sm-8">
                            {{ user.createdAt ? user.createdAt|date('F d, Y') : 'Unknown' }}
                        </div>
                    </div>
                    <hr>
                    <div class="row">
                        <div class="col-sm-4">
                            <strong>Last Updated:</strong>
                        </div>
                        <div class="col-sm-8">
                            {{ user.updatedAt ? user.updatedAt|date('F d, Y') : 'Never' }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# Modal: Deactivate account confirmation #}
<div class="modal fade" id="deactivateAccountModal" tabindex="-1" aria-labelledby="deactivateAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deactivateAccountModalLabel">Désactiver mon compte</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body">
                <p>Êtes-vous sûr de vouloir désactiver votre compte ? Vous pourrez le réactiver à tout moment en vous reconnectant (un email de réactivation vous sera envoyé).</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <form method="post" action="{{ path('user_profile_deactivate') }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('deactivate-account') }}">
                    <button type="submit" class="btn btn-danger">Oui, désactiver mon compte</button>
                </form>
            </div>
        </div>
    </div>
</div>

{# Face Registration Modal #}
<div class="modal fade" id="faceRegistrationModal" tabindex="-1" aria-labelledby="faceRegistrationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="faceRegistrationModalLabel">
                    <i class="bi bi-camera-video me-2"></i>Enable Face Authentication
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="face-registration-steps">
                    
                    {# Step 1: Instructions #}
                    <div id="step-instructions" class="text-center">
                        <i class="bi bi-info-circle text-primary" style="font-size: 4rem;"></i>
                        <h5 class="mt-3 mb-3">How Face Authentication Works</h5>
                        <ul class="text-start" style="max-width: 500px; margin: 0 auto;">
                            <li class="mb-2">Position your face in the camera frame</li>
                            <li class="mb-2">Make sure you're in a well-lit area</li>
                            <li class="mb-2">Look directly at the camera</li>
                            <li class="mb-2">We'll capture your face data securely</li>
                            <li class="mb-2">Your face data is encrypted and stored safely</li>
                        </ul>
                        <button type="button" class="btn btn-primary mt-4" id="start-face-capture-btn">
                            <i class="bi bi-camera-fill me-2"></i>Start Camera
                        </button>
                    </div>

                    {# Step 2: Camera Capture #}
                    <div id="step-camera" style="display: none;">
                        <div class="position-relative">
                            <video id="face-video" width="100%" height="auto" autoplay muted style="border-radius: 12px; max-height: 400px;"></video>
                            <canvas id="face-canvas" style="display: none;"></canvas>
                            
                            {# Face detection overlay #}
                            <div id="face-overlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none;">
                                <div id="face-detection-box" style="display: none; position: absolute; border: 3px solid #00ff00; border-radius: 8px; box-shadow: 0 0 20px rgba(0,255,0,0.5);"></div>
                            </div>
                        </div>
                        
                        <div class="text-center mt-3">
                            <div id="face-status" class="alert alert-info">
                                <i class="bi bi-camera-video me-2"></i>
                                <span id="face-status-text">Initializing camera...</span>
                            </div>
                            
                            <button type="button" class="btn btn-success" id="capture-face-btn" disabled>
                                <i class="bi bi-check-circle me-2"></i>Capture Face
                            </button>
                            <button type="button" class="btn btn-secondary" id="cancel-capture-btn">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </button>
                        </div>
                    </div>

                    {# Step 3: Processing #}
                    <div id="step-processing" style="display: none;" class="text-center py-5">
                        <div class="spinner-border text-primary mb-3" role="status" style="width: 4rem; height: 4rem;">
                            <span class="visually-hidden">Processing...</span>
                        </div>
                        <h5>Processing your face data...</h5>
                        <p class="text-muted">Please wait while we securely store your information.</p>
                    </div>

                    {# Step 4: Success #}
                    <div id="step-success" style="display: none;" class="text-center py-5">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
                        <h4 class="mt-3 mb-2">Face Authentication Enabled!</h4>
                        <p class="text-muted">You can now use your face to log in quickly and securely.</p>
                        <button type="button" class="btn btn-primary mt-3" data-bs-dismiss="modal">
                            Done
                        </button>
                    </div>

                    {# Step 5: Error #}
                    <div id="step-error" style="display: none;" class="text-center py-5">
                        <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 5rem;"></i>
                        <h4 class="mt-3 mb-2">Registration Failed</h4>
                        <p class="text-muted" id="error-message">An error occurred. Please try again.</p>
                        <button type="button" class="btn btn-primary mt-3" id="retry-face-capture-btn">
                            <i class="bi bi-arrow-clockwise me-2"></i>Try Again
                        </button>
                        <button type="button" class="btn btn-secondary mt-3" data-bs-dismiss="modal">
                            Cancel
                        </button>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

{# JavaScript for Face Registration — face-api.js 0.22.2 + justadudewhohacks models only #}
<script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    let videoStream = null;
    let faceDescriptor = null;

    const MODEL_URL = 'https://justadudewhohacks.github.io/face-api.js/models';
    const video = document.getElementById('face-video');
    const startBtn = document.getElementById('start-face-capture-btn');
    const captureBtn = document.getElementById('capture-face-btn');
    const cancelBtn = document.getElementById('cancel-capture-btn');
    const retryBtn = document.getElementById('retry-face-capture-btn');
    const disableBtn = document.getElementById('disable-face-auth-btn');
    const statusText = document.getElementById('face-status-text');
    const faceDetectionBox = document.getElementById('face-detection-box');

    async function loadModels() {
        await Promise.all([
            faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
            faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL),
            faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL)
        ]);
    }

    async function startCamera() {
        try {
            statusText.textContent = 'Loading face detection models...';
            await loadModels();
        } catch (modelErr) {
            console.error('Error loading face-api models:', modelErr);
            showError('Failed to load face detection models. Please refresh and try again.');
            return;
        }
        try {
            statusText.textContent = 'Starting camera...';
            const stream = await navigator.mediaDevices.getUserMedia({ video: true });
            video.srcObject = stream;
            videoStream = stream;
            await new Promise(function(resolve, reject) {
                video.onloadedmetadata = function() {
                    video.play().then(function() {
                        setTimeout(resolve, 500);
                    }).catch(reject);
                };
                video.onerror = function() { reject(new Error('Video failed to load')); };
            });
            statusText.textContent = 'Camera ready. Position your face in the frame.';
            detectFace();
        } catch (error) {
            console.error('Error starting camera:', error);
            showError('Unable to access camera. Please check permissions.');
        }
    }

    function stopCamera() {
        if (videoStream) {
            videoStream.getTracks().forEach(function(track) { track.stop(); });
            videoStream = null;
        }
    }

    async function detectFace() {
        if (video.readyState < 2) {
            if (videoStream) setTimeout(detectFace, 150);
            return;
        }
        try {
            const detection = await faceapi
                .detectSingleFace(video, new faceapi.TinyFaceDetectorOptions())
                .withFaceLandmarks()
                .withFaceDescriptor();
            if (detection) {
                faceDescriptor = Array.from(detection.descriptor);
                const box = detection.detection.box;
                faceDetectionBox.style.display = 'block';
                faceDetectionBox.style.left = box.x + 'px';
                faceDetectionBox.style.top = box.y + 'px';
                faceDetectionBox.style.width = box.width + 'px';
                faceDetectionBox.style.height = box.height + 'px';
                statusText.textContent = 'Face detected! Click Capture Face.';
                captureBtn.disabled = false;
                captureBtn.classList.remove('btn-secondary');
                captureBtn.classList.add('btn-success');
            } else {
                faceDetectionBox.style.display = 'none';
                statusText.textContent = 'Looking for face...';
                captureBtn.disabled = true;
            }
        } catch (e) {
            console.error('Detection error:', e);
        }
        if (videoStream) {
            setTimeout(detectFace, 300);
        }
    }

    async function captureFace() {
        if (!faceDescriptor) {
            showError('No face detected. Please try again.');
            return;
        }
        showStep('step-processing');
        stopCamera();
        try {
            const response = await fetch('{{ path('api_face_auth_register') }}', {
                method: 'POST',
                credentials: 'same-origin',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ descriptor: faceDescriptor })
            });
            const data = await response.json();
            if (data.success) {
                showStep('step-success');
                setTimeout(function() { location.reload(); }, 1000);
            } else {
                showError(data.message || 'Registration failed. Please try again.');
            }
        } catch (error) {
            console.error('Error registering face:', error);
            showError('Network error. Please check your connection and try again.');
        }
    }

    // Disable face authentication
    async function disableFaceAuth() {
        if (!confirm('Are you sure you want to disable face authentication?')) {
            return;
        }
        
        try {
            const response = await fetch('{{ path('api_face_auth_disable') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest',
                },
                credentials: 'same-origin',
                body: JSON.stringify({
                    '_token': '{{ csrf_token('face_auth_disable') }}'
                })
            });
            
            const text = await response.text();
            let data;
            try {
                data = JSON.parse(text);
            } catch (jsonError) {
                console.error('Server returned non-JSON:', text);
                throw new Error('Server returned HTML instead of JSON. Check logs. (First 100 chars: ' + text.substring(0, 100).replace(/</g, "&lt;") + ')');
            }
            
            if (data.success) {
                location.reload();
            } else {
                alert('Failed to disable face authentication: ' + (data.message || 'Unknown error'));
            }
            
        } catch (error) {
            console.error('Error disabling face auth:', error);
            alert('Network error (' + error.message + '). Please check your connection and try again.');
        }
    }

    // Show specific step
    function showStep(stepId) {
        document.querySelectorAll('#face-registration-steps > div').forEach(div => {
            div.style.display = 'none';
        });
        document.getElementById(stepId).style.display = 'block';
    }

    // Show error
    function showError(message) {
        document.getElementById('error-message').textContent = message;
        showStep('step-error');
    }

    if (startBtn) {
        startBtn.addEventListener('click', async function() {
            showStep('step-camera');
            await startCamera();
        });
    }

    if (captureBtn) {
        captureBtn.addEventListener('click', captureFace);
    }
    
    if (cancelBtn) {
        cancelBtn.addEventListener('click', function() {
            stopCamera();
            bootstrap.Modal.getInstance(document.getElementById('faceRegistrationModal')).hide();
        });
    }
    
    if (retryBtn) {
        retryBtn.addEventListener('click', function() {
            showStep('step-instructions');
        });
    }
    
    if (disableBtn) {
        disableBtn.addEventListener('click', disableFaceAuth);
    }

    // Clean up on modal close
    const modal = document.getElementById('faceRegistrationModal');
    if (modal) {
        modal.addEventListener('hidden.bs.modal', function() {
            stopCamera();
            showStep('step-instructions');
            if (captureBtn) captureBtn.disabled = true;
            faceDescriptor = null;
        });
    }
});
</script>
{% endblock %}