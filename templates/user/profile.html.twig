<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mon Profil — Bekri</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --dark:       #1a2332;
            --gray:       #64748b;
            --light:      #f8fafc;
            --white:      #ffffff;
            --sidebar-w:  260px;
            --shadow-sm:  0 2px 12px rgba(0,0,0,0.06);
            --shadow:     0 8px 30px rgba(0,0,0,0.10);
            --radius:     16px;
        }

        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior:smooth; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--light);
            color: var(--dark);
            display: flex;
            min-height: 100vh;
        }

        /* ── SIDEBAR ─────────────────────────────────────────────── */
        .sidebar { width:var(--sidebar-w); background:var(--dark); min-height:100vh; max-height:100vh; position:fixed; top:0; left:0; display:flex; flex-direction:column; z-index:100; transition:transform 0.3s ease; overflow:hidden; }
        .sidebar-logo { padding:28px 24px 20px; display:flex; align-items:center; gap:10px; border-bottom:1px solid rgba(255,255,255,0.07); flex-shrink:0; }
        .sidebar-logo img { height:36px; width:auto; }
        .sidebar-logo-text { font-size:20px; font-weight:800; background:linear-gradient(135deg, var(--teal), #a78bfa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .sidebar-user { padding:20px 24px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-avatar { width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg, var(--teal), var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:16px; flex-shrink:0; overflow:hidden; }
        .sidebar-avatar img { width:100%; height:100%; object-fit:cover; }
        .sidebar-user-name { font-size:14px; font-weight:600; color:white; }
        .sidebar-user-role { font-size:11px; color:rgba(255,255,255,0.4); margin-top:2px; }
        .sidebar-nav { flex:1; padding:16px 0; overflow-y:auto; }
        .nav-section-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:rgba(255,255,255,0.25); padding:12px 24px 6px; }
        .nav-item { display:flex; align-items:center; gap:12px; padding:11px 24px; color:rgba(255,255,255,0.6); text-decoration:none; font-size:14px; font-weight:500; transition:all 0.2s; border-left:3px solid transparent; }
        .nav-item:hover { color:white; background:rgba(255,255,255,0.05); }
        .nav-item.active { color:var(--teal); background:rgba(32,178,170,0.1); border-left-color:var(--teal); }
        .nav-item i { width:20px; text-align:center; font-size:16px; }
        .sidebar-footer { padding:16px 0; border-top:1px solid rgba(255,255,255,0.07); }

        /* ── MAIN ────────────────────────────────────────────────── */
        .main { margin-left:var(--sidebar-w); flex:1; display:flex; flex-direction:column; min-height:100vh; }

        /* ── TOPBAR ──────────────────────────────────────────────── */
        .topbar { background:white; padding:0 32px; height:68px; display:flex; align-items:center; justify-content:space-between; box-shadow:var(--shadow-sm); position:sticky; top:0; z-index:50; }
        .topbar-title { font-size:18px; font-weight:700; color:var(--dark); }
        .topbar-sub   { font-size:13px; color:var(--gray); margin-top:2px; }
        .topbar-right { display:flex; align-items:center; gap:12px; }
        .topbar-btn { width:40px; height:40px; border-radius:10px; background:var(--light); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; color:var(--gray); font-size:16px; text-decoration:none; transition:all 0.2s; }
        .topbar-btn:hover { background:var(--teal-light); color:var(--teal-dark); }
        .topbar-avatar-sm { width:40px; height:40px; border-radius:50%; background:linear-gradient(135deg, var(--teal), var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:14px; text-decoration:none; overflow:hidden; }
        .topbar-avatar-sm img { width:100%; height:100%; object-fit:cover; }

        /* ── CONTENT ─────────────────────────────────────────────── */
        .content { padding:32px; flex:1; }

        /* ── PROFILE LAYOUT ──────────────────────────────────────── */
        .profile-grid { display:grid; grid-template-columns:300px 1fr; gap:24px; }

        /* ── PROFILE CARD (LEFT) ─────────────────────────────────── */
        .profile-card {
            background: white;
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            border: 1px solid #f1f5f9;
            overflow: hidden;
        }

        .profile-card-banner {
            height: 80px;
            background: linear-gradient(135deg, var(--teal), var(--purple));
        }

        .profile-card-body { padding: 0 24px 24px; }

        .profile-avatar-wrap {
            display: flex;
            justify-content: center;
            margin-top: -44px;
            margin-bottom: 16px;
        }

        .profile-avatar {
            width: 88px; height: 88px;
            border-radius: 50%;
            border: 4px solid white;
            background: linear-gradient(135deg, var(--teal), var(--purple));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            font-weight: 800;
            color: white;
            overflow: hidden;
            box-shadow: var(--shadow-sm);
        }

        .profile-avatar img { width:100%; height:100%; object-fit:cover; }

        .profile-name  { font-size:18px; font-weight:800; color:var(--dark); text-align:center; margin-bottom:4px; }
        .profile-email { font-size:13px; color:var(--gray); text-align:center; margin-bottom:12px; }

        .profile-badge {
            display:inline-flex; align-items:center; gap:5px;
            padding:4px 12px; border-radius:50px; font-size:12px; font-weight:600;
            margin: 0 auto 20px; display:block; width:fit-content;
        }

        .badge-user  { background:var(--teal-light); color:var(--teal-dark); }
        .badge-admin { background:#fee2e2; color:#dc2626; }
        .badge-coach { background:#dbeafe; color:#2563eb; }

        .profile-divider { height:1px; background:#f1f5f9; margin:16px 0; }

        /* ── BUTTONS ─────────────────────────────────────────────── */
        .btn {
            display:inline-flex; align-items:center; gap:8px;
            padding:10px 18px; border-radius:10px; font-size:14px; font-weight:600;
            cursor:pointer; border:none; text-decoration:none;
            transition:all 0.25s; font-family:'Inter',sans-serif; width:100%;
            justify-content:center; margin-bottom:8px;
        }

        .btn-teal { background:linear-gradient(135deg, var(--teal), var(--teal-dark)); color:white; box-shadow:0 3px 10px rgba(32,178,170,0.25); }
        .btn-teal:hover { transform:translateY(-1px); box-shadow:0 5px 15px rgba(32,178,170,0.35); color:white; }
        .btn-ghost { background:var(--light); color:var(--gray); border:2px solid #e2e8f0; }
        .btn-ghost:hover { background:#e2e8f0; color:var(--dark); }
        .btn-danger-outline { background:white; color:#dc2626; border:2px solid #fecaca; }
        .btn-danger-outline:hover { background:#fee2e2; }
        .btn-danger { background:#dc2626; color:white; }
        .btn-danger:hover { background:#b91c1c; }
        .btn-purple { background:linear-gradient(135deg, var(--purple), #764ba2); color:white; box-shadow:0 3px 10px rgba(102,126,234,0.25); }
        .btn-purple:hover { transform:translateY(-1px); color:white; box-shadow:0 5px 15px rgba(102,126,234,0.35); }
        .btn-warning-outline { background:white; color:#d97706; border:2px solid #fde68a; }
        .btn-warning-outline:hover { background:#fef3c7; }
        .btn-sm { padding:7px 14px; font-size:13px; }

        /* ── SECURITY SECTIONS ───────────────────────────────────── */
        .security-section { margin-bottom:16px; }
        .security-title { font-size:13px; font-weight:700; color:var(--dark); display:flex; align-items:center; gap:6px; margin-bottom:10px; }
        .security-title i { color:var(--teal); }
        .security-status { padding:10px 14px; border-radius:10px; font-size:13px; display:flex; align-items:center; gap:8px; margin-bottom:10px; }
        .status-on  { background:#f0fdf4; color:#166534; border:1px solid #bbf7d0; }
        .status-off { background:#f0f9ff; color:#0369a1; border:1px solid #bae6fd; }
        .password-input-wrap { position:relative; margin-bottom:8px; }
        .password-input-wrap input { width:100%; padding:9px 40px 9px 12px; border:2px solid #e2e8f0; border-radius:10px; font-size:13px; font-family:'Inter',sans-serif; outline:none; transition:all 0.25s; background:var(--light); }
        .password-input-wrap input:focus { border-color:var(--teal); background:white; box-shadow:0 0 0 3px rgba(32,178,170,0.1); }
        .toggle-pwd-icon { position:absolute; right:10px; top:50%; transform:translateY(-50%); color:#94a3b8; cursor:pointer; font-size:15px; }
        .toggle-pwd-icon:hover { color:var(--teal); }

        /* ── INFO CARDS (RIGHT) ──────────────────────────────────── */
        .info-card { background:white; border-radius:var(--radius); box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; margin-bottom:20px; overflow:hidden; }
        .info-card-header { padding:18px 24px; display:flex; align-items:center; gap:8px; font-size:15px; font-weight:700; color:var(--dark); border-bottom:1px solid #f1f5f9; }
        .info-card-header i { color:var(--teal); font-size:18px; }
        .info-card-body { padding:0 24px; }
        .info-row { display:flex; align-items:center; gap:12px; padding:14px 0; border-bottom:1px solid #f8fafc; }
        .info-row:last-child { border-bottom:none; }
        .info-icon { width:36px; height:36px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:16px; flex-shrink:0; }
        .info-label { font-size:12px; color:var(--gray); margin-bottom:2px; }
        .info-value { font-size:14px; font-weight:600; color:var(--dark); }

        /* ── MODAL ───────────────────────────────────────────────── */
        .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); backdrop-filter:blur(6px); z-index:9999; align-items:center; justify-content:center; padding:20px; }
        .modal-overlay.open { display:flex; }
        .modal-box { background:white; border-radius:20px; max-width:480px; width:100%; overflow:hidden; box-shadow:0 24px 70px rgba(0,0,0,0.25); animation:modalIn 0.3s ease-out; }
        @keyframes modalIn { from{opacity:0;transform:translateY(-30px)} to{opacity:1;transform:translateY(0)} }
        .modal-header { padding:24px 28px 16px; border-bottom:1px solid #f1f5f9; }
        .modal-header h5 { font-size:17px; font-weight:700; color:var(--dark); }
        .modal-body   { padding:20px 28px; font-size:14px; color:var(--gray); line-height:1.6; }
        .modal-footer { padding:16px 28px 24px; display:flex; gap:10px; justify-content:flex-end; }
        .modal-footer .btn { width:auto; margin-bottom:0; }

        /* ── FACE MODAL ──────────────────────────────────────────── */
        .face-modal-box { max-width:620px; }
        .face-modal-header { background:linear-gradient(135deg, var(--purple), #764ba2); color:white; padding:24px 28px; }
        .face-modal-header h5 { font-size:17px; font-weight:700; margin:0; }
        #face-video { width:100%; border-radius:12px; max-height:380px; }
        .face-status { padding:12px 16px; border-radius:10px; font-size:14px; display:flex; align-items:center; gap:8px; margin-top:12px; }
        .face-status.info    { background:#f0f9ff; color:#0369a1; }
        .face-status.success { background:#f0fdf4; color:#166534; }
        .face-status.error   { background:#fff5f5; color:#dc2626; }

        /* ── MOBILE ──────────────────────────────────────────────── */
        .menu-toggle { display:none; background:none; border:none; font-size:22px; color:var(--dark); cursor:pointer; }
        .sidebar-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:99; }

        @media (max-width:1024px) { .profile-grid { grid-template-columns:1fr; } }
        @media (max-width:768px) {
            .sidebar { transform:translateX(-100%); }
            .sidebar.open { transform:translateX(0); }
            .sidebar-overlay.open { display:block; }
            .main { margin-left:0; }
            .menu-toggle { display:block; }
            .content { padding:16px; }
            .topbar { padding:0 16px; }
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'">
            <span class="sidebar-logo-text">Bekri</span>
        </div>
        <div class="sidebar-user">
            <div class="sidebar-avatar">
                {% if user.avatar %}<img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" alt="avatar">
                {% else %}{{ user.prenom|first|upper }}{{ user.nom|first|upper }}{% endif %}
            </div>
            <div>
                <div class="sidebar-user-name">{{ user.prenom }} {{ user.nom }}</div>
                <div class="sidebar-user-role">Membre Bekri</div>
            </div>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section-label">Principal</div>
            <a href="{{ path('user_dashboard') }}"   class="nav-item"><i class="bi bi-grid-fill"></i> Tableau de bord</a>
            <a href="{{ path('suivi_today') }}"       class="nav-item"><i class="bi bi-clipboard2-pulse-fill"></i> Check-in quotidien</a>
            <a href="{{ path('insight_weekly') }}"    class="nav-item"><i class="bi bi-graph-up-arrow"></i> Insights hebdo</a>
            <a href="{{ path('chat_index') }}"        class="nav-item"><i class="bi bi-robot"></i> Coach Eya IA</a>
            <div class="nav-section-label">Bien-être</div>
            <a href="{{ path('user_analyse') }}"      class="nav-item"><i class="bi bi-heart-pulse-fill"></i> Mon analyse bien-être</a>
            <a href="{{ path('objectif_index') }}"    class="nav-item"><i class="bi bi-trophy-fill"></i> Mes objectifs</a>
            <a href="{{ path('plan_index') }}" class="nav-item"><i class="bi bi-calendar2-week-fill"></i> Plan hebdomadaire</a>
            <a href="{{ path('food_analyzer_index') }}" class="nav-item"><i class="bi bi-egg-fried"></i> Analyseur Alimentaire</a>
            <div class="nav-section-label">Communauté</div>
            <a href="{{ path('posts_list') }}"        class="nav-item"><i class="bi bi-newspaper"></i> Publications</a>
            <a href="{{ path('evenements_home') }}"   class="nav-item"><i class="bi bi-calendar-event-fill"></i> Événements</a>
            <div class="nav-section-label">Mon compte</div>
            <a href="{{ path('user_profile') }}"      class="nav-item active"><i class="bi bi-person-fill"></i> Mon profil</a>
            <a href="{{ path('user_profile_edit') }}" class="nav-item"><i class="bi bi-gear-fill"></i> Paramètres</a>
        </nav>
        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;"><i class="bi bi-box-arrow-left"></i> Se déconnecter</a>
        </div>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- MAIN -->
    <div class="main">
        <header class="topbar">
            <div style="display:flex;align-items:center;gap:16px;">
                <button class="menu-toggle" id="menuToggle"><i class="bi bi-list"></i></button>
                <div>
                    <div class="topbar-title">Mon Profil</div>
                    <div class="topbar-sub">Gérez vos informations personnelles</div>
                </div>
            </div>
            <div class="topbar-right">
                <a href="{{ path('user_profile_edit') }}" class="topbar-btn" title="Modifier le profil"><i class="bi bi-pencil-fill"></i></a>
                <a href="{{ path('user_profile') }}" class="topbar-avatar-sm">
                    {% if user.avatar %}<img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" alt="avatar">
                    {% else %}{{ user.prenom|first|upper }}{{ user.nom|first|upper }}{% endif %}
                </a>
            </div>
        </header>

        <main class="content">
            <div class="profile-grid">

                <!-- LEFT: Profile card -->
                <div>
                    <div class="profile-card">
                        <div class="profile-card-banner"></div>
                        <div class="profile-card-body">

                            <div class="profile-avatar-wrap">
                                <div class="profile-avatar">
                                    {% if user.avatar %}
                                        <img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" alt="{{ user.prenom }}">
                                    {% else %}
                                        {{ user.prenom|first|upper }}{{ user.nom|first|upper }}
                                    {% endif %}
                                </div>
                            </div>

                            <div class="profile-name">{{ user.nom }} {{ user.prenom }}</div>
                            <div class="profile-email">{{ user.email }}</div>

                            {% if is_granted('ROLE_ADMIN') %}
                                <span class="profile-badge badge-admin"><i class="bi bi-shield-fill-check"></i> Administrateur</span>
                            {% elseif is_granted('ROLE_COACH') %}
                                <span class="profile-badge badge-coach"><i class="bi bi-award-fill"></i> Coach</span>
                            {% else %}
                                <span class="profile-badge badge-user"><i class="bi bi-person-fill"></i> Membre</span>
                            {% endif %}

                            <a href="{{ path('user_profile_edit') }}" class="btn btn-teal">
                                <i class="bi bi-pencil-fill"></i> Modifier le profil
                            </a>

                            <button type="button" class="btn btn-danger-outline" onclick="document.getElementById('deactivateModal').classList.add('open')">
                                <i class="bi bi-x-circle"></i> Désactiver mon compte
                            </button>

                            {# ── AI Avatar Generator ── #}
                            <a href="{{ path('avatar_generator') }}" class="btn btn-purple">
                                <i class="bi bi-stars"></i> Générer mon avatar IA
                            </a>

                            <div class="profile-divider"></div>

                            <!-- Face Auth -->
                            <div class="security-section">
                                <div class="security-title"><i class="bi bi-camera-video-fill"></i> Face Authentication</div>
                                {% if user.isFaceAuthEnabled() %}
                                    <div class="security-status status-on">
                                        <i class="bi bi-check-circle-fill"></i>
                                        <div>
                                            <strong>Activé</strong>
                                            <div style="font-size:11px;opacity:0.8;">Enregistré le {{ user.faceRegisteredAt|date('d/m/Y') }}</div>
                                        </div>
                                    </div>
                                    <button type="button" class="btn btn-danger-outline btn-sm" id="disable-face-auth-btn">
                                        <i class="bi bi-x-circle"></i> Désactiver Face Login
                                    </button>
                                {% else %}
                                    <div class="security-status status-off">
                                        <i class="bi bi-info-circle-fill"></i>
                                        <span>Connectez-vous plus rapidement avec votre visage</span>
                                    </div>
                                    <button type="button" class="btn btn-purple btn-sm" onclick="document.getElementById('faceModal').classList.add('open')">
                                        <i class="bi bi-camera-video-fill"></i> Activer Face Login
                                    </button>
                                {% endif %}
                            </div>

                            <div class="profile-divider"></div>

                            <!-- 2FA -->
                            <div class="security-section">
                                <div class="security-title"><i class="bi bi-shield-lock-fill"></i> Authentification 2FA</div>
                                {% if user.isTwoFactorEnabled() %}
                                    <div class="security-status status-on">
                                        <i class="bi bi-check-circle-fill"></i>
                                        <div>
                                            <strong>Activé</strong>
                                            <div style="font-size:11px;opacity:0.8;">{{ user.twoFactorEnabledAt ? user.twoFactorEnabledAt|date('d/m/Y') : '' }}</div>
                                        </div>
                                    </div>
                                    <form method="post" action="{{ path('app_2fa_disable') }}" style="margin-bottom:8px;">
                                        <div class="password-input-wrap">
                                            <input type="password" name="password" placeholder="Mot de passe pour désactiver" required>
                                            <i class="bi bi-eye toggle-pwd-icon" id="togglePwd2fa1"></i>
                                        </div>
                                        <input type="hidden" name="_token" value="{{ csrf_token('2fa_disable') }}">
                                        <button type="submit" class="btn btn-danger-outline btn-sm" onclick="return confirm('Désactiver la 2FA ?')">
                                            <i class="bi bi-x-circle"></i> Désactiver 2FA
                                        </button>
                                    </form>
                                    <form method="post" action="{{ path('app_2fa_regenerate_backup_codes') }}">
                                        <div class="password-input-wrap">
                                            <input type="password" name="password" placeholder="Mot de passe pour régénérer" required>
                                            <i class="bi bi-eye toggle-pwd-icon" id="togglePwd2fa2"></i>
                                        </div>
                                        <input type="hidden" name="_token" value="{{ csrf_token('2fa_regenerate') }}">
                                        <button type="submit" class="btn btn-warning-outline btn-sm">
                                            <i class="bi bi-arrow-clockwise"></i> Régénérer les codes
                                        </button>
                                    </form>
                                {% else %}
                                    <div class="security-status status-off">
                                        <i class="bi bi-info-circle-fill"></i>
                                        <span>Sécurisez davantage votre compte</span>
                                    </div>
                                    <a href="{{ path('app_2fa_enable') }}" class="btn btn-teal btn-sm">
                                        <i class="bi bi-shield-lock-fill"></i> Activer la 2FA
                                    </a>
                                {% endif %}
                            </div>

                        </div>
                    </div>
                </div>

                <!-- RIGHT: Info cards -->
                <div>
                    <div class="info-card">
                        <div class="info-card-header">
                            <i class="bi bi-person-badge-fill"></i> Informations personnelles
                        </div>
                        <div class="info-card-body">
                            <div class="info-row">
                                <div class="info-icon" style="background:var(--teal-light);color:var(--teal-dark);"><i class="bi bi-person-fill"></i></div>
                                <div><div class="info-label">Prénom</div><div class="info-value">{{ user.prenom }}</div></div>
                            </div>
                            <div class="info-row">
                                <div class="info-icon" style="background:#ede9fe;color:#7c3aed;"><i class="bi bi-person-fill"></i></div>
                                <div><div class="info-label">Nom</div><div class="info-value">{{ user.nom }}</div></div>
                            </div>
                            <div class="info-row">
                                <div class="info-icon" style="background:#dbeafe;color:#2563eb;"><i class="bi bi-envelope-fill"></i></div>
                                <div><div class="info-label">Email</div><div class="info-value">{{ user.email }}</div></div>
                            </div>
                            <div class="info-row">
                                <div class="info-icon" style="background:#fef3c7;color:#d97706;"><i class="bi bi-telephone-fill"></i></div>
                                <div><div class="info-label">Téléphone</div><div class="info-value">{{ user.telephone ?? 'Non renseigné' }}</div></div>
                            </div>
                            <div class="info-row">
                                <div class="info-icon" style="background:#fce7f3;color:#db2777;"><i class="bi bi-calendar-fill"></i></div>
                                <div><div class="info-label">Date de naissance</div><div class="info-value">{{ user.dateNaissance ? user.dateNaissance|date('d MMMM Y') : 'Non renseigné' }}</div></div>
                            </div>
                        </div>
                    </div>

                    <div class="info-card">
                        <div class="info-card-header">
                            <i class="bi bi-shield-lock-fill"></i> Détails du compte
                        </div>
                        <div class="info-card-body">
                            <div class="info-row">
                                <div class="info-icon" style="background:#d1fae5;color:#059669;"><i class="bi bi-calendar-check-fill"></i></div>
                                <div><div class="info-label">Compte créé le</div><div class="info-value">{{ user.createdAt ? user.createdAt|date('d/m/Y') : 'Inconnu' }}</div></div>
                            </div>
                            <div class="info-row">
                                <div class="info-icon" style="background:#f0f9ff;color:#0369a1;"><i class="bi bi-clock-fill"></i></div>
                                <div><div class="info-label">Dernière mise à jour</div><div class="info-value">{{ user.updatedAt ? user.updatedAt|date('d/m/Y') : 'Jamais' }}</div></div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <!-- Deactivate Modal -->
    <div class="modal-overlay" id="deactivateModal">
        <div class="modal-box">
            <div class="modal-header">
                <h5><i class="bi bi-exclamation-triangle-fill" style="color:#dc2626;margin-right:8px;"></i>Désactiver mon compte</h5>
            </div>
            <div class="modal-body">
                Êtes-vous sûr de vouloir désactiver votre compte ? Vous pourrez le réactiver à tout moment en vous reconnectant.
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" onclick="document.getElementById('deactivateModal').classList.remove('open')">Annuler</button>
                <form method="post" action="{{ path('user_profile_deactivate') }}" style="margin:0;">
                    <input type="hidden" name="_token" value="{{ csrf_token('deactivate-account') }}">
                    <button type="submit" class="btn btn-danger" style="margin-bottom:0;">Oui, désactiver</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Face Registration Modal -->
    <div class="modal-overlay" id="faceModal">
        <div class="modal-box face-modal-box">
            <div class="face-modal-header">
                <h5><i class="bi bi-camera-video-fill" style="margin-right:8px;"></i>Activer Face Authentication</h5>
            </div>
            <div style="padding:28px;">
                <div id="step-instructions" style="text-align:center;">
                    <i class="bi bi-camera-video-fill" style="font-size:3rem;color:var(--purple);display:block;margin-bottom:16px;"></i>
                    <h5 style="font-weight:700;margin-bottom:12px;">Comment ça fonctionne</h5>
                    <ul style="text-align:left;max-width:400px;margin:0 auto 20px;font-size:14px;color:var(--gray);line-height:2;">
                        <li>Positionnez votre visage dans le cadre de la caméra</li>
                        <li>Assurez-vous d'être dans un endroit bien éclairé</li>
                        <li>Regardez directement la caméra</li>
                        <li>Vos données sont chiffrées et sécurisées</li>
                    </ul>
                    <button type="button" class="btn btn-purple" style="width:auto;" id="start-face-capture-btn">
                        <i class="bi bi-camera-fill"></i> Démarrer la caméra
                    </button>
                </div>
                <div id="step-camera" style="display:none;">
                    <div style="position:relative;">
                        <video id="face-video" autoplay muted></video>
                        <canvas id="face-canvas" style="display:none;"></canvas>
                        <div id="face-detection-box" style="display:none;position:absolute;border:3px solid #00ff00;border-radius:8px;box-shadow:0 0 20px rgba(0,255,0,0.5);pointer-events:none;"></div>
                    </div>
                    <div id="face-status" class="face-status info">
                        <i class="bi bi-camera-video"></i>
                        <span id="face-status-text">Initialisation de la caméra...</span>
                    </div>
                    <div style="display:flex;gap:10px;margin-top:12px;">
                        <button type="button" class="btn btn-teal" id="capture-face-btn" disabled style="flex:1;opacity:0.5;cursor:not-allowed;">
                            <i class="bi bi-check-circle"></i> Capturer
                        </button>
                        <button type="button" class="btn btn-ghost" id="cancel-capture-btn" style="flex:1;">
                            <i class="bi bi-x-circle"></i> Annuler
                        </button>
                    </div>
                </div>
                <div id="step-processing" style="display:none;text-align:center;padding:40px 0;">
                    <div style="width:56px;height:56px;border:4px solid var(--teal-light);border-top-color:var(--teal);border-radius:50%;animation:spin 0.8s linear infinite;margin:0 auto 16px;"></div>
                    <h5 style="font-weight:700;">Traitement en cours...</h5>
                    <p style="color:var(--gray);font-size:14px;">Vos données sont sécurisées.</p>
                </div>
                <div id="step-success" style="display:none;text-align:center;padding:40px 0;">
                    <i class="bi bi-check-circle-fill" style="font-size:4rem;color:#22c55e;display:block;margin-bottom:16px;"></i>
                    <h4 style="font-weight:800;">Face Authentication activé !</h4>
                    <p style="color:var(--gray);font-size:14px;margin-top:8px;">Vous pouvez maintenant vous connecter avec votre visage.</p>
                    <button type="button" class="btn btn-teal" style="width:auto;margin-top:16px;" onclick="document.getElementById('faceModal').classList.remove('open');location.reload();">Terminer</button>
                </div>
                <div id="step-error" style="display:none;text-align:center;padding:40px 0;">
                    <i class="bi bi-exclamation-triangle-fill" style="font-size:4rem;color:#ef4444;display:block;margin-bottom:16px;"></i>
                    <h4 style="font-weight:800;">Échec de l'enregistrement</h4>
                    <p id="error-message" style="color:var(--gray);font-size:14px;margin-top:8px;">Une erreur est survenue.</p>
                    <div style="display:flex;gap:10px;justify-content:center;margin-top:16px;">
                        <button type="button" class="btn btn-teal" style="width:auto;" id="retry-face-capture-btn"><i class="bi bi-arrow-clockwise"></i> Réessayer</button>
                        <button type="button" class="btn btn-ghost" style="width:auto;" onclick="document.getElementById('faceModal').classList.remove('open')">Annuler</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
    <script>
        // Sidebar toggle
        const menuToggle = document.getElementById('menuToggle');
        const sidebar    = document.getElementById('sidebar');
        const overlay    = document.getElementById('sidebarOverlay');
        if (menuToggle) { menuToggle.addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('open'); }); }
        if (overlay)    { overlay.addEventListener('click', () => { sidebar.classList.remove('open'); overlay.classList.remove('open'); }); }

        // Password toggles
        function setupPwdToggle(iconId) {
            const icon = document.getElementById(iconId);
            if (!icon) return;
            icon.addEventListener('click', function() {
                const input = this.closest('.password-input-wrap').querySelector('input');
                if (!input) return;
                input.type = input.type === 'password' ? 'text' : 'password';
                this.classList.toggle('bi-eye');
                this.classList.toggle('bi-eye-slash');
            });
        }

        setupPwdToggle('togglePwd2fa1');
        setupPwdToggle('togglePwd2fa2');

        // Disable face auth
        const disableFaceBtn = document.getElementById('disable-face-auth-btn');
        if (disableFaceBtn) {
            disableFaceBtn.addEventListener('click', async () => {
                if (!confirm('Désactiver Face Authentication ?')) return;
                const res = await fetch('/api/face-auth/disable', { method:'POST', headers:{'Content-Type':'application/json'} });
                const data = await res.json();
                if (data.success) location.reload();
                else alert('Erreur. Veuillez réessayer.');
            });
        }

        // Face registration
        let videoStream = null, faceDescriptor = null, faceDetectedStartTime = null;
        const MIN_CONFIDENCE = 0.5, MIN_DURATION = 1500, MIN_SIZE = 100;

        function showFaceStep(id) {
            ['step-instructions','step-camera','step-processing','step-success','step-error'].forEach(s => {
                document.getElementById(s).style.display = s === id ? 'block' : 'none';
            });
        }

        function showFaceError(msg) {
            document.getElementById('error-message').textContent = msg;
            showFaceStep('step-error');
        }

        function stopCamera() {
            videoStream?.getTracks().forEach(t => t.stop());
            videoStream = null;
        }

        document.getElementById('start-face-capture-btn')?.addEventListener('click', async () => {
            showFaceStep('step-camera');
            const MODEL_URL = 'https://justadudewhohacks.github.io/face-api.js/models';
            try {
                await faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL);
                await faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL);
                await faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL);
            } catch(e) { showFaceError('Impossible de charger les modèles IA.'); return; }
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ video:{ width:{ideal:1280}, height:{ideal:720}, facingMode:'user' } });
                const video = document.getElementById('face-video');
                video.srcObject = stream; videoStream = stream;
                await new Promise(r => { video.onloadedmetadata = () => video.play().then(r); });
                document.getElementById('face-status-text').textContent = 'Caméra prête. Positionnez votre visage.';
                detectFaceLoop();
            } catch(e) { showFaceError('Impossible d\'accéder à la caméra.'); }
        });

        async function detectFaceLoop() {
            if (!videoStream) return;
            const video = document.getElementById('face-video');
            const capBtn = document.getElementById('capture-face-btn');
            const statusText = document.getElementById('face-status-text');
            const faceBox = document.getElementById('face-detection-box');
            const faceStatus = document.getElementById('face-status');

            try {
                const det = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions({inputSize:512, scoreThreshold:MIN_CONFIDENCE})).withFaceLandmarks().withFaceDescriptor();
                if (det?.detection) {
                    const { score, box } = det.detection;
                    const faceSize = Math.max(box.width, box.height);
                    if (score < MIN_CONFIDENCE || faceSize < MIN_SIZE) {
                        faceBox.style.display = 'none';
                        statusText.textContent = faceSize < MIN_SIZE ? 'Rapprochez-vous de la caméra.' : 'Qualité faible. Assurez un bon éclairage.';
                        faceStatus.className = 'face-status error';
                        capBtn.disabled = true; capBtn.style.opacity = '0.5'; faceDetectedStartTime = null;
                    } else {
                        const rect = video.getBoundingClientRect();
                        const sx = rect.width / (video.videoWidth || rect.width);
                        const sy = rect.height / (video.videoHeight || rect.height);
                        faceBox.style.display = 'block';
                        faceBox.style.left = (box.x*sx)+'px'; faceBox.style.top = (box.y*sy)+'px';
                        faceBox.style.width = (box.width*sx)+'px'; faceBox.style.height = (box.height*sy)+'px';
                        if (!faceDetectedStartTime) faceDetectedStartTime = Date.now();
                        const elapsed = Date.now() - faceDetectedStartTime;
                        if (elapsed < MIN_DURATION) {
                            statusText.textContent = `Visage détecté (${Math.round(score*100)}%). Restez immobile...`;
                            faceStatus.className = 'face-status info';
                            capBtn.disabled = true; capBtn.style.opacity = '0.5';
                        } else {
                            statusText.textContent = `Prêt ! (${Math.round(score*100)}%) Cliquez sur "Capturer"`;
                            faceStatus.className = 'face-status success';
                            capBtn.disabled = false; capBtn.style.opacity = '1'; capBtn.style.cursor = 'pointer';
                            faceDescriptor = Array.from(det.descriptor);
                        }
                    }
                } else {
                    faceBox.style.display = 'none';
                    statusText.textContent = 'Aucun visage détecté. Positionnez votre visage.';
                    faceStatus.className = 'face-status info';
                    capBtn.disabled = true; capBtn.style.opacity = '0.5'; faceDetectedStartTime = null;
                }
            } catch(e) { faceDetectedStartTime = null; }
            if (videoStream) requestAnimationFrame(detectFaceLoop);
        }

        document.getElementById('capture-face-btn')?.addEventListener('click', async () => {
            if (!faceDescriptor) { showFaceError('Aucun visage détecté.'); return; }
            showFaceStep('step-processing'); stopCamera();
            try {
                const res = await fetch('/api/face-auth/register', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({descriptor: faceDescriptor}) });
                const data = await res.json();
                if (data.success) { showFaceStep('step-success'); setTimeout(() => location.reload(), 2000); }
                else showFaceError(data.message || 'Échec de l\'enregistrement.');
            } catch(e) { showFaceError('Erreur réseau.'); }
        });

        document.getElementById('cancel-capture-btn')?.addEventListener('click', () => { stopCamera(); document.getElementById('faceModal').classList.remove('open'); });
        document.getElementById('retry-face-capture-btn')?.addEventListener('click', () => showFaceStep('step-instructions'));
    </script>
</body>
</html>