{% extends 'base.html.twig' %}

{% block title %}My Profile - Bekri Wellbeing{% endblock %}

{% block body_class %}profile-page{% endblock %}

{% block main %}
<div class="container" style="margin-top: 100px; margin-bottom: 80px;">
    <div class="row">
        <!-- Profile Header -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center p-4">
                    <div class="mb-3 position-relative">
                        {% if user.avatar %}
                            <img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" 
                                 alt="{{ user.prenom }}" 
                                 class="rounded-circle mx-auto d-block"
                                 style="width: 120px; height: 120px; object-fit: cover; border: 4px solid #667eea;">
                        {% else %}
                            <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center" 
                                 style="width: 120px; height: 120px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                <i class="bi bi-person-fill text-white" style="font-size: 60px;"></i>
                            </div>
                        {% endif %}
                    </div>
                    <h4 class="mb-1">{{ user.nom }} {{ user.prenom }}</h4>
                    <p class="text-muted mb-3">{{ user.email }}</p>
                    
                    {% if is_granted('ROLE_ADMIN') %}
                        <span class="badge bg-danger">Administrator</span>
                    {% elseif is_granted('ROLE_COACH') %}
                        <span class="badge bg-primary">Coach</span>
                    {% else %}
                        <span class="badge bg-success">User</span>
                    {% endif %}
                    
                    <hr class="my-4">
                    
                    <a href="{{ path('user_profile_edit') }}" class="btn btn-primary w-100">
                        <i class="bi bi-pencil-square me-2"></i>Edit Profile
                    </a>
                </div>
            </div>
        </div>

        <!-- Profile Information -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0"><i class="bi bi-person-badge me-2"></i>Personal Information</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong>First Name:</strong>
                        </div>
                        <div class="col-sm-8">
                            {{ user.prenom }}
                        </div>
                    </div>
                    <hr>
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong>Last Name:</strong>
                        </div>
                        <div class="col-sm-8">
                            {{ user.nom }}
                        </div>
                    </div>
                    <hr>
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong>Email:</strong>
                        </div>
                        <div class="col-sm-8">
                            {{ user.email }}
                        </div>
                    </div>
                    <hr>
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong>Phone:</strong>
                        </div>
                        <div class="col-sm-8">
                            {{ user.telephone ?? 'Not provided' }}
                        </div>
                    </div>
                    <hr>
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong>Date of Birth:</strong>
                        </div>
                        <div class="col-sm-8">
                            {{ user.dateNaissance ? user.dateNaissance|date('F d, Y') : 'Not provided' }}
                        </div>
                    </div>
                    <hr>
                    <div class="row">
                        <div class="col-sm-4">
                            <strong>Country:</strong>
                        </div>
                        <div class="col-sm-8">
                            {{ user.pays ?? 'Not specified' }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Account Information -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0"><i class="bi bi-shield-lock me-2"></i>Account Details</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong>Account Created:</strong>
                        </div>
                        <div class="col-sm-8">
                            {{ user.createdAt ? user.createdAt|date('F d, Y') : 'Unknown' }}
                        </div>
                    </div>
                    <hr>
                    <div class="row">
                        <div class="col-sm-4">
                            <strong>Last Updated:</strong>
                        </div>
                        <div class="col-sm-8">
                            {{ user.updatedAt ? user.updatedAt|date('F d, Y') : 'Never' }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}