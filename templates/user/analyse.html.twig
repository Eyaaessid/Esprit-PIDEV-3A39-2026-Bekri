<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mon Analyse Bien-être — Bekri</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --teal:      #20b2aa;
            --teal-dark: #0d9488;
            --teal-light:#e0f7f6;
            --purple:    #667eea;
            --dark:      #1a2332;
            --gray:      #64748b;
            --light:     #f8fafc;
            --white:     #ffffff;
            --sidebar-w: 260px;
            --shadow-sm: 0 2px 12px rgba(0,0,0,0.06);
            --shadow:    0 8px 30px rgba(0,0,0,0.10);
            --radius:    16px;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--light);
            color: var(--dark);
            display: flex;
            min-height: 100vh;
        }

        /* ── SIDEBAR (same as index) ─────────────────────────────── */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--dark);
            min-height: 100vh;
            position: fixed;
            top: 0; left: 0;
            display: flex;
            flex-direction: column;
            z-index: 100;
            transition: transform 0.3s ease;
        }
        .sidebar-logo {
            padding: 28px 24px 20px;
            display: flex; align-items: center; gap: 10px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }
        .sidebar-logo img { height: 36px; width: auto; }
        .sidebar-logo-text {
            font-size: 20px; font-weight: 800;
            background: linear-gradient(135deg, var(--teal), #a78bfa);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        .sidebar-user {
            padding: 20px 24px;
            display: flex; align-items: center; gap: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }
        .sidebar-avatar {
            width: 42px; height: 42px; border-radius: 50%;
            background: linear-gradient(135deg, var(--teal), var(--purple));
            display: flex; align-items: center; justify-content: center;
            color: white; font-weight: 700; font-size: 16px;
            flex-shrink: 0; overflow: hidden;
        }
        .sidebar-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .sidebar-user-name { font-size: 14px; font-weight: 600; color: white; }
        .sidebar-user-role { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 2px; }
        .sidebar-nav { flex: 1; padding: 16px 0; overflow-y: auto; }
        .nav-section-label {
            font-size: 10px; font-weight: 700; text-transform: uppercase;
            letter-spacing: 1px; color: rgba(255,255,255,0.25);
            padding: 12px 24px 6px;
        }
        .nav-item {
            display: flex; align-items: center; gap: 12px;
            padding: 11px 24px; color: rgba(255,255,255,0.6);
            text-decoration: none; font-size: 14px; font-weight: 500;
            transition: all 0.2s; border-left: 3px solid transparent;
        }
        .nav-item:hover { color: white; background: rgba(255,255,255,0.05); }
        .nav-item.active { color: var(--teal); background: rgba(32,178,170,0.1); border-left-color: var(--teal); }
        .nav-item i { width: 20px; text-align: center; font-size: 16px; }
        .sidebar-footer { padding: 16px 0; border-top: 1px solid rgba(255,255,255,0.07); }

        /* ── MAIN ────────────────────────────────────────────────── */
        .main { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; }

        /* ── TOPBAR ──────────────────────────────────────────────── */
        .topbar {
            background: white; padding: 0 32px; height: 68px;
            display: flex; align-items: center; justify-content: space-between;
            box-shadow: var(--shadow-sm); position: sticky; top: 0; z-index: 50;
        }
        .topbar-left { display: flex; align-items: center; gap: 16px; }
        .topbar-greeting h2 { font-size: 18px; font-weight: 700; color: var(--dark); }
        .topbar-greeting p  { font-size: 13px; color: var(--gray); }
        .topbar-right { display: flex; align-items: center; gap: 12px; }
        .topbar-btn {
            width: 40px; height: 40px; border-radius: 10px;
            background: var(--light); border: none; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            color: var(--gray); font-size: 16px; transition: all 0.2s; text-decoration: none;
        }
        .topbar-btn:hover { background: var(--teal-light); color: var(--teal-dark); }
        .topbar-avatar {
            width: 40px; height: 40px; border-radius: 50%;
            background: linear-gradient(135deg, var(--teal), var(--purple));
            display: flex; align-items: center; justify-content: center;
            color: white; font-weight: 700; font-size: 14px;
            overflow: hidden; text-decoration: none;
        }
        .topbar-avatar img { width: 100%; height: 100%; object-fit: cover; }

        /* ── CONTENT ─────────────────────────────────────────────── */
        .content { padding: 32px; flex: 1; }

        /* ── PAGE HEADER ─────────────────────────────────────────── */
        .page-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: var(--radius);
            padding: 32px 36px;
            margin-bottom: 28px;
            color: white;
            position: relative;
            overflow: hidden;
        }
        .page-header::before {
            content: '';
            position: absolute; top: -50px; right: -50px;
            width: 200px; height: 200px;
            background: rgba(255,255,255,0.06); border-radius: 50%;
        }
        .page-header h1 { font-size: 26px; font-weight: 800; margin-bottom: 6px; }
        .page-header p  { color: rgba(255,255,255,0.8); font-size: 14px; }

        /* ── SCORE CARDS ─────────────────────────────────────────── */
        .score-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-bottom: 28px;
        }
        .score-card {
            background: white;
            border-radius: var(--radius);
            padding: 28px;
            box-shadow: var(--shadow-sm);
            border: 1px solid #f1f5f9;
            display: flex; align-items: center; gap: 20px;
        }
        .score-circle {
            width: 90px; height: 90px; border-radius: 50%;
            background: linear-gradient(135deg, #667eea, #764ba2);
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            color: white; flex-shrink: 0;
        }
        .score-circle .score-num { font-size: 28px; font-weight: 800; line-height: 1; }
        .score-circle .score-max { font-size: 12px; opacity: 0.8; }
        .score-info h3 { font-size: 16px; font-weight: 700; color: var(--dark); margin-bottom: 6px; }
        .score-info p  { font-size: 13px; color: var(--gray); }
        .profil-badge {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 8px 16px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white; border-radius: 50px;
            font-size: 14px; font-weight: 600;
            margin-top: 8px;
        }

        /* ── ANALYSIS CARD ───────────────────────────────────────── */
        .analysis-card {
            background: white;
            border-radius: var(--radius);
            padding: 32px;
            box-shadow: var(--shadow-sm);
            border: 1px solid #f1f5f9;
            margin-bottom: 28px;
        }
        .analysis-card-header {
            display: flex; align-items: center; gap: 14px;
            margin-bottom: 24px;
            padding-bottom: 20px;
            border-bottom: 1px solid #f1f5f9;
        }
        .analysis-icon {
            width: 56px; height: 56px; border-radius: 16px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .analysis-icon i { color: white; font-size: 22px; }
        .analysis-card-header h2 { font-size: 18px; font-weight: 700; color: var(--dark); margin-bottom: 4px; }
        .analysis-card-header p  { font-size: 13px; color: var(--gray); }
        .analysis-text {
            font-size: 15px; color: var(--gray);
            line-height: 1.9;
            padding: 24px;
            background: linear-gradient(135deg, #f8f9ff, #f0f4ff);
            border-radius: 12px;
            border-left: 4px solid var(--purple);
            margin-bottom: 20px;
        }
        .analysis-disclaimer {
            font-size: 12px; font-style: italic;
            color: #94a3b8; margin-bottom: 24px;
            display: flex; align-items: center; gap: 6px;
        }

        /* ── ACTION BUTTONS ──────────────────────────────────────── */
        .action-row {
            display: flex; gap: 12px; flex-wrap: wrap;
        }
        .btn-primary-custom {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 12px 24px;
            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
            color: white; border-radius: 50px;
            font-weight: 600; font-size: 14px;
            text-decoration: none; border: none; cursor: pointer;
            box-shadow: 0 4px 15px rgba(32,178,170,0.3);
            transition: all 0.3s;
        }
        .btn-primary-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(32,178,170,0.4);
            color: white;
        }
        .btn-secondary-custom {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 12px 24px;
            background: white; color: var(--purple);
            border: 2px solid var(--purple); border-radius: 50px;
            font-weight: 600; font-size: 14px;
            text-decoration: none; cursor: pointer;
            transition: all 0.3s;
        }
        .btn-secondary-custom:hover {
            background: var(--purple); color: white;
            transform: translateY(-2px);
        }

        /* ── NO ANALYSIS ─────────────────────────────────────────── */
        .no-analysis {
            text-align: center; padding: 48px 32px;
        }
        .no-analysis i { font-size: 48px; color: #cbd5e1; margin-bottom: 16px; display: block; }
        .no-analysis h3 { font-size: 18px; font-weight: 700; color: var(--dark); margin-bottom: 8px; }
        .no-analysis p  { font-size: 14px; color: var(--gray); margin-bottom: 24px; }

        /* ── MOBILE ──────────────────────────────────────────────── */
        .menu-toggle {
            display: none; background: none; border: none;
            font-size: 22px; color: var(--dark); cursor: pointer;
        }
        .sidebar-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,0.5); z-index: 99;
        }
        @media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main { margin-left: 0; }
            .menu-toggle { display: block; }
            .content { padding: 20px 16px; }
            .topbar { padding: 0 16px; }
            .score-grid { grid-template-columns: 1fr; }
            .action-row { flex-direction: column; }
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'">
            <span class="sidebar-logo-text">Bekri</span>
        </div>
        <div class="sidebar-user">
            <div class="sidebar-avatar">
                {% if user.photo is defined and user.photo %}
                    <img src="{{ asset('uploads/photos/' ~ user.photo) }}" alt="avatar">
                {% else %}
                    {{ user.prenom|first|upper }}{{ user.nom|first|upper }}
                {% endif %}
            </div>
            <div>
                <div class="sidebar-user-name">{{ user.prenom }} {{ user.nom }}</div>
                <div class="sidebar-user-role">Membre Bekri</div>
            </div>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section-label">Principal</div>
            <a href="{{ path('user_dashboard') }}" class="nav-item">
                <i class="bi bi-grid-fill"></i> Tableau de bord
            </a>
            <a href="{{ path('suivi_today') }}" class="nav-item">
                <i class="bi bi-clipboard2-pulse-fill"></i> Check-in quotidien
            </a>
            <a href="{{ path('insight_weekly') }}" class="nav-item">
                <i class="bi bi-graph-up-arrow"></i> Insights hebdo
            </a>
            <a href="{{ path('chat_index') }}" class="nav-item">
                <i class="bi bi-robot"></i> Coach Eya IA
            </a>
            <div class="nav-section-label">Bien-être</div>
            <a href="{{ path('user_analyse') }}" class="nav-item active">
                <i class="bi bi-heart-pulse-fill"></i> Mon analyse bien-être
            </a>
            <a href="{{ path('objectif_index') }}" class="nav-item">
                <i class="bi bi-trophy-fill"></i> Mes objectifs
            </a>
            <div class="nav-section-label">Communauté</div>
            <a href="{{ path('posts_list') }}" class="nav-item">
                <i class="bi bi-newspaper"></i> Publications
            </a>
            <a href="{{ path('evenements_home') }}" class="nav-item">
                <i class="bi bi-calendar-event-fill"></i> Événements
            </a>
            <div class="nav-section-label">Mon compte</div>
            <a href="{{ path('user_profile') }}" class="nav-item">
                <i class="bi bi-person-fill"></i> Mon profil
            </a>
            <a href="{{ path('user_profile_edit') }}" class="nav-item">
                <i class="bi bi-gear-fill"></i> Paramètres
            </a>
        </nav>
        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;">
                <i class="bi bi-box-arrow-left"></i> Se déconnecter
            </a>
        </div>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- MAIN -->
    <div class="main">
        <header class="topbar">
            <div class="topbar-left">
                <button class="menu-toggle" id="menuToggle"><i class="bi bi-list"></i></button>
                <div class="topbar-greeting">
                    <h2>Mon analyse bien-être 💜</h2>
                    <p>Résultats de votre évaluation initiale</p>
                </div>
            </div>
            <div class="topbar-right">
                <a href="{{ path('suivi_today') }}" class="topbar-btn" title="Check-in du jour">
                    <i class="bi bi-clipboard2-pulse"></i>
                </a>
                <a href="{{ path('chat_index') }}" class="topbar-btn" title="Chat avec Eya">
                    <i class="bi bi-robot"></i>
                </a>
                <a href="{{ path('user_profile') }}" class="topbar-avatar" title="Mon profil">
                    {% if user.photo is defined and user.photo %}
                        <img src="{{ asset('uploads/photos/' ~ user.photo) }}" alt="avatar">
                    {% else %}
                        {{ user.prenom|first|upper }}{{ user.nom|first|upper }}
                    {% endif %}
                </a>
            </div>
        </header>

        <main class="content">

            {# Flash messages #}
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div style="
                        padding: 14px 20px; border-radius: 12px; margin-bottom: 20px;
                        background: {{ type == 'success' ? '#d1fae5' : (type == 'error' ? '#ffe4e6' : '#fef3c7') }};
                        color: {{ type == 'success' ? '#065f46' : (type == 'error' ? '#9f1239' : '#92400e') }};
                        font-size: 14px; font-weight: 500;
                        display: flex; align-items: center; gap: 8px;
                    ">
                        <i class="bi bi-{{ type == 'success' ? 'check-circle-fill' : (type == 'error' ? 'x-circle-fill' : 'exclamation-triangle-fill') }}"></i>
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {# Page Header #}
            <div class="page-header">
                <h1><i class="bi bi-heart-pulse-fill me-2"></i> Votre analyse bien-être</h1>
                <p>Analyse personnalisée générée par intelligence artificielle à partir de vos réponses au test initial.</p>
            </div>

            {# Score Cards #}
            <div class="score-grid">
                <div class="score-card">
                    <div class="score-circle">
                        <span class="score-num">{{ user.profilPsychologique.scoreGlobal }}</span>
                        <span class="score-max">/100</span>
                    </div>
                    <div class="score-info">
                        <h3>Score global</h3>
                        <p>Votre score de bien-être calculé lors de l'évaluation initiale.</p>
                        <span class="profil-badge">
                            <i class="bi bi-person-check-fill"></i>
                            {{ user.profilPsychologique.profilType }}
                        </span>
                    </div>
                </div>
                <div class="score-card">
                    <div style="
                        width:90px; height:90px; border-radius:50%;
                        background: linear-gradient(135deg, var(--teal), var(--teal-dark));
                        display:flex; flex-direction:column;
                        align-items:center; justify-content:center;
                        color:white; flex-shrink:0;
                    ">
                        <i class="bi bi-calendar-check-fill" style="font-size:28px;"></i>
                    </div>
                    <div class="score-info">
                        <h3>Date d'évaluation</h3>
                        <p>{{ user.profilPsychologique.dateEvaluation ? user.profilPsychologique.dateEvaluation|date('d/m/Y') : 'N/A' }}</p>
                        <a href="{{ path('objectif_new') }}" style="
                            display:inline-flex; align-items:center; gap:6px;
                            margin-top:8px; padding:8px 16px;
                            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
                            color:white; border-radius:50px;
                            font-size:13px; font-weight:600; text-decoration:none;
                        ">
                            <i class="bi bi-plus-circle-fill"></i> Définir mes objectifs
                        </a>
                    </div>
                </div>
            </div>

            {# AI Analysis Card #}
            <div class="analysis-card">
                <div class="analysis-card-header">
                    <div class="analysis-icon">
                        <i class="bi bi-stars"></i>
                    </div>
                    <div>
                        <h2>Analyse IA personnalisée</h2>
                        <p>Générée à partir de vos réponses au questionnaire initial</p>
                    </div>
                </div>

                {% if user.profilPsychologique.aiFeedback is not null and user.profilPsychologique.aiFeedback is not empty %}
                    <div class="analysis-text">
                        {{ user.profilPsychologique.aiFeedback|nl2br }}
                    </div>
                    <p class="analysis-disclaimer">
                        <i class="bi bi-info-circle-fill"></i>
                        Cette analyse ne remplace pas un avis médical professionnel.
                    </p>
                    <div class="action-row">
                        <a href="{{ path('objectif_new') }}" class="btn-primary-custom">
                            <i class="bi bi-plus-circle-fill"></i>
                            Définir mes objectifs
                        </a>
                        <a href="{{ path('insight_weekly') }}" class="btn-primary-custom" style="background: linear-gradient(135deg, var(--purple), #764ba2);">
                            <i class="bi bi-graph-up-arrow"></i>
                            Voir mes insights hebdo
                        </a>
                        <form method="post" action="{{ path('user_regenerate_insight') }}" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('regenerate_insight') }}">
                            <button type="submit" class="btn-secondary-custom">
                                <i class="bi bi-arrow-clockwise"></i>
                                Régénérer l'analyse
                            </button>
                        </form>
                    </div>
                {% else %}
                    <div class="no-analysis">
                        <i class="bi bi-robot"></i>
                        <h3>Analyse non générée</h3>
                        <p>Votre analyse personnalisée n'a pas pu être générée automatiquement. Cliquez ci-dessous pour la générer maintenant.</p>
                        <form method="post" action="{{ path('user_regenerate_insight') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('regenerate_insight') }}">
                            <button type="submit" class="btn-primary-custom" style="background: linear-gradient(135deg, var(--purple), #764ba2);">
                                <i class="bi bi-stars"></i>
                                Générer mon analyse maintenant
                            </button>
                        </form>
                    </div>
                {% endif %}
            </div>

        </main>
    </div>

    <script>
        const menuToggle = document.getElementById('menuToggle');
        const sidebar    = document.getElementById('sidebar');
        const overlay    = document.getElementById('sidebarOverlay');
        menuToggle.addEventListener('click', () => {
            sidebar.classList.toggle('open');
            overlay.classList.toggle('open');
        });
        overlay.addEventListener('click', () => {
            sidebar.classList.remove('open');
            overlay.classList.remove('open');
        });
    </script>
</body>
</html>