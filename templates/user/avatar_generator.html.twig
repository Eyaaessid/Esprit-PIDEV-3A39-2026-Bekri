<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Générateur d'Avatar IA — Bekri</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --dark:       #1a2332;
            --gray:       #64748b;
            --light:      #f8fafc;
            --white:      #ffffff;
            --sidebar-w:  260px;
            --shadow-sm:  0 2px 12px rgba(0,0,0,0.06);
            --shadow:     0 8px 30px rgba(0,0,0,0.10);
            --radius:     16px;
        }

        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior:smooth; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--light);
            color: var(--dark);
            display: flex;
            min-height: 100vh;
        }

        /* ── SIDEBAR ─────────────────────────────────────────────── */
        .sidebar { width:var(--sidebar-w); background:var(--dark); min-height:100vh; position:fixed; top:0; left:0; display:flex; flex-direction:column; z-index:100; transition:transform 0.3s ease; }
        .sidebar-logo { padding:28px 24px 20px; display:flex; align-items:center; gap:10px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-logo img { height:36px; width:auto; }
        .sidebar-logo-text { font-size:20px; font-weight:800; background:linear-gradient(135deg, var(--teal), #a78bfa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .sidebar-user { padding:20px 24px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-avatar { width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg, var(--teal), var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:16px; flex-shrink:0; overflow:hidden; }
        .sidebar-avatar img { width:100%; height:100%; object-fit:cover; }
        .sidebar-user-name { font-size:14px; font-weight:600; color:white; }
        .sidebar-user-role { font-size:11px; color:rgba(255,255,255,0.4); margin-top:2px; }
        .sidebar-nav { flex:1; padding:16px 0; overflow-y:auto; }
        .nav-section-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:rgba(255,255,255,0.25); padding:12px 24px 6px; }
        .nav-item { display:flex; align-items:center; gap:12px; padding:11px 24px; color:rgba(255,255,255,0.6); text-decoration:none; font-size:14px; font-weight:500; transition:all 0.2s; border-left:3px solid transparent; }
        .nav-item:hover { color:white; background:rgba(255,255,255,0.05); }
        .nav-item.active { color:var(--teal); background:rgba(32,178,170,0.1); border-left-color:var(--teal); }
        .nav-item i { width:20px; text-align:center; font-size:16px; }
        .sidebar-footer { padding:16px 0; border-top:1px solid rgba(255,255,255,0.07); }

        /* ── MAIN ────────────────────────────────────────────────── */
        .main { margin-left:var(--sidebar-w); flex:1; display:flex; flex-direction:column; min-height:100vh; }

        /* ── TOPBAR ──────────────────────────────────────────────── */
        .topbar { background:white; padding:0 32px; height:68px; display:flex; align-items:center; justify-content:space-between; box-shadow:var(--shadow-sm); position:sticky; top:0; z-index:50; }
        .topbar-title { font-size:18px; font-weight:700; color:var(--dark); }
        .topbar-sub   { font-size:13px; color:var(--gray); margin-top:2px; }
        .topbar-right { display:flex; align-items:center; gap:12px; }
        .topbar-btn { width:40px; height:40px; border-radius:10px; background:var(--light); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; color:var(--gray); font-size:16px; text-decoration:none; transition:all 0.2s; }
        .topbar-btn:hover { background:var(--teal-light); color:var(--teal-dark); }
        .topbar-avatar-sm { width:40px; height:40px; border-radius:50%; background:linear-gradient(135deg, var(--teal), var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:14px; text-decoration:none; overflow:hidden; }
        .topbar-avatar-sm img { width:100%; height:100%; object-fit:cover; }

        /* ── CONTENT ─────────────────────────────────────────────── */
        .content { padding:32px; flex:1; }

        /* ── PAGE HEADER ─────────────────────────────────────────── */
        .page-header {
            background: linear-gradient(135deg, var(--purple) 0%, #764ba2 100%);
            border-radius: var(--radius);
            padding: 32px 36px;
            margin-bottom: 28px;
            color: white;
            position: relative;
            overflow: hidden;
            text-align: center;
        }
        .page-header::before {
            content: '';
            position: absolute; top: -50px; right: -50px;
            width: 200px; height: 200px;
            background: rgba(255,255,255,0.06); border-radius: 50%;
        }
        .page-header::after {
            content: '';
            position: absolute; bottom: -30px; left: 60px;
            width: 120px; height: 120px;
            background: rgba(255,255,255,0.04); border-radius: 50%;
        }
        .page-header h1 { font-size: 28px; font-weight: 800; margin-bottom: 8px; position:relative; z-index:1; }
        .page-header p  { color: rgba(255,255,255,0.8); font-size: 15px; position:relative; z-index:1; }

        /* ── CARD ────────────────────────────────────────────────── */
        .card {
            background: white;
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            border: 1px solid #f1f5f9;
            margin-bottom: 24px;
            overflow: hidden;
        }

        .card-header-custom {
            padding: 20px 28px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .card-header-custom h5 {
            font-size: 15px;
            font-weight: 700;
            color: var(--dark);
            margin: 0;
        }

        .card-header-custom .step-badge {
            width: 28px; height: 28px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--purple), #764ba2);
            color: white;
            font-size: 13px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .card-body-custom { padding: 24px 28px; }

        /* ── UPLOAD & DESCRIPTION ────────────────────────────────── */
        .method-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .method-box {
            border: 2px dashed #e2e8f0;
            border-radius: 12px;
            padding: 24px;
            text-align: center;
            transition: all 0.3s;
        }

        .method-box:hover { border-color: var(--purple); background: #f8f9ff; }

        .method-box h6 { font-size: 14px; font-weight: 700; color: var(--dark); margin-bottom: 6px; }
        .method-box p  { font-size: 12px; color: var(--gray); margin-bottom: 14px; }

        .method-box-solid {
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            padding: 24px;
        }

        .method-box-solid h6 { font-size: 14px; font-weight: 700; color: var(--dark); margin-bottom: 6px; }
        .method-box-solid p  { font-size: 12px; color: var(--gray); margin-bottom: 14px; }

        textarea {
            width: 100%;
            padding: 12px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            color: var(--dark);
            resize: vertical;
            outline: none;
            transition: all 0.25s;
            background: var(--light);
        }

        textarea:focus { border-color: var(--purple); background: white; box-shadow: 0 0 0 3px rgba(102,126,234,0.1); }

        /* ── STYLE BUTTONS ───────────────────────────────────────── */
        .styles-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 12px;
        }

        .style-btn {
            background: white;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            padding: 14px 8px;
            text-align: center;
            cursor: pointer;
            transition: all 0.25s;
            font-family: 'Inter', sans-serif;
        }

        .style-btn:hover {
            border-color: var(--purple);
            background: #f8f9ff;
            transform: translateY(-2px);
        }

        .style-btn.selected {
            border-color: var(--purple);
            background: linear-gradient(135deg, #f0f4ff, #e8ecff);
            box-shadow: 0 4px 12px rgba(102,126,234,0.2);
        }

        .style-btn .style-emoji { font-size: 28px; display: block; margin-bottom: 6px; }
        .style-btn .style-label { font-size: 12px; font-weight: 600; color: var(--dark); }

        /* ── BUTTONS ─────────────────────────────────────────────── */
        .btn {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 12px 24px; border-radius: 10px;
            font-size: 14px; font-weight: 600;
            cursor: pointer; border: none; text-decoration: none;
            transition: all 0.25s; font-family: 'Inter', sans-serif;
            justify-content: center;
        }

        .btn-generate {
            width: 100%;
            padding: 16px;
            font-size: 16px;
            background: linear-gradient(135deg, var(--purple), #764ba2);
            color: white;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(102,126,234,0.3);
        }

        .btn-generate:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102,126,234,0.4);
        }

        .btn-generate:disabled {
            opacity: 0.6; cursor: not-allowed; transform: none;
        }

        .btn-upload {
            background: linear-gradient(135deg, var(--purple), #764ba2);
            color: white;
            padding: 10px 20px;
            border-radius: 10px;
            box-shadow: 0 3px 10px rgba(102,126,234,0.25);
        }

        .btn-upload:hover { transform: translateY(-1px); color: white; }

        .btn-success-custom {
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
            box-shadow: 0 3px 10px rgba(16,185,129,0.25);
        }

        .btn-success-custom:hover { transform: translateY(-1px); color: white; }

        .btn-ghost {
            background: var(--light); color: var(--gray);
            border: 2px solid #e2e8f0;
        }

        .btn-ghost:hover { background: #e2e8f0; color: var(--dark); }

        .btn-back {
            background: white;
            color: var(--gray);
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            padding: 10px 20px;
            font-size: 14px; font-weight: 600;
            text-decoration: none;
            display: inline-flex; align-items: center; gap: 8px;
            transition: all 0.25s;
        }

        .btn-back:hover { background: #e2e8f0; color: var(--dark); }

        /* ── LOADING ─────────────────────────────────────────────── */
        .loading-box {
            display: none;
            text-align: center;
            padding: 40px;
        }

        .spinner {
            width: 52px; height: 52px;
            border: 4px solid var(--teal-light);
            border-top-color: var(--purple);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 0 auto 16px;
        }

        @keyframes spin { to { transform: rotate(360deg); } }

        .loading-box h5 { font-size: 16px; font-weight: 700; color: var(--dark); margin-bottom: 6px; }
        .loading-box p  { font-size: 13px; color: var(--gray); }

        /* ── RESULT ──────────────────────────────────────────────── */
        .result-box {
            display: none;
            text-align: center;
            padding: 32px;
        }

        .result-box h5 { font-size: 18px; font-weight: 700; color: var(--dark); margin-bottom: 20px; }

        .result-box img {
            max-width: 360px;
            width: 100%;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            margin-bottom: 24px;
        }

        .result-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

        /* ── ALERT ───────────────────────────────────────────────── */
        .alert-warn {
            background: #fef3c7; color: #92400e;
            border: 1px solid #fde68a; border-radius: 10px;
            padding: 12px 16px; font-size: 13px;
            display: flex; align-items: center; gap: 8px;
            margin-top: 12px;
        }

        /* ── MOBILE ──────────────────────────────────────────────── */
        .menu-toggle { display:none; background:none; border:none; font-size:22px; color:var(--dark); cursor:pointer; }
        .sidebar-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:99; }

        @media (max-width: 768px) {
            .sidebar { transform:translateX(-100%); }
            .sidebar.open { transform:translateX(0); }
            .sidebar-overlay.open { display:block; }
            .main { margin-left:0; }
            .menu-toggle { display:block; }
            .content { padding:16px; }
            .topbar { padding:0 16px; }
            .method-grid { grid-template-columns: 1fr; }
            .styles-grid { grid-template-columns: repeat(3, 1fr); }
            .result-actions { flex-direction: column; }
        }

        @media (max-width: 480px) {
            .styles-grid { grid-template-columns: repeat(2, 1fr); }
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'">
            <span class="sidebar-logo-text">Bekri</span>
        </div>
        <div class="sidebar-user">
            <div class="sidebar-avatar">
                {% if user.avatar %}<img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" alt="avatar">
                {% else %}{{ user.prenom|first|upper }}{{ user.nom|first|upper }}{% endif %}
            </div>
            <div>
                <div class="sidebar-user-name">{{ user.prenom }} {{ user.nom }}</div>
                <div class="sidebar-user-role">Membre Bekri</div>
            </div>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section-label">Principal</div>
            <a href="{{ path('user_dashboard') }}"   class="nav-item"><i class="bi bi-grid-fill"></i> Tableau de bord</a>
            <a href="{{ path('suivi_today') }}"       class="nav-item"><i class="bi bi-clipboard2-pulse-fill"></i> Check-in quotidien</a>
            <a href="{{ path('insight_weekly') }}"    class="nav-item"><i class="bi bi-graph-up-arrow"></i> Insights hebdo</a>
            <a href="{{ path('chat_index') }}"        class="nav-item"><i class="bi bi-robot"></i> Coach Eya IA</a>
            <div class="nav-section-label">Bien-être</div>
            <a href="{{ path('user_analyse') }}"      class="nav-item"><i class="bi bi-heart-pulse-fill"></i> Mon analyse bien-être</a>
            <a href="{{ path('objectif_index') }}"    class="nav-item"><i class="bi bi-trophy-fill"></i> Mes objectifs</a>
            <a href="#"                               class="nav-item"><i class="bi bi-brain"></i> Test de santé mentale</a>
            <div class="nav-section-label">Communauté</div>
            <a href="{{ path('posts_list') }}"        class="nav-item"><i class="bi bi-newspaper"></i> Publications</a>
            <a href="{{ path('evenements_home') }}"   class="nav-item"><i class="bi bi-calendar-event-fill"></i> Événements</a>
            <div class="nav-section-label">Mon compte</div>
            <a href="{{ path('user_profile') }}"      class="nav-item active"><i class="bi bi-person-fill"></i> Mon profil</a>
            <a href="{{ path('user_profile_edit') }}" class="nav-item"><i class="bi bi-gear-fill"></i> Paramètres</a>
        </nav>
        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;"><i class="bi bi-box-arrow-left"></i> Se déconnecter</a>
        </div>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- MAIN -->
    <div class="main">
        <header class="topbar">
            <div style="display:flex;align-items:center;gap:16px;">
                <button class="menu-toggle" id="menuToggle"><i class="bi bi-list"></i></button>
                <div>
                    <div class="topbar-title">Générateur d'Avatar IA</div>
                    <div class="topbar-sub">Créez votre avatar personnalisé avec l'IA</div>
                </div>
            </div>
            <div class="topbar-right">
                <a href="{{ path('user_profile') }}" class="topbar-btn" title="Retour au profil">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <a href="{{ path('user_profile') }}" class="topbar-avatar-sm">
                    {% if user.avatar %}<img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" alt="avatar">
                    {% else %}{{ user.prenom|first|upper }}{{ user.nom|first|upper }}{% endif %}
                </a>
            </div>
        </header>

        <main class="content">

            {# Page Header #}
            <div class="page-header">
                <h1><i class="bi bi-stars"></i> Générateur d'Avatar IA</h1>
                <p>Créez des photos de profil uniques générées par intelligence artificielle</p>
            </div>

            {# Step 1: Method #}
            <div class="card">
                <div class="card-header-custom">
                    <div class="step-badge">1</div>
                    <h5>Choisissez votre méthode</h5>
                </div>
                <div class="card-body-custom">
                    <div class="method-grid">

                        <div class="method-box">
                            <div style="font-size:2rem;margin-bottom:10px;">📸</div>
                            <h6>Télécharger une photo</h6>
                            <p>L'IA analysera votre photo automatiquement</p>
                            <input type="file" id="photoUpload" accept="image/*" style="display:none;">
                            <button onclick="document.getElementById('photoUpload').click()" class="btn btn-upload">
                                <i class="bi bi-upload"></i> Choisir une photo
                            </button>
                            <div id="photoName" style="font-size:12px;color:var(--teal);margin-top:8px;display:none;"></div>
                        </div>

                        <div class="method-box-solid">
                            <div style="font-size:2rem;margin-bottom:10px;">✍️</div>
                            <h6>Décrivez-vous</h6>
                            <p>Entrez votre propre description</p>
                            <textarea id="description" rows="4"
                                placeholder="Ex : jeune femme aux cheveux bruns, yeux bleus, lunettes, sourire..."></textarea>
                        </div>

                    </div>

                    <div id="loadingDescribe" style="display:none;text-align:center;padding:20px 0;">
                        <div class="spinner" style="border-top-color:var(--purple);"></div>
                        <p style="font-size:13px;color:var(--gray);">Analyse de votre photo en cours...</p>
                    </div>

                    <div id="describeError" style="display:none;" class="alert-warn">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <span id="describeErrorText"></span>
                    </div>
                </div>
            </div>

            {# Step 2: Style #}
            <div class="card">
                <div class="card-header-custom">
                    <div class="step-badge">2</div>
                    <h5>Choisissez un style d'avatar</h5>
                </div>
                <div class="card-body-custom">
                    <div class="styles-grid">
                        <button onclick="selectStyle('anime')" class="style-btn selected" data-style="anime">
                            <span class="style-emoji">🎨</span>
                            <span class="style-label">Anime</span>
                        </button>
                        <button onclick="selectStyle('cartoon')" class="style-btn" data-style="cartoon">
                            <span class="style-emoji">🎬</span>
                            <span class="style-label">Cartoon</span>
                        </button>
                        <button onclick="selectStyle('manga')" class="style-btn" data-style="manga">
                            <span class="style-emoji">📖</span>
                            <span class="style-label">Manga</span>
                        </button>
                        <button onclick="selectStyle('pixel')" class="style-btn" data-style="pixel">
                            <span class="style-emoji">🎮</span>
                            <span class="style-label">Pixel Art</span>
                        </button>
                        <button onclick="selectStyle('fantasy')" class="style-btn" data-style="fantasy">
                            <span class="style-emoji">🧙</span>
                            <span class="style-label">Fantasy</span>
                        </button>
                        <button onclick="selectStyle('realistic')" class="style-btn" data-style="realistic">
                            <span class="style-emoji">📷</span>
                            <span class="style-label">Réaliste</span>
                        </button>
                    </div>
                </div>
            </div>

            {# Step 3: Generate #}
            <div class="card">
                <div class="card-header-custom">
                    <div class="step-badge">3</div>
                    <h5>Générer votre avatar</h5>
                </div>
                <div class="card-body-custom">

                    <button id="generateBtn" onclick="generateAvatar()" class="btn btn-generate">
                        <i class="bi bi-stars"></i> Générer mon avatar IA
                    </button>

                    <div id="loadingGenerate" class="loading-box">
                        <div class="spinner"></div>
                        <h5>Création de votre avatar...</h5>
                        <p>Cela peut prendre jusqu'à 2 minutes.</p>
                        <p id="retryMessage" style="font-size:12px;color:#94a3b8;margin-top:6px;"></p>
                    </div>

                    <div id="result" class="result-box">
                        <h5>🎉 Votre avatar est prêt !</h5>
                        <img id="generatedAvatar" src="" alt="Avatar généré">
                        <div class="result-actions">
                            <button onclick="saveAsProfile()" class="btn btn-success-custom">
                                <i class="bi bi-check-circle-fill"></i> Enregistrer comme photo de profil
                            </button>
                            <button onclick="location.reload()" class="btn btn-ghost">
                                <i class="bi bi-arrow-clockwise"></i> Générer un autre
                            </button>
                        </div>
                    </div>

                </div>
            </div>

            {# Back Button #}
            <div style="text-align:center;margin-top:8px;">
                <a href="{{ path('user_profile') }}" class="btn-back">
                    <i class="bi bi-arrow-left"></i> Retour au profil
                </a>
            </div>

        </main>
    </div>

    <script>
        // Sidebar toggle
        const menuToggle = document.getElementById('menuToggle');
        const sidebar    = document.getElementById('sidebar');
        const overlay    = document.getElementById('sidebarOverlay');
        if (menuToggle) { menuToggle.addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('open'); }); }
        if (overlay)    { overlay.addEventListener('click', () => { sidebar.classList.remove('open'); overlay.classList.remove('open'); }); }

        let selectedStyle = 'anime';
        let currentAvatarUrl = '';

        // ── PHOTO UPLOAD ──────────────────────────────────────────
        document.getElementById('photoUpload').addEventListener('change', async function(e) {
            const file = e.target.files[0];
            if (!file) return;

            const nameEl = document.getElementById('photoName');
            nameEl.textContent = '📎 ' + file.name;
            nameEl.style.display = 'block';

            const formData = new FormData();
            formData.append('photo', file);
            formData.append('_token', '{{ csrf_token('avatar_describe') }}');

            document.getElementById('loadingDescribe').style.display = 'block';
            document.getElementById('description').value = '';
            document.getElementById('description').placeholder = 'Analyse de votre photo...';
            hideDescribeError();

            try {
                const response = await fetch('{{ path('avatar_describe') }}', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (data.model_loading) {
                    const retrySeconds = data.retry_after || 15;
                    setTimeout(() => {
                        document.getElementById('photoUpload').dispatchEvent(new Event('change'));
                    }, retrySeconds * 1000);
                    return;
                }

                if (data.success && !data.fallback) {
                    document.getElementById('description').value = data.description;
                    document.getElementById('description').placeholder = 'Description extraite par IA';
                } else if (data.fallback) {
                    document.getElementById('description').placeholder = 'API vision indisponible — décrivez-vous manuellement';
                    showDescribeError('⚠️ Impossible d\'analyser la photo automatiquement. Veuillez saisir votre description manuellement.');
                } else {
                    document.getElementById('description').placeholder = 'Décrivez-vous manuellement';
                    showDescribeError('⚠️ Échec de l\'analyse : ' + (data.error || 'Erreur inconnue'));
                }
            } catch (error) {
                showDescribeError('⚠️ Erreur réseau lors de l\'analyse. Veuillez vous décrire manuellement.');
            } finally {
                document.getElementById('loadingDescribe').style.display = 'none';
            }
        });

        function showDescribeError(msg) {
            document.getElementById('describeErrorText').textContent = msg;
            document.getElementById('describeError').style.display = 'flex';
            setTimeout(() => hideDescribeError(), 8000);
        }

        function hideDescribeError() {
            document.getElementById('describeError').style.display = 'none';
        }

        // ── STYLE SELECTION ───────────────────────────────────────
        function selectStyle(style) {
            selectedStyle = style;
            document.querySelectorAll('.style-btn').forEach(btn => btn.classList.remove('selected'));
            document.querySelector(`[data-style="${style}"]`).classList.add('selected');
        }

        // ── GENERATE AVATAR ───────────────────────────────────────
        async function generateAvatar() {
            const description = document.getElementById('description').value.trim();
            const photoFile   = document.getElementById('photoUpload').files[0];

            if (!description && !photoFile) {
                alert('⚠️ Veuillez entrer une description ou télécharger une photo.');
                return;
            }

            document.getElementById('generateBtn').disabled = true;
            document.getElementById('loadingGenerate').style.display = 'block';
            document.getElementById('result').style.display = 'none';

            const formData = new FormData();
            formData.append('description', description);
            formData.append('style', selectedStyle);
            formData.append('_token', '{{ csrf_token('avatar_generate') }}');
            if (photoFile) formData.append('photo', photoFile);

            try {
                const response = await fetch('{{ path('avatar_generate') }}', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (data.model_loading) {
                    const retrySeconds = data.retry_after || 20;
                    document.getElementById('retryMessage').textContent =
                        `Modèle en cours de chargement... Nouvelle tentative dans ${retrySeconds} secondes`;
                    setTimeout(generateAvatar, retrySeconds * 1000);
                    return;
                }

                if (data.success) {
                    currentAvatarUrl = data.avatar_url;
                    document.getElementById('generatedAvatar').src = data.avatar_url;
                    document.getElementById('result').style.display = 'block';
                    document.getElementById('result').scrollIntoView({ behavior: 'smooth' });
                } else {
                    alert('❌ Erreur : ' + (data.error || 'Échec de la génération'));
                }
            } catch (error) {
                alert('❌ Erreur lors de la génération de l\'avatar.');
            } finally {
                document.getElementById('loadingGenerate').style.display = 'none';
                document.getElementById('generateBtn').disabled = false;
                document.getElementById('retryMessage').textContent = '';
            }
        }

        // ── SAVE AS PROFILE ───────────────────────────────────────
        async function saveAsProfile() {
            if (!currentAvatarUrl) return;

            const formData = new FormData();
            formData.append('avatar_url', currentAvatarUrl);
            formData.append('_token', '{{ csrf_token('avatar_save') }}');

            try {
                const response = await fetch('{{ path('avatar_save') }}', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (data.success) {
                    alert('✅ Avatar enregistré comme photo de profil !');
                    window.location.href = '{{ path("user_profile") }}';
                } else {
                    alert('❌ Erreur : ' + (data.error || 'Échec de l\'enregistrement'));
                }
            } catch (error) {
                alert('❌ Erreur lors de l\'enregistrement de l\'avatar.');
            }
        }
    </script>
</body>
</html>