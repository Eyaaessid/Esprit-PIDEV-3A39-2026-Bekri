{% extends 'base.html.twig' %}

{% block title %}Verify your email - Bekri Wellbeing{% endblock %}

{% block main %}
  <div class="container" style="margin-top: 120px; margin-bottom: 80px; max-width: 720px;">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4 p-md-5 text-center">
        <div class="mb-3">
          <i class="bi bi-envelope-check" style="font-size: 3rem; color: #20b2aa;"></i>
        </div>
        <h2 class="mb-2">Check your email</h2>
        <p class="text-muted mb-4">
          We sent a verification link{% if email %} to <strong>{{ email }}</strong>{% endif %}.
          Please click it to verify your account before logging in.
        </p>

        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
          <a href="{{ path('app_login') }}" class="btn btn-primary">
            Go to login
          </a>
          <a href="{{ path('app_verify_resend', { email: email }) }}" class="btn btn-outline-secondary">
            Resend verification email
          </a>
        </div>

        <hr class="my-4">
        <p class="text-muted mb-0" style="font-size: 0.95rem;">
          Didn’t receive it? Check your spam/junk folder, or resend using the button above.
        </p>
      </div>
    </div>
  </div>
{% endblock %}

