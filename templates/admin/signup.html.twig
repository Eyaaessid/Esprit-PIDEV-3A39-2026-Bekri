<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <title>{% block title %}Inscription - Bekri{% endblock %}</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #e0f2f7 0%, #f0f8fa 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .signup-container {
            background: white;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
            max-width: 520px;
            width: 100%;
            padding: 50px 40px;
            position: relative;
            overflow: hidden;
        }

        .signup-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #20b2aa, #3ecdc7);
        }

        .logo-container {
            text-align: center;
            margin-bottom: 30px;
        }

        .logo {
            max-width: 120px;
            height: auto;
        }

        .welcome-text {
            text-align: center;
            margin-bottom: 35px;
        }

        .welcome-text h1 {
            color: #2c3e50;
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .welcome-text p {
            color: #95a5a6;
            font-size: 14px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            color: #2c3e50;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 6px;
        }

        /* ✨ AMÉLIORATION: Étoile rouge pour champs obligatoires */
        .required-star {
            color: #e74c3c;
            margin-left: 2px;
        }

        /* ✨ AMÉLIORATION: Badge optionnel */
        .optional-badge {
            color: #95a5a6;
            font-weight: 400;
            font-size: 11px;
            margin-left: 4px;
        }

        .input-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #bdc3c7;
            font-size: 16px;
        }

        /* ✨ AMÉLIORATION: Toggle password eye icon */
        .toggle-password {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #95a5a6;
            font-size: 16px;
            cursor: pointer;
            transition: color 0.3s ease;
            z-index: 10;
        }

        .toggle-password:hover {
            color: #20b2aa;
        }

        .toggle-password.active {
            color: #20b2aa;
        }

        .form-input {
            width: 100%;
            padding: 14px 16px 14px 46px;
            border: 2px solid #e8eef1;
            border-radius: 12px;
            font-size: 14px;
            color: #2c3e50;
            transition: all 0.3s ease;
            background: #f8fafb;
            font-family: 'Inter', sans-serif;
        }

        .form-input:focus {
            outline: none;
            border-color: #20b2aa;
            background: white;
            box-shadow: 0 0 0 4px rgba(32, 178, 170, 0.08);
        }

        /* ✨ AMÉLIORATION: Input avec erreur */
        .form-input.error {
            border-color: #e74c3c;
            background: #fff5f5;
        }

        .form-input.error:focus {
            border-color: #e74c3c;
            box-shadow: 0 0 0 4px rgba(231, 76, 60, 0.08);
        }

        /* ✨ AMÉLIORATION: Messages d'erreur améliorés */
        .form-error {
            display: flex;
            align-items: flex-start;
            gap: 6px;
            margin-top: 6px;
            padding: 8px 12px;
            background: #fff5f5;
            border-left: 3px solid #e74c3c;
            border-radius: 6px;
            font-size: 12px;
            color: #c0392b;
            line-height: 1.4;
            animation: slideDown 0.3s ease-out;
        }

        .form-error i {
            margin-top: 1px;
            font-size: 13px;
            flex-shrink: 0;
        }

        /* ✨ AMÉLIORATION: Aide pour le mot de passe */
        .password-help {
            font-size: 11px;
            color: #7f8c8d;
            margin-top: 6px;
            line-height: 1.5;
            padding-left: 46px;
        }

        /* ✨ AMÉLIORATION: Indicateur de force du mot de passe */
        .password-strength {
            margin-top: 8px;
            padding-left: 46px;
        }

        .strength-bar {
            height: 4px;
            background: #e8eef1;
            border-radius: 2px;
            overflow: hidden;
            margin-bottom: 6px;
        }

        .strength-fill {
            height: 100%;
            width: 0%;
            transition: all 0.3s ease;
            border-radius: 2px;
        }

        .strength-weak .strength-fill {
            width: 33%;
            background: #e74c3c;
        }

        .strength-medium .strength-fill {
            width: 66%;
            background: #f39c12;
        }

        .strength-strong .strength-fill {
            width: 100%;
            background: #27ae60;
        }

        .strength-text {
            font-size: 11px;
            font-weight: 500;
        }

        .strength-weak .strength-text {
            color: #e74c3c;
        }

        .strength-medium .strength-text {
            color: #f39c12;
        }

        .strength-strong .strength-text {
            color: #27ae60;
        }

        .password-requirements {
            margin-top: 8px;
            padding: 10px 12px;
            background: #f8fafb;
            border-radius: 8px;
            font-size: 11px;
            color: #7f8c8d;
        }

        .requirement {
            display: flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 4px;
        }

        .requirement:last-child {
            margin-bottom: 0;
        }

        .requirement i {
            font-size: 10px;
            color: #bdc3c7;
        }

        .requirement.met i {
            color: #27ae60;
        }

        .checkbox-wrapper {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin: 24px 0;
        }

        .checkbox-wrapper input[type="checkbox"] {
            width: 18px;
            height: 18px;
            margin-top: 2px;
            cursor: pointer;
            accent-color: #20b2aa;
        }

        .checkbox-wrapper label {
            color: #7f8c8d;
            font-size: 13px;
            cursor: pointer;
            line-height: 1.5;
        }

        .btn-signup {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #20b2aa 0%, #3ecdc7 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 4px 15px rgba(32, 178, 170, 0.3);
            margin-top: 8px;
        }

        .btn-signup:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(32, 178, 170, 0.4);
        }

        .btn-signup:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        .signin-link {
            text-align: center;
            margin-top: 24px;
            color: #95a5a6;
            font-size: 14px;
        }

        .signin-link a {
            color: #20b2aa;
            text-decoration: none;
            font-weight: 600;
        }

        .alert {
            padding: 14px 16px;
            border-radius: 12px;
            margin-bottom: 20px;
            font-size: 14px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
            line-height: 1.5;
            animation: slideDown 0.3s ease-out;
        }

        .alert i {
            margin-top: 2px;
            font-size: 16px;
            flex-shrink: 0;
        }

        .alert-danger {
            background: #fff5f5;
            color: #c0392b;
            border-left: 4px solid #e74c3c;
        }

        .alert-success {
            background: #f0fdf4;
            color: #166534;
            border-left: 4px solid #22c55e;
        }

        .alert-link {
            color: #20b2aa;
            text-decoration: underline;
            font-weight: 600;
        }

        .alert-link:hover {
            color: #188884;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .captcha-honeypot {
            position: absolute !important;
            left: -9999px !important;
            width: 1px !important;
            height: 1px !important;
            opacity: 0 !important;
            pointer-events: none !important;
        }
        .captcha-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .captcha-modal-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(5px);
        }
        .captcha-modal-content {
            position: relative;
            background: white;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            max-width: 440px;
            width: 100%;
            animation: modalSlideIn 0.3s ease-out;
            overflow: hidden;
        }
        @keyframes modalSlideIn {
            from { opacity: 0; transform: translateY(-40px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .captcha-modal-header {
            background: linear-gradient(135deg, #14b8a6 0%, #0d9488 100%);
            color: white;
            padding: 24px;
            text-align: center;
        }
        .captcha-modal-header i { font-size: 32px; display: block; margin-bottom: 10px; }
        .captcha-modal-header h5 { margin: 0; font-size: 18px; font-weight: 600; }
        .captcha-modal-body { padding: 28px; }
        .captcha-modal-body .captcha-question {
            background: linear-gradient(135deg, #0f766e 0%, #14b8a6 100%);
            color: white;
            padding: 18px 20px;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 500;
            text-align: center;
            margin-bottom: 20px;
            line-height: 1.5;
        }
        .captcha-input-group { margin-top: 8px; }
        .captcha-input-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            color: #2c3e50;
            font-size: 14px;
        }
        .captcha-input-group input {
            width: 100%;
            padding: 14px 16px;
            font-size: 18px;
            text-align: center;
            border: 2px solid #e8eef1;
            border-radius: 10px;
        }
        .captcha-input-group input:focus {
            outline: none;
            border-color: #14b8a6;
            box-shadow: 0 0 0 4px rgba(20, 184, 166, 0.15);
        }
        .captcha-modal-footer {
            padding: 20px 28px;
            border-top: 1px solid #eee;
            display: flex;
            gap: 12px;
            justify-content: flex-end;
        }
        .captcha-modal-footer .btn-modal {
            padding: 12px 24px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            border: none;
        }
        .captcha-modal-footer .btn-modal-secondary {
            background: #f1f5f9;
            color: #475569;
        }
        .captcha-modal-footer .btn-modal-primary {
            background: linear-gradient(135deg, #14b8a6 0%, #0d9488 100%);
            color: white;
        }

        @media (max-width: 576px) {
            .form-row {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .signup-container {
                padding: 40px 28px;
            }

            .password-help,
            .password-strength {
                padding-left: 0;
            }
        }
    </style>
</head>
<body>
    <div class="signup-container">
        <div class="logo-container">
            <img src="{{ asset('images/logo.png') }}" alt="Bekri Logo" class="logo">
        </div>

        <div class="welcome-text">
            <h1>Créer un compte</h1>
            <p>Commencez votre parcours de bien-être</p>
        </div>

        {# Flash Messages #}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i>
                <div>{{ message|raw }}</div>
            </div>
        {% endfor %}

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i>
                <div>{{ message|raw }}</div>
            </div>
        {% endfor %}

        {# Form Global Errors #}
        {% for error in registrationForm.vars.errors %}
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i>
                <div>{{ error.message }}</div>
            </div>
        {% endfor %}

        {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate', 'id': 'signup-form'}}) }}
            <div class="form-row">
                {# Nom #}
                <div class="form-group">
                    <label class="form-label">Nom <span class="required-star">*</span></label>
                    <div class="input-wrapper">
                        <i class="fas fa-user input-icon"></i>
                        {{ form_widget(registrationForm.nom, {
                            'attr': {
                                'class': 'form-input' ~ (registrationForm.nom.vars.errors|length > 0 ? ' error' : '')
                            }
                        }) }}
                    </div>
                    {% if registrationForm.nom.vars.errors|length > 0 %}
                        <div class="form-error">
                            <i class="fas fa-exclamation-circle"></i>
                            <span>{{ registrationForm.nom.vars.errors[0].message }}</span>
                        </div>
                    {% endif %}
                </div>

                {# Prénom #}
                <div class="form-group">
                    <label class="form-label">Prénom <span class="required-star">*</span></label>
                    <div class="input-wrapper">
                        <i class="fas fa-user input-icon"></i>
                        {{ form_widget(registrationForm.prenom, {
                            'attr': {
                                'class': 'form-input' ~ (registrationForm.prenom.vars.errors|length > 0 ? ' error' : '')
                            }
                        }) }}
                    </div>
                    {% if registrationForm.prenom.vars.errors|length > 0 %}
                        <div class="form-error">
                            <i class="fas fa-exclamation-circle"></i>
                            <span>{{ registrationForm.prenom.vars.errors[0].message }}</span>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# Email #}
            <div class="form-group">
                <label class="form-label">Adresse email <span class="required-star">*</span></label>
                <div class="input-wrapper">
                    <i class="fas fa-envelope input-icon"></i>
                    {{ form_widget(registrationForm.email, {
                        'attr': {
                            'class': 'form-input' ~ (registrationForm.email.vars.errors|length > 0 ? ' error' : '')
                        }
                    }) }}
                </div>
                {% if registrationForm.email.vars.errors|length > 0 %}
                    <div class="form-error">
                        <i class="fas fa-exclamation-circle"></i>
                        <span>{{ registrationForm.email.vars.errors[0].message }}</span>
                    </div>
                {% endif %}
            </div>

            <div class="form-row">
                {# Téléphone #}
                <div class="form-group">
                    <label class="form-label">Téléphone <span class="optional-badge">(optionnel)</span></label>
                    <div class="input-wrapper">
                        <i class="fas fa-phone input-icon"></i>
                        {{ form_widget(registrationForm.telephone, {
                            'attr': {
                                'class': 'form-input' ~ (registrationForm.telephone.vars.errors|length > 0 ? ' error' : '')
                            }
                        }) }}
                    </div>
                    {% if registrationForm.telephone.vars.errors|length > 0 %}
                        <div class="form-error">
                            <i class="fas fa-exclamation-circle"></i>
                            <span>{{ registrationForm.telephone.vars.errors[0].message }}</span>
                        </div>
                    {% endif %}
                </div>

                {# Date de naissance #}
                <div class="form-group">
                    <label class="form-label">Date de naissance <span class="required-star">*</span></label>
                    <div class="input-wrapper">
                        <i class="fas fa-calendar input-icon"></i>
                        {{ form_widget(registrationForm.dateNaissance, {
                            'attr': {
                                'class': 'form-input' ~ (registrationForm.dateNaissance.vars.errors|length > 0 ? ' error' : '')
                            }
                        }) }}
                    </div>
                    {% if registrationForm.dateNaissance.vars.errors|length > 0 %}
                        <div class="form-error">
                            <i class="fas fa-exclamation-circle"></i>
                            <span>{{ registrationForm.dateNaissance.vars.errors[0].message }}</span>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# Mot de passe #}
            <div class="form-group">
                <label class="form-label">Mot de passe <span class="required-star">*</span></label>
                <div class="input-wrapper">
                    <i class="fas fa-lock input-icon"></i>
                    {{ form_widget(registrationForm.plainPassword.first, {
                        'attr': {
                            'class': 'form-input password-input' ~ (registrationForm.plainPassword.first.vars.errors|length > 0 ? ' error' : ''),
                            'id': 'password-field'
                        }
                    }) }}
                    <i class="fas fa-eye toggle-password" id="toggle-password-1"></i>
                </div>
                
                {# Indicateur de force du mot de passe #}
                <div class="password-strength" id="password-strength" style="display: none;">
                    <div class="strength-bar">
                        <div class="strength-fill"></div>
                    </div>
                    <div class="strength-text"></div>
                </div>

                <div class="password-help">
                    Minimum 8 caractères, 1 majuscule, 1 minuscule, 1 chiffre et 1 caractère spécial (@$!%*?&-_)
                </div>

                {% if registrationForm.plainPassword.first.vars.errors|length > 0 %}
                    <div class="form-error">
                        <i class="fas fa-exclamation-circle"></i>
                        <span>{{ registrationForm.plainPassword.first.vars.errors[0].message }}</span>
                    </div>
                {% endif %}
            </div>

            {# Confirmer mot de passe #}
            <div class="form-group">
                <label class="form-label">Confirmer le mot de passe <span class="required-star">*</span></label>
                <div class="input-wrapper">
                    <i class="fas fa-lock input-icon"></i>
                    {{ form_widget(registrationForm.plainPassword.second, {
                        'attr': {
                            'class': 'form-input' ~ (registrationForm.plainPassword.second.vars.errors|length > 0 ? ' error' : ''),
                            'id': 'password-confirm-field'
                        }
                    }) }}
                    <i class="fas fa-eye toggle-password" id="toggle-password-2"></i>
                </div>
                {% if registrationForm.plainPassword.second.vars.errors|length > 0 %}
                    <div class="form-error">
                        <i class="fas fa-exclamation-circle"></i>
                        <span>{{ registrationForm.plainPassword.second.vars.errors[0].message }}</span>
                    </div>
                {% endif %}
            </div>

            {# Accepter les conditions #}
            <div class="checkbox-wrapper">
                {{ form_widget(registrationForm.agreeTerms) }}
                <label for="{{ registrationForm.agreeTerms.vars.id }}">
                    J'accepte les conditions d'utilisation <span class="required-star">*</span>
                </label>
            </div>
            {% if registrationForm.agreeTerms.vars.errors|length > 0 %}
                <div class="form-error" style="margin-top: -16px; margin-bottom: 20px;">
                    <i class="fas fa-exclamation-circle"></i>
                    <span>{{ registrationForm.agreeTerms.vars.errors[0].message }}</span>
                </div>
            {% endif %}

            {# Invisible honeypot + timestamp #}
            <input type="text" name="website" value="" tabindex="-1" autocomplete="off" class="captcha-honeypot" aria-hidden="true">
            <input type="hidden" name="form_timestamp" value="{{ 'now'|date('U') }}">

            <button type="submit" class="btn-signup" id="signup-submit-btn">
                <i class="fas fa-user-plus"></i>
                <span>Créer mon compte</span>
            </button>

            <div class="signin-link">
                Déjà un compte ? <a href="{{ path('app_login') }}">Se connecter</a>
            </div>
        {{ form_end(registrationForm) }}
    </div>

    <!-- CAPTCHA Modal -->
    <div id="captcha-modal" class="captcha-modal" style="display: none;">
        <div class="captcha-modal-overlay" onclick="closeCaptchaModal()"></div>
        <div class="captcha-modal-content">
            <div class="captcha-modal-header">
                <i class="fas fa-shield-alt"></i>
                <h5>Vérification de sécurité</h5>
            </div>
            <div class="captcha-modal-body">
                <div class="captcha-question">
                    <span id="captcha-question-text"></span>
                </div>
                <div class="captcha-input-group">
                    <label for="captcha-modal-input">Votre réponse <span class="required-star">*</span></label>
                    <input type="number" id="captcha-modal-input" class="form-input" placeholder="?" min="0" step="1" autocomplete="off">
                </div>
            </div>
            <div class="captcha-modal-footer">
                <button type="button" class="btn-modal btn-modal-secondary" onclick="closeCaptchaModal()">Annuler</button>
                <button type="button" class="btn-modal btn-modal-primary" onclick="submitCaptchaAndSignup()">Vérifier et créer mon compte</button>
            </div>
        </div>
    </div>

    <script>
        // ✨ Toggle Password Visibility
        function setupPasswordToggle(toggleId, fieldId) {
            const toggle = document.getElementById(toggleId);
            const field = document.getElementById(fieldId);
            
            if (toggle && field) {
                toggle.addEventListener('click', function() {
                    const type = field.getAttribute('type') === 'password' ? 'text' : 'password';
                    field.setAttribute('type', type);
                    
                    // Toggle eye icon
                    this.classList.toggle('fa-eye');
                    this.classList.toggle('fa-eye-slash');
                    this.classList.toggle('active');
                });
            }
        }

        // Initialize both password fields
        setupPasswordToggle('toggle-password-1', 'password-field');
        setupPasswordToggle('toggle-password-2', 'password-confirm-field');

        // ✨ Password Strength Indicator
        const passwordField = document.getElementById('password-field');
        const strengthIndicator = document.getElementById('password-strength');
        
        if (passwordField) {
            passwordField.addEventListener('input', function() {
                const password = this.value;
                
                if (password.length === 0) {
                    strengthIndicator.style.display = 'none';
                    return;
                }
                
                strengthIndicator.style.display = 'block';
                
                let strength = 0;
                const requirements = {
                    length: password.length >= 8,
                    uppercase: /[A-Z]/.test(password),
                    lowercase: /[a-z]/.test(password),
                    number: /\d/.test(password),
                    special: /[@$!%*?&\-_]/.test(password)
                };
                
                // Calculate strength
                if (requirements.length) strength++;
                if (requirements.uppercase) strength++;
                if (requirements.lowercase) strength++;
                if (requirements.number) strength++;
                if (requirements.special) strength++;
                
                // Update UI
                strengthIndicator.className = 'password-strength';
                
                if (strength <= 2) {
                    strengthIndicator.classList.add('strength-weak');
                    strengthIndicator.querySelector('.strength-text').textContent = 'Faible';
                } else if (strength <= 4) {
                    strengthIndicator.classList.add('strength-medium');
                    strengthIndicator.querySelector('.strength-text').textContent = 'Moyen';
                } else {
                    strengthIndicator.classList.add('strength-strong');
                    strengthIndicator.querySelector('.strength-text').textContent = 'Fort';
                }
            });
        }

        var signupCaptchaVerified = false;
        var signupCaptchaQuestion = {{ captcha_question|default('')|json_encode|raw }};
        function showCaptchaModalSignup(question) {
            document.getElementById('captcha-question-text').textContent = question || signupCaptchaQuestion;
            document.getElementById('captcha-modal').style.display = 'flex';
            document.getElementById('captcha-modal-input').value = '';
            setTimeout(function() { document.getElementById('captcha-modal-input').focus(); }, 100);
        }
        function closeCaptchaModal() {
            document.getElementById('captcha-modal').style.display = 'none';
        }
        function submitCaptchaAndSignup() {
            var userAnswer = document.getElementById('captcha-modal-input').value.trim();
            if (!userAnswer) {
                alert('Veuillez entrer une réponse.');
                return;
            }
            var form = document.getElementById('signup-form');
            var input = form.querySelector('input[name="captcha_answer"]');
            if (!input) {
                input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'captcha_answer';
                form.appendChild(input);
            }
            input.value = userAnswer;
            signupCaptchaVerified = true;
            closeCaptchaModal();
            form.submit();
        }
        document.getElementById('captcha-modal-input').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') { submitCaptchaAndSignup(); }
        });
        document.getElementById('signup-form').addEventListener('submit', function(e) {
            var honeypot = document.querySelector('input[name="website"]');
            if (honeypot && honeypot.value !== '') {
                e.preventDefault();
                return false;
            }
            var ts = parseInt(document.querySelector('input[name="form_timestamp"]').value, 10);
            if (ts && (Math.floor(Date.now() / 1000) - ts) < 3) {
                e.preventDefault();
                alert('Veuillez patienter quelques secondes avant d\'envoyer le formulaire.');
                return false;
            }
            if (!signupCaptchaVerified) {
                e.preventDefault();
                showCaptchaModalSignup();
                return false;
            }
        });

        // Auto-focus on first error field
        document.addEventListener('DOMContentLoaded', function() {
            const firstError = document.querySelector('.form-input.error');
            if (firstError) {
                firstError.focus();
                firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });
    </script>
</body>
</html>
