<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <title>Inscription - Bekri</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --dark:       #1a2332;
            --gray:       #64748b;
            --white:      #ffffff;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            background: var(--dark);
        }

        /* ── LEFT PANEL ──────────────────────────────────────────────── */
        .left-panel {
            flex: 1;
            background: linear-gradient(135deg, #0d9488 0%, #20b2aa 45%, #667eea 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 60px 48px;
            position: relative;
            overflow: hidden;
        }

        .left-panel::before {
            content: '';
            position: absolute;
            top: -80px; right: -80px;
            width: 300px; height: 300px;
            background: rgba(255,255,255,0.06);
            border-radius: 50%;
        }

        .left-panel::after {
            content: '';
            position: absolute;
            bottom: -60px; left: -60px;
            width: 250px; height: 250px;
            background: rgba(255,255,255,0.04);
            border-radius: 50%;
        }

        .left-content {
            position: relative;
            z-index: 1;
            text-align: center;
            max-width: 400px;
        }

        .left-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-bottom: 40px;
        }

        .left-logo img { height: 48px; width: auto; }
        .left-logo-text { font-size: 28px; font-weight: 800; color: white; }

        .left-title {
            font-size: 34px;
            font-weight: 800;
            color: white;
            line-height: 1.2;
            margin-bottom: 14px;
            letter-spacing: -0.5px;
        }

        .left-title span {
            background: linear-gradient(135deg, #a7f3d0, #bfdbfe);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .left-subtitle {
            font-size: 15px;
            color: rgba(255,255,255,0.8);
            line-height: 1.7;
            margin-bottom: 40px;
        }

        .left-steps {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .left-step {
            display: flex;
            align-items: center;
            gap: 14px;
            background: rgba(255,255,255,0.12);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 14px;
            padding: 14px 18px;
            text-align: left;
        }

        .step-num {
            width: 36px; height: 36px;
            background: rgba(255,255,255,0.25);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 15px;
            color: white;
            flex-shrink: 0;
        }

        .step-text { font-size: 14px; font-weight: 600; color: white; }
        .step-sub  { font-size: 12px; color: rgba(255,255,255,0.65); margin-top: 2px; }

        /* ── RIGHT PANEL ─────────────────────────────────────────────── */
        .right-panel {
            width: 560px;
            background: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 48px 52px;
            overflow-y: auto;
        }

        .form-header { margin-bottom: 28px; }

        .form-header h1 {
            font-size: 28px;
            font-weight: 800;
            color: var(--dark);
            letter-spacing: -0.5px;
            margin-bottom: 6px;
        }

        .form-header p { font-size: 15px; color: var(--gray); }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .form-group { margin-bottom: 18px; }

        .form-label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--dark);
            margin-bottom: 6px;
        }

        .required-star { color: #ef4444; margin-left: 2px; }
        .optional-tag  { font-size: 11px; color: #94a3b8; font-weight: 400; margin-left: 4px; }

        .input-wrapper { position: relative; }

        .input-icon {
            position: absolute;
            left: 14px; top: 50%;
            transform: translateY(-50%);
            color: #cbd5e1; font-size: 15px;
            pointer-events: none;
        }

        .toggle-password {
            position: absolute;
            right: 14px; top: 50%;
            transform: translateY(-50%);
            background: none; border: none;
            color: #94a3b8; cursor: pointer; font-size: 15px;
            padding: 0; transition: color 0.2s;
        }

        .toggle-password:hover { color: var(--teal); }

        .form-input {
            width: 100%;
            padding: 13px 14px 13px 42px;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            font-size: 14px;
            color: var(--dark);
            font-family: 'Inter', sans-serif;
            background: #f8fafc;
            transition: all 0.25s;
        }

        .form-input:focus {
            outline: none;
            border-color: var(--teal);
            background: white;
            box-shadow: 0 0 0 4px rgba(32,178,170,0.1);
        }

        .form-input.error  { border-color: #ef4444; background: #fff5f5; }
        .form-input::placeholder { color: #cbd5e1; }

        .form-error {
            display: flex;
            align-items: flex-start;
            gap: 6px;
            margin-top: 6px;
            padding: 8px 12px;
            background: #fff5f5;
            border-left: 3px solid #ef4444;
            border-radius: 6px;
            font-size: 12px;
            color: #dc2626;
            animation: slideDown 0.3s ease-out;
        }

        @keyframes slideDown {
            from { opacity:0; transform: translateY(-8px); }
            to   { opacity:1; transform: translateY(0); }
        }

        .password-strength { margin-top: 8px; }

        .strength-bar {
            height: 4px;
            background: #e2e8f0;
            border-radius: 2px;
            overflow: hidden;
            margin-bottom: 4px;
        }

        .strength-fill { height: 100%; width: 0; transition: all 0.3s; border-radius: 2px; }
        .strength-weak   .strength-fill { width: 33%; background: #ef4444; }
        .strength-medium .strength-fill { width: 66%; background: #f59e0b; }
        .strength-strong .strength-fill { width: 100%; background: #10b981; }
        .strength-text { font-size: 11px; font-weight: 600; }
        .strength-weak   .strength-text { color: #ef4444; }
        .strength-medium .strength-text { color: #f59e0b; }
        .strength-strong .strength-text { color: #10b981; }

        .password-hint {
            font-size: 11px;
            color: #94a3b8;
            margin-top: 5px;
            line-height: 1.5;
        }

        .checkbox-wrapper {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin: 16px 0;
        }

        .checkbox-wrapper input[type="checkbox"] {
            width: 16px; height: 16px;
            margin-top: 2px;
            accent-color: var(--teal);
            cursor: pointer;
            flex-shrink: 0;
        }

        .checkbox-wrapper label {
            font-size: 13px;
            color: var(--gray);
            cursor: pointer;
            line-height: 1.5;
        }

        .btn-primary {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, var(--teal) 0%, var(--teal-dark) 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 4px 15px rgba(32,178,170,0.3);
            font-family: 'Inter', sans-serif;
            margin-top: 8px;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(32,178,170,0.4);
        }

        .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

        .form-footer {
            text-align: center;
            margin-top: 20px;
            font-size: 14px;
            color: var(--gray);
        }

        .form-footer a { color: var(--teal); font-weight: 600; text-decoration: none; }
        .form-footer a:hover { text-decoration: underline; }

        .alert {
            padding: 13px 16px;
            border-radius: 12px;
            margin-bottom: 18px;
            font-size: 14px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
            line-height: 1.5;
        }

        .alert-danger  { background: #fff5f5; color: #dc2626; border-left: 4px solid #ef4444; }
        .alert-success { background: #f0fdf4; color: #166534; border-left: 4px solid #22c55e; }

        /* CAPTCHA */
        .captcha-honeypot {
            position: absolute !important; left: -9999px !important;
            width: 1px !important; height: 1px !important;
            opacity: 0 !important; pointer-events: none !important;
        }

        .modal-overlay {
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(6px);
            z-index: 9999;
            display: flex; align-items: center; justify-content: center;
            padding: 20px;
        }

        .modal-box {
            background: white;
            border-radius: 20px;
            max-width: 440px; width: 100%;
            overflow: hidden;
            box-shadow: 0 24px 70px rgba(0,0,0,0.25);
            animation: modalIn 0.3s ease-out;
        }

        @keyframes modalIn { from{opacity:0;transform:translateY(-30px)} to{opacity:1;transform:translateY(0)} }

        .modal-header {
            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
            padding: 24px; text-align: center; color: white;
        }

        .modal-header i { font-size: 32px; display: block; margin-bottom: 10px; }
        .modal-header h5 { margin: 0; font-size: 18px; font-weight: 700; }

        .modal-body { padding: 28px; }

        .captcha-q {
            background: linear-gradient(135deg, var(--teal-dark), var(--teal));
            color: white; padding: 18px; border-radius: 12px;
            font-size: 15px; font-weight: 600; text-align: center; margin-bottom: 20px;
        }

        .modal-body input {
            width: 100%; padding: 14px; font-size: 18px; text-align: center;
            border: 2px solid #e2e8f0; border-radius: 12px; font-family: 'Inter', sans-serif;
        }

        .modal-body input:focus { outline: none; border-color: var(--teal); box-shadow: 0 0 0 4px rgba(32,178,170,0.1); }

        .modal-footer { padding: 20px 28px; border-top: 1px solid #f1f5f9; display: flex; gap: 12px; justify-content: flex-end; }

        .btn-modal-cancel  { padding:11px 22px; background:#f1f5f9; color:#475569; border:none; border-radius:10px; font-weight:600; font-size:14px; cursor:pointer; font-family:'Inter',sans-serif; }
        .btn-modal-confirm { padding:11px 22px; background:linear-gradient(135deg, var(--teal), var(--teal-dark)); color:white; border:none; border-radius:10px; font-weight:600; font-size:14px; cursor:pointer; font-family:'Inter',sans-serif; }

        @media (max-width: 1024px) { .left-panel { display: none; } }
        @media (max-width: 600px) { .right-panel { width: 100%; padding: 32px 20px; } .form-row { grid-template-columns: 1fr; } }
    </style>
</head>
<body>

    <!-- LEFT PANEL -->
    <div class="left-panel">
        <div class="left-content">
            <div class="left-logo">
                <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'">
                <span class="left-logo-text">Bekri</span>
            </div>
            <h1 class="left-title">Commencez votre<br><span>parcours bien-être</span><br>aujourd'hui</h1>
            <p class="left-subtitle">Rejoignez Bekri et prenez le contrôle de votre santé mentale et physique en quelques étapes.</p>
            <div class="left-steps">
                <div class="left-step">
                    <div class="step-num">1</div>
                    <div>
                        <div class="step-text">Créez votre compte</div>
                        <div class="step-sub">Inscription gratuite en 1 minute</div>
                    </div>
                </div>
                <div class="left-step">
                    <div class="step-num">2</div>
                    <div>
                        <div class="step-text">Faites votre premier check-in</div>
                        <div class="step-sub">Évaluez votre bien-être du jour</div>
                    </div>
                </div>
                <div class="left-step">
                    <div class="step-num">3</div>
                    <div>
                        <div class="step-text">Recevez vos insights IA</div>
                        <div class="step-sub">Analyses et conseils personnalisés</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT PANEL -->
    <div class="right-panel">
        <div class="form-header">
            <h1>Créer un compte ✨</h1>
            <p>Commencez votre parcours de bien-être gratuitement</p>
        </div>

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i><span>{{ message|raw }}</span></div>
        {% endfor %}

        {% for message in app.flashes('success') %}
            <div class="alert alert-success"><i class="fas fa-check-circle"></i><span>{{ message|raw }}</span></div>
        {% endfor %}

        {% for error in registrationForm.vars.errors %}
            <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i><span>{{ error.message }}</span></div>
        {% endfor %}

        {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate', 'id': 'signup-form'}}) }}

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Nom <span class="required-star">*</span></label>
                    <div class="input-wrapper">
                        <i class="fas fa-user input-icon"></i>
                        {{ form_widget(registrationForm.nom, {'attr': {'class': 'form-input' ~ (registrationForm.nom.vars.errors|length > 0 ? ' error' : ''), 'placeholder': 'Votre nom'}}) }}
                    </div>
                    {% if registrationForm.nom.vars.errors|length > 0 %}
                        <div class="form-error"><i class="fas fa-exclamation-circle"></i><span>{{ registrationForm.nom.vars.errors[0].message }}</span></div>
                    {% endif %}
                </div>
                <div class="form-group">
                    <label class="form-label">Prénom <span class="required-star">*</span></label>
                    <div class="input-wrapper">
                        <i class="fas fa-user input-icon"></i>
                        {{ form_widget(registrationForm.prenom, {'attr': {'class': 'form-input' ~ (registrationForm.prenom.vars.errors|length > 0 ? ' error' : ''), 'placeholder': 'Votre prénom'}}) }}
                    </div>
                    {% if registrationForm.prenom.vars.errors|length > 0 %}
                        <div class="form-error"><i class="fas fa-exclamation-circle"></i><span>{{ registrationForm.prenom.vars.errors[0].message }}</span></div>
                    {% endif %}
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Adresse email <span class="required-star">*</span></label>
                <div class="input-wrapper">
                    <i class="fas fa-envelope input-icon"></i>
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'form-input' ~ (registrationForm.email.vars.errors|length > 0 ? ' error' : ''), 'placeholder': 'nom@exemple.com'}}) }}
                </div>
                {% if registrationForm.email.vars.errors|length > 0 %}
                    <div class="form-error"><i class="fas fa-exclamation-circle"></i><span>{{ registrationForm.email.vars.errors[0].message }}</span></div>
                {% endif %}
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Téléphone <span class="optional-tag">(optionnel)</span></label>
                    <div class="input-wrapper">
                        <i class="fas fa-phone input-icon"></i>
                        {{ form_widget(registrationForm.telephone, {'attr': {'class': 'form-input' ~ (registrationForm.telephone.vars.errors|length > 0 ? ' error' : ''), 'placeholder': '+216 XX XXX XXX'}}) }}
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Date de naissance <span class="required-star">*</span></label>
                    <div class="input-wrapper">
                        <i class="fas fa-calendar input-icon"></i>
                        {{ form_widget(registrationForm.dateNaissance, {'attr': {'class': 'form-input' ~ (registrationForm.dateNaissance.vars.errors|length > 0 ? ' error' : '')}}) }}
                    </div>
                    {% if registrationForm.dateNaissance.vars.errors|length > 0 %}
                        <div class="form-error"><i class="fas fa-exclamation-circle"></i><span>{{ registrationForm.dateNaissance.vars.errors[0].message }}</span></div>
                    {% endif %}
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Mot de passe <span class="required-star">*</span></label>
                <div class="input-wrapper">
                    <i class="fas fa-lock input-icon"></i>
                    {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-input' ~ (registrationForm.plainPassword.first.vars.errors|length > 0 ? ' error' : ''), 'id': 'password-field', 'placeholder': '••••••••'}}) }}
                    <button type="button" class="toggle-password" id="toggle-pwd-1"><i class="fas fa-eye"></i></button>
                </div>
                <div class="password-strength" id="pwd-strength" style="display:none;">
                    <div class="strength-bar"><div class="strength-fill"></div></div>
                    <div class="strength-text"></div>
                </div>
                <p class="password-hint">Min. 8 caractères, 1 majuscule, 1 chiffre et 1 caractère spécial</p>
                {% if registrationForm.plainPassword.first.vars.errors|length > 0 %}
                    <div class="form-error"><i class="fas fa-exclamation-circle"></i><span>{{ registrationForm.plainPassword.first.vars.errors[0].message }}</span></div>
                {% endif %}
            </div>

            <div class="form-group">
                <label class="form-label">Confirmer le mot de passe <span class="required-star">*</span></label>
                <div class="input-wrapper">
                    <i class="fas fa-lock input-icon"></i>
                    {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-input' ~ (registrationForm.plainPassword.second.vars.errors|length > 0 ? ' error' : ''), 'id': 'password-confirm-field', 'placeholder': '••••••••'}}) }}
                    <button type="button" class="toggle-password" id="toggle-pwd-2"><i class="fas fa-eye"></i></button>
                </div>
                {% if registrationForm.plainPassword.second.vars.errors|length > 0 %}
                    <div class="form-error"><i class="fas fa-exclamation-circle"></i><span>{{ registrationForm.plainPassword.second.vars.errors[0].message }}</span></div>
                {% endif %}
            </div>

            <div class="checkbox-wrapper">
                {{ form_widget(registrationForm.agreeTerms) }}
                <label for="{{ registrationForm.agreeTerms.vars.id }}">
                    J'accepte les <a href="#" style="color:var(--teal);font-weight:600;" target="_blank">conditions d'utilisation</a> <span class="required-star">*</span>
                </label>
            </div>
            {% if registrationForm.agreeTerms.vars.errors|length > 0 %}
                <div class="form-error" style="margin-top:-10px;margin-bottom:16px;"><i class="fas fa-exclamation-circle"></i><span>{{ registrationForm.agreeTerms.vars.errors[0].message }}</span></div>
            {% endif %}

            <input type="text" name="website" value="" tabindex="-1" autocomplete="off" class="captcha-honeypot" aria-hidden="true">
            <input type="hidden" name="form_timestamp" value="{{ 'now'|date('U') }}">

            <button type="submit" class="btn-primary" id="signup-submit-btn">
                <i class="bi bi-person-plus-fill"></i>
                <span>Créer mon compte gratuitement</span>
            </button>

            <div class="form-footer">
                Déjà un compte ? <a href="{{ path('app_login') }}">Se connecter</a>
            </div>

        {{ form_end(registrationForm) }}
    </div>

    <!-- CAPTCHA Modal -->
    <div id="captcha-modal" style="display:none;" class="modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <i class="fas fa-shield-alt"></i>
                <h5>Vérification de sécurité</h5>
            </div>
            <div class="modal-body">
                <div class="captcha-q"><span id="captcha-question-text"></span></div>
                <input type="number" id="captcha-modal-input" placeholder="?" min="0" step="1" autocomplete="off">
            </div>
            <div class="modal-footer">
                <button class="btn-modal-cancel" onclick="closeCaptchaModal()">Annuler</button>
                <button class="btn-modal-confirm" onclick="submitCaptchaAndSignup()">Vérifier et créer mon compte</button>
            </div>
        </div>
    </div>

    <script>
        // Password toggles
        [['toggle-pwd-1','password-field'],['toggle-pwd-2','password-confirm-field']].forEach(([tid, fid]) => {
            document.getElementById(tid)?.addEventListener('click', function() {
                const f = document.getElementById(fid);
                const i = this.querySelector('i');
                f.type = f.type === 'password' ? 'text' : 'password';
                i.classList.toggle('fa-eye'); i.classList.toggle('fa-eye-slash');
            });
        });

        // Password strength
        document.getElementById('password-field')?.addEventListener('input', function() {
            const pwd = this.value;
            const box = document.getElementById('pwd-strength');
            if (!pwd.length) { box.style.display = 'none'; return; }
            box.style.display = 'block';
            let s = 0;
            if (pwd.length >= 8)              s++;
            if (/[A-Z]/.test(pwd))            s++;
            if (/[a-z]/.test(pwd))            s++;
            if (/\d/.test(pwd))               s++;
            if (/[@$!%*?&\-_]/.test(pwd))     s++;
            box.className = 'password-strength ' + (s <= 2 ? 'strength-weak' : s <= 4 ? 'strength-medium' : 'strength-strong');
            box.querySelector('.strength-text').textContent = s <= 2 ? 'Faible' : s <= 4 ? 'Moyen' : 'Fort';
        });

        // CAPTCHA
        var signupCaptchaVerified = false;
        var captchaQuestion = {{ captcha_question|default('')|json_encode|raw }};

        function showCaptchaModalSignup() {
            document.getElementById('captcha-question-text').textContent = captchaQuestion;
            document.getElementById('captcha-modal').style.display = 'flex';
            setTimeout(() => document.getElementById('captcha-modal-input').focus(), 100);
        }

        function closeCaptchaModal() { document.getElementById('captcha-modal').style.display = 'none'; }

        function submitCaptchaAndSignup() {
            const ans = document.getElementById('captcha-modal-input').value.trim();
            if (!ans) { alert('Veuillez entrer une réponse.'); return; }
            const form = document.getElementById('signup-form');
            let input = form.querySelector('input[name="captcha_answer"]');
            if (!input) { input = document.createElement('input'); input.type='hidden'; input.name='captcha_answer'; form.appendChild(input); }
            input.value = ans;
            signupCaptchaVerified = true;
            closeCaptchaModal();
            form.submit();
        }

        document.getElementById('captcha-modal-input').addEventListener('keypress', e => { if (e.key==='Enter') submitCaptchaAndSignup(); });

        document.getElementById('signup-form').addEventListener('submit', function(e) {
            if (document.querySelector('input[name="website"]')?.value !== '') { e.preventDefault(); return; }
            const ts = parseInt(document.querySelector('input[name="form_timestamp"]').value, 10);
            if (ts && (Math.floor(Date.now()/1000) - ts) < 3) { e.preventDefault(); alert('Veuillez patienter quelques secondes.'); return; }
            if (!signupCaptchaVerified) { e.preventDefault(); showCaptchaModalSignup(); }
        });

        // Auto-focus first error
        document.addEventListener('DOMContentLoaded', () => {
            const firstErr = document.querySelector('.form-input.error');
            if (firstErr) { firstErr.focus(); firstErr.scrollIntoView({behavior:'smooth',block:'center'}); }
        });
    </script>
</body>
</html>