<!DOCTYPE html>
<html lang="fr" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Modifier question</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                        },
                        teal: {
                            500: '#14b8a6',
                            600: '#0d9488',
                        }
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="h-full bg-gray-50 antialiased">

<div class="min-h-screen py-10">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="mb-8">
            <a href="{{ path('admin_question_index') }}"
               class="inline-flex items-center text-primary-600 hover:text-primary-800 font-medium">
                <i class="fas fa-arrow-left mr-2"></i> Retour à la liste
            </a>
            <h1 class="text-3xl font-bold text-gray-900 mt-3">Modifier la question</h1>
            <p class="text-gray-600 mt-1 line-clamp-1">{{ question.texte }}</p>
        </div>

        <div class="bg-white rounded-xl shadow border border-gray-200 p-8">

            {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

            <!-- Texte -->
            <div>
                {{ form_label(form.texte) }}
                {{ form_widget(form.texte) }}
                {{ form_errors(form.texte) }}
            </div>

            <!-- Catégorie -->
            <div>
                {{ form_label(form.category) }}
                {{ form_widget(form.category) }}
                {{ form_errors(form.category) }}
            </div>

            <!-- Les 3 options -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                    {{ form_label(form.option1, 'Option 1') }}
                    {{ form_widget(form.option1) }}
                    {{ form_errors(form.option1) }}
                </div>
                <div>
                    {{ form_label(form.option2, 'Option 2') }}
                    {{ form_widget(form.option2) }}
                    {{ form_errors(form.option2) }}
                </div>
                <div>
                    {{ form_label(form.option3, 'Option 3') }}
                    {{ form_widget(form.option3) }}
                    {{ form_errors(form.option3) }}
                </div>
            </div>

            <!-- Actions -->
            <div class="pt-8 flex justify-end gap-4 border-t border-gray-100">
                <a href="{{ path('admin_question_index') }}"
                   class="px-6 py-3 bg-white border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">
                    Annuler
                </a>
                <button type="submit"
                        class="px-8 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 shadow-sm transition flex items-center">
                    <i class="fas fa-save mr-2"></i>
                    Enregistrer les modifications
                </button>
            </div>

            {{ form_end(form) }}
        </div>

    </div>
</div>

</body>
</html>