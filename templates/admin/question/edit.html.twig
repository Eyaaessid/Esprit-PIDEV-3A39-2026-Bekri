<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modifier la question — Bekri</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --dark:       #1a2332;
            --dark2:      #1e3a5f;
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --light:      #f8fafc;
            --white:      #ffffff;
            --gray:       #64748b;
            --sidebar-w:  260px;
            --shadow-sm:  0 2px 12px rgba(0,0,0,0.06);
            --shadow:     0 8px 30px rgba(0,0,0,0.10);
            --radius:     16px;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior:smooth; }
        body { font-family:'Inter',sans-serif; background:var(--light); color:var(--dark); display:flex; min-height:100vh; }

        /* ── SIDEBAR ── */
        .sidebar { width:var(--sidebar-w); background:var(--dark); min-height:100vh; position:fixed; top:0; left:0; display:flex; flex-direction:column; z-index:100; }
        .sidebar-logo { padding:28px 24px 20px; display:flex; align-items:center; gap:10px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-logo-text { font-size:20px; font-weight:800; background:linear-gradient(135deg,var(--teal),#a78bfa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .sidebar-user { padding:20px 24px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-avatar { width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:16px; flex-shrink:0; overflow:hidden; position:relative; }
        .sidebar-avatar img { width:100%; height:100%; object-fit:cover; }
        .avatar-dot { width:10px; height:10px; background:#22c55e; border-radius:50%; border:2px solid var(--dark); position:absolute; bottom:1px; right:1px; }
        .sidebar-user-name { font-size:14px; font-weight:600; color:white; }
        .sidebar-user-role { font-size:11px; color:rgba(255,255,255,0.4); margin-top:2px; }
        .sidebar-nav { flex:1; padding:16px 0; overflow-y:auto; }
        .nav-section-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:rgba(255,255,255,0.25); padding:12px 24px 6px; }
        .nav-item { display:flex; align-items:center; gap:12px; padding:11px 24px; color:rgba(255,255,255,0.6); text-decoration:none; font-size:14px; font-weight:500; transition:all 0.2s; border-left:3px solid transparent; }
        .nav-item:hover { color:white; background:rgba(255,255,255,0.05); }
        .nav-item.active { color:var(--teal); background:rgba(32,178,170,0.1); border-left-color:var(--teal); }
        .nav-item i { width:20px; text-align:center; font-size:16px; }
        .sidebar-footer { padding:16px 0; border-top:1px solid rgba(255,255,255,0.07); }

        /* ── MAIN ── */
        .main { margin-left:var(--sidebar-w); flex:1; display:flex; flex-direction:column; min-height:100vh; }

        /* ── TOPBAR ── */
        .topbar { background:white; padding:0 32px; height:68px; display:flex; align-items:center; justify-content:space-between; box-shadow:var(--shadow-sm); position:sticky; top:0; z-index:50; }
        .topbar-title { font-size:18px; font-weight:700; color:var(--dark); }
        .topbar-sub { font-size:13px; color:var(--gray); margin-top:1px; }
        .topbar-right { display:flex; align-items:center; gap:12px; }
        .topbar-icon-btn { width:38px; height:38px; border-radius:10px; background:var(--light); border:1px solid #e2e8f0; display:flex; align-items:center; justify-content:center; color:var(--gray); font-size:16px; text-decoration:none; transition:all 0.2s; }
        .topbar-icon-btn:hover { background:var(--teal-light); color:var(--teal-dark); border-color:var(--teal); }
        .topbar-avatar { width:38px; height:38px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:14px; text-decoration:none; overflow:hidden; flex-shrink:0; }
        .topbar-avatar img { width:100%; height:100%; object-fit:cover; }

        /* ── PAGE HEADER ── */
        .page-header { background:linear-gradient(135deg,var(--dark) 0%,#1e3a5f 60%,#0d9488 100%); padding:36px 40px 28px; position:relative; overflow:hidden; }
        .page-header::before { content:''; position:absolute; top:-60px; right:-60px; width:260px; height:260px; background:rgba(32,178,170,0.08); border-radius:50%; }
        .page-header::after { content:''; position:absolute; bottom:-40px; right:200px; width:160px; height:160px; background:rgba(102,126,234,0.06); border-radius:50%; }
        .page-header-inner { max-width:1200px; margin:0 auto; position:relative; z-index:1; }
        .page-header-tag { display:inline-flex; align-items:center; gap:6px; background:rgba(32,178,170,0.2); border:1px solid rgba(32,178,170,0.35); color:#7fffd4; padding:4px 12px; border-radius:50px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:10px; }
        .page-header-title { font-size:26px; font-weight:800; color:white; margin-bottom:4px; }
        .page-header-sub { font-size:14px; color:rgba(255,255,255,0.55); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; max-width:600px; }

        /* ── CONTENT ── */
        .content { flex:1; padding:32px 40px; }

        /* ── BACK LINK ── */
        .back-link { display:inline-flex; align-items:center; gap:6px; font-size:13px; font-weight:600; color:var(--gray); text-decoration:none; margin-bottom:24px; transition:color 0.2s; }
        .back-link:hover { color:var(--teal-dark); }

        /* ── FORM CARD ── */
        .form-card { background:white; border-radius:var(--radius); box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; overflow:hidden; max-width:860px; }
        .form-card-header { padding:20px 28px; border-bottom:1px solid #f1f5f9; display:flex; align-items:center; gap:12px; }
        .form-card-icon { width:40px; height:40px; border-radius:12px; background:#fff7ed; display:flex; align-items:center; justify-content:center; font-size:18px; color:#ea580c; flex-shrink:0; }
        .form-card-title { font-size:15px; font-weight:700; color:var(--dark); }
        .form-card-sub { font-size:12px; color:var(--gray); margin-top:2px; }
        .form-card-body { padding:28px; }

        /* ── FORM ELEMENTS ── */
        .form-group { margin-bottom:22px; }
        .form-group:last-child { margin-bottom:0; }
        .form-label { display:block; font-size:13px; font-weight:600; color:var(--dark); margin-bottom:7px; }
        .form-label span { font-weight:400; color:var(--gray); }
        .form-control { width:100%; padding:10px 14px; border:1px solid #e2e8f0; border-radius:10px; font-size:14px; font-family:'Inter',sans-serif; color:var(--dark); background:white; outline:none; transition:all 0.2s; }
        .form-control:focus { border-color:var(--teal); box-shadow:0 0 0 3px rgba(32,178,170,0.1); }
        .form-control.is-invalid { border-color:#f87171; background:#fff5f5; }
        .form-control.is-invalid:focus { box-shadow:0 0 0 3px rgba(248,113,113,0.15); }
        select.form-control { cursor:pointer; }

        /* ── OPTIONS GRID ── */
        .options-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; }
        .option-item { position:relative; }
        .option-badge { position:absolute; top:-10px; left:14px; background:var(--teal-dark); color:white; font-size:10px; font-weight:700; padding:2px 8px; border-radius:50px; letter-spacing:0.3px; }

        /* ── ERROR ── */
        .field-error { display:flex; align-items:center; gap:5px; font-size:12px; color:#dc2626; margin-top:5px; }
        .error-summary { display:flex; align-items:flex-start; gap:12px; padding:14px 16px; background:#fff5f5; border:1px solid #fecaca; border-radius:12px; margin-bottom:22px; }
        .error-summary i { color:#dc2626; font-size:16px; margin-top:1px; flex-shrink:0; }
        .error-summary p { font-size:13px; font-weight:600; color:#dc2626; margin-bottom:4px; }
        .error-summary ul { font-size:12px; color:#dc2626; padding-left:16px; }
        .error-summary ul li { margin-bottom:2px; }

        /* ── DIVIDER ── */
        .section-divider { border:none; border-top:1px solid #f1f5f9; margin:24px 0; }

        /* ── FORM ACTIONS ── */
        .form-actions { display:flex; align-items:center; justify-content:flex-end; gap:10px; padding-top:4px; }
        .btn { display:inline-flex; align-items:center; gap:6px; padding:10px 20px; border-radius:10px; font-size:14px; font-weight:600; border:none; cursor:pointer; text-decoration:none; transition:all 0.2s; font-family:'Inter',sans-serif; }
        .btn-teal { background:var(--teal-dark); color:white; }
        .btn-teal:hover { background:var(--teal); }
        .btn-cancel { background:var(--light); color:var(--dark); border:1px solid #e2e8f0; }
        .btn-cancel:hover { background:#f1f5f9; }

        @media (max-width:768px) { .main { margin-left:0; } .content { padding:20px 16px; } .options-grid { grid-template-columns:1fr; } .page-header { padding:24px 20px; } }
        @media (max-width:640px) { .form-actions { flex-direction:column-reverse; } .btn { width:100%; justify-content:center; } }
    </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
    <div class="sidebar-logo">
        <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'" style="height:36px;">
        <span class="sidebar-logo-text">Bekri Admin</span>
    </div>
    <div class="sidebar-user">
        <div class="sidebar-avatar">
            {% if app.user and app.user.avatar %}
                <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
            {% else %}
                {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
            {% endif %}
            <div class="avatar-dot"></div>
        </div>
        <div>
            <div class="sidebar-user-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
            <div class="sidebar-user-role">{{ app.user.role.getLabel() }}</div>
        </div>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-section-label">Principal</div>
        <a href="{{ path('admin_dashboard') }}" class="nav-item"><i class="bi bi-grid-fill"></i> Dashboard</a>
        <a href="{{ path('admin_profile') }}" class="nav-item"><i class="bi bi-person-fill"></i> Mon profil</a>

        <div class="nav-section-label">Gestion</div>
        <a href="{{ path('admin_users_list') }}" class="nav-item"><i class="bi bi-people-fill"></i> Utilisateurs</a>
        <a href="{{ path('admin_reactivation_requests') }}" class="nav-item"><i class="bi bi-person-check-fill"></i> Réactivations</a>
        <a href="{{ path('admin_question_index') }}" class="nav-item active"><i class="bi bi-clipboard2-pulse-fill"></i> Questions de suivi</a>
        <a href="{{ path('admin_post_list') }}" class="nav-item"><i class="bi bi-newspaper"></i> Publications</a>
        <a href="{{ path('evenements_admin_supervision') }}" class="nav-item"><i class="bi bi-calendar-event-fill"></i> Événements</a>

        <div class="nav-section-label">Compte</div>
        <a href="{{ path('app_login') }}" class="nav-item"><i class="bi bi-box-arrow-in-right"></i> Connexion</a>
        <a href="{{ path('app_register') }}" class="nav-item"><i class="bi bi-person-plus-fill"></i> Inscription</a>
    </nav>
    <div class="sidebar-footer">
        <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;">
            <i class="bi bi-box-arrow-left"></i> Se déconnecter
        </a>
    </div>
</aside>

<!-- MAIN -->
<div class="main">

    <!-- TOPBAR -->
    <header class="topbar">
        <div>
            <div class="topbar-title">Modifier la question</div>
            <div class="topbar-sub">Questions de suivi</div>
        </div>
        <div class="topbar-right">
            <a href="{{ path('admin_question_index') }}" class="topbar-icon-btn" title="Retour à la liste"><i class="bi bi-arrow-left"></i></a>
            <a href="{{ path('admin_profile') }}" class="topbar-avatar">
                {% if app.user and app.user.avatar %}
                    <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
                {% else %}
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                {% endif %}
            </a>
        </div>
    </header>

    <!-- PAGE HEADER -->
    <div class="page-header">
        <div class="page-header-inner">
            <div class="page-header-tag"><i class="bi bi-pencil-fill"></i> Édition</div>
            <div class="page-header-title">Modifier la question</div>
            <div class="page-header-sub">{{ question.texte }}</div>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="content">

        <a href="{{ path('admin_question_index') }}" class="back-link">
            <i class="bi bi-arrow-left"></i> Retour à la liste
        </a>

        <div class="form-card">
            <div class="form-card-header">
                <div class="form-card-icon"><i class="bi bi-pencil-square"></i></div>
                <div>
                    <div class="form-card-title">Modifier les détails</div>
                    <div class="form-card-sub">Modifiez les champs ci-dessous puis enregistrez</div>
                </div>
            </div>
            <div class="form-card-body">

                {# novalidate disables HTML5 browser validation — Assert handles everything server-side #}
                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                {# Global error summary #}
                {% if not form.vars.valid and form.vars.submitted %}
                <div class="error-summary">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <div>
                        <p>Veuillez corriger les erreurs suivantes :</p>
                        <ul>
                            {% for child in form %}
                                {% for error in child.vars.errors %}
                                    <li>{{ error.message }}</li>
                                {% endfor %}
                            {% endfor %}
                        </ul>
                    </div>
                </div>
                {% endif %}

                <!-- Texte de la question -->
                <div class="form-group">
                    {{ form_label(form.texte, 'Texte de la question', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.texte, {'attr': {
                        'class': 'form-control' ~ (form.texte.vars.errors|length > 0 ? ' is-invalid' : '')
                    }}) }}
                    {% for error in form.texte.vars.errors %}
                        <div class="field-error"><i class="bi bi-exclamation-circle"></i> {{ error.message }}</div>
                    {% endfor %}
                </div>

                <!-- Catégorie -->
                <div class="form-group">
                    {{ form_label(form.category, 'Catégorie', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.category, {'attr': {
                        'class': 'form-control' ~ (form.category.vars.errors|length > 0 ? ' is-invalid' : '')
                    }}) }}
                    {% for error in form.category.vars.errors %}
                        <div class="field-error"><i class="bi bi-exclamation-circle"></i> {{ error.message }}</div>
                    {% endfor %}
                </div>

                <hr class="section-divider">

                <!-- Les 3 options -->
                <div class="form-group">
                    <div class="form-label">Options de réponse <span>(3 options requises)</span></div>
                    <div class="options-grid">
                        <div class="option-item">
                            <span class="option-badge">Option 1</span>
                            {{ form_widget(form.option1, {'attr': {
                                'class': 'form-control' ~ (form.option1.vars.errors|length > 0 ? ' is-invalid' : '')
                            }}) }}
                            {% for error in form.option1.vars.errors %}
                                <div class="field-error"><i class="bi bi-exclamation-circle"></i> {{ error.message }}</div>
                            {% endfor %}
                        </div>
                        <div class="option-item">
                            <span class="option-badge">Option 2</span>
                            {{ form_widget(form.option2, {'attr': {
                                'class': 'form-control' ~ (form.option2.vars.errors|length > 0 ? ' is-invalid' : '')
                            }}) }}
                            {% for error in form.option2.vars.errors %}
                                <div class="field-error"><i class="bi bi-exclamation-circle"></i> {{ error.message }}</div>
                            {% endfor %}
                        </div>
                        <div class="option-item">
                            <span class="option-badge">Option 3</span>
                            {{ form_widget(form.option3, {'attr': {
                                'class': 'form-control' ~ (form.option3.vars.errors|length > 0 ? ' is-invalid' : '')
                            }}) }}
                            {% for error in form.option3.vars.errors %}
                                <div class="field-error"><i class="bi bi-exclamation-circle"></i> {{ error.message }}</div>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <hr class="section-divider">

                <!-- Actions -->
                <div class="form-actions">
                    <a href="{{ path('admin_question_index') }}" class="btn btn-cancel">Annuler</a>
                    <button type="submit" class="btn btn-teal">
                        <i class="bi bi-floppy-fill"></i> Enregistrer les modifications
                    </button>
                </div>

                {{ form_end(form) }}
            </div>
        </div>

    </div>
</div>

</body>
</html>
