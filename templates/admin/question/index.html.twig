<!DOCTYPE html>
<html lang="fr" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Questions d'évaluation</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                        }
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="h-full bg-gray-50 antialiased">

<div class="min-h-screen flex flex-col">

    <!-- Header -->
    <header class="bg-white border-b border-gray-200 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex items-center justify-between">
            <h1 class="text-2xl font-bold text-gray-900">Questions d'évaluation</h1>
            <a href="{{ path('admin_question_new') }}"
               class="inline-flex items-center px-5 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-700 shadow-sm transition">
                <i class="fas fa-plus mr-2"></i> Nouvelle question
            </a>
        </div>
    </header>

    <!-- Main -->
    <main class="flex-1 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

        <!-- Recherche -->
        <div class="mb-6">
            <form method="get" class="flex items-center gap-4">
                <input type="text" name="search" value="{{ search }}" placeholder="Rechercher par texte ou catégorie..." 
                       class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                <button type="submit" class="px-6 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700">
                    <i class="fas fa-search mr-2"></i> Rechercher
                </button>
                {% if search %}
                    <a href="{{ path('admin_question_index') }}" class="text-gray-600 hover:text-gray-800">
                        <i class="fas fa-times mr-1"></i> Effacer
                    </a>
                {% endif %}
            </form>
        </div>

        {% if questions is empty %}
            <div class="bg-white rounded-xl shadow p-12 text-center">
                <h2 class="text-2xl font-semibold mb-4">Aucune question trouvée</h2>
                <a href="{{ path('admin_question_new') }}" class="text-primary-600 hover:underline">
                    Créer une nouvelle question
                </a>
            </div>
        {% else %}
            <div class="overflow-x-auto bg-white rounded-xl shadow border border-gray-200">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                <a href="{{ path('admin_question_index', {'sort': 'texte', 'direction': sort == 'texte' and direction == 'asc' ? 'desc' : 'asc', 'search': search}) }}">
                                    Question
                                    {% if sort == 'texte' %}
                                        <i class="fas fa-sort-{{ direction == 'asc' ? 'up' : 'down' }} ml-1"></i>
                                    {% else %}
                                        <i class="fas fa-sort ml-1"></i>
                                    {% endif %}
                                </a>
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                <a href="{{ path('admin_question_index', {'sort': 'category', 'direction': sort == 'category' and direction == 'asc' ? 'desc' : 'asc', 'search': search}) }}">
                                    Catégorie
                                    {% if sort == 'category' %}
                                        <i class="fas fa-sort-{{ direction == 'asc' ? 'up' : 'down' }} ml-1"></i>
                                    {% else %}
                                        <i class="fas fa-sort ml-1"></i>
                                    {% endif %}
                                </a>
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Options
                            </th>
                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Actions
                            </th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        {% for question in questions %}
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4">
                                    <div class="text-sm font-medium text-gray-900 line-clamp-2">{{ question.texte }}</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-2 py-1 text-xs font-medium rounded-full bg-teal-50 text-teal-700">
                                        {{ question.category|capitalize }}
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex flex-wrap gap-2">
                                        {% if question.option1 %}<span class="px-2.5 py-1 bg-indigo-50 text-indigo-700 text-xs rounded">{{ question.option1 }}</span>{% endif %}
                                        {% if question.option2 %}<span class="px-2.5 py-1 bg-indigo-50 text-indigo-700 text-xs rounded">{{ question.option2 }}</span>{% endif %}
                                        {% if question.option3 %}<span class="px-2.5 py-1 bg-indigo-50 text-indigo-700 text-xs rounded">{{ question.option3 }}</span>{% endif %}
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-right text-sm font-medium">
                                    <a href="{{ path('admin_question_edit', {id: question.id}) }}" class="text-primary-600 hover:text-primary-900 mr-3">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" action="{{ path('admin_question_delete', {id: question.id}) }}" class="inline"
                                          onsubmit="return confirm('Confirmer la suppression ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ question.id) }}">
                                        <button type="submit" class="text-red-600 hover:text-red-900">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </main>
</div>

</body>
</html>