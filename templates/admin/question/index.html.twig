<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Questions d'évaluation — Bekri</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --dark:       #1a2332;
            --dark2:      #1e3a5f;
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --light:      #f8fafc;
            --white:      #ffffff;
            --gray:       #64748b;
            --sidebar-w:  260px;
            --shadow-sm:  0 2px 12px rgba(0,0,0,0.06);
            --shadow:     0 8px 30px rgba(0,0,0,0.10);
            --radius:     16px;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior:smooth; }
        body { font-family:'Inter',sans-serif; background:var(--light); color:var(--dark); display:flex; min-height:100vh; }

        /* ── SIDEBAR ── */
        .sidebar { width:var(--sidebar-w); background:var(--dark); min-height:100vh; max-height:100vh; position:fixed; top:0; left:0; display:flex; flex-direction:column; z-index:100; overflow:hidden; }
        .sidebar-logo { padding:28px 24px 20px; display:flex; align-items:center; gap:10px; border-bottom:1px solid rgba(255,255,255,0.07); flex-shrink:0; }
        .sidebar-logo-text { font-size:20px; font-weight:800; background:linear-gradient(135deg,var(--teal),#a78bfa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .sidebar-user { padding:20px 24px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-avatar { width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:16px; flex-shrink:0; overflow:hidden; position:relative; }
        .sidebar-avatar img { width:100%; height:100%; object-fit:cover; }
        .avatar-dot { width:10px; height:10px; background:#22c55e; border-radius:50%; border:2px solid var(--dark); position:absolute; bottom:1px; right:1px; }
        .sidebar-user-name { font-size:14px; font-weight:600; color:white; }
        .sidebar-user-role { font-size:11px; color:rgba(255,255,255,0.4); margin-top:2px; }
        .sidebar-nav { flex:1; padding:16px 0; overflow-y:auto; min-height:0; }
        .sidebar-nav::-webkit-scrollbar { width:5px; }
        .sidebar-nav::-webkit-scrollbar-track { background:transparent; }
        .sidebar-nav::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.3); border-radius:10px; }
        .nav-section-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:rgba(255,255,255,0.25); padding:12px 24px 6px; }
        .nav-item { display:flex; align-items:center; gap:12px; padding:11px 24px; color:rgba(255,255,255,0.6); text-decoration:none; font-size:14px; font-weight:500; transition:all 0.2s; border-left:3px solid transparent; }
        .nav-item:hover { color:white; background:rgba(255,255,255,0.05); }
        .nav-item.active { color:var(--teal); background:rgba(32,178,170,0.1); border-left-color:var(--teal); }
        .nav-item i { width:20px; text-align:center; font-size:16px; }
        .sidebar-footer { padding:16px 0; border-top:1px solid rgba(255,255,255,0.07); flex-shrink:0; margin-top:auto; }

        /* ── MAIN ── */
        .main { margin-left:var(--sidebar-w); flex:1; display:flex; flex-direction:column; min-height:100vh; }

        /* ── TOPBAR ── */
        .topbar { background:white; padding:0 32px; height:68px; display:flex; align-items:center; justify-content:space-between; box-shadow:var(--shadow-sm); position:sticky; top:0; z-index:50; }
        .topbar-title { font-size:18px; font-weight:700; color:var(--dark); }
        .topbar-sub { font-size:13px; color:var(--gray); margin-top:1px; }
        .topbar-right { display:flex; align-items:center; gap:12px; }
        .topbar-icon-btn { width:38px; height:38px; border-radius:10px; background:var(--light); border:1px solid #e2e8f0; display:flex; align-items:center; justify-content:center; color:var(--gray); font-size:16px; text-decoration:none; transition:all 0.2s; }
        .topbar-icon-btn:hover { background:var(--teal-light); color:var(--teal-dark); border-color:var(--teal); }
        .topbar-avatar { width:38px; height:38px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:14px; text-decoration:none; overflow:hidden; flex-shrink:0; }
        .topbar-avatar img { width:100%; height:100%; object-fit:cover; }

        /* ── PAGE HEADER ── */
        .page-header { background:linear-gradient(135deg,var(--dark) 0%,#1e3a5f 60%,#0d9488 100%); padding:36px 40px 28px; position:relative; overflow:hidden; }
        .page-header::before { content:''; position:absolute; top:-60px; right:-60px; width:260px; height:260px; background:rgba(32,178,170,0.08); border-radius:50%; }
        .page-header::after { content:''; position:absolute; bottom:-40px; right:200px; width:160px; height:160px; background:rgba(102,126,234,0.06); border-radius:50%; }
        .page-header-inner { max-width:1200px; margin:0 auto; position:relative; z-index:1; display:flex; align-items:flex-end; justify-content:space-between; gap:16px; flex-wrap:wrap; }
        .page-header-tag { display:inline-flex; align-items:center; gap:6px; background:rgba(32,178,170,0.2); border:1px solid rgba(32,178,170,0.35); color:#7fffd4; padding:4px 12px; border-radius:50px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:10px; }
        .page-header-title { font-size:26px; font-weight:800; color:white; margin-bottom:4px; }
        .page-header-sub { font-size:14px; color:rgba(255,255,255,0.55); }
        .btn-header { display:inline-flex; align-items:center; gap:6px; padding:10px 18px; border-radius:10px; font-size:13px; font-weight:600; background:rgba(255,255,255,0.12); color:white; border:1px solid rgba(255,255,255,0.25); text-decoration:none; transition:all 0.2s; cursor:pointer; }
        .btn-header:hover { background:rgba(255,255,255,0.22); color:white; }

        /* ── CONTENT ── */
        .content { flex:1; padding:32px 40px; max-width:1280px; margin:0 auto; width:100%; }

        /* ── SEARCH ── */
        .search-bar { display:flex; gap:10px; margin-bottom:24px; align-items:center; }
        .search-wrap { flex:1; position:relative; }
        .search-wrap i { position:absolute; left:14px; top:50%; transform:translateY(-50%); color:var(--gray); font-size:14px; pointer-events:none; }
        .search-input { width:100%; padding:10px 14px 10px 40px; border:1px solid #e2e8f0; border-radius:10px; font-size:14px; font-family:'Inter',sans-serif; color:var(--dark); background:white; outline:none; transition:all 0.2s; box-shadow:var(--shadow-sm); }
        .search-input:focus { border-color:var(--teal); box-shadow:0 0 0 3px rgba(32,178,170,0.1); }
        .btn { display:inline-flex; align-items:center; gap:6px; padding:10px 18px; border-radius:10px; font-size:13px; font-weight:600; border:none; cursor:pointer; text-decoration:none; transition:all 0.2s; font-family:'Inter',sans-serif; }
        .btn-teal { background:var(--teal-dark); color:white; }
        .btn-teal:hover { background:var(--teal); }
        .btn-ghost { background:none; color:var(--gray); border:1px solid #e2e8f0; }
        .btn-ghost:hover { color:var(--dark); border-color:#cbd5e1; }

        /* ── CARD ── */
        .card { background:white; border-radius:var(--radius); box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; overflow:hidden; }
        .card-header { padding:20px 24px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid #f1f5f9; }
        .card-title { font-size:15px; font-weight:700; color:var(--dark); }
        .card-sub { font-size:12px; color:var(--gray); margin-top:2px; }

        /* ── TABLE ── */
        .table-wrap { overflow-x:auto; }
        table { width:100%; border-collapse:collapse; }
        thead th { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; color:var(--gray); padding:12px 20px; background:#f8fafc; border-bottom:1px solid #f1f5f9; text-align:left; white-space:nowrap; }
        thead th a { color:var(--gray); text-decoration:none; display:inline-flex; align-items:center; gap:4px; transition:color 0.2s; }
        thead th a:hover { color:var(--dark); }
        tbody td { padding:16px 20px; font-size:14px; color:var(--dark); border-bottom:1px solid #f8fafc; vertical-align:middle; }
        tbody tr:last-child td { border-bottom:none; }
        tbody tr:hover td { background:#fafbfc; }

        /* ── BADGES ── */
        .badge-category { display:inline-flex; align-items:center; padding:4px 10px; border-radius:50px; font-size:11px; font-weight:700; background:var(--teal-light); color:var(--teal-dark); }
        .badge-option { display:inline-flex; padding:3px 10px; border-radius:6px; font-size:12px; font-weight:500; background:#eef2ff; color:#4f46e5; }
        .options-wrap { display:flex; flex-wrap:wrap; gap:6px; }

        /* ── ROW ACTIONS ── */
        .action-group { display:flex; justify-content:flex-end; gap:6px; }
        .btn-icon { width:32px; height:32px; border-radius:8px; display:inline-flex; align-items:center; justify-content:center; font-size:14px; border:none; cursor:pointer; text-decoration:none; transition:all 0.2s; }
        .btn-icon.edit   { background:#eff6ff; color:#2563eb; }
        .btn-icon.edit:hover { background:#2563eb; color:white; }
        .btn-icon.delete { background:#fff1f2; color:#dc2626; }
        .btn-icon.delete:hover { background:#dc2626; color:white; }

        /* ── EMPTY STATE ── */
        .empty-state { text-align:center; padding:64px 20px; }
        .empty-icon { width:64px; height:64px; border-radius:20px; background:var(--light); border:1px solid #e2e8f0; display:flex; align-items:center; justify-content:center; font-size:26px; color:#cbd5e1; margin:0 auto 16px; }
        .empty-state h3 { font-size:16px; font-weight:700; margin-bottom:6px; }
        .empty-state p { font-size:14px; color:var(--gray); margin-bottom:20px; }

        @media (max-width:768px) { .main { margin-left:0; } .content { padding:20px 16px; } .page-header { padding:24px 20px; } }
    </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
    <div class="sidebar-logo">
        <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'" style="height:36px;">
        <span class="sidebar-logo-text">Bekri Admin</span>
    </div>
    <div class="sidebar-user">
        <div class="sidebar-avatar">
            {% if app.user and app.user.avatar %}
                <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
            {% else %}
                {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
            {% endif %}
            <div class="avatar-dot"></div>
        </div>
        <div>
            <div class="sidebar-user-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
            <div class="sidebar-user-role">{{ app.user.role.getLabel() }}</div>
        </div>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-section-label">Principal</div>
        <a href="{{ path('admin_dashboard') }}" class="nav-item"><i class="bi bi-grid-fill"></i> Dashboard</a>
        <a href="{{ path('admin_profile') }}" class="nav-item"><i class="bi bi-person-fill"></i> Mon profil</a>

        <div class="nav-section-label">Gestion</div>
        <a href="{{ path('admin_users_list') }}" class="nav-item"><i class="bi bi-people-fill"></i> Utilisateurs</a>
        <a href="{{ path('admin_reactivation_requests') }}" class="nav-item"><i class="bi bi-person-check-fill"></i> Réactivations</a>
        <a href="{{ path('admin_question_index') }}" class="nav-item active"><i class="bi bi-clipboard2-pulse-fill"></i> Questions de suivi</a>
        <a href="{{ path('admin_post_list') }}" class="nav-item"><i class="bi bi-newspaper"></i> Publications</a>
        <a href="{{ path('evenements_admin_supervision') }}" class="nav-item"><i class="bi bi-calendar-event-fill"></i> Événements</a>

        <div class="nav-section-label">Compte</div>
    </nav>
    <div class="sidebar-footer">
        <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;">
            <i class="bi bi-box-arrow-left"></i> Déconnexion
        </a>
    </div>
</aside>

<!-- MAIN -->
<div class="main">

    <!-- TOPBAR -->
    <header class="topbar">
        <div>
            <div class="topbar-title">Questions d'évaluation</div>
            <div class="topbar-sub">Gérez les questions de suivi des utilisateurs</div>
        </div>
        <div class="topbar-right">
            <a href="{{ path('admin_dashboard') }}" class="topbar-icon-btn" title="Dashboard"><i class="bi bi-grid"></i></a>
            <a href="{{ path('admin_users_list') }}" class="topbar-icon-btn" title="Utilisateurs"><i class="bi bi-people"></i></a>
            <a href="{{ path('admin_profile') }}" class="topbar-avatar">
                {% if app.user and app.user.avatar %}
                    <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
                {% else %}
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                {% endif %}
            </a>
        </div>
    </header>

    <!-- PAGE HEADER -->
    <div class="page-header">
        <div class="page-header-inner">
            <div>
                <div class="page-header-tag"><i class="bi bi-clipboard2-pulse-fill"></i> Suivi</div>
                <div class="page-header-title">Questions d'évaluation</div>
                <div class="page-header-sub">Créez et gérez les questions posées aux utilisateurs</div>
            </div>
            <a href="{{ path('admin_question_new') }}" class="btn-header">
                <i class="bi bi-plus-lg"></i> Nouvelle question
            </a>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="content">

        <!-- Search -->
        <form method="get" class="search-bar">
            <div class="search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" name="search" value="{{ search }}" placeholder="Rechercher par texte ou catégorie..." class="search-input">
            </div>
            <button type="submit" class="btn btn-teal"><i class="bi bi-search"></i> Rechercher</button>
            {% if search %}
                <a href="{{ path('admin_question_index') }}" class="btn btn-ghost"><i class="bi bi-x-lg"></i> Effacer</a>
            {% endif %}
        </form>

        {% if questions is empty %}
            <div class="card">
                <div class="empty-state">
                    <div class="empty-icon"><i class="bi bi-clipboard2"></i></div>
                    <h3>Aucune question trouvée</h3>
                    <p>{% if search %}Aucun résultat pour « {{ search }} ».{% else %}Commencez par créer votre première question.{% endif %}</p>
                    <a href="{{ path('admin_question_new') }}" class="btn btn-teal"><i class="bi bi-plus-lg"></i> Créer une question</a>
                </div>
            </div>
        {% else %}
            <div class="card">
                <div class="card-header">
                    <div>
                        <div class="card-title">Liste des questions</div>
                        <div class="card-sub">{{ questions|length }} question(s){% if search %} pour « {{ search }} »{% endif %}</div>
                    </div>
                    <a href="{{ path('admin_question_new') }}" class="btn btn-teal"><i class="bi bi-plus-lg"></i> Ajouter</a>
                </div>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>
                                    <a href="{{ path('admin_question_index', {'sort': 'texte', 'direction': sort == 'texte' and direction == 'asc' ? 'desc' : 'asc', 'search': search}) }}">
                                        Question
                                        {% if sort == 'texte' %}<i class="bi bi-arrow-{{ direction == 'asc' ? 'up' : 'down' }}"></i>{% else %}<i class="bi bi-arrow-down-up" style="opacity:.4;"></i>{% endif %}
                                    </a>
                                </th>
                                <th>
                                    <a href="{{ path('admin_question_index', {'sort': 'category', 'direction': sort == 'category' and direction == 'asc' ? 'desc' : 'asc', 'search': search}) }}">
                                        Catégorie
                                        {% if sort == 'category' %}<i class="bi bi-arrow-{{ direction == 'asc' ? 'up' : 'down' }}"></i>{% else %}<i class="bi bi-arrow-down-up" style="opacity:.4;"></i>{% endif %}
                                    </a>
                                </th>
                                <th>Options</th>
                                <th style="text-align:right;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for question in questions %}
                                <tr>
                                    <td style="max-width:340px;">
                                        <div style="font-weight:600;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">{{ question.texte }}</div>
                                    </td>
                                    <td><span class="badge-category">{{ question.category|capitalize }}</span></td>
                                    <td>
                                        <div class="options-wrap">
                                            {% if question.option1 %}<span class="badge-option">{{ question.option1 }}</span>{% endif %}
                                            {% if question.option2 %}<span class="badge-option">{{ question.option2 }}</span>{% endif %}
                                            {% if question.option3 %}<span class="badge-option">{{ question.option3 }}</span>{% endif %}
                                        </div>
                                    </td>
                                    <td>
                                        <div class="action-group">
                                            <a href="{{ path('admin_question_edit', {id: question.id}) }}" class="btn-icon edit" title="Modifier"><i class="bi bi-pencil"></i></a>
                                            <form method="post" action="{{ path('admin_question_delete', {id: question.id}) }}" class="inline" onsubmit="return confirm('Confirmer la suppression ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ question.id) }}">
                                                <button type="submit" class="btn-icon delete" title="Supprimer"><i class="bi bi-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}

    </div>
</div>

</body>
</html>
