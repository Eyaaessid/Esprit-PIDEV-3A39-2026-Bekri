<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Détail utilisateur — Bekri</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="{{ asset('admin/css/bootstrap.min.css') }}" rel="stylesheet">
    <style>
        :root {
            --dark:       #1a2332;
            --dark2:      #1e3a5f;
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --light:      #f8fafc;
            --white:      #ffffff;
            --gray:       #64748b;
            --sidebar-w:  260px;
            --shadow-sm:  0 2px 12px rgba(0,0,0,0.06);
            --shadow:     0 8px 30px rgba(0,0,0,0.10);
            --radius:     16px;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior:smooth; }
        body { font-family:'Inter',sans-serif; background:var(--light); color:var(--dark); display:flex; min-height:100vh; }

        /* ── SIDEBAR ── */
        .sidebar { width:var(--sidebar-w); background:var(--dark); min-height:100vh; max-height:100vh; position:fixed; top:0; left:0; display:flex; flex-direction:column; z-index:100; overflow:hidden; }
        .sidebar-logo { padding:28px 24px 20px; display:flex; align-items:center; gap:10px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-logo-text { font-size:20px; font-weight:800; background:linear-gradient(135deg,var(--teal),#a78bfa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .sidebar-user { padding:20px 24px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-avatar { width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:16px; flex-shrink:0; overflow:hidden; position:relative; }
        .sidebar-avatar img { width:100%; height:100%; object-fit:cover; }
        .avatar-dot { width:10px; height:10px; background:#22c55e; border-radius:50%; border:2px solid var(--dark); position:absolute; bottom:1px; right:1px; }
        .sidebar-user-name { font-size:14px; font-weight:600; color:white; }
        .sidebar-user-role { font-size:11px; color:rgba(255,255,255,0.4); margin-top:2px; }
        .sidebar-nav { flex:1; padding:16px 0; overflow-y:auto; min-height:0; }
        .sidebar-nav::-webkit-scrollbar { width:5px; }
        .sidebar-nav::-webkit-scrollbar-track { background:transparent; }
        .sidebar-nav::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.3); border-radius:10px; }
        .nav-section-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:rgba(255,255,255,0.25); padding:12px 24px 6px; }
        .nav-item { display:flex; align-items:center; gap:12px; padding:11px 24px; color:rgba(255,255,255,0.6); text-decoration:none; font-size:14px; font-weight:500; transition:all 0.2s; border-left:3px solid transparent; }
        .nav-item:hover { color:white; background:rgba(255,255,255,0.05); }
        .nav-item.active { color:var(--teal); background:rgba(32,178,170,0.1); border-left-color:var(--teal); }
        .nav-item i { width:20px; text-align:center; font-size:16px; }
        .sidebar-footer { padding:16px 0; border-top:1px solid rgba(255,255,255,0.07); flex-shrink:0; margin-top:auto; }

        /* ── MAIN ── */
        .main { margin-left:var(--sidebar-w); flex:1; display:flex; flex-direction:column; min-height:100vh; }

        /* ── TOPBAR ── */
        .topbar { background:white; padding:0 32px; height:68px; display:flex; align-items:center; justify-content:space-between; box-shadow:var(--shadow-sm); position:sticky; top:0; z-index:50; }
        .topbar-left { display:flex; align-items:center; gap:16px; }
        .topbar-title { font-size:18px; font-weight:700; color:var(--dark); }
        .topbar-sub { font-size:13px; color:var(--gray); margin-top:1px; }
        .topbar-right { display:flex; align-items:center; gap:12px; }
        .topbar-icon-btn { width:38px; height:38px; border-radius:10px; background:var(--light); border:1px solid #e2e8f0; display:flex; align-items:center; justify-content:center; color:var(--gray); font-size:16px; cursor:pointer; text-decoration:none; transition:all 0.2s; }
        .topbar-icon-btn:hover { background:var(--teal-light); color:var(--teal-dark); border-color:var(--teal); }
        .topbar-avatar { width:38px; height:38px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:14px; text-decoration:none; overflow:hidden; flex-shrink:0; }
        .topbar-avatar img { width:100%; height:100%; object-fit:cover; }

        /* ── PAGE HEADER ── */
        .page-header { background:linear-gradient(135deg,var(--dark) 0%,#1e3a5f 60%,#0d9488 100%); padding:36px 40px 28px; position:relative; overflow:hidden; }
        .page-header::before { content:''; position:absolute; top:-60px; right:-60px; width:260px; height:260px; background:rgba(32,178,170,0.08); border-radius:50%; }
        .page-header::after { content:''; position:absolute; bottom:-40px; right:200px; width:160px; height:160px; background:rgba(102,126,234,0.06); border-radius:50%; }
        .page-header-inner { max-width:1200px; margin:0 auto; position:relative; z-index:1; display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap; }
        .page-header-tag { display:inline-flex; align-items:center; gap:6px; background:rgba(32,178,170,0.2); border:1px solid rgba(32,178,170,0.35); color:#7fffd4; padding:4px 12px; border-radius:50px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:10px; }
        .page-header-title { font-size:26px; font-weight:800; color:white; margin-bottom:4px; }
        .page-header-sub { font-size:14px; color:rgba(255,255,255,0.55); }
        .btn-back { display:inline-flex; align-items:center; gap:8px; background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); color:white; padding:10px 18px; border-radius:10px; font-size:13px; font-weight:600; text-decoration:none; transition:all 0.2s; backdrop-filter:blur(4px); }
        .btn-back:hover { background:rgba(255,255,255,0.2); color:white; transform:translateX(-2px); }

        /* ── CONTENT ── */
        .content { flex:1; padding:32px 40px; max-width:1280px; margin:0 auto; width:100%; }

        /* ── CARDS ── */
        .card { background:white; border-radius:var(--radius); box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; overflow:hidden; margin-bottom:24px; }
        .card-header-bar { padding:20px 24px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid #f1f5f9; }
        .card-title { font-size:15px; font-weight:700; color:var(--dark); display:flex; align-items:center; gap:8px; }
        .card-title i { color:var(--teal-dark); font-size:16px; }
        .card-body { padding:24px; }

        /* ── PROFILE AVATAR ── */
        .profile-avatar-lg { width:120px; height:120px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:800; font-size:40px; overflow:hidden; border:4px solid var(--teal-light); margin:0 auto 16px; flex-shrink:0; }
        .profile-avatar-lg img { width:100%; height:100%; object-fit:cover; }

        /* ── ROLE BADGES ── */
        .role-badge { display:inline-flex; align-items:center; gap:4px; padding:4px 12px; border-radius:50px; font-size:11px; font-weight:700; }
        .role-badge.admin   { background:#fef3c7; color:#d97706; }
        .role-badge.coach   { background:var(--teal-light); color:var(--teal-dark); }
        .role-badge.user    { background:#f0f9ff; color:#0284c7; }

        /* ── STATUS BADGE ── */
        .status-badge { display:inline-flex; align-items:center; gap:6px; padding:4px 12px; border-radius:50px; font-size:12px; font-weight:600; }
        .status-badge.active   { background:#f0fdf4; color:#16a34a; }
        .status-badge.inactive { background:#fef2f2; color:#dc2626; }
        .status-dot { width:7px; height:7px; border-radius:50%; flex-shrink:0; }
        .status-dot.active   { background:#22c55e; }
        .status-dot.inactive { background:#ef4444; }

        /* ── INFO ROWS ── */
        .info-row { display:flex; align-items:flex-start; padding:14px 0; border-bottom:1px solid #f8fafc; }
        .info-row:last-child { border-bottom:none; }
        .info-label { width:180px; font-size:13px; font-weight:600; color:var(--gray); flex-shrink:0; display:flex; align-items:center; gap:6px; }
        .info-label i { font-size:14px; color:var(--teal-dark); }
        .info-value { font-size:14px; color:var(--dark); font-weight:500; }
        .info-value .sub { font-size:12px; color:var(--gray); margin-top:3px; }

        /* ── ALERT BOXES ── */
        .alert-box { padding:14px 16px; border-radius:10px; font-size:13px; font-weight:500; display:flex; align-items:flex-start; gap:10px; }
        .alert-box.warning { background:#fff7ed; color:#c2410c; border:1px solid #fed7aa; }
        .alert-box.danger  { background:#fef2f2; color:#991b1b; border:1px solid #fecaca; }
        .alert-box i { font-size:16px; flex-shrink:0; margin-top:1px; }

        /* ── BUTTONS ── */
        .btn-teal { background:linear-gradient(135deg,var(--teal),var(--teal-dark)); color:white; border:none; padding:10px 20px; border-radius:10px; font-size:14px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:8px; transition:all 0.2s; text-decoration:none; font-family:'Inter',sans-serif; }
        .btn-teal:hover { opacity:0.9; transform:translateY(-1px); box-shadow:0 4px 12px rgba(32,178,170,0.3); color:white; }
        .btn-green { background:#16a34a; color:white; border:none; padding:10px 20px; border-radius:10px; font-size:14px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:8px; transition:all 0.2s; font-family:'Inter',sans-serif; }
        .btn-green:hover { background:#15803d; transform:translateY(-1px); box-shadow:0 4px 12px rgba(22,163,74,0.3); color:white; }
        .btn-red { background:#ef4444; color:white; border:none; padding:10px 20px; border-radius:10px; font-size:14px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:8px; transition:all 0.2s; font-family:'Inter',sans-serif; }
        .btn-red:hover { background:#dc2626; transform:translateY(-1px); box-shadow:0 4px 12px rgba(239,68,68,0.3); }
        .btn-outline { background:white; color:var(--gray); border:1.5px solid #e2e8f0; padding:10px 20px; border-radius:10px; font-size:14px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:8px; transition:all 0.2s; font-family:'Inter',sans-serif; }
        .btn-outline:hover { border-color:var(--teal); color:var(--teal-dark); background:var(--teal-light); }

        /* ── MODAL ── */
        .modal-content { border-radius:var(--radius); border:none; box-shadow:var(--shadow); font-family:'Inter',sans-serif; }
        .modal-header { border-bottom:1px solid #f1f5f9; padding:20px 24px; }
        .modal-title { font-size:16px; font-weight:700; color:var(--dark); display:flex; align-items:center; gap:8px; }
        .modal-body { padding:24px; }
        .modal-footer { border-top:1px solid #f1f5f9; padding:16px 24px; gap:10px; }

        /* ── RESPONSIVE ── */
        @media (max-width:1024px) { .two-col { grid-template-columns:1fr; } }
        @media (max-width:768px) { .main { margin-left:0; } .content { padding:20px 16px; } .page-header { padding:24px 20px; } }
    </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
    <div class="sidebar-logo">
        <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'" style="height:36px;">
        <span class="sidebar-logo-text">Bekri Admin</span>
    </div>
    <div class="sidebar-user">
        <div class="sidebar-avatar">
            {% if app.user and app.user.avatar %}
                <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
            {% else %}
                {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
            {% endif %}
            <div class="avatar-dot"></div>
        </div>
        <div>
            <div class="sidebar-user-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
            <div class="sidebar-user-role">{{ app.user.role.getLabel() }}</div>
        </div>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-section-label">Principal</div>
        <a href="{{ path('admin_dashboard') }}" class="nav-item"><i class="bi bi-grid-fill"></i> Dashboard</a>
        <a href="{{ path('admin_profile') }}" class="nav-item"><i class="bi bi-person-fill"></i> Mon profil</a>

        <div class="nav-section-label">Gestion</div>
        <a href="{{ path('admin_users_list') }}" class="nav-item active"><i class="bi bi-people-fill"></i> Utilisateurs</a>
        <a href="{{ path('admin_question_index') }}" class="nav-item"><i class="bi bi-clipboard2-pulse-fill"></i> Questions de suivi</a>
        <a href="{{ path('admin_post_list') }}" class="nav-item"><i class="bi bi-newspaper"></i> Publications</a>
        <a href="{{ path('evenements_admin_supervision') }}" class="nav-item"><i class="bi bi-calendar-event-fill"></i> Événements</a>

        <div class="nav-section-label">Compte</div>
    </nav>
    <div class="sidebar-footer">
        <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;">
            <i class="bi bi-box-arrow-left"></i> Déconnexion
        </a>
    </div>
</aside>

<!-- MAIN -->
<div class="main">

    <!-- TOPBAR -->
    <header class="topbar">
        <div class="topbar-left">
            <div>
                <div class="topbar-title">Détail de l'utilisateur</div>
                <div class="topbar-sub">{{ user.prenom }} {{ user.nom }}</div>
            </div>
        </div>
        <div class="topbar-right">
            <a href="{{ path('admin_users_list') }}" class="topbar-icon-btn" title="Utilisateurs">
                <i class="bi bi-people"></i>
            </a>
            <a href="{{ path('admin_profile') }}" class="topbar-avatar">
                {% if app.user and app.user.avatar %}
                    <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
                {% else %}
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                {% endif %}
            </a>
        </div>
    </header>

    <!-- PAGE HEADER -->
    <div class="page-header">
        <div class="page-header-inner">
            <div>
                <div class="page-header-tag"><i class="bi bi-person-badge-fill"></i> Fiche utilisateur</div>
                <div class="page-header-title">{{ user.prenom }} {{ user.nom }}</div>
                <div class="page-header-sub">{{ user.email }}</div>
            </div>
            <a href="{{ path('admin_users_list') }}" class="btn-back">
                <i class="bi bi-arrow-left"></i> Retour à la liste
            </a>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="content">

        <div style="display:grid; grid-template-columns:300px 1fr; gap:24px; align-items:start;" class="two-col">

            <!-- LEFT: Avatar Card -->
            <div>
                <div class="card">
                    <div class="card-body" style="text-align:center; padding:32px 20px;">
                        <div class="profile-avatar-lg">
                            {% if user.avatar %}
                                <img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" alt="{{ user.prenom }}">
                            {% else %}
                                {{ user.prenom|first|upper }}{{ user.nom|first|upper }}
                            {% endif %}
                        </div>
                        <div style="font-size:18px; font-weight:700; color:var(--dark); margin-bottom:4px;">
                            {{ user.prenom }} {{ user.nom }}
                        </div>
                        <div style="font-size:13px; color:var(--gray); margin-bottom:14px;">{{ user.email }}</div>

                        {# Role badge #}
                        {% set roleVal = user.role.value ?? user.role %}
                        {% if roleVal == 'admin' %}
                            <span class="role-badge admin"><i class="bi bi-shield-fill-check"></i> Administrateur</span>
                        {% elseif roleVal == 'coach' %}
                            <span class="role-badge coach"><i class="bi bi-person-workspace"></i> Coach</span>
                        {% else %}
                            <span class="role-badge user"><i class="bi bi-person-fill"></i> Utilisateur</span>
                        {% endif %}

                        <div style="margin-top:10px;">
                            {% set statutVal = user.statut.value ?? user.statut %}
                            {% if statutVal == 'actif' or statutVal == 'active' %}
                                <span class="status-badge active">
                                    <span class="status-dot active"></span> Actif
                                </span>
                            {% else %}
                                <span class="status-badge inactive">
                                    <span class="status-dot inactive"></span> Inactif
                                </span>
                            {% endif %}
                        </div>

                        {# Reactivate button (card version) #}
                        {% if user.statut.value == 'inactif' and user.deactivatedBy == 'admin' and user.id != app.user.id %}
                        <div style="margin-top:20px;">
                            <form method="post" action="{{ path('admin_user_reactivate', {id: user.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('reactivate-user-' ~ user.id) }}">
                                <button type="submit" class="btn-green" style="width:100%; justify-content:center;">
                                    <i class="bi bi-person-check-fill"></i> Réactiver le compte
                                </button>
                            </form>
                            <p style="font-size:12px; color:var(--gray); margin-top:8px;">Ou modifiez l'utilisateur et changez le statut sur Actif.</p>
                        </div>
                        {% endif %}

                        {# Delete button (card version) #}
                        {% if user.id != app.user.id %}
                        <div style="margin-top:12px;">
                            <button type="button" class="btn-red" style="width:100%; justify-content:center;" data-bs-toggle="modal" data-bs-target="#deleteModal">
                                <i class="bi bi-trash3-fill"></i> Supprimer l'utilisateur
                            </button>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- RIGHT: Details -->
            <div>
                <!-- User Information -->
                <div class="card">
                    <div class="card-header-bar">
                        <div class="card-title"><i class="bi bi-person-lines-fill"></i> Informations utilisateur</div>
                    </div>
                    <div class="card-body">
                        <div class="info-row">
                            <div class="info-label"><i class="bi bi-person"></i> Prénom</div>
                            <div class="info-value">{{ user.prenom }}</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label"><i class="bi bi-person"></i> Nom</div>
                            <div class="info-value">{{ user.nom }}</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label"><i class="bi bi-envelope-fill"></i> Email</div>
                            <div class="info-value">{{ user.email }}</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label"><i class="bi bi-telephone-fill"></i> Téléphone</div>
                            <div class="info-value">
                                {% if user.telephone %}
                                    {{ user.telephone }}
                                {% else %}
                                    <span style="color:var(--gray); font-style:italic;">Non renseigné</span>
                                {% endif %}
                            </div>
                        </div>
                        <div class="info-row">
                            <div class="info-label"><i class="bi bi-cake2-fill"></i> Date de naissance</div>
                            <div class="info-value">
                                {% if user.dateNaissance %}
                                    {{ user.dateNaissance|date('d F Y') }}
                                {% else %}
                                    <span style="color:var(--gray); font-style:italic;">Non renseignée</span>
                                {% endif %}
                            </div>
                        </div>
                        <div class="info-row">
                            <div class="info-label"><i class="bi bi-shield-fill"></i> Rôle</div>
                            <div class="info-value">
                                {% set roleVal = user.role.value ?? user.role %}
                                {% if roleVal == 'admin' %}
                                    <span class="role-badge admin"><i class="bi bi-shield-fill-check"></i> Administrateur</span>
                                {% elseif roleVal == 'coach' %}
                                    <span class="role-badge coach"><i class="bi bi-person-workspace"></i> Coach</span>
                                {% else %}
                                    <span class="role-badge user"><i class="bi bi-person-fill"></i> Utilisateur</span>
                                {% endif %}
                            </div>
                        </div>
                        <div class="info-row">
                            <div class="info-label"><i class="bi bi-toggle-on"></i> Statut</div>
                            <div class="info-value">
                                {% set statutVal = user.statut.value ?? user.statut %}
                                {% if statutVal == 'actif' or statutVal == 'active' %}
                                    <span class="status-badge active"><span class="status-dot active"></span> Actif</span>
                                {% else %}
                                    <span class="status-badge inactive"><span class="status-dot inactive"></span> Inactif</span>
                                {% endif %}
                                {% if user.deactivatedAt %}
                                    <div class="sub" style="margin-top:6px; font-size:12px; color:var(--gray);">
                                        Désactivé le {{ user.deactivatedAt|date('d/m/Y') }}
                                        {% if user.deactivatedBy %} par {{ user.deactivatedBy }}{% endif %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                        <div class="info-row">
                            <div class="info-label"><i class="bi bi-calendar-plus-fill"></i> Compte créé le</div>
                            <div class="info-value">{{ user.createdAt|date('d F Y \\à H:i') }}</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label"><i class="bi bi-clock-history"></i> Dernière mise à jour</div>
                            <div class="info-value">
                                {% if user.updatedAt %}
                                    {{ user.updatedAt|date('d F Y \\à H:i') }}
                                {% else %}
                                    <span style="color:var(--gray); font-style:italic;">Jamais</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>

                {# Reactivation notice (right column) #}
                {% if user.statut.value == 'inactif' and user.deactivatedBy == 'admin' and user.id != app.user.id %}
                <div class="alert-box warning" style="margin-bottom:24px;">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <div>
                        <strong>Compte désactivé par un administrateur.</strong>
                        <div style="margin-top:4px; font-size:12px;">Vous pouvez réactiver ce compte via le bouton dans la carte de profil ou en modifiant le statut.</div>
                    </div>
                </div>
                {% endif %}

            </div>
        </div>
    </div>
    <!-- Content End -->

</div>
<!-- Main End -->

{# Delete Confirmation Modal #}
{% if user.id != app.user.id %}
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle-fill" style="color:#ef4444;"></i>
                    Confirmer la suppression
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert-box danger" style="margin-bottom:16px;">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>Cette action est <strong>irréversible</strong>. Toutes les données de cet utilisateur seront définitivement supprimées.</span>
                </div>
                <p style="font-size:14px; color:var(--dark);">
                    Êtes-vous sûr de vouloir supprimer l'utilisateur
                    <strong>{{ user.prenom }} {{ user.nom }}</strong> ?
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-outline" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Annuler
                </button>
                <form method="post" action="{{ path('admin_user_delete', {id: user.id}) }}" style="display:inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete-user-' ~ user.id) }}">
                    <button type="submit" class="btn-red">
                        <i class="bi bi-trash3-fill"></i> Supprimer définitivement
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endif %}

<script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="{{ asset('admin/js/main.js') }}"></script>
</body>
</html>