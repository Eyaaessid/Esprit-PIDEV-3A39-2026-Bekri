{% extends 'admin/base.html.twig' %}

{% block title %}Admin Dashboard - Posts & Comments Management{% endblock %}

{% block stylesheets %}
    <style>
        .action-buttons {
            white-space: nowrap;
        }
        .table-responsive {
            overflow-x: auto;
        }
        .badge-status {
            font-size: 0.85rem;
            padding: 0.35em 0.65em;
        }
        .text-truncate-content {
            max-width: 300px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
    </style>
{% endblock %}

{% block content %}
    <!-- Dashboard Header Start -->
    <div class="container-fluid pt-4 px-4">
        <div class="row g-4">
            <div class="col-sm-6 col-xl-3">
                <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">
                    <i class="fa fa-file-alt fa-3x text-primary"></i>
                    <div class="ms-3">
                        <p class="mb-2">Total Posts</p>
                        <h6 class="mb-0">{{ posts|length }}</h6>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">
                    <i class="fa fa-comments fa-3x text-primary"></i>
                    <div class="ms-3">
                        <p class="mb-2">Total Comments</p>
                        <h6 class="mb-0">{{ comments|length }}</h6>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">
                    <i class="fa fa-calendar fa-3x text-success"></i>
                    <div class="ms-3">
                        <p class="mb-2">Posts This Week</p>
                        <h6 class="mb-0">{{ posts|filter(p => p.createdAt|date('U') > "now"|date_modify('-7 days')|date('U'))|length }}</h6>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">
                    <i class="fa fa-heart fa-3x text-danger"></i>
                    <div class="ms-3">
                        <p class="mb-2">Total Likes</p>
                        <h6 class="mb-0">{{ posts|reduce((carry, p) => carry + p.likes|length, 0) }}</h6>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Dashboard Header End -->

    <!-- Posts Table Start -->
    <div class="container-fluid pt-4 px-4">
        <div class="bg-light text-center rounded p-4">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h6 class="mb-0">Posts Management</h6>
                <a href="{{ path('admin_post_create') }}" class="btn btn-sm btn-primary">
                    <i class="fa fa-plus me-2"></i>New Post
                </a>
            </div>
            <div class="table-responsive">
                <table class="table text-start align-middle table-bordered table-hover mb-0">
                    <thead>
                        <tr class="text-dark">
                            <th scope="col" style="width: 50px;">#</th>
                            <th scope="col">Title</th>
                            <th scope="col">Author</th>
                            <th scope="col" style="width: 120px;">Category</th>
                            <th scope="col" style="width: 100px;">Comments</th>
                            <th scope="col" style="width: 120px;">Created At</th>
                            <th scope="col" style="width: 80px;">Likes</th>
                            <th scope="col" style="width: 180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for post in posts %}
                        <tr>
                            <td>{{ post.id }}</td>
                            <td>
                                <div class="text-truncate-content" title="{{ post.titre }}">
                                    {{ post.titre }}
                                </div>
                            </td>
                            <td>{{ post.utilisateur.nom ?? 'Unknown' }}</td>
                            <td>{{ post.categorie ?? 'Uncategorized' }}</td>
                            <td>
                                <span class="badge bg-info">{{ post.commentaires|length }}</span>
                            </td>
                            <td>{{ post.createdAt|date('Y-m-d') }}</td>
                            <td>
                                <span class="badge bg-danger">{{ post.likes|length }}</span>
                            </td>
                            <td class="action-buttons">
                                <a href="{{ path('admin_post_view', {id: post.id}) }}" class="btn btn-sm btn-info" title="View">
                                    <i class="fa fa-eye"></i>
                                </a>
                                <a href="{{ path('admin_post_edit', {id: post.id}) }}" class="btn btn-sm btn-primary" title="Edit">
                                    <i class="fa fa-edit"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-danger" 
                                        onclick="deletePost({{ post.id }})" 
                                        title="Delete">
                                    <i class="fa fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="fa fa-inbox fa-3x mb-3 d-block"></i>
                                No posts found
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            
            <!-- Pagination -->
            {% if posts|length > 0 %}
            <div class="d-flex justify-content-between align-items-center mt-3">
                <div>
                    Showing {{ posts|length }} posts
                </div>
                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item disabled">
                            <a class="page-link" href="#">Previous</a>
                        </li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item"><a class="page-link" href="#">2</a></li>
                        <li class="page-item"><a class="page-link" href="#">3</a></li>
                        <li class="page-item">
                            <a class="page-link" href="#">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
            {% endif %}
        </div>
    </div>
    <!-- Posts Table End -->

    <!-- Comments Table Start -->
    <div class="container-fluid pt-4 px-4">
        <div class="bg-light text-center rounded p-4">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h6 class="mb-0">Comments Management</h6>
                <div>
                    <button class="btn btn-sm btn-outline-danger" onclick="deleteSelectedComments()">
                        <i class="fa fa-trash me-2"></i>Delete Selected
                    </button>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table text-start align-middle table-bordered table-hover mb-0">
                    <thead>
                        <tr class="text-dark">
                            <th scope="col" style="width: 30px;">
                                <input type="checkbox" id="selectAllComments" onclick="toggleSelectAll(this)">
                            </th>
                            <th scope="col" style="width: 50px;">#</th>
                            <th scope="col">Comment</th>
                            <th scope="col" style="width: 150px;">Author</th>
                            <th scope="col" style="width: 200px;">Post</th>
                            <th scope="col" style="width: 100px;">Status</th>
                            <th scope="col" style="width: 120px;">Date</th>
                            <th scope="col" style="width: 180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for comment in comments %}
                        <tr>
                            <td>
                                <input type="checkbox" class="comment-checkbox" value="{{ comment.id }}">
                            </td>
                            <td>{{ comment.id }}</td>
                            <td>
                                <div class="text-truncate-content" title="{{ comment.contenu }}">
                                    {{ comment.contenu|striptags|slice(0, 100) }}{% if comment.contenu|length > 100 %}...{% endif %}
                                </div>
                            </td>
                            <td>
                                {{ comment.utilisateur.nom ?? 'Anonymous' }}<br>
                                <small class="text-muted">{{ comment.utilisateur.email ?? '' }}</small>
                            </td>
                            <td>
                                <div class="text-truncate-content" title="{{ comment.post.titre }}">
                                    {{ comment.post.titre }}
                                </div>
                            </td>
                            <td>
                                {% if comment.deletedAt is null %}
                                    <span class="badge badge-status bg-success">Active</span>
                                {% else %}
                                    <span class="badge badge-status bg-danger">Deleted</span>
                                {% endif %}
                            </td>
                            <td>{{ comment.createdAt|date('Y-m-d H:i') }}</td>
                            <td class="action-buttons">
                                <a href="{{ path('admin_comment_view', {id: comment.id}) }}" class="btn btn-sm btn-info" title="View">
                                    <i class="fa fa-eye"></i>
                                </a>
                                <a href="{{ path('admin_comment_edit', {id: comment.id}) }}" class="btn btn-sm btn-primary" title="Edit">
                                    <i class="fa fa-edit"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-danger" 
                                        onclick="deleteComment({{ comment.id }})" 
                                        title="Delete">
                                    <i class="fa fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="fa fa-inbox fa-3x mb-3 d-block"></i>
                                No comments found
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            
            <!-- Pagination -->
            {% if comments|length > 0 %}
            <div class="d-flex justify-content-between align-items-center mt-3">
                <div>
                    Showing {{ comments|length }} comments
                </div>
                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item disabled">
                            <a class="page-link" href="#">Previous</a>
                        </li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item"><a class="page-link" href="#">2</a></li>
                        <li class="page-item"><a class="page-link" href="#">3</a></li>
                        <li class="page-item">
                            <a class="page-link" href="#">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
            {% endif %}
        </div>
    </div>
    <!-- Comments Table End -->
{% endblock %}

{% block javascripts %}
    <script>
        // Delete Post Function
        function deletePost(postId) {
            if (confirm('Are you sure you want to delete this post? This action cannot be undone.')) {
                // Build the URL in JavaScript
                const url = '/admin/posts/' + postId + '/delete';
                
                // AJAX call to delete post
                fetch(url, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Post deleted successfully!');
                        location.reload();
                    } else {
                        alert('Error deleting post: ' + (data.message || 'Unknown error'));
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('An error occurred while deleting the post.');
                });
            }
        }

        // Delete Comment Function
        function deleteComment(commentId) {
            if (confirm('Are you sure you want to delete this comment?')) {
                // Build the URL in JavaScript
                const url = '/admin/comments/' + commentId + '/delete';
                
                // AJAX call to delete comment
                fetch(url, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Comment deleted successfully!');
                        location.reload();
                    } else {
                        alert('Error deleting comment: ' + (data.message || 'Unknown error'));
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('An error occurred while deleting the comment.');
                });
            }
        }

        // Toggle Select All Checkboxes
        function toggleSelectAll(checkbox) {
            const checkboxes = document.querySelectorAll('.comment-checkbox');
            checkboxes.forEach(cb => cb.checked = checkbox.checked);
        }

        // Delete Selected Comments
        function deleteSelectedComments() {
            const selectedIds = Array.from(document.querySelectorAll('.comment-checkbox:checked'))
                .map(cb => cb.value);
            
            if (selectedIds.length === 0) {
                alert('Please select at least one comment to delete.');
                return;
            }

            if (confirm(`Are you sure you want to delete ${selectedIds.length} comment(s)?`)) {
                fetch('/admin/comments/bulk-delete', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({ ids: selectedIds })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert(`${selectedIds.length} comment(s) deleted successfully!`);
                        location.reload();
                    } else {
                        alert('Error deleting comments: ' + (data.message || 'Unknown error'));
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('An error occurred while deleting comments.');
                });
            }
        }
    </script>
{% endblock %}
