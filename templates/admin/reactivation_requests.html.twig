{% extends 'admin/base.html.twig' %}

{% block title %}Reactivation Requests - DASHMIN{% endblock %}

{% block content %}
    <div class="container-fluid pt-4 px-4">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show">
                <i class="fa fa-check-circle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="fa fa-exclamation-triangle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
        {% for message in app.flashes('info') %}
            <div class="alert alert-info alert-dismissible fade show">
                <i class="fa fa-info-circle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        <div class="mb-3">
            <a href="{{ path('admin_users_list') }}" class="btn btn-secondary">
                <i class="fa fa-arrow-left me-2"></i>Back to Users
            </a>
        </div>
        
        <div class="bg-light rounded p-4">
            <h5 class="mb-4"><i class="fa fa-user-check me-2"></i>Pending Reactivation Requests</h5>
            {% if requests is empty %}
                <p class="text-muted mb-0">No pending reactivation requests.</p>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-bordered table-hover mb-0">
                        <thead class="text-dark">
                            <tr>
                                <th>User</th>
                                <th>Email</th>
                                <th>Requested at</th>
                                <th>Reason</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for req in requests %}
                            <tr>
                                <td>{{ req.utilisateur.prenom }} {{ req.utilisateur.nom }}</td>
                                <td>{{ req.utilisateur.email }}</td>
                                <td>{{ req.requestedAt|date('Y-m-d H:i') }}</td>
                                <td><span class="text-break">{{ req.reason }}</span></td>
                                <td>
                                    <form method="post" action="{{ path('admin_reactivation_request_approve', {id: req.id}) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('reactivation-approve-' ~ req.id) }}">
                                        <button type="submit" class="btn btn-sm btn-success"><i class="fa fa-check me-1"></i>Approve</button>
                                    </form>
                                    <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#denyModal{{ req.id }}"><i class="fa fa-times me-1"></i>Deny</button>
                                    
                                    <div class="modal fade" id="denyModal{{ req.id }}" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Refuse reactivation</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <form method="post" action="{{ path('admin_reactivation_request_deny', {id: req.id}) }}">
                                                    <div class="modal-body">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('reactivation-deny-' ~ req.id) }}">
                                                        <label class="form-label">Note (optional)</label>
                                                        <textarea name="admin_note" class="form-control" rows="2" placeholder="Reason for denial..."></textarea>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                        <button type="submit" class="btn btn-danger">Refuse</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
