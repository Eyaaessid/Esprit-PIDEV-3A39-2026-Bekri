<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Reactivation Requests - DASHMIN</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <link href="{{ asset('admin/img/favicon.ico') }}" rel="icon">
    <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="{{ asset('admin/css/bootstrap.min.css') }}" rel="stylesheet">
    <link href="{{ asset('admin/css/style.css') }}" rel="stylesheet">
</head>
<body>
    <div class="container-xxl position-relative bg-white d-flex p-0">
        <div class="sidebar pe-4 pb-3">
            <nav class="navbar bg-light navbar-light">
                <a href="{{ path('admin_dashboard') }}" class="navbar-brand mx-4 mb-3"><h3 class="text-primary"><i class="fa fa-hashtag me-2"></i>DASHMIN</h3></a>
                <div class="d-flex align-items-center ms-4 mb-4">
                    <div class="position-relative">
                        {% if app.user.avatar %}
                            <img class="rounded-circle" src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="" style="width: 40px; height: 40px; object-fit: cover;">
                        {% else %}
                            <img class="rounded-circle" src="{{ asset('admin/img/user.jpg') }}" alt="" style="width: 40px; height: 40px;">
                        {% endif %}
                    </div>
                    <div class="ms-3"><h6 class="mb-0">{{ app.user.nom }} {{ app.user.prenom }}</h6><span>{{ app.user.role.getLabel() }}</span></div>
                </div>
                <div class="navbar-nav w-100">
                    <a href="{{ path('admin_dashboard') }}" class="nav-item nav-link"><i class="fa fa-tachometer-alt me-2"></i>Dashboard</a>
                    <a href="{{ path('admin_users_list') }}" class="nav-item nav-link"><i class="fa fa-users me-2"></i>Users</a>
                    <a href="{{ path('admin_reactivation_requests') }}" class="nav-item nav-link active"><i class="fa fa-user-check me-2"></i>Reactivation Requests</a>
                    <a href="{{ path('admin_profile') }}" class="nav-item nav-link"><i class="fa fa-user me-2"></i>My Profile</a>
                </div>
            </nav>
        </div>
        <div class="content">
            <nav class="navbar navbar-expand bg-light navbar-light sticky-top px-4 py-0">
                <a href="{{ path('admin_dashboard') }}" class="navbar-brand d-flex d-lg-none me-4"><h2 class="text-primary mb-0"><i class="fa fa-hashtag"></i></h2></a>
                <a href="#" class="sidebar-toggler flex-shrink-0"><i class="fa fa-bars"></i></a>
                <div class="navbar-nav align-items-center ms-auto">
                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                            {% if app.user.avatar %}
                                <img class="rounded-circle me-lg-2" src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="" style="width: 40px; height: 40px; object-fit: cover;">
                            {% else %}
                                <img class="rounded-circle me-lg-2" src="{{ asset('admin/img/user.jpg') }}" alt="" style="width: 40px; height: 40px;">
                            {% endif %}
                            <span class="d-none d-lg-inline-flex">{{ app.user.nom }} {{ app.user.prenom }}</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end bg-light border-0 rounded-0 rounded-bottom m-0">
                            <a href="{{ path('admin_profile') }}" class="dropdown-item"><i class="fa fa-user me-2"></i>My Profile</a>
                            <a href="{{ path('app_logout') }}" class="dropdown-item text-danger"><i class="fa fa-sign-out-alt me-2"></i>Log Out</a>
                        </div>
                    </div>
                </div>
            </nav>
            <div class="container-fluid pt-4 px-4">
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success alert-dismissible fade show"><i class="fa fa-check-circle me-2"></i>{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="alert alert-danger alert-dismissible fade show"><i class="fa fa-exclamation-triangle me-2"></i>{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
                {% endfor %}
                {% for message in app.flashes('info') %}
                    <div class="alert alert-info alert-dismissible fade show"><i class="fa fa-info-circle me-2"></i>{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
                {% endfor %}

                <div class="mb-3">
                    <a href="{{ path('admin_users_list') }}" class="btn btn-secondary"><i class="fa fa-arrow-left me-2"></i>Back to Users</a>
                </div>
                <div class="bg-light rounded p-4">
                    <h5 class="mb-4"><i class="fa fa-user-check me-2"></i>Pending Reactivation Requests</h5>
                    {% if requests is empty %}
                        <p class="text-muted mb-0">No pending reactivation requests.</p>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover mb-0">
                                <thead class="text-dark">
                                    <tr>
                                        <th>User</th>
                                        <th>Email</th>
                                        <th>Requested at</th>
                                        <th>Reason</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for req in requests %}
                                    <tr>
                                        <td>{{ req.utilisateur.prenom }} {{ req.utilisateur.nom }}</td>
                                        <td>{{ req.utilisateur.email }}</td>
                                        <td>{{ req.requestedAt|date('Y-m-d H:i') }}</td>
                                        <td><span class="text-break">{{ req.reason }}</span></td>
                                        <td>
                                            <form method="post" action="{{ path('admin_reactivation_request_approve', {id: req.id}) }}" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('reactivation-approve-' ~ req.id) }}">
                                                <button type="submit" class="btn btn-sm btn-success"><i class="fa fa-check me-1"></i>Approve</button>
                                            </form>
                                            <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#denyModal{{ req.id }}"><i class="fa fa-times me-1"></i>Deny</button>
                                            <div class="modal fade" id="denyModal{{ req.id }}" tabindex="-1">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">
                                                        <div class="modal-header"><h5 class="modal-title">Refuse reactivation</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                                                        <form method="post" action="{{ path('admin_reactivation_request_deny', {id: req.id}) }}">
                                                            <div class="modal-body">
                                                                <input type="hidden" name="_token" value="{{ csrf_token('reactivation-deny-' ~ req.id) }}">
                                                                <label class="form-label">Note (optional)</label>
                                                                <textarea name="admin_note" class="form-control" rows="2" placeholder="Reason for denial..."></textarea>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                                <button type="submit" class="btn btn-danger">Refuse</button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
