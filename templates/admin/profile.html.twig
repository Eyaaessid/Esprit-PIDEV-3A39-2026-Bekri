<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mon Profil — Bekri</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="{{ asset('admin/css/bootstrap.min.css') }}" rel="stylesheet">
    <style>
        :root {
            --dark:       #1a2332;
            --dark2:      #1e3a5f;
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --light:      #f8fafc;
            --white:      #ffffff;
            --gray:       #64748b;
            --sidebar-w:  260px;
            --shadow-sm:  0 2px 12px rgba(0,0,0,0.06);
            --shadow:     0 8px 30px rgba(0,0,0,0.10);
            --radius:     16px;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior:smooth; }
        body { font-family:'Inter',sans-serif; background:var(--light); color:var(--dark); display:flex; min-height:100vh; }

        /* ── SIDEBAR ── */
        .sidebar { width:var(--sidebar-w); background:var(--dark); min-height:100vh; position:fixed; top:0; left:0; display:flex; flex-direction:column; z-index:100; transition:transform 0.3s; }
        .sidebar-logo { padding:28px 24px 20px; display:flex; align-items:center; gap:10px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-logo-text { font-size:20px; font-weight:800; background:linear-gradient(135deg,var(--teal),#a78bfa); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .sidebar-user { padding:20px 24px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(255,255,255,0.07); }
        .sidebar-avatar { width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:16px; flex-shrink:0; overflow:hidden; position:relative; }
        .sidebar-avatar img { width:100%; height:100%; object-fit:cover; }
        .avatar-dot { width:10px; height:10px; background:#22c55e; border-radius:50%; border:2px solid var(--dark); position:absolute; bottom:1px; right:1px; }
        .sidebar-user-name { font-size:14px; font-weight:600; color:white; }
        .sidebar-user-role { font-size:11px; color:rgba(255,255,255,0.4); margin-top:2px; }
        .sidebar-nav { flex:1; padding:16px 0; overflow-y:auto; }
        .nav-section-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:rgba(255,255,255,0.25); padding:12px 24px 6px; }
        .nav-item { display:flex; align-items:center; gap:12px; padding:11px 24px; color:rgba(255,255,255,0.6); text-decoration:none; font-size:14px; font-weight:500; transition:all 0.2s; border-left:3px solid transparent; }
        .nav-item:hover { color:white; background:rgba(255,255,255,0.05); }
        .nav-item.active { color:var(--teal); background:rgba(32,178,170,0.1); border-left-color:var(--teal); }
        .nav-item i { width:20px; text-align:center; font-size:16px; }
        .sidebar-footer { padding:16px 0; border-top:1px solid rgba(255,255,255,0.07); }

        /* ── MAIN ── */
        .main { margin-left:var(--sidebar-w); flex:1; display:flex; flex-direction:column; min-height:100vh; }

        /* ── TOPBAR ── */
        .topbar { background:white; padding:0 32px; height:68px; display:flex; align-items:center; justify-content:space-between; box-shadow:var(--shadow-sm); position:sticky; top:0; z-index:50; }
        .topbar-left { display:flex; align-items:center; gap:16px; }
        .topbar-title { font-size:18px; font-weight:700; color:var(--dark); }
        .topbar-sub { font-size:13px; color:var(--gray); margin-top:1px; }
        .topbar-right { display:flex; align-items:center; gap:12px; }
        .topbar-icon-btn { width:38px; height:38px; border-radius:10px; background:var(--light); border:1px solid #e2e8f0; display:flex; align-items:center; justify-content:center; color:var(--gray); font-size:16px; cursor:pointer; text-decoration:none; transition:all 0.2s; position:relative; }
        .topbar-icon-btn:hover { background:var(--teal-light); color:var(--teal-dark); border-color:var(--teal); }
        .topbar-avatar { width:38px; height:38px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:14px; text-decoration:none; overflow:hidden; flex-shrink:0; }
        .topbar-avatar img { width:100%; height:100%; object-fit:cover; }

        /* ── PAGE HEADER ── */
        .page-header { background:linear-gradient(135deg,var(--dark) 0%,#1e3a5f 60%,#0d9488 100%); padding:36px 40px 28px; position:relative; overflow:hidden; }
        .page-header::before { content:''; position:absolute; top:-60px; right:-60px; width:260px; height:260px; background:rgba(32,178,170,0.08); border-radius:50%; }
        .page-header::after { content:''; position:absolute; bottom:-40px; right:200px; width:160px; height:160px; background:rgba(102,126,234,0.06); border-radius:50%; }
        .page-header-inner { max-width:1200px; margin:0 auto; position:relative; z-index:1; }
        .page-header-tag { display:inline-flex; align-items:center; gap:6px; background:rgba(32,178,170,0.2); border:1px solid rgba(32,178,170,0.35); color:#7fffd4; padding:4px 12px; border-radius:50px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:10px; }
        .page-header-title { font-size:26px; font-weight:800; color:white; margin-bottom:4px; }
        .page-header-sub { font-size:14px; color:rgba(255,255,255,0.55); }

        /* ── CONTENT ── */
        .content { flex:1; padding:32px 40px; max-width:1280px; margin:0 auto; width:100%; }

        /* ── CARDS ── */
        .card { background:white; border-radius:var(--radius); box-shadow:var(--shadow-sm); border:1px solid #f1f5f9; overflow:hidden; }
        .card-header-bar { padding:20px 24px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid #f1f5f9; }
        .card-title { font-size:15px; font-weight:700; color:var(--dark); display:flex; align-items:center; gap:8px; }
        .card-title i { color:var(--teal-dark); font-size:16px; }
        .card-body { padding:24px; }

        /* ── PROFILE AVATAR ── */
        .profile-avatar-lg { width:120px; height:120px; border-radius:50%; background:linear-gradient(135deg,var(--teal),var(--purple)); display:flex; align-items:center; justify-content:center; color:white; font-weight:800; font-size:40px; overflow:hidden; border:4px solid var(--teal-light); margin:0 auto 16px; }
        .profile-avatar-lg img { width:100%; height:100%; object-fit:cover; }

        /* ── BADGES ── */
        .role-badge { display:inline-flex; align-items:center; padding:4px 12px; border-radius:50px; font-size:11px; font-weight:700; }
        .role-badge.admin { background:#fef3c7; color:#d97706; }
        .role-badge.coach { background:var(--teal-light); color:var(--teal-dark); }
        .role-badge.user { background:#f0f9ff; color:#0284c7; }

        /* ── INFO ROWS ── */
        .info-row { display:flex; align-items:flex-start; padding:14px 0; border-bottom:1px solid #f8fafc; }
        .info-row:last-child { border-bottom:none; }
        .info-label { width:160px; font-size:13px; font-weight:600; color:var(--gray); flex-shrink:0; }
        .info-value { font-size:14px; color:var(--dark); font-weight:500; }

        /* ── SECURITY SECTION ── */
        .security-item { padding:16px; background:var(--light); border-radius:12px; border:1px solid #e2e8f0; margin-bottom:12px; }
        .security-item-title { font-size:13px; font-weight:700; color:var(--dark); margin-bottom:4px; display:flex; align-items:center; gap:6px; }
        .security-item-title i { color:var(--teal-dark); }
        .security-status { font-size:12px; }
        .security-status.enabled { color:#16a34a; }
        .security-status.disabled { color:var(--gray); }

        /* ── BUTTONS ── */
        .btn-primary-teal { background:linear-gradient(135deg,var(--teal),var(--teal-dark)); color:white; border:none; padding:10px 20px; border-radius:10px; font-size:14px; font-weight:600; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:8px; transition:all 0.2s; }
        .btn-primary-teal:hover { opacity:0.9; transform:translateY(-1px); color:white; box-shadow:0 4px 12px rgba(32,178,170,0.3); }
        .btn-outline { background:white; color:var(--gray); border:1px solid #e2e8f0; padding:10px 20px; border-radius:10px; font-size:14px; font-weight:600; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:8px; transition:all 0.2s; }
        .btn-outline:hover { border-color:var(--teal); color:var(--teal-dark); background:var(--teal-light); }
        .btn-danger-outline { background:white; color:#ef4444; border:1px solid #fecaca; padding:10px 20px; border-radius:10px; font-size:14px; font-weight:600; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:8px; transition:all 0.2s; }
        .btn-danger-outline:hover { background:#fee2e2; border-color:#ef4444; }
        .btn-success { background:#16a34a; color:white; border:none; padding:10px 20px; border-radius:10px; font-size:14px; font-weight:600; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:8px; transition:all 0.2s; }
        .btn-success:hover { background:#15803d; color:white; transform:translateY(-1px); }
        .btn-purple { background:linear-gradient(135deg,#667eea,#764ba2); color:white; border:none; padding:10px 20px; border-radius:10px; font-size:14px; font-weight:600; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:8px; transition:all 0.2s; }
        .btn-purple:hover { opacity:0.9; color:white; transform:translateY(-1px); box-shadow:0 4px 12px rgba(102,126,234,0.4); }
        .btn-block { width:100%; justify-content:center; }

        /* ── ALERTS ── */
        .alert { padding:12px 16px; border-radius:10px; font-size:13px; font-weight:500; display:flex; align-items:center; gap:8px; margin-bottom:8px; }
        .alert-success { background:#f0fdf4; color:#166534; border:1px solid #bbf7d0; }
        .alert-info { background:#f0f9ff; color:#0c4a6e; border:1px solid #bae6fd; }
        .alert-danger { background:#fef2f2; color:#991b1b; border:1px solid #fecaca; }

        /* ── FORM CONTROLS ── */
        .form-control { border:1px solid #cbd5e1; border-radius:8px; padding:8px 12px; font-size:14px; color:var(--dark); transition:all 0.2s; background:white; width:100%; }
        .form-control:focus { border-color:var(--teal); box-shadow:0 0 0 3px rgba(32,178,170,0.1); outline:none; }
        .position-relative { position:relative; }
        .toggle-password { position:absolute; right:12px; top:50%; transform:translateY(-50%); cursor:pointer; color:var(--gray); font-size:1rem; }
        .toggle-password:hover { color:var(--teal-dark); }

        /* ── RESPONSIVE ── */
        @media (max-width:1024px) { .profile-grid { grid-template-columns:1fr; } }
        @media (max-width:768px) { .main { margin-left:0; } .content { padding:20px 16px; } }
    </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
        <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'" style="height:36px;">
        <span class="sidebar-logo-text">Bekri Admin</span>
    </div>
    <div class="sidebar-user">
        <div class="sidebar-avatar">
            {% if app.user and app.user.avatar %}
                <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
            {% else %}
                {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
            {% endif %}
            <div class="avatar-dot"></div>
        </div>
        <div>
            <div class="sidebar-user-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
            <div class="sidebar-user-role">{{ app.user.role.getLabel() }}</div>
        </div>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-section-label">Principal</div>
        <a href="{{ path('admin_dashboard') }}" class="nav-item"><i class="bi bi-grid-fill"></i> Dashboard</a>
        <a href="{{ path('admin_profile') }}" class="nav-item active"><i class="bi bi-person-fill"></i> Mon profil</a>

        <div class="nav-section-label">Gestion</div>
        <a href="{{ path('admin_users_list') }}" class="nav-item"><i class="bi bi-people-fill"></i> Utilisateurs</a>
        <a href="{{ path('admin_question_index') }}" class="nav-item"><i class="bi bi-clipboard2-pulse-fill"></i> Questions de suivi</a>
        <a href="{{ path('admin_post_list') }}" class="nav-item"><i class="bi bi-newspaper"></i> Publications</a>
        <a href="{{ path('evenements_admin_supervision') }}" class="nav-item"><i class="bi bi-calendar-event-fill"></i> Événements</a>

        <div class="nav-section-label">Compte</div>
        <a href="{{ path('app_login') }}" class="nav-item"><i class="bi bi-box-arrow-in-right"></i> Connexion</a>
        <a href="{{ path('app_register') }}" class="nav-item"><i class="bi bi-person-plus-fill"></i> Inscription</a>
    </nav>
    <div class="sidebar-footer">
        <a href="{{ path('app_logout') }}" class="nav-item" style="color:#f87171;">
            <i class="bi bi-box-arrow-left"></i> Se déconnecter
        </a>
    </div>
</aside>

<!-- MAIN -->
<div class="main">

    <!-- TOPBAR -->
    <header class="topbar">
        <div class="topbar-left">
            <div>
                <div class="topbar-title">Mon Profil</div>
                <div class="topbar-sub">{{ app.user.prenom }} {{ app.user.nom }}</div>
            </div>
        </div>
        <div class="topbar-right">
            <a href="{{ path('admin_users_list') }}" class="topbar-icon-btn" title="Utilisateurs">
                <i class="bi bi-people"></i>
            </a>
            <a href="{{ path('admin_profile_edit') }}" class="topbar-icon-btn" title="Modifier le profil">
                <i class="bi bi-pencil-square"></i>
            </a>
            <a href="{{ path('admin_profile') }}" class="topbar-avatar">
                {% if app.user and app.user.avatar %}
                    <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="avatar">
                {% else %}
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                {% endif %}
            </a>
        </div>
    </header>

    <!-- PAGE HEADER -->
    <div class="page-header">
        <div class="page-header-inner">
            <div class="page-header-tag"><i class="bi bi-person-fill"></i> Profil Administrateur</div>
            <div class="page-header-title">{{ user.prenom }} {{ user.nom }}</div>
            <div class="page-header-sub">{{ user.email }}</div>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="content">

        <!-- Flash Messages -->
        {% for message in app.flashes('success') %}
            <div class="alert alert-success" style="margin-bottom:20px;">
                <i class="bi bi-check-circle-fill"></i> {{ message }}
            </div>
        {% endfor %}

        <div style="display:grid; grid-template-columns:320px 1fr; gap:24px; align-items:start;">

            <!-- LEFT COLUMN: Avatar Card + Security -->
            <div style="display:flex; flex-direction:column; gap:24px;">

                <!-- Avatar Card -->
                <div class="card">
                    <div class="card-body" style="text-align:center; padding:32px 24px;">
                        <div class="profile-avatar-lg">
                            {% if user.avatar %}
                                <img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" alt="{{ user.prenom }}">
                            {% else %}
                                {{ user.prenom|first|upper }}{{ user.nom|first|upper }}
                            {% endif %}
                        </div>
                        <div style="font-size:18px; font-weight:700; color:var(--dark); margin-bottom:4px;">{{ user.prenom }} {{ user.nom }}</div>
                        <div style="font-size:13px; color:var(--gray); margin-bottom:12px;">{{ user.email }}</div>
                        <span class="role-badge admin" style="margin-bottom:20px; display:inline-flex;">
                            <i class="bi bi-shield-fill-check" style="margin-right:4px;"></i> Administrateur
                        </span>

                        <div style="display:flex; flex-direction:column; gap:10px; margin-top:20px;">
                            <a href="{{ path('admin_profile_edit') }}" class="btn-primary-teal btn-block">
                                <i class="bi bi-pencil-square"></i> Modifier le profil
                            </a>
                            <a href="{{ path('avatar_generator') }}" class="btn-purple btn-block">
                                <i class="bi bi-stars"></i> Générer un avatar IA
                            </a>
                            <a href="{{ path('admin_dashboard') }}" class="btn-outline btn-block">
                                <i class="bi bi-arrow-left"></i> Retour au dashboard
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Face Authentication Card -->
                <div class="card">
                    <div class="card-header-bar">
                        <div class="card-title"><i class="bi bi-camera-video-fill"></i> Authentification faciale</div>
                    </div>
                    <div class="card-body">
                        {% if user.isFaceAuthEnabled() %}
                            <div class="alert alert-success">
                                <i class="bi bi-check-circle-fill"></i>
                                <div>
                                    <strong>Activée</strong>
                                    <div style="font-size:11px; margin-top:2px;">Enregistrée le {{ user.faceRegisteredAt|date('d M Y') }}</div>
                                </div>
                            </div>
                            <button type="button" class="btn-danger-outline btn-block" id="disable-face-auth-btn" style="width:100%; justify-content:center;">
                                <i class="bi bi-x-circle"></i> Désactiver
                            </button>
                        {% else %}
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle"></i> Activez la connexion par reconnaissance faciale.
                            </div>
                            <button type="button" class="btn-success btn-block" data-bs-toggle="modal" data-bs-target="#faceRegistrationModal" style="width:100%; justify-content:center;">
                                <i class="bi bi-camera-video"></i> Activer
                            </button>
                        {% endif %}
                    </div>
                </div>

                <!-- 2FA Card -->
                <div class="card">
                    <div class="card-header-bar">
                        <div class="card-title"><i class="bi bi-shield-lock-fill"></i> Double authentification (2FA)</div>
                    </div>
                    <div class="card-body">
                        {% if user.isTwoFactorEnabled() %}
                            <div class="alert alert-success">
                                <i class="bi bi-check-circle-fill"></i>
                                <div>
                                    <strong>Activée</strong>
                                    <div style="font-size:11px; margin-top:2px;">Depuis le {{ user.twoFactorEnabledAt ? user.twoFactorEnabledAt|date('d M Y') : 'Inconnu' }}</div>
                                </div>
                            </div>
                            <form method="post" action="{{ path('app_2fa_disable') }}" style="margin-bottom:10px;">
                                <div class="position-relative" style="margin-bottom:8px;">
                                    <input type="password" class="form-control" name="password" placeholder="Mot de passe pour désactiver" required>
                                    <i class="bi bi-eye toggle-password"></i>
                                </div>
                                <input type="hidden" name="_token" value="{{ csrf_token('2fa_disable') }}">
                                <button type="submit" class="btn-danger-outline btn-block" onclick="return confirm('Désactiver la 2FA ?')" style="width:100%; justify-content:center;">
                                    <i class="bi bi-x-circle"></i> Désactiver la 2FA
                                </button>
                            </form>
                            <form method="post" action="{{ path('app_2fa_regenerate_backup_codes') }}">
                                <div class="position-relative" style="margin-bottom:8px;">
                                    <input type="password" class="form-control" name="password" placeholder="Mot de passe pour régénérer" required>
                                    <i class="bi bi-eye toggle-password"></i>
                                </div>
                                <input type="hidden" name="_token" value="{{ csrf_token('2fa_regenerate') }}">
                                <button type="submit" class="btn-outline btn-block" style="width:100%; justify-content:center; color:#d97706; border-color:#fde68a;">
                                    <i class="bi bi-arrow-clockwise"></i> Régénérer les codes
                                </button>
                            </form>
                        {% else %}
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle"></i> Ajoutez une couche de sécurité supplémentaire.
                            </div>
                            <a href="{{ path('app_2fa_enable') }}" class="btn-primary-teal btn-block" style="justify-content:center;">
                                <i class="bi bi-shield-lock"></i> Activer la 2FA
                            </a>
                        {% endif %}
                    </div>
                </div>

            </div>

            <!-- RIGHT COLUMN: Info + Account Details -->
            <div style="display:flex; flex-direction:column; gap:24px;">

                <!-- Personal Information -->
                <div class="card">
                    <div class="card-header-bar">
                        <div class="card-title"><i class="bi bi-person-lines-fill"></i> Informations personnelles</div>
                        <a href="{{ path('admin_profile_edit') }}" style="font-size:13px; font-weight:600; color:var(--teal-dark); text-decoration:none;">
                            <i class="bi bi-pencil"></i> Modifier
                        </a>
                    </div>
                    <div class="card-body">
                        <div class="info-row">
                            <div class="info-label">Prénom</div>
                            <div class="info-value">{{ user.prenom }}</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">Nom</div>
                            <div class="info-value">{{ user.nom }}</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">Email</div>
                            <div class="info-value">{{ user.email }}</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">Téléphone</div>
                            <div class="info-value">{{ user.telephone ?? '<span style="color:var(--gray);font-style:italic;">Non renseigné</span>'|raw }}</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">Date de naissance</div>
                            <div class="info-value">{{ user.dateNaissance ? user.dateNaissance|date('d F Y') : '<span style="color:var(--gray);font-style:italic;">Non renseignée</span>'|raw }}</div>
                        </div>
                    </div>
                </div>

                <!-- Account Details -->
                <div class="card">
                    <div class="card-header-bar">
                        <div class="card-title"><i class="bi bi-shield-check"></i> Détails du compte</div>
                    </div>
                    <div class="card-body">
                        <div class="info-row">
                            <div class="info-label">Rôle</div>
                            <div class="info-value">
                                <span class="role-badge admin"><i class="bi bi-shield-fill-check" style="margin-right:4px;"></i> Administrateur</span>
                            </div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">Compte créé le</div>
                            <div class="info-value">{{ user.createdAt|date('d F Y') }}</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">Dernière mise à jour</div>
                            <div class="info-value">{{ user.updatedAt ? user.updatedAt|date('d F Y') : '<span style="color:var(--gray);font-style:italic;">Jamais</span>'|raw }}</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">Authentification faciale</div>
                            <div class="info-value security-status {{ user.isFaceAuthEnabled() ? 'enabled' : 'disabled' }}">
                                {% if user.isFaceAuthEnabled() %}
                                    <i class="bi bi-check-circle-fill"></i> Activée
                                {% else %}
                                    <i class="bi bi-x-circle"></i> Désactivée
                                {% endif %}
                            </div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">Double authentification</div>
                            <div class="info-value security-status {{ user.isTwoFactorEnabled() ? 'enabled' : 'disabled' }}">
                                {% if user.isTwoFactorEnabled() %}
                                    <i class="bi bi-check-circle-fill"></i> Activée
                                {% else %}
                                    <i class="bi bi-x-circle"></i> Désactivée
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
    <!-- Content End -->

</div>
<!-- Main End -->

{# Face Registration Modal #}
<div class="modal fade" id="faceRegistrationModal" tabindex="-1" aria-labelledby="faceRegistrationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="border-radius:var(--radius); border:none; box-shadow:var(--shadow);">
            <div class="modal-header" style="border-bottom:1px solid #f1f5f9; padding:20px 24px;">
                <h5 class="modal-title" style="font-weight:700; color:var(--dark); display:flex; align-items:center; gap:8px;">
                    <i class="bi bi-camera-video" style="color:var(--teal-dark);"></i> Activer l'authentification faciale
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding:24px;">
                <div id="face-registration-steps">
                    <div id="step-instructions" class="text-center">
                        <i class="bi bi-info-circle" style="font-size:4rem; color:var(--teal-dark);"></i>
                        <h5 style="margin:16px 0 12px; font-weight:700; color:var(--dark);">Comment fonctionne l'authentification faciale</h5>
                        <ul style="text-align:left; max-width:500px; margin:0 auto; list-style:none; padding:0;">
                            {% for tip in ['Positionnez votre visage dans le cadre','Assurez-vous d\'être dans un endroit bien éclairé','Regardez directement la caméra','Nous capturons vos données faciales en toute sécurité','Vos données sont chiffrées et stockées en sécurité'] %}
                            <li style="display:flex; align-items:center; gap:8px; padding:6px 0; font-size:14px; color:var(--dark);">
                                <i class="bi bi-check-circle-fill" style="color:var(--teal-dark);"></i> {{ tip }}
                            </li>
                            {% endfor %}
                        </ul>
                        <button type="button" class="btn-primary-teal" style="margin-top:20px;" id="start-face-capture-btn">
                            <i class="bi bi-camera-fill"></i> Démarrer la caméra
                        </button>
                    </div>
                    <div id="step-camera" style="display:none;">
                        <div class="position-relative">
                            <video id="face-video" width="100%" height="auto" autoplay muted style="border-radius:12px; max-height:400px;"></video>
                            <canvas id="face-canvas" style="display:none;"></canvas>
                            <div id="face-overlay" style="position:absolute; top:0; left:0; width:100%; height:100%; pointer-events:none;">
                                <div id="face-detection-box" style="display:none; position:absolute; border:3px solid #00ff00; border-radius:8px; box-shadow:0 0 20px rgba(0,255,0,0.5);"></div>
                            </div>
                        </div>
                        <div style="text-align:center; margin-top:16px;">
                            <div id="face-status" class="alert alert-info"><i class="bi bi-camera-video"></i> <span id="face-status-text">Initialisation…</span></div>
                            <div style="display:flex; gap:10px; justify-content:center;">
                                <button type="button" class="btn-primary-teal" id="capture-face-btn" disabled style="opacity:0.5;">
                                    <i class="bi bi-check-circle"></i> Capturer
                                </button>
                                <button type="button" class="btn-outline" id="cancel-capture-btn">
                                    <i class="bi bi-x-circle"></i> Annuler
                                </button>
                            </div>
                        </div>
                    </div>
                    <div id="step-processing" style="display:none; text-align:center; padding:40px;">
                        <div class="spinner-border" role="status" style="width:4rem; height:4rem; color:var(--teal-dark);"></div>
                        <h5 style="margin-top:16px; font-weight:700;">Traitement en cours…</h5>
                        <p style="color:var(--gray);">Veuillez patienter.</p>
                    </div>
                    <div id="step-success" style="display:none; text-align:center; padding:40px;">
                        <i class="bi bi-check-circle-fill" style="font-size:5rem; color:#16a34a;"></i>
                        <h4 style="margin:16px 0 8px; font-weight:700;">Authentification faciale activée !</h4>
                        <p style="color:var(--gray);">Vous pouvez désormais vous connecter avec votre visage.</p>
                        <button type="button" class="btn-primary-teal" style="margin-top:16px;" data-bs-dismiss="modal">Terminer</button>
                    </div>
                    <div id="step-error" style="display:none; text-align:center; padding:40px;">
                        <i class="bi bi-exclamation-triangle-fill" style="font-size:5rem; color:#ef4444;"></i>
                        <h4 style="margin:16px 0 8px; font-weight:700;">Échec de l'enregistrement</h4>
                        <p style="color:var(--gray);" id="error-message">Une erreur est survenue. Veuillez réessayer.</p>
                        <div style="display:flex; gap:10px; justify-content:center; margin-top:16px;">
                            <button type="button" class="btn-primary-teal" id="retry-face-capture-btn"><i class="bi bi-arrow-clockwise"></i> Réessayer</button>
                            <button type="button" class="btn-outline" data-bs-dismiss="modal">Annuler</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="{{ asset('admin/js/main.js') }}"></script>
<script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    let videoStream = null;
    let faceDescriptor = null;
    const MODEL_URL = 'https://justadudewhohacks.github.io/face-api.js/models';
    const video = document.getElementById('face-video');
    const startBtn = document.getElementById('start-face-capture-btn');
    const captureBtn = document.getElementById('capture-face-btn');
    const cancelBtn = document.getElementById('cancel-capture-btn');
    const retryBtn = document.getElementById('retry-face-capture-btn');
    const disableBtn = document.getElementById('disable-face-auth-btn');
    const statusText = document.getElementById('face-status-text');
    const faceDetectionBox = document.getElementById('face-detection-box');

    async function loadModels() {
        await Promise.all([
            faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
            faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL),
            faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL)
        ]);
    }

    async function startCamera() {
        try {
            statusText.textContent = 'Chargement des modèles…';
            await loadModels();
        } catch (e) { showError('Impossible de charger les modèles. Actualisez la page.'); return; }
        try {
            statusText.textContent = 'Démarrage de la caméra…';
            const stream = await navigator.mediaDevices.getUserMedia({ video: true });
            video.srcObject = stream;
            videoStream = stream;
            await new Promise((res, rej) => { video.onloadedmetadata = () => video.play().then(() => setTimeout(res,500)).catch(rej); video.onerror = rej; });
            statusText.textContent = 'Caméra prête. Positionnez votre visage.';
            detectFace();
        } catch (e) { showError('Impossible d\'accéder à la caméra. Vérifiez les permissions.'); }
    }

    function stopCamera() { if (videoStream) { videoStream.getTracks().forEach(t => t.stop()); videoStream = null; } }

    async function detectFace() {
        if (video.readyState < 2) { if (videoStream) setTimeout(detectFace, 150); return; }
        try {
            const det = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions()).withFaceLandmarks().withFaceDescriptor();
            if (det) {
                faceDescriptor = Array.from(det.descriptor);
                const b = det.detection.box;
                faceDetectionBox.style.cssText = `display:block;left:${b.x}px;top:${b.y}px;width:${b.width}px;height:${b.height}px;`;
                statusText.textContent = 'Visage détecté ! Cliquez sur Capturer.';
                captureBtn.disabled = false; captureBtn.style.opacity = '1';
            } else {
                faceDetectionBox.style.display = 'none';
                statusText.textContent = 'Recherche de visage…';
                captureBtn.disabled = true; captureBtn.style.opacity = '0.5';
            }
        } catch (e) {}
        if (videoStream) setTimeout(detectFace, 300);
    }

    async function captureFace() {
        if (!faceDescriptor) { showError('Aucun visage détecté.'); return; }
        showStep('step-processing'); stopCamera();
        try {
            const res = await fetch('{{ path('api_face_auth_register') }}', { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'}, body: JSON.stringify({ descriptor: faceDescriptor }) });
            const data = await res.json();
            if (data.success) { showStep('step-success'); setTimeout(() => location.reload(), 1000); }
            else showError(data.message || 'Échec de l\'enregistrement.');
        } catch (e) { showError('Erreur réseau. Vérifiez votre connexion.'); }
    }

    async function disableFaceAuth() {
        if (!confirm('Désactiver l\'authentification faciale ?')) return;
        try {
            const res = await fetch('{{ path('api_face_auth_disable') }}', { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'}, body: JSON.stringify({}) });
            const data = await res.json();
            if (data.success) location.reload();
            else alert('Erreur : ' + (data.message || 'Inconnue'));
        } catch (e) { alert('Erreur réseau.'); }
    }

    function showStep(id) { document.querySelectorAll('#face-registration-steps > div').forEach(d => d.style.display='none'); document.getElementById(id).style.display='block'; }
    function showError(msg) { document.getElementById('error-message').textContent = msg; showStep('step-error'); }

    if (startBtn) startBtn.addEventListener('click', async () => { showStep('step-camera'); await startCamera(); });
    if (captureBtn) captureBtn.addEventListener('click', captureFace);
    if (cancelBtn) cancelBtn.addEventListener('click', () => { stopCamera(); bootstrap.Modal.getInstance(document.getElementById('faceRegistrationModal')).hide(); });
    if (retryBtn) retryBtn.addEventListener('click', () => showStep('step-instructions'));
    if (disableBtn) disableBtn.addEventListener('click', disableFaceAuth);

    const modal = document.getElementById('faceRegistrationModal');
    if (modal) {
        modal.addEventListener('hidden.bs.modal', () => { stopCamera(); showStep('step-instructions'); if(captureBtn){captureBtn.disabled=true;captureBtn.style.opacity='0.5';} faceDescriptor=null; });
        modal.addEventListener('show.bs.modal', () => { if(captureBtn){captureBtn.disabled=true;captureBtn.style.opacity='0.5';} faceDescriptor=null; });
    }

    document.querySelectorAll('.toggle-password').forEach(btn => {
        btn.addEventListener('click', function() {
            const input = this.previousElementSibling;
            if (input) { input.type = input.type === 'password' ? 'text' : 'password'; this.classList.toggle('bi-eye'); this.classList.toggle('bi-eye-slash'); }
        });
    });
});
</script>
</body>
</html>