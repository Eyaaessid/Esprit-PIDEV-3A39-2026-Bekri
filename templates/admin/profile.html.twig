<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Admin Profile - DASHMIN</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <!-- Favicon -->
    <link href="{{ asset('admin/img/favicon.ico') }}" rel="icon">

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Icon Font Stylesheet -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Customized Bootstrap Stylesheet -->
    <link href="{{ asset('admin/css/bootstrap.min.css') }}" rel="stylesheet">

    <!-- Template Stylesheet -->
    <link href="{{ asset('admin/css/style.css') }}" rel="stylesheet">
    
    <style>
        * {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
        
        .profile-avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid #009CFF;
            box-shadow: 0 4px 12px rgba(0, 156, 255, 0.25);
        }
        
        .profile-initials {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            color: white;
            font-weight: 700;
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
        }
        
        .info-row {
            padding: 0.75rem 0;
        }
        
        .info-label {
            font-weight: 600;
            color: #64748b;
        }
        
        .info-value {
            color: #1e293b;
        }
        
        .edit-profile-btn {
            transition: all 0.2s ease;
        }
        
        .edit-profile-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(0, 123, 255, 0.3);
        }
    </style>
</head>
<body>
    <div class="container-xxl position-relative bg-white d-flex p-0">
        <!-- Sidebar Start -->
        <div class="sidebar pe-4 pb-3">
            <nav class="navbar bg-light navbar-light">
                <a href="{{ path('admin_dashboard') }}" class="navbar-brand mx-4 mb-3">
                    <h3 class="text-primary"><i class="fa fa-hashtag me-2"></i>DASHMIN</h3>
                </a>
                <div class="d-flex align-items-center ms-4 mb-4">
                    <div class="position-relative">
                        {% if user.avatar %}
                            <img class="rounded-circle" src="{{ asset('uploads/avatars/' ~ user.avatar) }}" alt="" style="width: 40px; height: 40px; object-fit: cover;">
                        {% else %}
                            <img class="rounded-circle" src="{{ asset('admin/img/user.jpg') }}" alt="" style="width: 40px; height: 40px;">
                        {% endif %}
                        <div class="bg-success rounded-circle border border-2 border-white position-absolute end-0 bottom-0 p-1"></div>
                    </div>
                    <div class="ms-3">
                        <h6 class="mb-0">{{ app.user.nom }} {{ app.user.prenom }}</h6>
                        <span>{{ app.user.role.getLabel() }}</span>
                    </div>
                </div>
                <div class="navbar-nav w-100">
                    <a href="{{ path('admin_dashboard') }}" class="nav-item nav-link">
                        <i class="fa fa-tachometer-alt me-2"></i>Dashboard
                    </a>
                    <a href="{{ path('admin_users_list') }}" class="nav-item nav-link">
                        <i class="fa fa-users me-2"></i>Users
                    </a>
                    <a href="{{ path('admin_profile') }}" class="nav-item nav-link active">
                        <i class="fa fa-user me-2"></i>My Profile
                    </a>
                </div>
            </nav>
        </div>
        <!-- Sidebar End -->

        <!-- Content Start -->
        <div class="content">
            <!-- Navbar Start -->
            <nav class="navbar navbar-expand bg-light navbar-light sticky-top px-4 py-0">
                <a href="{{ path('admin_dashboard') }}" class="navbar-brand d-flex d-lg-none me-4">
                    <h2 class="text-primary mb-0"><i class="fa fa-hashtag"></i></h2>
                </a>
                <a href="#" class="sidebar-toggler flex-shrink-0">
                    <i class="fa fa-bars"></i>
                </a>
                <div class="navbar-nav align-items-center ms-auto">
                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                            {% if user.avatar %}
                                <img class="rounded-circle me-lg-2" src="{{ asset('uploads/avatars/' ~ user.avatar) }}" alt="" style="width: 40px; height: 40px; object-fit: cover;">
                            {% else %}
                                <img class="rounded-circle me-lg-2" src="{{ asset('admin/img/user.jpg') }}" alt="" style="width: 40px; height: 40px;">
                            {% endif %}
                            <span class="d-none d-lg-inline-flex">{{ app.user.nom }} {{ app.user.prenom }}</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end bg-light border-0 rounded-0 rounded-bottom m-0">
                            <a href="{{ path('admin_profile') }}" class="dropdown-item"><i class="fa fa-user me-2"></i>My Profile</a>
                            <a href="{{ path('admin_profile_edit') }}" class="dropdown-item"><i class="fa fa-cog me-2"></i>Settings</a>
                            <hr class="dropdown-divider">
                            <a href="{{ path('app_logout') }}" class="dropdown-item text-danger"><i class="fa fa-sign-out-alt me-2"></i>Log Out</a>
                        </div>
                    </div>
                </div>
            </nav>
            <!-- Navbar End -->

            <!-- Profile Content -->
            <div class="container-fluid pt-4 px-4">
                <!-- Flash Messages -->
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
                
                <div class="row g-4">
                    <!-- Profile Card -->
                    <div class="col-lg-4">
                        <div class="bg-light rounded p-4">
                            <div class="text-center mb-4">
                                {% if user.avatar %}
                                    <img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" 
                                         alt="{{ user.prenom }}" 
                                         class="profile-avatar mb-3">
                                {% else %}
                                    <div class="profile-initials mx-auto mb-3">
                                        {{ user.prenom|first|upper }}{{ user.nom|first|upper }}
                                    </div>
                                {% endif %}
                                
                                <h4 class="mb-1">{{ user.nom }} {{ user.prenom }}</h4>
                                <p class="text-muted mb-3">{{ user.email }}</p>
                                <span class="badge bg-danger">{{ user.role.getLabel() }}</span>
                            </div>
                            
                            <hr class="my-4">
                            
                            <a href="{{ path('admin_profile_edit') }}" class="btn btn-primary w-100 edit-profile-btn">
                                <i class="fa fa-edit me-2"></i>Edit Profile
                            </a>
                        </div>
                    </div>
                    
                    <!-- Profile Information -->
                    <div class="col-lg-8">
                        <div class="bg-light rounded p-4 mb-4">
                            <h5 class="mb-4">
                                <i class="fa fa-user me-2 text-primary"></i>
                                Personal Information
                            </h5>
                            
                            <div class="info-row row">
                                <div class="col-sm-4 info-label">First Name:</div>
                                <div class="col-sm-8 info-value">{{ user.prenom }}</div>
                            </div>
                            <hr>
                            
                            <div class="info-row row">
                                <div class="col-sm-4 info-label">Last Name:</div>
                                <div class="col-sm-8 info-value">{{ user.nom }}</div>
                            </div>
                            <hr>
                            
                            <div class="info-row row">
                                <div class="col-sm-4 info-label">Email:</div>
                                <div class="col-sm-8 info-value">{{ user.email }}</div>
                            </div>
                            <hr>
                            
                            <div class="info-row row">
                                <div class="col-sm-4 info-label">Role:</div>
                                <div class="col-sm-8">
                                    <span class="badge bg-danger">{{ user.role.getLabel() }}</span>
                                </div>
                            </div>
                            <hr>
                            
                            <div class="info-row row">
                                <div class="col-sm-4 info-label">Status:</div>
                                <div class="col-sm-8">
                                    {% if user.statut.value == 'actif' %}
                                        <span class="badge bg-success">{{ user.statut.getLabel() }}</span>
                                    {% elseif user.statut.value == 'bloque' %}
                                        <span class="badge bg-danger">{{ user.statut.getLabel() }}</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ user.statut.getLabel() }}</span>
                                    {% endif %}
                                </div>
                            </div>
                            <hr>
                            
                            <div class="info-row row">
                                <div class="col-sm-4 info-label">Account Created:</div>
                                <div class="col-sm-8 info-value">{{ user.createdAt|date('F d, Y') }}</div>
                            </div>
                            
                            {% if user.updatedAt %}
                            <hr>
                            <div class="info-row row">
                                <div class="col-sm-4 info-label">Last Updated:</div>
                                <div class="col-sm-8 info-value">{{ user.updatedAt|date('F d, Y') }}</div>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="container-fluid pt-4 px-4">
                <div class="bg-light rounded-top p-4">
                    <div class="row">
                        <div class="col-12 text-center">
                             Bekri Wellbeing Platform, All Rights Reserved.
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Content End -->
    </div>

    <!-- JavaScript Libraries -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="{{ asset('admin/js/main.js') }}"></script>
</body>
</html>
