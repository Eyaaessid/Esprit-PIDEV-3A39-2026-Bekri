{% extends 'admin/base.html.twig' %}

{% block title %}Add User - DASHMIN{% endblock %}

{% block content %}
    <!-- Add User Form -->
    <div class="container-fluid pt-4 px-4">
        <div class="mb-3">
            <a href="{{ path('admin_users_list') }}" class="btn btn-secondary">
                <i class="fa fa-arrow-left me-2"></i>Back to Users List
            </a>
        </div>

        <!-- Flash Messages -->
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show">
                <i class="fa fa-check-circle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
                
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="fa fa-exclamation-triangle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        <div class="row g-4">
            <div class="col-12">
                <div class="bg-light rounded p-4">
                    <h5 class="mb-4"><i class="fa fa-user-plus me-2"></i>Add New User</h5>
                            
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}
                            
                    <div class="row mb-3">
                        <div class="col-md-6">
                            {{ form_row(form.prenom) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.nom) }}
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            {{ form_row(form.email) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.telephone) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_row(form.dateNaissance) }}
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            {{ form_row(form.role) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.statut) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_row(form.avatarFile) }}
                    </div>

                    <hr class="my-4">
                    <h6 class="mb-3">Password</h6>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            {{ form_row(form.plainPassword.first) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.plainPassword.second) }}
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a href="{{ path('admin_users_list') }}" class="btn btn-secondary">
                            <i class="fa fa-times me-2"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-save me-2"></i>Create User
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
