<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <title>Connexion - Bekri</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    
    <style>
        /* NOUVEAU DESIGN SIGNIN - VERSION 2 */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #e0f2f7 0%, #f0f8fa 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .login-container {
            background: white;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
            max-width: 480px;
            width: 100%;
            padding: 50px 40px;
            position: relative;
            overflow: hidden;
        }

        .login-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #20b2aa, #3ecdc7);
        }

        .logo-container {
            text-align: center;
            margin-bottom: 35px;
        }

        .logo {
            max-width: 140px;
            height: auto;
            margin-bottom: 10px;
        }

        .welcome-text {
            text-align: center;
            margin-bottom: 40px;
        }

        .welcome-text h1 {
            color: #2c3e50;
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 8px;
            letter-spacing: -0.5px;
        }

        .welcome-text p {
            color: #95a5a6;
            font-size: 15px;
            font-weight: 400;
        }

        .form-group {
            margin-bottom: 24px;
        }

        .form-label {
            display: block;
            color: #2c3e50;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 8px;
        }

        .input-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: #bdc3c7;
            font-size: 18px;
        }

        .form-input {
            width: 100%;
            padding: 16px 18px 16px 52px;
            border: 2px solid #e8eef1;
            border-radius: 12px;
            font-size: 15px;
            color: #2c3e50;
            transition: all 0.3s ease;
            background: #f8fafb;
            font-family: 'Inter', sans-serif;
        }

        .form-input:focus {
            outline: none;
            border-color: #20b2aa;
            background: white;
            box-shadow: 0 0 0 4px rgba(32, 178, 170, 0.08);
        }

        .form-input::placeholder {
            color: #bdc3c7;
        }

        .form-options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 28px;
        }

        .remember-me {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
        }

        .remember-me input[type="checkbox"] {
            width: 18px;
            height: 18px;
            border: 2px solid #dfe6e9;
            border-radius: 4px;
            cursor: pointer;
            accent-color: #20b2aa;
        }

        .remember-me label {
            color: #7f8c8d;
            font-size: 14px;
            cursor: pointer;
            user-select: none;
        }

        .forgot-password {
            color: #20b2aa;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .forgot-password:hover {
            color: #1a8f89;
            transform: translateX(2px);
        }

        .forgot-password i {
            font-size: 12px;
        }

        .btn-login {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #20b2aa 0%, #3ecdc7 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 4px 15px rgba(32, 178, 170, 0.3);
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(32, 178, 170, 0.4);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        /* Face Login Button */
        .btn-face-login {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
            margin-top: 12px;
        }

        .btn-face-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        }

        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 24px 0;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid #e8eef1;
        }

        .divider span {
            padding: 0 16px;
            color: #95a5a6;
            font-size: 14px;
            font-weight: 500;
        }

        .signup-link {
            text-align: center;
            margin-top: 28px;
            color: #95a5a6;
            font-size: 14px;
        }

        .signup-link a {
            color: #20b2aa;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s;
        }

        .signup-link a:hover {
            color: #1a8f89;
        }

        .alert {
            padding: 14px 18px;
            border-radius: 10px;
            margin-bottom: 24px;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .alert-danger {
            background: #fff5f5;
            color: #e74c3c;
            border-left: 4px solid #e74c3c;
        }

        .alert-success {
            background: #f0fdf4;
            color: #059669;
            border-left: 4px solid #10b981;
        }

        @media (max-width: 576px) {
            .login-container {
                padding: 40px 28px;
            }

            .welcome-text h1 {
                font-size: 26px;
            }

            .form-input {
                padding: 14px 16px 14px 48px;
            }
            
            .form-options {
                flex-direction: column;
                gap: 12px;
                align-items: flex-start;
            }
        }

        .btn-login.loading {
            opacity: 0.7;
            cursor: not-allowed;
        }

        .btn-login .spinner {
            display: none;
            width: 18px;
            height: 18px;
            border: 2px solid #ffffff;
            border-top-color: transparent;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }

        .btn-login.loading .spinner {
            display: inline-block;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Honeypot: invisible */
        .captcha-honeypot {
            position: absolute !important;
            left: -9999px !important;
            width: 1px !important;
            height: 1px !important;
            opacity: 0 !important;
            pointer-events: none !important;
        }

        /* CAPTCHA Modal */
        .captcha-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .captcha-modal-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(5px);
        }
        .captcha-modal-content {
            position: relative;
            background: white;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            max-width: 440px;
            width: 100%;
            animation: modalSlideIn 0.3s ease-out;
            overflow: hidden;
        }
        @keyframes modalSlideIn {
            from { opacity: 0; transform: translateY(-40px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .captcha-modal-header {
            background: linear-gradient(135deg, #14b8a6 0%, #0d9488 100%);
            color: white;
            padding: 24px;
            text-align: center;
        }
        .captcha-modal-header i { font-size: 32px; display: block; margin-bottom: 10px; }
        .captcha-modal-header h5 { margin: 0; font-size: 18px; font-weight: 600; }
        .captcha-modal-body { padding: 28px; }
        .captcha-modal-body .captcha-question {
            background: linear-gradient(135deg, #0f766e 0%, #14b8a6 100%);
            color: white;
            padding: 18px 20px;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 500;
            text-align: center;
            margin-bottom: 20px;
            line-height: 1.5;
        }
        .captcha-input-group { margin-top: 8px; }
        .captcha-input-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            color: #2c3e50;
            font-size: 14px;
        }
        .captcha-input-group input {
            width: 100%;
            padding: 14px 16px;
            font-size: 18px;
            text-align: center;
            border: 2px solid #e8eef1;
            border-radius: 10px;
            transition: border-color 0.3s, box-shadow 0.3s;
        }
        .captcha-input-group input:focus {
            outline: none;
            border-color: #14b8a6;
            box-shadow: 0 0 0 4px rgba(20, 184, 166, 0.15);
        }
        .captcha-modal-footer {
            padding: 20px 28px;
            border-top: 1px solid #eee;
            display: flex;
            gap: 12px;
            justify-content: flex-end;
        }
        .captcha-modal-footer .btn-modal {
            padding: 12px 24px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            border: none;
            transition: all 0.2s;
        }
        .captcha-modal-footer .btn-modal-secondary {
            background: #f1f5f9;
            color: #475569;
        }
        .captcha-modal-footer .btn-modal-secondary:hover { background: #e2e8f0; }
        .captcha-modal-footer .btn-modal-primary {
            background: linear-gradient(135deg, #14b8a6 0%, #0d9488 100%);
            color: white;
        }
        .captcha-modal-footer .btn-modal-primary:hover { opacity: 0.95; transform: translateY(-1px); }

        /* Face Login Modal */
        .face-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(5px);
            z-index: 10000;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .face-modal.active {
            display: flex;
        }

        .face-modal-content {
            background: white;
            border-radius: 20px;
            max-width: 600px;
            width: 100%;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            animation: modalSlideIn 0.3s ease-out;
        }

        .face-modal-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 24px;
            border-radius: 20px 20px 0 0;
            text-align: center;
        }

        .face-modal-body {
            padding: 32px;
        }

        #face-login-video {
            width: 100%;
            border-radius: 12px;
            max-height: 400px;
        }

        .face-status-box {
            margin-top: 20px;
            padding: 16px;
            border-radius: 12px;
            text-align: center;
            font-weight: 500;
        }

        .face-status-box.info {
            background: #e0f2fe;
            color: #0369a1;
        }

        .face-status-box.success {
            background: #d1fae5;
            color: #065f46;
        }

        .face-status-box.error {
            background: #fee2e2;
            color: #991b1b;
        }

        .btn-close-modal {
            background: #e5e7eb;
            color: #374151;
            padding: 12px 24px;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 20px;
            width: 100%;
        }

        .btn-close-modal:hover {
            background: #d1d5db;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="logo-container">
            <img src="{{ asset('images/logo.png') }}" alt="Bekri Logo" class="logo" onerror="this.style.display='none'">
        </div>

        <div class="welcome-text">
            <h1>Bon retour</h1>
            <p>Connectez-vous à votre compte</p>
        </div>

        {% if error %}
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i>
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
            <div style="margin-top: -10px; margin-bottom: 18px; font-size: 14px;">
                <a class="forgot-password" href="{{ path('app_verify_resend', { email: last_username }) }}">
                    <i class="fas fa-envelope"></i>
                    <span>Resend verification email</span>
                </a>
            </div>
        {% endif %}

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i>
                {{ message }}
            </div>
        {% endfor %}

        <form method="post" action="{{ path('app_login') }}" id="loginForm">
            <div class="form-group">
                <label class="form-label" for="email">Adresse email</label>
                <div class="input-wrapper">
                    <i class="fas fa-envelope input-icon"></i>
                    <input 
                        type="email" 
                        class="form-input" 
                        id="email" 
                        name="_username"
                        value="{{ last_username }}"
                        placeholder="nom@exemple.com"
                        required
                        autocomplete="email"
                    >
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Mot de passe</label>
                <div class="input-wrapper">
                    <i class="fas fa-lock input-icon"></i>
                    <input 
                        type="password" 
                        class="form-input" 
                        id="password" 
                        name="_password"
                        placeholder="••••••••"
                        required
                        autocomplete="current-password"
                    >
                    <button type="button" class="toggle-password" style="position: absolute; right: 18px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #bdc3c7; cursor: pointer; padding: 0; font-size: 18px;">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
            </div>

            <div class="form-options">
                <div class="remember-me">
                    <input 
                        type="checkbox" 
                        id="remember_me" 
                        name="_remember_me"
                    >
                    <label for="remember_me">Se souvenir de moi</label>
                </div>
                <a href="{{ path('forgot_password_request') }}" class="forgot-password">
                    <i class="fas fa-key"></i>
                    <span>Mot de passe oublié ?</span>
                </a>
            </div>

            {# Invisible honeypot + timestamp #}
            <input type="text" name="website" value="" tabindex="-1" autocomplete="off" class="captcha-honeypot" aria-hidden="true">
            <input type="hidden" name="form_timestamp" value="{{ 'now'|date('U') }}">

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn-login" id="loginBtn">
                <i class="fas fa-sign-in-alt"></i>
                <span>Se connecter</span>
                <div class="spinner"></div>
            </button>

            <div class="divider">
                <span>OU</span>
            </div>

            <button type="button" class="btn-face-login" id="faceLoginBtn">
                <i class="bi bi-camera-video-fill"></i>
                <span>Se connecter avec Face ID</span>
            </button>

            <div class="signup-link">
                Pas encore de compte ? <a href="{{ path('app_register') }}">Créer un compte</a>
            </div>
            <div class="signup-link mt-2">
                <a href="{{ path('request_reactivation') }}">Compte désactivé par un admin ? Demander une réactivation</a>
            </div>
        </form>
    </div>

    <!-- CAPTCHA Modal (shown when login_attempts >= 2) -->
    <div id="captcha-modal" class="captcha-modal" style="display: none;">
        <div class="captcha-modal-overlay" onclick="closeCaptchaModal()"></div>
        <div class="captcha-modal-content">
            <div class="captcha-modal-header">
                <i class="fas fa-shield-alt"></i>
                <h5>Vérification de sécurité</h5>
            </div>
            <div class="captcha-modal-body">
                <div class="captcha-question">
                    <span id="captcha-question-text">{{ captcha_question|default('')|e('js') }}</span>
                </div>
                <div class="captcha-input-group">
                    <label for="captcha-modal-input">Votre réponse</label>
                    <input type="number" id="captcha-modal-input" class="form-input" placeholder="?" min="0" step="1" autocomplete="off">
                </div>
            </div>
            <div class="captcha-modal-footer">
                <button type="button" class="btn-modal btn-modal-secondary" onclick="closeCaptchaModal()">Annuler</button>
                <button type="button" class="btn-modal btn-modal-primary" onclick="submitCaptchaAndLogin()">Vérifier et connecter</button>
            </div>
        </div>
    </div>

    <!-- Face Login Modal -->
    <div id="face-login-modal" class="face-modal" onclick="if(event.target === this) { document.getElementById('close-face-modal-btn').click(); }">
        <div class="face-modal-content" onclick="event.stopPropagation();">
            <div class="face-modal-header">
                <h3><i class="bi bi-camera-video-fill me-2"></i>Face Authentication</h3>
                <p style="margin: 8px 0 0 0; font-size: 14px; opacity: 0.9;">Look at the camera to sign in</p>
            </div>
            <div class="face-modal-body">
                <div id="face-login-email-step">
                    <label for="face-login-email" style="display: block; margin-bottom: 8px; font-weight: 500;">Enter your email first:</label>
                    <input type="email" id="face-login-email" class="form-input" placeholder="your@email.com" style="margin-bottom: 16px;">
                    <button type="button" class="btn-login" id="start-face-login-btn">
                        <i class="bi bi-camera-video-fill"></i>
                        <span>Start Face Login</span>
                    </button>
                </div>

                <div id="face-login-camera-step" style="display: none;">
                    <video id="face-login-video" autoplay muted></video>
                    <div id="face-login-status" class="face-status-box info">
                        <i class="bi bi-camera-video me-2"></i>
                        <span id="face-login-status-text">Initializing camera...</span>
                    </div>
                </div>

                <button type="button" class="btn-close-modal" id="close-face-modal-btn">
                    <i class="bi bi-x-circle me-2"></i>Cancel
                </button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
    <script>
        // Ensure faceapi is available globally
        if (typeof faceapi === 'undefined') {
            console.error('face-api.js library failed to load');
        }
    </script>
    <script>
        // Password CAPTCHA (existing code)
        var loginAttempts = {{ app.session.get('login_attempts', 0) }};
        var captchaVerified = false;
        var captchaQuestion = {{ captcha_question|default('')|json_encode|raw }};

        function showCaptchaModal(question) {
            document.getElementById('captcha-question-text').textContent = question || captchaQuestion;
            document.getElementById('captcha-modal').style.display = 'flex';
            document.getElementById('captcha-modal-input').value = '';
            setTimeout(function() { document.getElementById('captcha-modal-input').focus(); }, 100);
        }
        function closeCaptchaModal() {
            document.getElementById('captcha-modal').style.display = 'none';
        }
        function submitCaptchaAndLogin() {
            var userAnswer = document.getElementById('captcha-modal-input').value.trim();
            if (!userAnswer) {
                alert('Veuillez entrer une réponse.');
                return;
            }
            var input = document.querySelector('input[name="captcha_answer"]');
            if (!input) {
                input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'captcha_answer';
                document.getElementById('loginForm').appendChild(input);
            }
            input.value = userAnswer;
            captchaVerified = true;
            closeCaptchaModal();
            document.getElementById('loginForm').submit();
        }
        document.addEventListener('DOMContentLoaded', function() {
            var captchaInput = document.getElementById('captcha-modal-input');
            if (captchaInput) {
                captchaInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') { submitCaptchaAndLogin(); }
                });
            }
        });
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            var honeypot = document.querySelector('input[name="website"]');
            if (honeypot && honeypot.value !== '') {
                e.preventDefault();
                return false;
            }
            var ts = parseInt(document.querySelector('input[name="form_timestamp"]').value, 10);
            if (ts && (Math.floor(Date.now() / 1000) - ts) < 3) {
                e.preventDefault();
                alert('Veuillez patienter quelques secondes avant de vous connecter.');
                return false;
            }
            if (loginAttempts >= 2 && !captchaVerified) {
                e.preventDefault();
                showCaptchaModal();
                return false;
            }
            var btn = document.getElementById('loginBtn');
            btn.classList.add('loading');
            btn.querySelector('span').textContent = 'Connexion...';
        });

        // FACE LOGIN FUNCTIONALITY
        let faceLoginStream = null;
        
        // Security settings
        const MIN_DETECTION_CONFIDENCE = 0.5; // Minimum confidence score (0-1)
        const MIN_DETECTION_DURATION = 2000; // Minimum milliseconds face must be detected before authentication (longer for login)
        const MIN_FACE_SIZE = 100; // Minimum face size in pixels
        
        let faceLoginDetectedStartTime = null;
        let lastLoginDetectionConfidence = 0;
        
        const faceLoginModal = document.getElementById('face-login-modal');
        const faceLoginBtn = document.getElementById('faceLoginBtn');
        const startFaceLoginBtn = document.getElementById('start-face-login-btn');
        const closeFaceModalBtn = document.getElementById('close-face-modal-btn');
        const faceLoginEmail = document.getElementById('face-login-email');
        const faceLoginVideo = document.getElementById('face-login-video');
        const faceLoginStatus = document.getElementById('face-login-status');
        const faceLoginStatusText = document.getElementById('face-login-status-text');
        const emailStep = document.getElementById('face-login-email-step');
        const cameraStep = document.getElementById('face-login-camera-step');

        // Open face login modal
        faceLoginBtn.addEventListener('click', function() {
            faceLoginModal.classList.add('active');
            // Pre-fill email if available
            const emailInput = document.getElementById('email');
            if (emailInput && emailInput.value) {
                faceLoginEmail.value = emailInput.value;
            }
        });

        // Close face login modal
        closeFaceModalBtn.addEventListener('click', function() {
            stopFaceLoginCamera();
            isAuthenticating = false;
            detectionRunning = false;
            faceLoginDetectedStartTime = null;
            lastLoginDetectionConfidence = 0;
            faceLoginModal.classList.remove('active');
            emailStep.style.display = 'block';
            cameraStep.style.display = 'none';
            faceLoginStatusText.textContent = 'Initializing camera...';
            faceLoginStatus.className = 'face-status-box info';
        });

        // Start face login process
        startFaceLoginBtn.addEventListener('click', async function() {
            const email = faceLoginEmail.value.trim();
            if (!email || !email.includes('@')) {
                alert('Please enter a valid email address');
                return;
            }

            // Reset state
            isAuthenticating = false;
            detectionRunning = false;
            faceLoginDetectedStartTime = null;
            lastLoginDetectionConfidence = 0;
            
            emailStep.style.display = 'none';
            cameraStep.style.display = 'block';

            // Load models first
            const modelsLoaded = await loadFaceLoginModels();
            if (!modelsLoaded) {
                emailStep.style.display = 'block';
                cameraStep.style.display = 'none';
                return;
            }

            // Start camera after models are loaded
            await startFaceLoginCamera(email);
        });

        // Load face-api models
        async function loadFaceLoginModels() {
            const MODEL_URL = 'https://justadudewhohacks.github.io/face-api.js/models';
            try {
                faceLoginStatusText.textContent = 'Loading AI models...';
                faceLoginStatus.className = 'face-status-box info';
                await faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL);
                await faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL);
                await faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL);
                console.log('Face models loaded successfully');
                return true;
            } catch (error) {
                console.error('Error loading models:', error);
                showFaceLoginError('Failed to load face recognition models. Please refresh and try again.');
                return false;
            }
        }

        // Start camera for face login
        async function startFaceLoginCamera(email) {
            try {
                faceLoginStatusText.textContent = 'Starting camera...';
                faceLoginStatus.className = 'face-status-box info';
                
                const stream = await navigator.mediaDevices.getUserMedia({ 
                    video: { 
                        width: { ideal: 1280 },
                        height: { ideal: 720 },
                        facingMode: 'user'
                    } 
                });
                
                faceLoginVideo.srcObject = stream;
                faceLoginStream = stream;
                
                // Wait for video to be ready
                await new Promise((resolve) => {
                    faceLoginVideo.onloadedmetadata = () => {
                        faceLoginVideo.play().then(() => {
                            faceLoginStatusText.textContent = 'Camera ready. Position your face in the frame...';
                            faceLoginStatus.className = 'face-status-box info';
                            resolve();
                        });
                    };
                });
                
                // Start face detection and authentication loop
                detectAndAuthenticateFace(email);
                
            } catch (error) {
                console.error('Camera error:', error);
                showFaceLoginError('Unable to access camera. Please check permissions.');
            }
        }

        // Stop camera
        function stopFaceLoginCamera() {
            if (faceLoginStream) {
                faceLoginStream.getTracks().forEach(track => track.stop());
                faceLoginStream = null;
            }
            if (faceLoginVideo.srcObject) {
                faceLoginVideo.srcObject = null;
            }
            isAuthenticating = false;
            detectionRunning = false;
        }

        // Detect face and authenticate
        let isAuthenticating = false;
        let detectionRunning = false;
        
        async function detectAndAuthenticateFace(email) {
            if (!faceLoginStream || !faceLoginVideo.srcObject) return;
            if (isAuthenticating) return; // Don't start new detection if already authenticating
            
            detectionRunning = true;
            
            try {
                const detection = await faceapi
                    .detectSingleFace(faceLoginVideo, new faceapi.TinyFaceDetectorOptions({ 
                        inputSize: 512, // Higher resolution for better accuracy
                        scoreThreshold: MIN_DETECTION_CONFIDENCE 
                    }))
                    .withFaceLandmarks()
                    .withFaceDescriptor();
                
                if (detection && detection.detection) {
                    const confidence = detection.detection.score;
                    const box = detection.detection.box;
                    const faceSize = Math.max(box.width, box.height);
                    
                    // Check confidence threshold
                    if (confidence < MIN_DETECTION_CONFIDENCE) {
                        faceLoginStatusText.textContent = `Low detection quality (${Math.round(confidence * 100)}%). Please ensure good lighting and look directly at the camera.`;
                        faceLoginStatus.className = 'face-status-box error';
                        faceLoginDetectedStartTime = null;
                        
                        if (faceLoginStream && faceLoginVideo.srcObject) {
                            requestAnimationFrame(() => detectAndAuthenticateFace(email));
                        }
                        return;
                    }
                    
                    // Check minimum face size
                    if (faceSize < MIN_FACE_SIZE) {
                        faceLoginStatusText.textContent = 'Move closer to the camera for better detection.';
                        faceLoginStatus.className = 'face-status-box error';
                        faceLoginDetectedStartTime = null;
                        
                        if (faceLoginStream && faceLoginVideo.srcObject) {
                            requestAnimationFrame(() => detectAndAuthenticateFace(email));
                        }
                        return;
                    }
                    
                    // Track detection duration
                    const now = Date.now();
                    if (!faceLoginDetectedStartTime) {
                        faceLoginDetectedStartTime = now;
                    }
                    
                    const detectionDuration = now - faceLoginDetectedStartTime;
                    lastLoginDetectionConfidence = confidence;
                    
                    // Require minimum detection duration before authenticating
                    if (detectionDuration < MIN_DETECTION_DURATION) {
                        const remainingTime = Math.ceil((MIN_DETECTION_DURATION - detectionDuration) / 1000);
                        faceLoginStatusText.textContent = `Face detected (${Math.round(confidence * 100)}% confidence). Hold still for ${remainingTime} more second${remainingTime !== 1 ? 's' : ''}...`;
                        faceLoginStatus.className = 'face-status-box info';
                        
                        if (faceLoginStream && faceLoginVideo.srcObject) {
                            requestAnimationFrame(() => detectAndAuthenticateFace(email));
                        }
                        return;
                    }
                    
                    // Face detected with good confidence, size, and duration
                    if (!isAuthenticating) {
                        isAuthenticating = true;
                        faceLoginStatusText.textContent = `Face detected! (${Math.round(confidence * 100)}% confidence) Authenticating...`;
                        faceLoginStatus.className = 'face-status-box info';
                        
                        const descriptor = Array.from(detection.descriptor);
                        
                        try {
                            // Send to server for authentication
                            const response = await fetch('/api/face-auth/login', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                },
                                body: JSON.stringify({
                                    email: email,
                                    descriptor: descriptor
                                })
                            });
                            
                            const data = await response.json();
                            
                            if (data.success) {
                                showFaceLoginSuccess('Authentication successful! Redirecting...');
                                stopFaceLoginCamera();
                                
                                // Redirect to URL provided by backend
                                // The backend has already authenticated the user and set the session
                                setTimeout(() => {
                                    if (data.redirectUrl) {
                                        // Use the redirect URL from backend
                                        window.location.href = data.redirectUrl;
                                    } else {
                                        // Fallback to role-based redirect if redirectUrl not provided
                                        if (data.user.role === 'admin') {
                                            window.location.href = '/admin';
                                        } else if (data.user.role === 'coach') {
                                            window.location.href = '/coach';
                                        } else {
                                            window.location.href = '/user';
                                        }
                                    }
                                }, 500);
                                return; // Stop detection loop
                            } else {
                                if (data.lockoutTime) {
                                    showFaceLoginError(`Too many failed attempts. Try again in ${data.lockoutTime} minutes.`);
                                    stopFaceLoginCamera();
                                    return; // Stop detection loop
                                } else {
                                    // If user is not verified, stop retry loop
                                    if (data.message && data.message.includes('verify your email')) {
                                        showFaceLoginError(data.message);
                                        stopFaceLoginCamera();
                                        isAuthenticating = false;
                                        return;
                                    }

                                    faceLoginStatusText.textContent = data.message || 'Face not recognized. Please try again...';
                                    faceLoginStatus.className = 'face-status-box error';
                                    isAuthenticating = false;
                                    // Wait a bit before continuing detection
                                    setTimeout(() => {
                                        if (faceLoginStream) {
                                            detectAndAuthenticateFace(email);
                                        }
                                    }, 2000);
                                    return;
                                }
                            }
                        } catch (fetchError) {
                            console.error('Authentication request error:', fetchError);
                            faceLoginStatusText.textContent = 'Network error. Please try again...';
                            faceLoginStatus.className = 'face-status-box error';
                            isAuthenticating = false;
                            setTimeout(() => {
                                if (faceLoginStream) {
                                    detectAndAuthenticateFace(email);
                                }
                            }, 2000);
                            return;
                        }
                    }
                } else {
                    // No face detected
                    if (!isAuthenticating) {
                        faceLoginStatusText.textContent = 'No face detected. Position your face in the frame...';
                        faceLoginStatus.className = 'face-status-box info';
                    }
                    faceLoginDetectedStartTime = null;
                    // Continue detection loop
                    if (faceLoginStream && faceLoginVideo.srcObject) {
                        requestAnimationFrame(() => detectAndAuthenticateFace(email));
                    }
                }
            } catch (error) {
                console.error('Face detection error:', error);
                isAuthenticating = false;
                faceLoginDetectedStartTime = null;
                // Continue detection loop even on error
                if (faceLoginStream && faceLoginVideo.srcObject) {
                    requestAnimationFrame(() => detectAndAuthenticateFace(email));
                }
            }
        }

        function showFaceLoginSuccess(message) {
            faceLoginStatusText.textContent = message;
            faceLoginStatus.className = 'face-status-box success';
        }

        function showFaceLoginError(message) {
            faceLoginStatusText.textContent = message;
            faceLoginStatus.className = 'face-status-box error';
        }

        // Password visibility toggle
        document.addEventListener('DOMContentLoaded', function() {
            const togglePassword = document.querySelector('.toggle-password');
            if (togglePassword) {
                togglePassword.addEventListener('click', function() {
                    const input = document.getElementById('password');
                    const icon = this.querySelector('i');
                    
                    if (input.type === 'password') {
                        input.type = 'text';
                        icon.classList.remove('fa-eye');
                        icon.classList.add('fa-eye-slash');
                    } else {
                        input.type = 'password';
                        icon.classList.remove('fa-eye-slash');
                        icon.classList.add('fa-eye');
                    }
                });
            }
        });
    </script>
</body>
</html>