<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <title>Connexion - Bekri</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --teal:       #20b2aa;
            --teal-dark:  #0d9488;
            --teal-light: #e0f7f6;
            --purple:     #667eea;
            --dark:       #1a2332;
            --gray:       #64748b;
            --white:      #ffffff;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            background: var(--dark);
        }

        /* ── LEFT PANEL ──────────────────────────────────────────────── */
        .left-panel {
            flex: 1;
            background: linear-gradient(135deg, #0d9488 0%, #20b2aa 45%, #667eea 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 60px 48px;
            position: relative;
            overflow: hidden;
        }

        .left-panel::before {
            content: '';
            position: absolute;
            top: -80px; right: -80px;
            width: 300px; height: 300px;
            background: rgba(255,255,255,0.06);
            border-radius: 50%;
        }

        .left-panel::after {
            content: '';
            position: absolute;
            bottom: -60px; left: -60px;
            width: 250px; height: 250px;
            background: rgba(255,255,255,0.04);
            border-radius: 50%;
        }

        .left-content {
            position: relative;
            z-index: 1;
            text-align: center;
            max-width: 400px;
        }

        .left-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-bottom: 48px;
        }

        .left-logo img { height: 48px; width: auto; }

        .left-logo-text {
            font-size: 28px;
            font-weight: 800;
            color: white;
            letter-spacing: -0.5px;
        }

        .left-title {
            font-size: 36px;
            font-weight: 800;
            color: white;
            line-height: 1.2;
            margin-bottom: 16px;
            letter-spacing: -0.5px;
        }

        .left-title span {
            background: linear-gradient(135deg, #a7f3d0, #bfdbfe);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .left-subtitle {
            font-size: 16px;
            color: rgba(255,255,255,0.8);
            line-height: 1.7;
            margin-bottom: 48px;
        }

        .left-features {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .left-feature {
            display: flex;
            align-items: center;
            gap: 14px;
            background: rgba(255,255,255,0.12);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 14px;
            padding: 14px 18px;
            text-align: left;
        }

        .left-feature-icon {
            width: 40px; height: 40px;
            background: rgba(255,255,255,0.2);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: white;
            flex-shrink: 0;
        }

        .left-feature-text {
            font-size: 14px;
            font-weight: 500;
            color: white;
        }

        .left-feature-sub {
            font-size: 12px;
            color: rgba(255,255,255,0.65);
            margin-top: 2px;
        }

        /* ── RIGHT PANEL ───────��─────────────────────────────────────── */
        .right-panel {
            width: 520px;
            background: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 48px 52px;
            overflow-y: auto;
        }

        .form-header { margin-bottom: 36px; }

        .form-header h1 {
            font-size: 30px;
            font-weight: 800;
            color: var(--dark);
            letter-spacing: -0.5px;
            margin-bottom: 8px;
        }

        .form-header p { font-size: 15px; color: var(--gray); }

        .form-group { margin-bottom: 22px; }

        .form-label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--dark);
            margin-bottom: 8px;
        }

        .input-wrapper { position: relative; }

        .input-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #cbd5e1;
            font-size: 16px;
            pointer-events: none;
        }

        .form-input {
            width: 100%;
            padding: 14px 16px 14px 46px;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            font-size: 15px;
            color: var(--dark);
            font-family: 'Inter', sans-serif;
            background: #f8fafc;
            transition: all 0.25s;
        }

        .form-input:focus {
            outline: none;
            border-color: var(--teal);
            background: white;
            box-shadow: 0 0 0 4px rgba(32,178,170,0.1);
        }

        .form-input::placeholder { color: #cbd5e1; }

        .toggle-password {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #94a3b8;
            cursor: pointer;
            font-size: 16px;
            padding: 0;
            transition: color 0.2s;
        }

        .toggle-password:hover { color: var(--teal); }

        .form-options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 28px;
        }

        .remember-me {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .remember-me input[type="checkbox"] {
            width: 16px; height: 16px;
            accent-color: var(--teal);
            cursor: pointer;
        }

        .remember-me label {
            font-size: 14px;
            color: var(--gray);
            cursor: pointer;
        }

        .forgot-link {
            font-size: 14px;
            font-weight: 600;
            color: var(--teal);
            text-decoration: none;
            transition: color 0.2s;
        }

        .forgot-link:hover { color: var(--teal-dark); }

        .btn-primary {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, var(--teal) 0%, var(--teal-dark) 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 4px 15px rgba(32,178,170,0.3);
            font-family: 'Inter', sans-serif;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(32,178,170,0.4);
        }

        .btn-primary:active { transform: translateY(0); }

        .btn-face {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, var(--purple) 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 4px 15px rgba(102,126,234,0.3);
            font-family: 'Inter', sans-serif;
        }

        .btn-face:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(102,126,234,0.4);
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 16px;
            margin: 20px 0;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e2e8f0;
        }

        .divider span {
            font-size: 13px;
            color: #94a3b8;
            font-weight: 500;
        }

        .form-footer {
            text-align: center;
            margin-top: 24px;
            font-size: 14px;
            color: var(--gray);
        }

        .form-footer a {
            color: var(--teal);
            font-weight: 600;
            text-decoration: none;
        }

        .form-footer a:hover { text-decoration: underline; }

        .form-footer-secondary {
            text-align: center;
            margin-top: 10px;
            font-size: 13px;
        }

        .form-footer-secondary a {
            color: var(--gray);
            text-decoration: none;
            transition: color 0.2s;
        }

        .form-footer-secondary a:hover { color: var(--teal); }

        .alert {
            padding: 14px 16px;
            border-radius: 12px;
            margin-bottom: 20px;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            line-height: 1.5;
        }

        .alert-danger  { background: #fff5f5; color: #dc2626; border-left: 4px solid #ef4444; }
        .alert-success { background: #f0fdf4; color: #166534; border-left: 4px solid #22c55e; }

        .spinner {
            display: none;
            width: 18px; height: 18px;
            border: 2px solid rgba(255,255,255,0.4);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }

        .btn-primary.loading .spinner { display: inline-block; }
        .btn-primary.loading { opacity: 0.75; cursor: not-allowed; }

        @keyframes spin { to { transform: rotate(360deg); } }

        .captcha-honeypot {
            position: absolute !important;
            left: -9999px !important;
            width: 1px !important; height: 1px !important;
            opacity: 0 !important; pointer-events: none !important;
        }

        /* ── CAPTCHA MODAL ───────────────────────────────────────────── */
        .modal-overlay {
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(6px);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .modal-box {
            background: white;
            border-radius: 20px;
            max-width: 440px;
            width: 100%;
            overflow: hidden;
            box-shadow: 0 24px 70px rgba(0,0,0,0.25);
            animation: modalIn 0.3s ease-out;
        }

        @keyframes modalIn {
            from { opacity:0; transform: translateY(-30px); }
            to   { opacity:1; transform: translateY(0); }
        }

        .modal-header {
            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
            padding: 24px;
            text-align: center;
            color: white;
        }

        .modal-header i  { font-size: 32px; display: block; margin-bottom: 10px; }
        .modal-header h5 { margin: 0; font-size: 18px; font-weight: 700; }

        .modal-body { padding: 28px; }

        .captcha-q {
            background: linear-gradient(135deg, var(--teal-dark), var(--teal));
            color: white;
            padding: 18px;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            text-align: center;
            margin-bottom: 20px;
        }

        .modal-body input {
            width: 100%;
            padding: 14px;
            font-size: 18px;
            text-align: center;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            transition: all 0.25s;
        }

        .modal-body input:focus {
            outline: none;
            border-color: var(--teal);
            box-shadow: 0 0 0 4px rgba(32,178,170,0.1);
        }

        .modal-footer {
            padding: 20px 28px;
            border-top: 1px solid #f1f5f9;
            display: flex;
            gap: 12px;
            justify-content: flex-end;
        }

        .btn-modal-cancel {
            padding: 11px 22px;
            background: #f1f5f9;
            color: #475569;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            font-family: 'Inter', sans-serif;
        }

        .btn-modal-cancel:hover { background: #e2e8f0; }

        .btn-modal-confirm {
            padding: 11px 22px;
            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            font-family: 'Inter', sans-serif;
        }

        /* ── 2FA MODAL ───────────────────────────────────────────────── */
        #twofa-login-overlay {
            display: none;
            position: fixed; inset: 0;
            z-index: 10100;
            background: rgba(0,0,0,0.55);
            backdrop-filter: blur(6px);
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        #twofa-login-overlay.active { display: flex; }

        #twofa-login-box {
            background: white;
            border-radius: 20px;
            max-width: 420px;
            width: 100%;
            box-shadow: 0 24px 70px rgba(0,0,0,0.25);
            overflow: hidden;
            animation: modalIn 0.3s ease-out;
        }

        .twofa-bar { height: 4px; background: linear-gradient(90deg, var(--teal), var(--purple)); }
        .twofa-body { padding: 36px 32px 28px; }

        .twofa-icon-ring {
            width: 72px; height: 72px;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(32,178,170,0.1), rgba(62,205,199,0.1));
            border: 3px solid rgba(32,178,170,0.25);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: var(--teal);
            margin: 0 auto 16px;
            animation: twofaPulse 2s ease-in-out infinite;
        }

        @keyframes twofaPulse {
            0%,100% { box-shadow: 0 0 0 0 rgba(32,178,170,0.3); }
            50%      { box-shadow: 0 0 0 12px rgba(32,178,170,0); }
        }

        .twofa-digits-row {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-bottom: 24px;
        }

        .twofa-digit {
            width: 48px; height: 58px;
            text-align: center;
            font-size: 1.6rem;
            font-weight: 700;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            background: white;
            color: var(--dark);
            outline: none;
            transition: all 0.2s;
            font-family: 'Inter', sans-serif;
        }

        .twofa-digit:focus  { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(32,178,170,0.15); transform: scale(1.05); }
        .twofa-digit.filled { border-color: var(--teal); background: #f0fffe; }
        .twofa-digit.error  { border-color: #ef4444 !important; background: #fff5f5 !important; }
        .twofa-digit-sep    { color: #94a3b8; font-size: 1.2rem; }

        @keyframes twofaShake {
            0%,100% { transform: translateX(0); }
            20%     { transform: translateX(-6px); }
            40%     { transform: translateX(6px); }
            60%     { transform: translateX(-4px); }
            80%     { transform: translateX(4px); }
        }

        .twofa-digit.shake { animation: twofaShake 0.35s ease; }

        .twofa-submit-btn {
            background: linear-gradient(135deg, var(--teal), var(--teal-dark));
            border: none;
            color: white;
            width: 100%;
            padding: 14px;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(32,178,170,0.3);
            font-family: 'Inter', sans-serif;
        }

        .twofa-submit-btn:not(:disabled):hover { transform: translateY(-2px); }
        .twofa-submit-btn:disabled { opacity: 0.55; cursor: not-allowed; }

        .twofa-spinner {
            display: inline-block;
            width: 16px; height: 16px;
            border: 2px solid rgba(255,255,255,0.4);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            vertical-align: middle;
            margin-right: 6px;
        }

        /* ── FACE MODAL ──────────────────────────────────────────────── */
        .face-modal {
            display: none;
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(5px);
            z-index: 10000;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .face-modal.active { display: flex; }

        .face-modal-content {
            background: white;
            border-radius: 20px;
            max-width: 560px;
            width: 100%;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            animation: modalIn 0.3s ease-out;
        }

        .face-modal-header {
            background: linear-gradient(135deg, var(--purple), #764ba2);
            color: white;
            padding: 24px;
            border-radius: 20px 20px 0 0;
            text-align: center;
        }

        .face-modal-body { padding: 28px; }

        #face-login-video {
            width: 100%;
            border-radius: 12px;
            max-height: 360px;
        }

        .face-status-box {
            margin-top: 16px;
            padding: 14px 16px;
            border-radius: 12px;
            text-align: center;
            font-weight: 500;
            font-size: 14px;
        }

        .face-status-box.info    { background: #e0f2fe; color: #0369a1; }
        .face-status-box.success { background: #d1fae5; color: #065f46; }
        .face-status-box.error   { background: #fee2e2; color: #991b1b; }

        .btn-close-face {
            background: #f1f5f9;
            color: var(--dark);
            padding: 12px;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 16px;
            width: 100%;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
        }

        .btn-close-face:hover { background: #e2e8f0; }

        /* ── RESPONSIVE ──────────────────────────────────────────────── */
        @media (max-width: 1024px) { .left-panel { display: none; } }
        @media (max-width: 600px)  { .right-panel { width: 100%; padding: 36px 24px; } }
    </style>
</head>
<body>

    <!-- LEFT PANEL -->
    <div class="left-panel">
        <div class="left-content">
            <div class="left-logo">
                <img src="{{ asset('images/logo.png') }}" alt="Bekri" onerror="this.style.display='none'">
                <span class="left-logo-text">Bekri</span>
            </div>
            <h1 class="left-title">Prenez soin de<br><span>votre bien-être</span><br>chaque jour</h1>
            <p class="left-subtitle">Une plateforme dédiée à la prévention mentale et physique, conçue pour vous accompagner au quotidien.</p>
            <div class="left-features">
                <div class="left-feature">
                    <div class="left-feature-icon"><i class="bi bi-clipboard2-pulse-fill"></i></div>
                    <div>
                        <div class="left-feature-text">Suivi quotidien</div>
                        <div class="left-feature-sub">Humeur, sommeil, activité & nutrition</div>
                    </div>
                </div>
                <div class="left-feature">
                    <div class="left-feature-icon"><i class="bi bi-graph-up-arrow"></i></div>
                    <div>
                        <div class="left-feature-text">Insights hebdomadaires IA</div>
                        <div class="left-feature-sub">Analyses personnalisées chaque semaine</div>
                    </div>
                </div>
                <div class="left-feature">
                    <div class="left-feature-icon"><i class="bi bi-robot"></i></div>
                    <div>
                        <div class="left-feature-text">Coach Eya — IA bien-être</div>
                        <div class="left-feature-sub">Disponible 24h/24 en français & anglais</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT PANEL -->
    <div class="right-panel">
        <div class="form-header">
            <h1>Bon retour 👋</h1>
            <p>Connectez-vous à votre espace bien-être</p>
        </div>

        {% if error %}
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i>
                <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
            </div>
        {% endif %}

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i>
                <span>{{ message }}</span>
            </div>
        {% endfor %}

        <form method="post" action="{{ path('app_login') }}" id="loginForm">

            <div class="form-group">
                <label class="form-label">Adresse email</label>
                <div class="input-wrapper">
                    <i class="fas fa-envelope input-icon"></i>
                    <input type="email" class="form-input" name="_username"
                           value="{{ last_username }}" placeholder="nom@exemple.com"
                           required autocomplete="email">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Mot de passe</label>
                <div class="input-wrapper">
                    <i class="fas fa-lock input-icon"></i>
                    <input type="password" class="form-input" id="password"
                           name="_password" placeholder="••••••••"
                           required autocomplete="current-password">
                    <button type="button" class="toggle-password" id="togglePwd">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
            </div>

            <div class="form-options">
                <div class="remember-me">
                    <input type="checkbox" id="remember_me" name="_remember_me">
                    <label for="remember_me">Se souvenir de moi</label>
                </div>
                <a href="{{ path('forgot_password_request') }}" class="forgot-link">Mot de passe oublié ?</a>
            </div>

            <input type="text" name="website" value="" tabindex="-1" autocomplete="off" class="captcha-honeypot" aria-hidden="true">
            <input type="hidden" name="form_timestamp" value="{{ 'now'|date('U') }}">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn-primary" id="loginBtn">
                <i class="bi bi-box-arrow-in-right"></i>
                <span>Se connecter</span>
                <div class="spinner"></div>
            </button>

            <div class="divider"><span>OU</span></div>

            <button type="button" class="btn-face" id="faceLoginBtn">
                <i class="bi bi-camera-video-fill"></i>
                <span>Se connecter avec Face ID</span>
            </button>

            <div class="form-footer">
                Pas encore de compte ? <a href="{{ path('app_register') }}">Créer un compte</a>
            </div>
            <div class="form-footer-secondary">
                <a href="{{ path('request_reactivation') }}">Compte désactivé ? Demander une réactivation</a>
            </div>
        </form>
    </div>

    <!-- 2FA Modal -->
    <div id="twofa-login-overlay">
        <div id="twofa-login-box">
            <div class="twofa-bar"></div>
            <div class="twofa-body">
                <div style="text-align:center; margin-bottom:20px;">
                    <img src="{{ asset('images/logo.png') }}" alt="Bekri" style="max-width:64px;" onerror="this.style.display='none'">
                </div>
                <div style="text-align:center; margin-bottom:24px;">
                    <div class="twofa-icon-ring"><i class="bi bi-shield-lock-fill"></i></div>
                    <h5 style="color:var(--dark);font-weight:800;margin:12px 0 6px;">Authentification à deux facteurs</h5>
                    <p style="color:var(--gray);font-size:14px;">Entrez le code à 6 chiffres de votre application TOTP</p>
                </div>
                <div id="twofa-login-error" style="display:none;background:#fff5f5;color:#dc2626;border-left:4px solid #ef4444;padding:12px 16px;border-radius:10px;font-size:14px;margin-bottom:18px;align-items:center;gap:10px;">
                    <i class="fas fa-exclamation-circle"></i>
                    <span id="twofa-login-error-text">Code incorrect. Réessayez.</span>
                </div>
                <div class="twofa-digits-row" id="twofa-login-digits" style="margin-bottom:24px;">
                    <input type="text" class="twofa-digit" maxlength="1" inputmode="numeric" autocomplete="one-time-code">
                    <input type="text" class="twofa-digit" maxlength="1" inputmode="numeric">
                    <input type="text" class="twofa-digit" maxlength="1" inputmode="numeric">
                    <span class="twofa-digit-sep">—</span>
                    <input type="text" class="twofa-digit" maxlength="1" inputmode="numeric">
                    <input type="text" class="twofa-digit" maxlength="1" inputmode="numeric">
                    <input type="text" class="twofa-digit" maxlength="1" inputmode="numeric">
                </div>
                <input type="hidden" id="twofa-login-code" value="">
                <p style="text-align:center;color:var(--gray);font-size:13px;margin-bottom:20px;">
                    <i class="bi bi-clock" style="margin-right:4px;"></i>Code valable 30 secondes
                </p>
                <button type="button" id="twofa-login-submit" class="twofa-submit-btn" disabled>
                    <i class="bi bi-check-circle" style="margin-right:8px;"></i>Vérifier le code
                </button>
                <div style="text-align:center;margin-top:16px;">
                    <a href="{{ path('app_logout') }}" style="color:var(--gray);font-size:14px;text-decoration:none;">
                        <i class="bi bi-arrow-left" style="margin-right:4px;"></i>Annuler et se déconnecter
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- CAPTCHA Modal -->
    <div id="captcha-modal" style="display:none;" class="modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <i class="fas fa-shield-alt"></i>
                <h5>Vérification de sécurité</h5>
            </div>
            <div class="modal-body">
                <div class="captcha-q"><span id="captcha-question-text">{{ captcha_question|default('')|e('html') }}</span></div>
                <input type="number" id="captcha-modal-input" placeholder="?" min="0" step="1" autocomplete="off">
            </div>
            <div class="modal-footer">
                <button class="btn-modal-cancel" onclick="closeCaptchaModal()">Annuler</button>
                <button class="btn-modal-confirm" onclick="submitCaptchaAndLogin()">Vérifier et connecter</button>
            </div>
        </div>
    </div>

    <!-- Face Login Modal -->
    <div id="face-login-modal" class="face-modal" onclick="if(event.target===this)document.getElementById('close-face-modal-btn').click()">
        <div class="face-modal-content" onclick="event.stopPropagation()">
            <div class="face-modal-header">
                <h3><i class="bi bi-camera-video-fill" style="margin-right:8px;"></i>Face Authentication</h3>
                <p style="margin:6px 0 0;font-size:14px;opacity:0.85;">Look at the camera to sign in</p>
            </div>
            <div class="face-modal-body">
                <div id="face-login-email-step">
                    <label style="display:block;margin-bottom:8px;font-weight:600;font-size:14px;">Enter your email first:</label>
                    <input type="email" id="face-login-email" class="form-input" placeholder="your@email.com" style="margin-bottom:16px;padding-left:16px;">
                    <button type="button" class="btn-primary" id="start-face-login-btn">
                        <i class="bi bi-camera-video-fill"></i>
                        <span>Start Face Login</span>
                    </button>
                </div>
                <div id="face-login-camera-step" style="display:none;">
                    <video id="face-login-video" autoplay muted></video>
                    <div id="face-login-status" class="face-status-box info">
                        <i class="bi bi-camera-video" style="margin-right:8px;"></i>
                        <span id="face-login-status-text">Initializing camera...</span>
                    </div>
                </div>
                <button type="button" class="btn-close-face" id="close-face-modal-btn">
                    <i class="bi bi-x-circle" style="margin-right:8px;"></i>Cancel
                </button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
    <script>
        // ── Password toggle ───────────────────────────────────────────
        document.getElementById('togglePwd').addEventListener('click', function() {
            const input = document.getElementById('password');
            const icon  = this.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        });

        // ── CAPTCHA ───────────────────────────────────────────────────
        var loginAttempts   = {{ app.session.get('login_attempts', 0) }};
        var captchaVerified = false;
        var captchaQuestion = {{ captcha_question|default('')|json_encode|raw }};

        function showCaptchaModal() {
            document.getElementById('captcha-question-text').textContent = captchaQuestion;
            document.getElementById('captcha-modal').style.display = 'flex';
            setTimeout(() => document.getElementById('captcha-modal-input').focus(), 100);
        }

        function closeCaptchaModal() {
            document.getElementById('captcha-modal').style.display = 'none';
        }

        function submitCaptchaAndLogin() {
            var ans = document.getElementById('captcha-modal-input').value.trim();
            if (!ans) { alert('Veuillez entrer une réponse.'); return; }
            var input = document.querySelector('input[name="captcha_answer"]');
            if (!input) {
                input = document.createElement('input');
                input.type = 'hidden'; input.name = 'captcha_answer';
                document.getElementById('loginForm').appendChild(input);
            }
            input.value = ans;
            captchaVerified = true;
            closeCaptchaModal();
            document.getElementById('loginForm').requestSubmit
                ? document.getElementById('loginForm').requestSubmit()
                : document.getElementById('loginForm').submit();
        }

        document.getElementById('captcha-modal-input').addEventListener('keypress', e => {
            if (e.key === 'Enter') submitCaptchaAndLogin();
        });

        // ── Login form ────────────────────────────────────────────────
        document.getElementById('loginForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            if (document.querySelector('input[name="website"]').value !== '') return;

            var ts = parseInt(document.querySelector('input[name="form_timestamp"]').value, 10);
            if (ts && (Math.floor(Date.now() / 1000) - ts) < 3) {
                alert('Veuillez patienter quelques secondes.');
                return;
            }

            if (loginAttempts >= 2 && !captchaVerified) { showCaptchaModal(); return; }

            const btn = document.getElementById('loginBtn');
            btn.classList.add('loading');
            btn.querySelector('span').textContent = 'Connexion...';

            let response;
            try {
                response = await fetch(this.action, {
                    method: 'POST', body: new FormData(this),
                    redirect: 'follow', credentials: 'same-origin'
                });
            } catch (err) {
                btn.classList.remove('loading');
                btn.querySelector('span').textContent = 'Se connecter';
                this.submit(); return;
            }

            const finalPath = (() => { try { return new URL(response.url).pathname; } catch(e) { return ''; } })();

            if (finalPath.startsWith('/2fa')) {
                btn.classList.remove('loading');
                btn.querySelector('span').textContent = 'Se connecter';
                openTwofaLoginModal(); return;
            }

            if (finalPath === '/login') {
                btn.classList.remove('loading');
                btn.querySelector('span').textContent = 'Se connecter';
                this.removeEventListener('submit', arguments.callee);
                this.submit(); return;
            }

            window.location.href = response.url || '/';
        });

        // ── 2FA modal ─────────────────────────────────────────────────
        function openTwofaLoginModal() {
            const overlay = document.getElementById('twofa-login-overlay');
            overlay.classList.add('active');
            const digits = [...document.querySelectorAll('#twofa-login-digits .twofa-digit')];
            digits.forEach(d => { d.value = ''; d.classList.remove('filled','error','shake'); });
            document.getElementById('twofa-login-code').value = '';
            document.getElementById('twofa-login-submit').disabled = true;
            document.getElementById('twofa-login-error').style.display = 'none';
            if (digits[0]) setTimeout(() => digits[0].focus(), 150);
            if (!overlay.dataset.wired) { overlay.dataset.wired = '1'; initTwofaDigits(); document.getElementById('twofa-login-submit').addEventListener('click', submitTwofaCode); }
        }

        function initTwofaDigits() {
            const digits = [...document.querySelectorAll('#twofa-login-digits .twofa-digit')];
            const hidden = document.getElementById('twofa-login-code');
            const btn    = document.getElementById('twofa-login-submit');
            const sync   = () => { const v = digits.map(d => d.value).join(''); hidden.value = v; btn.disabled = v.length < 6; digits.forEach(d => d.classList.toggle('filled', d.value !== '')); return v; };
            digits.forEach((d, i) => {
                d.addEventListener('keydown', e => { if (e.key === 'Backspace' && !d.value && i > 0) digits[i-1].focus(); });
                d.addEventListener('input', () => { d.value = d.value.replace(/[^0-9]/g,'').slice(-1); const v = sync(); if (d.value && i < digits.length-1) digits[i+1].focus(); if (v.length === 6) setTimeout(submitTwofaCode, 250); });
                d.addEventListener('paste', e => { e.preventDefault(); const nums = (e.clipboardData||window.clipboardData).getData('text').replace(/[^0-9]/g,'').slice(0,6); [...nums].forEach((n,j) => { if(digits[j]) digits[j].value=n; }); const v = sync(); digits[Math.min(nums.length, digits.length-1)].focus(); if (v.length===6) setTimeout(submitTwofaCode,250); });
            });
        }

        async function submitTwofaCode() {
            const code = document.getElementById('twofa-login-code').value;
            if (code.length < 6) return;
            const btn = document.getElementById('twofa-login-submit');
            const orig = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="twofa-spinner"></span>Vérification…';
            document.getElementById('twofa-login-error').style.display = 'none';
            const fd = new FormData(); fd.append('_auth_code', code);
            let res;
            try { res = await fetch('/2fa_check', { method:'POST', body:fd, redirect:'follow', credentials:'same-origin', headers:{'X-Requested-With':'XMLHttpRequest'} }); }
            catch(e) { window.location.href = '/2fa'; return; }
            const path = (() => { try { return new URL(res.url).pathname; } catch(e) { return ''; } })();
            if (path.startsWith('/2fa')) {
                const digits = [...document.querySelectorAll('#twofa-login-digits .twofa-digit')];
                digits.forEach(d => { d.classList.remove('shake'); void d.offsetWidth; d.classList.add('shake','error'); d.value=''; d.classList.remove('filled'); });
                document.getElementById('twofa-login-code').value=''; btn.disabled=true; btn.innerHTML=orig;
                const err = document.getElementById('twofa-login-error'); err.style.display='flex';
                setTimeout(() => { digits.forEach(d=>d.classList.remove('shake','error')); digits[0]?.focus(); }, 400);
                return;
            }
            window.location.href = res.url || '/';
        }

        // ── Face Login ────────────────────────────────────────────────
        let faceLoginStream = null, isAuthenticating = false, faceLoginDetectedStartTime = null;
        const MIN_CONFIDENCE = 0.5, MIN_DURATION = 2000, MIN_FACE_SIZE = 100;

        document.getElementById('faceLoginBtn').addEventListener('click', () => {
            document.getElementById('face-login-modal').classList.add('active');
            const emailInput = document.querySelector('input[name="_username"]');
            if (emailInput?.value) document.getElementById('face-login-email').value = emailInput.value;
        });

        document.getElementById('close-face-modal-btn').addEventListener('click', () => {
            stopFaceLoginCamera();
            isAuthenticating = false; faceLoginDetectedStartTime = null;
            document.getElementById('face-login-modal').classList.remove('active');
            document.getElementById('face-login-email-step').style.display = 'block';
            document.getElementById('face-login-camera-step').style.display = 'none';
            document.getElementById('face-login-status').className = 'face-status-box info';
            document.getElementById('face-login-status-text').textContent = 'Initializing camera...';
        });

        document.getElementById('start-face-login-btn').addEventListener('click', async () => {
            const email = document.getElementById('face-login-email').value.trim();
            if (!email || !email.includes('@')) { alert('Please enter a valid email address'); return; }
            isAuthenticating = false; faceLoginDetectedStartTime = null;
            document.getElementById('face-login-email-step').style.display = 'none';
            document.getElementById('face-login-camera-step').style.display = 'block';
            const MODEL_URL = 'https://justadudewhohacks.github.io/face-api.js/models';
            try {
                document.getElementById('face-login-status-text').textContent = 'Loading AI models...';
                await faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL);
                await faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL);
                await faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL);
            } catch(e) {
                document.getElementById('face-login-status').className = 'face-status-box error';
                document.getElementById('face-login-status-text').textContent = 'Failed to load models.';
                document.getElementById('face-login-email-step').style.display = 'block';
                document.getElementById('face-login-camera-step').style.display = 'none'; return;
            }
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ video: { width:{ideal:1280}, height:{ideal:720}, facingMode:'user' } });
                const video = document.getElementById('face-login-video');
                video.srcObject = stream; faceLoginStream = stream;
                await new Promise(r => { video.onloadedmetadata = () => video.play().then(r); });
                document.getElementById('face-login-status-text').textContent = 'Camera ready. Position your face...';
                detectAndAuthenticateFace(email);
            } catch(e) {
                document.getElementById('face-login-status').className = 'face-status-box error';
                document.getElementById('face-login-status-text').textContent = 'Unable to access camera.';
            }
        });

        function stopFaceLoginCamera() {
            faceLoginStream?.getTracks().forEach(t => t.stop());
            faceLoginStream = null;
            const v = document.getElementById('face-login-video');
            if (v.srcObject) v.srcObject = null;
            isAuthenticating = false;
        }

        async function detectAndAuthenticateFace(email) {
            if (!faceLoginStream || isAuthenticating) return;
            const video = document.getElementById('face-login-video');
            const status = document.getElementById('face-login-status');
            const statusText = document.getElementById('face-login-status-text');
            try {
                const det = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions({inputSize:512,scoreThreshold:MIN_CONFIDENCE})).withFaceLandmarks().withFaceDescriptor();
                if (det?.detection) {
                    const { score, box } = det.detection;
                    if (score < MIN_CONFIDENCE || Math.max(box.width,box.height) < MIN_FACE_SIZE) {
                        status.className = 'face-status-box error';
                        statusText.textContent = score < MIN_CONFIDENCE ? 'Low quality. Ensure good lighting.' : 'Move closer to camera.';
                        faceLoginDetectedStartTime = null;
                    } else {
                        if (!faceLoginDetectedStartTime) faceLoginDetectedStartTime = Date.now();
                        const remaining = Math.ceil((MIN_DURATION - (Date.now() - faceLoginDetectedStartTime)) / 1000);
                        if (Date.now() - faceLoginDetectedStartTime < MIN_DURATION) {
                            status.className = 'face-status-box info';
                            statusText.textContent = `Face detected (${Math.round(score*100)}%). Hold still${remaining > 0 ? ' for '+remaining+'s' : ''}...`;
                        } else if (!isAuthenticating) {
                            isAuthenticating = true;
                            status.className = 'face-status-box info';
                            statusText.textContent = 'Authenticating...';
                            const res = await fetch('/api/face-auth/login', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({email, descriptor: Array.from(det.descriptor)}) });
                            const data = await res.json();
                            if (data.success) {
                                status.className = 'face-status-box success';
                                statusText.textContent = 'Authentication successful! Redirecting...';
                                stopFaceLoginCamera();
                                setTimeout(() => { window.location.href = data.redirectUrl || '/user'; }, 500);
                                return;
                            } else {
                                status.className = 'face-status-box error';
                                statusText.textContent = data.message || 'Face not recognized. Retrying...';
                                isAuthenticating = false;
                                setTimeout(() => { if (faceLoginStream) detectAndAuthenticateFace(email); }, 2000);
                                return;
                            }
                        }
                    }
                } else {
                    if (!isAuthenticating) { status.className='face-status-box info'; statusText.textContent='No face detected. Position your face...'; }
                    faceLoginDetectedStartTime = null;
                }
            } catch(e) { isAuthenticating = false; faceLoginDetectedStartTime = null; }
            if (faceLoginStream) requestAnimationFrame(() => detectAndAuthenticateFace(email));
        }
    </script>
</body>
</html>