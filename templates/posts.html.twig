{% extends 'base.html.twig' %}

{% block title %}Community Posts - MediNest{% endblock %}

{% block body_class %}posts-page{% endblock %}

{% block main %}

    <!-- Page Title -->
    <div class="page-title">
      <div class="heading">
        <div class="container">
          <div class="row d-flex justify-content-center text-center">
            <div class="col-lg-8">
              <h1 class="heading-title">Community Posts</h1>
              <p class="mb-0">
                Share your health journey, connect with others, and discover valuable insights 
                from our community of healthcare professionals and patients.
              </p>
            </div>
          </div>
        </div>
      </div>
      <nav class="breadcrumbs">
        <div class="container">
          <ol>
            <li><a href="{{ path('home') }}">Home</a></li>
            <li class="current">Posts</li>
          </ol>
        </div>
      </nav>
    </div><!-- End Page Title -->

    <!-- Posts Section -->
    <section id="posts" class="posts section">

      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <!-- Create Post Button -->
        <div class="row mb-4">
          <div class="col-12 d-flex justify-content-between align-items-center">
            <div class="filter-buttons">
              <button class="filter-btn active" data-filter="all">All Posts</button>
              <button class="filter-btn" data-filter="health">Health Tips</button>
              <button class="filter-btn" data-filter="nutrition">Nutrition</button>
              <button class="filter-btn" data-filter="mental">Mental Health</button>
              <button class="filter-btn" data-filter="fitness">Fitness</button>
            </div>
            <button class="btn-create-post" data-bs-toggle="modal" data-bs-target="#createPostModal">
              <i class="bi bi-plus-circle"></i> Create Post
            </button>
          </div>
        </div>

        <!-- Flash Messages -->
        {% for message in app.flashes('success') %}
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        {% endfor %}

        <!-- Posts Grid -->
        <div class="row gy-4" id="postsContainer">

          {% if posts is empty %}
            <div class="col-12">
              <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <h3>No posts yet</h3>
                <p>Be the first to share your thoughts with the community!</p>
                <button class="btn-primary" data-bs-toggle="modal" data-bs-target="#createPostModal">
                  Create First Post
                </button>
              </div>
            </div>
          {% else %}
            {% for post in posts %}
              <div class="col-lg-6" data-aos="fade-up" data-aos-delay="{{ loop.index * 100 }}" data-category="{{ post.categorie|lower }}">
                <article class="post-card">
                  
                  <!-- Post Header -->
                  <div class="post-header">
                    <div class="author-info">
                      <div class="author-avatar">
    {% if post.utilisateur.avatar %}
        <img src="{{ post.utilisateur.avatar }}" alt="{{ post.utilisateur.nom }}">
    {% else %}
        <div class="avatar-placeholder">{{ post.utilisateur.nom|first|upper }}</div>
    {% endif %}
</div>
                      <div class="author-details">
                        <h5 class="author-name">{{ post.utilisateur.nom }} {{ post.utilisateur.prenom }}</h5>
                        <span class="post-date">
                          <i class="bi bi-clock"></i>
                          {{ post.createdAt|date('M d, Y') }}
                          {% if post.updatedAt %}
                            <span class="text-muted small">(edited)</span>
                          {% endif %}
                        </span>
                      </div>
                    </div>

                    {% if true %}  {# ← force show for testing #}
                      <div class="post-actions">
                        <div class="dropdown">
                          <button class="btn-action" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-three-dots-vertical"></i>
                          </button>
                          <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                              <a class="dropdown-item" href="#" data-bs-toggle="modal" 
                                 data-bs-target="#editPostModal{{ post.id }}">
                                <i class="bi bi-pencil"></i> Edit
                              </a>
                            </li>
                            <li>
                              <a class="dropdown-item text-danger" href="#" 
                                 onclick="confirmDelete({{ post.id }}); return false;">
                                <i class="bi bi-trash"></i> Delete
                              </a>
                            </li>
                          </ul>
                        </div>
                      </div>
                    {% endif %}
                  </div>

                  <!-- Post Media (if exists) -->
                  {% if post.mediaUrl %}
                    <div class="post-media">
                      <img src="{{ post.mediaUrl }}" alt="{{ post.titre }}" class="post-image">
                    </div>
                  {% endif %}

                  <!-- Post Content -->
                  <div class="post-body">
                    {% if post.categorie %}
                      <span class="post-category category-{{ post.categorie|lower }}">
                        {{ post.categorie }}
                      </span>
                    {% endif %}
                    <h3 class="post-title">{{ post.titre }}</h3>
                    <p class="post-content">{{ post.contenu|slice(0, 200) }}{% if post.contenu|length > 200 %}...{% endif %}</p>
                  </div>

                  <!-- Post Footer -->
                  <div class="post-footer">
                    <div class="post-stats">
                      <button class="stat-btn like-btn" data-post-id="{{ post.id }}">
                        <i class="bi bi-heart"></i>
                        <span>{{ post.likes|length }}</span>
                      </button>
                      <button class="stat-btn">
                        <i class="bi bi-chat"></i>
                        <span>{{ post.commentaires|length }}</span>
                      </button>
                    </div>
                    <a href="{{ path('post_details', {'id': post.id}) }}" class="btn-read-more">
                      Read More <i class="bi bi-arrow-right"></i>
                    </a>
                  </div>

                  <!-- Delete Form (hidden) -->
                  <form id="deleteForm{{ post.id }}" action="{{ path('post_delete', {'id': post.id}) }}" 
                        method="post" style="display: none;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
                  </form>

                </article>
              </div>

              <!-- Edit Post Modal for this post -->
              <div class="modal fade" id="editPostModal{{ post.id }}" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                  <div class="modal-content">
                    <div class="modal-header">
                      <h5 class="modal-title">Edit Post</h5>
                      <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <form action="{{ path('post_edit', {'id': post.id}) }}" method="post" enctype="multipart/form-data">
                      <div class="modal-body">
                        <input type="hidden" name="_token" value="{{ csrf_token('edit' ~ post.id) }}">
                        
                        <div class="mb-3">
                          <label for="editTitre{{ post.id }}" class="form-label">Title *</label>
                          <input type="text" class="form-control" id="editTitre{{ post.id }}" 
                                 name="titre" value="{{ post.titre }}" required>
                        </div>

                        <div class="mb-3">
                          <label for="editCategorie{{ post.id }}" class="form-label">Category</label>
                          <select class="form-select" id="editCategorie{{ post.id }}" name="categorie">
                            <option value="">Select category...</option>
                            <option value="Health" {% if post.categorie == 'Health' %}selected{% endif %}>Health Tips</option>
                            <option value="Nutrition" {% if post.categorie == 'Nutrition' %}selected{% endif %}>Nutrition</option>
                            <option value="Mental" {% if post.categorie == 'Mental' %}selected{% endif %}>Mental Health</option>
                            <option value="Fitness" {% if post.categorie == 'Fitness' %}selected{% endif %}>Fitness</option>
                          </select>
                        </div>

                        <div class="mb-3">
                          <label for="editContenu{{ post.id }}" class="form-label">Content *</label>
                          <textarea class="form-control" id="editContenu{{ post.id }}" name="contenu" 
                                    rows="6" required>{{ post.contenu }}</textarea>
                        </div>

                        <div class="mb-3">
                          <label for="editMedia{{ post.id }}" class="form-label">Update Image</label>
                          {% if post.mediaUrl %}
                            <div class="current-image mb-2">
                              <img src="{{ post.mediaUrl }}" alt="Current" style="max-width: 200px;">
                            </div>
                          {% endif %}
                          <input type="file" class="form-control" id="editMedia{{ post.id }}" 
                                 name="media" accept="image/*">
                        </div>
                      </div>
                      <div class="modal-footer">
                        <button type="button" class="btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn-primary">
                          <i class="bi bi-check-circle"></i> Update Post
                        </button>
                      </div>
                    </form>
                  </div>
                </div>
              </div>

            {% endfor %}
          {% endif %}

        </div>

        <!-- Pagination -->
        {% if posts|length > 0 %}
          <div class="pagination-wrapper mt-5" data-aos="fade-up">
            <nav aria-label="Page navigation">
              <ul class="pagination justify-content-center">
                <li class="page-item disabled">
                  <a class="page-link" href="#" tabindex="-1">
                    <i class="bi bi-chevron-left"></i>
                  </a>
                </li>
                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                <li class="page-item"><a class="page-link" href="#">2</a></li>
                <li class="page-item"><a class="page-link" href="#">3</a></li>
                <li class="page-item">
                  <a class="page-link" href="#">
                    <i class="bi bi-chevron-right"></i>
                  </a>
                </li>
              </ul>
            </nav>
          </div>
        {% endif %}

      </div>

    </section><!-- /Posts Section -->

    <!-- Create Post Modal -->
    <div class="modal fade" id="createPostModal" tabindex="-1" aria-labelledby="createPostModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="createPostModalLabel">Create New Post</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <form action="{{ path('post_create') }}" method="post" enctype="multipart/form-data">
            <div class="modal-body">
              <input type="hidden" name="_token" value="{{ csrf_token('create_post') }}">
              
              <div class="mb-3">
                <label for="titre" class="form-label">Title *</label>
                <input type="text" class="form-control" id="titre" name="titre" 
                       placeholder="Give your post a catchy title..." required>
              </div>

              <div class="mb-3">
                <label for="categorie" class="form-label">Category</label>
                <select class="form-select" id="categorie" name="categorie">
                  <option value="">Select a category...</option>
                  <option value="Health">Health Tips</option>
                  <option value="Nutrition">Nutrition</option>
                  <option value="Mental">Mental Health</option>
                  <option value="Fitness">Fitness</option>
                </select>
              </div>

              <div class="mb-3">
                <label for="contenu" class="form-label">Content *</label>
                <textarea class="form-control" id="contenu" name="contenu" rows="6" 
                          placeholder="Share your thoughts, experiences, or advice..." required></textarea>
                <div class="form-text">
                  <i class="bi bi-info-circle"></i> Be respectful and constructive in your posts
                </div>
              </div>

              <div class="mb-3">
                <label for="media" class="form-label">Add Image (Optional)</label>
                <input type="file" class="form-control" id="media" name="media" accept="image/*">
                <div class="form-text">Supported formats: JPG, PNG, GIF (Max 5MB)</div>
              </div>

              <div class="preview-container" id="imagePreview" style="display: none;">
                <img src="" alt="Preview" id="previewImage">
                <button type="button" class="btn-remove-preview" onclick="removePreview()">
                  <i class="bi bi-x"></i>
                </button>
              </div>

            </div>
            <div class="modal-footer">
              <button type="button" class="btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn-primary">
                <i class="bi bi-send"></i> Publish Post
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
/* Posts Page Styles */
.posts-page {
  background: #f8f9fa;
}

/* Filter Buttons */
.filter-buttons {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.filter-btn {
  padding: 8px 20px;
  border: 2px solid #e0e0e0;
  background: white;
  color: #666;
  border-radius: 25px;
  cursor: pointer;
  transition: all 0.3s ease;
  font-weight: 500;
  font-size: 14px;
}

.filter-btn:hover {
  border-color: var(--accent-color, #3498db);
  color: var(--accent-color, #3498db);
}

.filter-btn.active {
  background: var(--accent-color, #3498db);
  border-color: var(--accent-color, #3498db);
  color: white;
}

/* Create Post Button */
.btn-create-post {
  padding: 12px 30px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 30px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  gap: 8px;
  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
}

.btn-create-post:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(102, 126, 234, 0.5);
}

.btn-create-post i {
  font-size: 18px;
}

/* Post Card */
.post-card {
  background: white;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.post-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
}

/* Post Header */
.post-header {
  padding: 20px;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  border-bottom: 1px solid #f0f0f0;
}

.author-info {
  display: flex;
  gap: 12px;
  align-items: center;
}

.author-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  overflow: hidden;
}

.author-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 20px;
}

.author-details {
  display: flex;
  flex-direction: column;
}

.author-name {
  margin: 0;
  font-size: 16px;
  font-weight: 600;
  color: #2c3e50;
}

.post-date {
  font-size: 13px;
  color: #7f8c8d;
  display: flex;
  align-items: center;
  gap: 5px;
}

/* Post Actions Dropdown */
.btn-action {
  background: transparent;
  border: none;
  padding: 5px 10px;
  cursor: pointer;
  color: #7f8c8d;
  font-size: 20px;
  transition: color 0.3s ease;
}

.btn-action:hover {
  color: #2c3e50;
}

/* Post Media */
.post-media {
  width: 100%;
  max-height: 400px;
  overflow: hidden;
  background: #f8f9fa;
}

.post-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.post-card:hover .post-image {
  transform: scale(1.05);
}

/* Post Body */
.post-body {
  padding: 20px;
  flex: 1;
}

.post-category {
  display: inline-block;
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 12px;
}

.category-health {
  background: #e8f5e9;
  color: #2e7d32;
}

.category-nutrition {
  background: #fff3e0;
  color: #e65100;
}

.category-mental {
  background: #e3f2fd;
  color: #1565c0;
}

.category-fitness {
  background: #fce4ec;
  color: #c2185b;
}

.post-title {
  font-size: 20px;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 12px;
  line-height: 1.4;
}

.post-content {
  color: #666;
  line-height: 1.7;
  margin-bottom: 0;
}

/* Post Footer */
.post-footer {
  padding: 15px 20px;
  border-top: 1px solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.post-stats {
  display: flex;
  gap: 15px;
}

.stat-btn {
  background: transparent;
  border: none;
  display: flex;
  align-items: center;
  gap: 6px;
  color: #7f8c8d;
  cursor: pointer;
  transition: all 0.3s ease;
  font-size: 14px;
  font-weight: 500;
}

.stat-btn:hover {
  color: #e74c3c;
}

.stat-btn i {
  font-size: 18px;
}

.like-btn.liked {
  color: #e74c3c;
}

.like-btn.liked i {
  animation: heartbeat 0.3s ease;
}

@keyframes heartbeat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.3); }
}

.btn-read-more {
  color: var(--accent-color, #3498db);
  font-weight: 600;
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 5px;
  transition: gap 0.3s ease;
}

.btn-read-more:hover {
  gap: 10px;
}

/* Empty State */
.empty-state {
  text-align: center;
  padding: 80px 20px;
  background: white;
  border-radius: 16px;
}

.empty-state i {
  font-size: 80px;
  color: #e0e0e0;
  margin-bottom: 20px;
}

.empty-state h3 {
  color: #2c3e50;
  margin-bottom: 10px;
}

.empty-state p {
  color: #7f8c8d;
  margin-bottom: 25px;
}

/* Modal Customization */
.modal-content {
  border-radius: 20px;
  border: none;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
}

.modal-header {
  border-bottom: 2px solid #f0f0f0;
  padding: 25px 30px;
}

.modal-title {
  font-size: 22px;
  font-weight: 700;
  color: #2c3e50;
}

.modal-body {
  padding: 30px;
}

.modal-footer {
  border-top: 2px solid #f0f0f0;
  padding: 20px 30px;
}

.form-label {
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 8px;
}

.form-control, .form-select {
  border: 2px solid #e0e0e0;
  border-radius: 10px;
  padding: 12px 15px;
  transition: all 0.3s ease;
}

.form-control:focus, .form-select:focus {
  border-color: var(--accent-color, #3498db);
  box-shadow: 0 0 0 0.2rem rgba(52, 152, 219, 0.15);
}

/* Preview Container */
.preview-container {
  position: relative;
  margin-top: 15px;
  border-radius: 12px;
  overflow: hidden;
  background: #f8f9fa;
  padding: 10px;
}

#previewImage {
  max-width: 100%;
  border-radius: 8px;
}

.btn-remove-preview {
  position: absolute;
  top: 20px;
  right: 20px;
  background: rgba(231, 76, 60, 0.9);
  color: white;
  border: none;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.btn-remove-preview:hover {
  background: #e74c3c;
  transform: scale(1.1);
}

/* Buttons */
.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  padding: 12px 30px;
  border-radius: 25px;
  color: white;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
}

.btn-secondary {
  background: #ecf0f1;
  border: none;
  padding: 12px 30px;
  border-radius: 25px;
  color: #7f8c8d;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.btn-secondary:hover {
  background: #bdc3c7;
}

/* Pagination */
.pagination {
  gap: 8px;
}

.page-link {
  border: 2px solid #e0e0e0;
  color: #666;
  border-radius: 8px;
  padding: 8px 15px;
  font-weight: 500;
  transition: all 0.3s ease;
}

.page-link:hover {
  background: var(--accent-color, #3498db);
  border-color: var(--accent-color, #3498db);
  color: white;
}

.page-item.active .page-link {
  background: var(--accent-color, #3498db);
  border-color: var(--accent-color, #3498db);
}

/* Responsive */
@media (max-width: 768px) {
  .filter-buttons {
    margin-bottom: 15px;
  }
  
  .btn-create-post {
    width: 100%;
    justify-content: center;
  }
  
  .post-title {
    font-size: 18px;
  }
}
</style>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// Image Preview
document.getElementById('media')?.addEventListener('change', function(e) {
  const file = e.target.files[0];
  if (file) {
    const reader = new FileReader();
    reader.onload = function(e) {
      document.getElementById('previewImage').src = e.target.result;
      document.getElementById('imagePreview').style.display = 'block';
    }
    reader.readAsDataURL(file);
  }
});

function removePreview() {
  document.getElementById('media').value = '';
  document.getElementById('imagePreview').style.display = 'none';
}

// Filter Posts
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    // Update active state
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    this.classList.add('active');
    
    const filter = this.dataset.filter;
    const posts = document.querySelectorAll('#postsContainer > div[data-category]');
    
    posts.forEach(post => {
      if (filter === 'all' || post.dataset.category === filter) {
        post.style.display = 'block';
        setTimeout(() => post.style.opacity = '1', 10);
      } else {
        post.style.opacity = '0';
        setTimeout(() => post.style.display = 'none', 300);
      }
    });
  });
});

// Delete Confirmation
function confirmDelete(postId) {
  if (confirm('Are you sure you want to delete this post? This action cannot be undone.')) {
    document.getElementById('deleteForm' + postId).submit();
  }
}

// Like Button
document.querySelectorAll('.like-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    this.classList.toggle('liked');
    const count = parseInt(this.querySelector('span').textContent);
    this.querySelector('span').textContent = this.classList.contains('liked') ? count + 1 : count - 1;
    
    // TODO: Send AJAX request to server to save like
    const postId = this.dataset.postId;
    // fetch('/post/like/' + postId, { method: 'POST' })
  });
});

// Auto-dismiss alerts
setTimeout(() => {
  document.querySelectorAll('.alert').forEach(alert => {
    alert.classList.remove('show');
    setTimeout(() => alert.remove(), 300);
  });
}, 5000);
</script>
